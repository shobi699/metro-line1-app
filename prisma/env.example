# ============================================================================
# .env.example — اپ سیر و حرکت خط ۱ مترو
# این فایل را به .env کپی کنید و مقادیر واقعی را جایگزین کنید.
# هرگز .env واقعی را در گیت کامیت نکنید (در .gitignore باشد).
# ============================================================================

# --- پایگاه‌داده (PostgreSQL) ---
# قالب: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metro_line1?schema=public"

# --- JWT / احراز هویت ---
# با دستور زیر یک کلید امن بسازید:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="CHANGE_ME_access_secret"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
BCRYPT_ROUNDS="12"

# --- حساب مدیر کل اولیه (برای seed) ---
SUPERADMIN_PERSONNEL_CODE="10001"
SUPERADMIN_PASSWORD="ChangeMe@12345"
SUPERADMIN_NAME="مدیر کل سامانه"

# --- آپلود فایل (لوحه/عکس تیکت/آواتار) ---
# local | s3
STORAGE_DRIVER="local"
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_MB="15"

# اگر STORAGE_DRIVER=s3 بود:
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# --- برنامه ---
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="سامانه سیر و حرکت خط ۱"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_TIMEZONE="Asia/Tehran"
