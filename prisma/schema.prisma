}

// ── Crisis Management ──────────────────────────────────

enum CrisisLevel {
  normal
  elevated
  high
  critical
}

model CrisisEvent {
  id          String      @id @default(cuid())
  title       String
  description String?
  level       CrisisLevel @default(normal)
  stationId   String?
  activatedBy String
  activatedAt DateTime    @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  activator User @relation("CrisisActivator", fields: [activatedBy], references: [id])

  @@index([activatedBy])
  @@index([level])
  @@index([activatedAt])
}

// ── Gamification ───────────────────────────────────────

model GamificationScore {
  id        String   @id @default(cuid())
  userId    String
  points    Int      @default(0)
  reason    String
  period    String // e.g. "2026-03"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, period, reason])
  @@index([userId])
  @@index([period])
}

// ── Performance Evaluation & KPIs ──────────────────────

model Competency {
  id        String   @id
  name      String
  weight    Float    @default(1.0)
  direction String // "positive" | "negative" | "both"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionTypes PerformanceActionType[]
}

model PerformanceActionType {
  id           String   @id
  competencyId String
  title        String
  defaultScore Float
  maxSeverity  String // "L1" | "L2" | "L3"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competency Competency       @relation(fields: [competencyId], references: [id])
  logs       PerformanceLog[]
}

model PerformanceLog {
  id           String   @id @default(cuid())
  employeeId   String
  recordedById String
  actionTypeId String
  severity     String // "L1" | "L2" | "L3"
  scoreValue   Float
  note         String?
  evidenceUrl  String?
  periodId     String // e.g., "1405-04" (jalali year-month)
  status       String   @default("active") // "active" | "appealed" | "overturned"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee   User                  @relation("PerformanceReceiver", fields: [employeeId], references: [id])
  recordedBy User                  @relation("PerformanceRecorder", fields: [recordedById], references: [id])
  actionType PerformanceActionType @relation(fields: [actionTypeId], references: [id])
  appeals    PerformanceAppeal[]

  @@index([employeeId])
  @@index([recordedById])
  @@index([actionTypeId])
  @@index([periodId])
}

model PerformanceAppeal {
  id           String    @id @default(cuid())
  logId        String
  employeeId   String
  reason       String
  status       String    @default("pending") // "pending" | "approved" | "rejected"
  reviewedById String?
  note         String? // Review note
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  log        PerformanceLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  employee   User           @relation("PerformanceAppealingUser", fields: [employeeId], references: [id])
  reviewedBy User?          @relation("PerformanceAppealReviewer", fields: [reviewedById], references: [id])

  @@index([logId])
  @@index([employeeId])
}

model ScoreSnapshot {
  id              String   @id @default(cuid())
  employeeId      String
  periodId        String
  rawScore        Float
  normalizedScore Float
  percentile      Float
  createdAt       DateTime @default(now())

  employee User @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, periodId])
  @@index([periodId])
}

model Nomination {
  id               String   @id @default(cuid())
  periodId         String
  employeeId       String
  rank             Int
  tiebreakerReason String?
  status           String   @default("nominated") // "nominated" | "approved"
  createdAt        DateTime @default(now())

  periodEmployee User @relation(fields: [employeeId], references: [id])

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
}

model RosterDay {
  id               String   @id @default(cuid())
  lineCode         String   @default("LINE_1")
  jalaliDate       String   @unique
  gregorianDate    DateTime
  weekday          String?
  title            String?
  schedulingTitle  String?
  processingNumber Int?
  issuedByName     String?
  status           String   @default("DRAFT") // DRAFT | PROCESSING | REVIEW | PUBLISHED | ARCHIVED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  versions   RosterVersion[]
  snapshot   RosterSnapshot?
  amendments RosterAmendment[]
}

model RosterVersion {
  id               String    @id @default(cuid())
  rosterDayId      String
  versionNo        Int       @default(1)
  fileUrl          String?
  originalFileName String?
  checksum         String?
  status           String    @default("UPLOADED") // UPLOADED | PARSED | VALIDATED | PUBLISHED | REJECTED
  uploadedById     String?
  uploadedAt       DateTime  @default(now())
  publishedById    String?
  publishedAt      DateTime?
  changeReason     String?
  changeSummary    String?

  rosterDay   RosterDay @relation(fields: [rosterDayId], references: [id], onDelete: Cascade)
  uploadedBy  User?     @relation("RosterVersionUploader", fields: [uploadedById], references: [id])
  publishedBy User?     @relation("RosterVersionPublisher", fields: [publishedById], references: [id])
  trips       Trip[]

  @@index([rosterDayId])
}

model Trip {
  id                 String  @id @default(cuid())
  rosterVersionId    String
  rowNo              Int
  trainNumber        String?
  direction          String // TAJRISH_TO_SHAHRREY | SHAHRREY_TO_TAJRISH
  originStation      String?
  destinationStation String?
  departureTime      String? // HH:mm:ss
  arrivalTime        String? // HH:mm:ss
  operationalNote    String?
  status             String  @default("NORMAL") // NORMAL | EMPTY | CANCELLED | DEPOT | SPECIAL

  rosterVersion RosterVersion     @relation(fields: [rosterVersionId], references: [id], onDelete: Cascade)
  assignments   TripAssignment[]
  amendments    RosterAmendment[]

  @@index([rosterVersionId])
}

model TripAssignment {
  id             String    @id @default(cuid())
  tripId         String
  role           String // H1 | H2 | T | R
  rawName        String?
  matchedUserId  String?
  personnelNo    String?
  matchScore     Float?
  matchStatus    String    @default("UNMATCHED") // AUTO_MATCHED | NEEDS_REVIEW | MANUAL_MATCHED | UNMATCHED
  confirmedById  String?
  confirmedAt    DateTime?
  acknowledgedAt DateTime? // Confirm Sight
  readyAt        DateTime?
  handoverAt     DateTime?
  disputed       Boolean   @default(false)
  disputeNote    String?

  trip                      Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  matchedUser               User?             @relation("TripAssignmentUser", fields: [matchedUserId], references: [id])
  confirmedBy               User?             @relation("TripAssignmentConfirmer", fields: [confirmedById], references: [id])
  tripSwapSourceAssignments TripSwapRequest[] @relation("TripSwapSourceAssignment")
  tripSwapTargetAssignments TripSwapRequest[] @relation("TripSwapTargetAssignment")
  amendments                RosterAmendment[]

  @@index([tripId])
  @@index([matchedUserId])
}

model RosterTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  sourceType   String   @default("EXCEL") // EXCEL | PDF
  // Excel column mappings (existing)
  rightMapping Json? // ColumnMapping JSON for Excel right block
  leftMapping  Json? // ColumnMapping JSON for Excel left block
  // PDF template fields (§۴.۳)
  pageWidth    Int? // PDF page width in pixels
  pageHeight   Int? // PDF page height in pixels
  rightBlock   Json? // { x, y, width, height } — right table block coordinates
  leftBlock    Json? // { x, y, width, height } — left table block coordinates
  headerZones  Json? // [{ label, box: {x, y, width, height} }] — metadata extraction zones
  pdfColumns   Json? // ColumnMapping[] for PDF column positions
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── UI Builder / Server-Driven UI ─────────────────────

model UiMenuItem {
  id                 String   @id @default(cuid())
  parentId           String?
  label              String
  icon               String
  route              String // target route name or page slug
  orderIndex         Int      @default(0)
  isVisible          Boolean  @default(true)
  requiredPermission String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parent   UiMenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children UiMenuItem[] @relation("MenuHierarchy")

  @@index([parentId])
  @@index([orderIndex])
  @@map("ui_menu_items")
}

model UiPage {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  layoutType       String   @default("list") // list | detail | dashboard | form
  status           String   @default("draft") // draft | published
  currentVersionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  versions UiPageVersion[]

  @@map("ui_pages")
}

model UiPageVersion {
  id            String   @id @default(cuid())
  pageId        String
  schemaJson    Json // JSON representing component tree
  versionNumber Int
  createdById   String?
  createdAt     DateTime @default(now())

  page UiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("ui_page_versions")
}

model UiDashboardWidget {
  id                 String   @id @default(cuid())
  pageId             String?
  widgetType         String // stat_card | chart | list | banner
  title              String?
  size               String   @default("md") // sm | md | lg
  orderIndex         Int      @default(0)
  isVisible          Boolean  @default(true)
  configJson         Json // JSON representing configuration
  requiredPermission String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([orderIndex])
  @@map("ui_dashboard_widgets")
}

model UiTheme {
  id              String   @id @default(cuid())
  primaryColor    String   @default("#ae0011") // Default Metro Red
  accentColor     String   @default("#575e70")
  radius          Int      @default(12)
  fontSize        String   @default("md")
  darkModeDefault Boolean  @default(false)
  logoUrl         String?
  apiBaseUrl      String   @default("https://metro.qzz.io")
  updatedAt       DateTime @updatedAt

  @@map("ui_themes")
}

// ── Leave & Mission Management ─────────────────────────

enum LeaveRequestStatus {
  pending
  approved
  rejected
  cancelled
}

model LeaveRequest {
  id               String             @id @default(cuid())
  userId           String
  type             String // e.g., 'annual_leave', 'sick_leave', 'mission', 'overtime', 'on_call'
  fromDate         DateTime
  toDate           DateTime
  reason           String?
  amount           Float? // e.g., 4.5 hours or 2 days
  unit             String? // 'hours', 'days', 'count'
  calculatedAmount Float? // After admin multiplier logic
  status           LeaveRequestStatus @default(pending)
  reviewedById     String?
  reviewedAt       DateTime?
  reviewNote       String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user       User  @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([fromDate])
}

// ── AI Gateway & Semantic Cache ─────────────────────────

model AiProvider {
  id                  String    @id @default(cuid())
  name                String // e.g., "Gemini Flash", "Ollama Local"
  providerType        String // gemini, openrouter, ollama, grok, custom
  baseUrl             String
  apiKey              String? // Store encrypted or raw depending on implementation
  modelName           String?
  requestFormat       String    @default("openai_compatible")
  priority            Int       @default(100)
  isActive            Boolean   @default(true)
  maxRetries          Int       @default(2)
  timeoutMs           Int       @default(8000)
  costPer1kTokens     Float     @default(0)
  healthStatus        String    @default("healthy") // healthy, degraded, down
  lastFailureAt       DateTime?
  consecutiveFailures Int       @default(0)
  extraHeaders        String? // JSON string
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([priority])
}

model AiKnowledgeCache {
  id                String    @id @default(cuid())
  questionText      String
  questionEmbedding String // JSON array of floats as string for SQLite compatibility
  answerText        String
  source            String // 'ai_generated', 'admin_manual', 'database'
  providerUsed      String?
  hitCount          Int       @default(0)
  confidenceScore   Float?
  isVerified        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime  @default(now())
  personaKey        String?
  ttlAt             DateTime?
  sourceRefs        Json?
}

// ── Fleet ──────────────────────────────────────────────

model Train {
  id             String      @id @default(cuid())
  trainNumber    String      @unique // e.g. "110"
  fleetSeries    String? // DC01, AC02, etc.
  manufacturer   String? // CNR, CRRC, etc.
  wagonCount     Int         @default(7)
  commissionedAt DateTime?
  status         TrainStatus @default(active)
  qrToken        String      @unique @default(cuid())
  notes          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  wagons Wagon[]
  faults FaultReport[]

  @@index([status])
}

model Wagon {
  id        String  @id @default(cuid())
  trainId   String
  wagonCode String // e.g. "110-3"
  position  Int // 1..7
  wagonType String? // Mc / Tp / M / T
  isActive  Boolean @default(true)

  train  Train         @relation(fields: [trainId], references: [id])
  faults FaultReport[]

  @@unique([trainId, position])
  @@index([trainId])
}

// ── Fault Catalog ──────────────────────────────────────────────

model FaultCategory {
  id        String  @id @default(cuid())
  code      String  @unique // BRK, DRS, TRC, HVAC, SIG, BOG, PAN, etc.
  title     String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  faultCodes FaultCode[]
}

model FaultCode {
  id              String         @id @default(cuid())
  categoryId      String
  code            String         @unique // e.g. DRS-004
  title           String
  description     String?
  defaultPriority TicketPriority @default(medium)
  safetyCritical  Boolean        @default(false)
  requiresWagon   Boolean        @default(true)
  operatorGuide   String?
  keywords        String?
  aliases         String?
  embedding       Bytes?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  category FaultCategory @relation(fields: [categoryId], references: [id])
  faults   FaultReport[]

  @@index([categoryId])
}

// ── Fault Report & Workflow ──────────────────────────────────────────────

model FaultReport {
  id          String         @id @default(cuid())
  faultNo     Int            @unique // Managed programmatically to avoid SQLite non-primary autoincrement error
  trainId     String
  wagonId     String?
  faultCodeId String
  status      FaultStatus    @default(submitted)
  priority    TicketPriority @default(medium)

  // Registration
  reporterId    String
  description   String
  locationNote  String?
  occurredAt    DateTime
  serviceImpact String? // none | delay | evacuated | removed_from_service
  photoUrls     Json?
  annotations   Json?

  // Review
  reviewerId String?
  reviewNote String?
  reviewedAt DateTime?

  // Repair
  assigneeId    String?
  repairStartAt DateTime?
  repairEndAt   DateTime?
  rootCause     String?
  actionsTaken  String?
  partsUsed     Json? // [{name, qty, partNo?}]

  // Verification/Deferral
  verifierId  String?
  verifiedAt  DateTime?
  closedAt    DateTime?
  deferReason String?
  deferUntil  DateTime?

  // Recurrence & SLA
  recurrenceOfId String?
  slaDueAt       DateTime?
  slaBreached    Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  train        Train         @relation(fields: [trainId], references: [id])
  wagon        Wagon?        @relation(fields: [wagonId], references: [id])
  faultCode    FaultCode     @relation(fields: [faultCodeId], references: [id])
  reporter     User          @relation("FaultReporter", fields: [reporterId], references: [id])
  reviewer     User?         @relation("FaultReviewer", fields: [reviewerId], references: [id])
  assignee     User?         @relation("FaultAssignee", fields: [assigneeId], references: [id])
  verifier     User?         @relation("FaultVerifier", fields: [verifierId], references: [id])
  recurrenceOf FaultReport?  @relation("FaultRecurrence", fields: [recurrenceOfId], references: [id])
  recurrences  FaultReport[] @relation("FaultRecurrence")
  logs         FaultLog[]

  @@index([trainId, status])
  @@index([faultCodeId])
  @@index([status])
  @@index([occurredAt])
  @@index([slaDueAt])
}

model FaultLog {
  id         String         @id @default(cuid())
  faultId    String
  actorId    String
  action     FaultLogAction
  fromStatus FaultStatus?
  toStatus   FaultStatus?
  note       String?
  changes    Json? // {field: {before, after}}
  createdAt  DateTime       @default(now())

  fault FaultReport @relation(fields: [faultId], references: [id], onDelete: Cascade)
  actor User        @relation("FaultLogActor", fields: [actorId], references: [id])

  @@index([faultId])
}

// ── Life Calendar (تقویم زندگی شیفت‌محور) ─────────────

model PersonalEvent {
  id          String            @id @default(cuid())
  userId      String
  type        PersonalEventType @default(event)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean           @default(true)
  color       String?
  location    String?
  isDone      Boolean           @default(false)
  recurrence  Json? // {freq: yearly|monthly|weekly|daily, interval, until, jalali:true}
  reminders   Json? // [{minutesBefore: 60}]
  metadata    Json? // e.g. {amount: 5000, category: "Kahrizak", hours: 4}
  isPrivate   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation("PersonalEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
}

