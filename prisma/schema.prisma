// ── Knowledge Base ─────────────────────────────────────

model KnowledgeArticle {
  id                   String    @id @default(cuid())
  title                String
  slug                 String    @unique
  body                 String
  category             String?
  tags                 String? // comma-separated
  attachments          Json? // [{ url, name, type }]
  version              Int       @default(1)
  validFrom            DateTime?
  validUntil           DateTime?
  ownerId              String?
  confidentialityLevel String    @default("internal") // public | internal | confidential | secret
