generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Enums ──────────────────────────────────────────────

enum UserStatus {
  pending
  active
  suspended
}

enum ShiftCode {
  morning
  evening
  night
  off
  office
}

enum ImportJobStatus {
  pending
  processing
  completed
  failed
}

enum SwapRequestStatus {
  pending
  approved
  rejected
}

enum TicketPriority {
  low
  medium
  high
  critical
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketLogAction {
  created
  status_changed
  assigned
  comment
  priority_changed
}

enum AuditLogAction {
  create
  update
  delete
  login
  logout
  import
  export
}

enum TrainStatus {
  active
  standby
  maintenance
  out_of_service
}

enum FaultStatus {
  submitted
  under_review
  needs_info
  rejected
  approved
  in_repair
  repaired
  verified_closed
  deferred
  reopened
}

enum FaultLogAction {
  created
  status_changed
  edited
  assigned
  comment
  priority_changed
  attachment_added
  sla_breached
  reopened
  deferred
}

enum ChatRoomType {
  direct
  group
}

enum ChatRoomKind {
  general
  operators
  occ
  shift
  station
  custom
  training
  announcement
  emergency
  management
}

enum PersonalEventType {
  event
  birthday
  task
  note
}

enum PostType {
  news
  blog
  training
  circular
  gallery
  announcement
  directive
  form
}

// ── Models ─────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  nationalId    String      @unique
  name          String
  phone         String?
  email         String?
  passwordHash  String
  status        UserStatus  @default(pending)
  roleId        String
  customFields  Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  role              Role              @relation(fields: [roleId], references: [id])
  importJobs        ImportJob[]       @relation("ImportActor")

  shifts            Shift[]           @relation("ShiftAssignee")
  swapRequestsInit  SwapRequest[]     @relation("SwapRequester")
  swapRequestsTarget SwapRequest[]    @relation("SwapTarget")
  tripSwapRequestsInit   TripSwapRequest[] @relation("TripSwapRequester")
  tripSwapRequestsTarget TripSwapRequest[] @relation("TripSwapTarget")
  ticketsCreated    Ticket[]          @relation("TicketCreator")
  ticketLogs        TicketLog[]       @relation("TicketLogActor")
  auditLogs         AuditLog[]        @relation("AuditActor")
  readReceipts      ReadReceipt[]     @relation("ReceiptUser")
  chatMemberships   ChatMember[]      @relation("ChatMemberUser")
  messages          Message[]         @relation("MessageSender")
  posts             Post[]            @relation("PostAuthor")
  postReads         PostRead[]        @relation("PostReadUser")
  postReactions     PostReaction[]    @relation("PostReactionUser")
  comments          Comment[]         @relation("CommentUser")
  notifications     Notification[]
  feedback          Feedback[]
  attendance        AttendanceRecord[]
  pollsCreated      Poll[]            @relation("PollCreator")
  pollVotes         PollVote[]
  meetingsInitiated MeetingRequest[]  @relation("MeetingRequester")
  meetingsTarget    MeetingRequest[]  @relation("MeetingTarget")
  checklistRecords  ChecklistRecord[]
  knowledgeArticles KnowledgeArticle[]
  crisisEvents      CrisisEvent[]     @relation("CrisisActivator")
  gamificationScores GamificationScore[]
  performanceLogsReceived   PerformanceLog[] @relation("PerformanceReceiver")
  performanceLogsRecorded   PerformanceLog[] @relation("PerformanceRecorder")
  performanceAppeals        PerformanceAppeal[] @relation("PerformanceAppealingUser")
  performanceAppealsReviewed PerformanceAppeal[] @relation("PerformanceAppealReviewer")
  scoreSnapshots            ScoreSnapshot[]
  nominations               Nomination[]
  shiftNotes                ShiftNote[]
  shiftTasks                ShiftTask[]
  rosterVersionsUploaded    RosterVersion[]     @relation("RosterVersionUploader")
  rosterVersionsPublished   RosterVersion[]     @relation("RosterVersionPublisher")
  tripAssignmentsMatched    TripAssignment[]    @relation("TripAssignmentUser")
  tripAssignmentsConfirmed  TripAssignment[]    @relation("TripAssignmentConfirmer")
  leaveRequests             LeaveRequest[]      @relation("LeaveRequester")
  reviewedLeaves            LeaveRequest[]      @relation("LeaveReviewer")
  aiConversations           AiConversation[]
  faultsReporter            FaultReport[]     @relation("FaultReporter")
  faultsReviewer            FaultReport[]     @relation("FaultReviewer")
  faultsAssignee            FaultReport[]     @relation("FaultAssignee")
  faultsVerifier            FaultReport[]     @relation("FaultVerifier")
  faultLogsActor            FaultLog[]        @relation("FaultLogActor")
  personalEvents            PersonalEvent[]   @relation("PersonalEvents")
  calendarPreference        CalendarPreference? @relation("CalendarPref")

  @@index([roleId])
  @@index([status])
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  permissions Json
  rank        Int      @default(0)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model CustomFieldDef {
  id           String   @id @default(cuid())
  entityType   String
  name         String
  label        String
  type         String
  options      Json?
  required     Boolean  @default(false)
  defaultValue String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType])
}

model ImportJob {
  id          String          @id @default(cuid())
  fileName    String
  fileType    String
  status      ImportJobStatus @default(pending)
  rowCount    Int             @default(0)
  errorCount  Int             @default(0)
  errors      Json?
  actorId     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  actor User @relation("ImportActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([status])
}


model Shift {
  id          String     @id @default(cuid())
  date        DateTime
  code        ShiftCode
  source      String     @default("manual") // "cycle" | "roster" | "manual"
  note        String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user          User          @relation("ShiftAssignee", fields: [userId], references: [id])
  swapAsSource  SwapRequest[] @relation("SwapSourceShift")
  swapAsTarget  SwapRequest[] @relation("SwapTargetShift")

  @@unique([userId, date])
  @@index([date])
  @@index([code])
  @@index([source])
}

// ── Shift Cycle Templates (server-side source of truth) ──

model ShiftTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // "rotational" | "staff"
  length      Int      // cycle length in days
  shifts      Json     // CycleShiftDetail[] { day, code, label, hours, startTime, endTime }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ShiftAssignment[]

  @@index([isActive])
}

model ShiftAssignment {
  id          String   @id @default(cuid())
  templateId  String
  targetType  String   // "user" | "group"
  targetId    String   // user ID or group key ("A","B","C","Staff")
  anchorDate  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId])
  @@index([templateId])
}

// ── Shift Notes & Tasks (server-side persisted) ──

model ShiftNote {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model ShiftTask {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime
  title      String
  time       String
  priority   String   @default("medium") // "low" | "medium" | "high"
  status     String   @default("todo")   // "todo" | "in_progress" | "done"
  type       String   @default("personal") // "personal" | "system"
  overtime   Float?
  extraData  Json?    // kahrizakCount and other custom numeric fields
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([status])
}

model SwapRequest {
  id              String            @id @default(cuid())
  requesterId     String
  targetId        String
  sourceShiftId   String
  targetShiftId   String
  status          SwapRequestStatus @default(pending)
  note            String?
  reviewedBy      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  requester   User   @relation("SwapRequester", fields: [requesterId], references: [id])
  target      User   @relation("SwapTarget", fields: [targetId], references: [id])
  sourceShift Shift  @relation("SwapSourceShift", fields: [sourceShiftId], references: [id])
  targetShift Shift  @relation("SwapTargetShift", fields: [targetShiftId], references: [id])

  @@index([requesterId])
  @@index([targetId])
  @@index([sourceShiftId])
  @@index([targetShiftId])
  @@index([status])
}

model TripSwapRequest {
  id                  String            @id @default(cuid())
  requesterId         String
  targetId            String
  sourceAssignmentId  String            // TripAssignment being swapped by requester
  targetAssignmentId  String            // TripAssignment being swapped by target
  status              SwapRequestStatus @default(pending)
  note                String?
  reviewedBy          String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  requester         User           @relation("TripSwapRequester", fields: [requesterId], references: [id])
  target            User           @relation("TripSwapTarget", fields: [targetId], references: [id])
  sourceAssignment  TripAssignment @relation("TripSwapSourceAssignment", fields: [sourceAssignmentId], references: [id])
  targetAssignment  TripAssignment @relation("TripSwapTargetAssignment", fields: [targetAssignmentId], references: [id])

  @@index([requesterId])
  @@index([targetId])
  @@index([sourceAssignmentId])
  @@index([targetAssignmentId])
  @@index([status])
}

model SafetyBulletin {
  id          String   @id @default(cuid())
  title       String
  body        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  readReceipts ReadReceipt[]
}

model ReadReceipt {
  id              String   @id @default(cuid())
  userId          String
  safetyBulletinId String
  readAt          DateTime @default(now())
  device          String?

  user            User            @relation("ReceiptUser", fields: [userId], references: [id])
  safetyBulletin  SafetyBulletin  @relation(fields: [safetyBulletinId], references: [id])

  @@unique([userId, safetyBulletinId])
  @@index([safetyBulletinId])
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String?
  priority    TicketPriority @default(medium)
  status      TicketStatus   @default(open)
  wagonCode   String?
  photoUrl    String?
  annotations Json?
  creatorId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator User        @relation("TicketCreator", fields: [creatorId], references: [id])
  logs    TicketLog[]

  @@index([creatorId])
  @@index([status])
  @@index([priority])
}

model TicketLog {
  id        String           @id @default(cuid())
  ticketId  String
  actorId   String
  action    TicketLogAction
  note      String?
  createdAt DateTime         @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  actor  User   @relation("TicketLogActor", fields: [actorId], references: [id])

  @@index([ticketId])
  @@index([actorId])
}

model AuditLog {
  id        String         @id @default(cuid())
  actorId   String
  entity    String
  entityId  String
  action    AuditLogAction
  before    Json?
  after     Json?
  reason    String?        // دلیل تغییر
  ipAddress String?        // آدرس آی‌پی درخواست‌دهنده
  userAgent String?        // مشخصات مرورگر / کلاینت
  device    String?        // نوع دستگاه: mobile | desktop | tablet
  metadata  Json?          // اطلاعات اضافی دلخواه
  createdAt DateTime       @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

// ── Chat ───────────────────────────────────────────────

model ChatRoom {
  id        String       @id @default(cuid())
  name      String
  type      ChatRoomType @default(group)
  kind      ChatRoomKind @default(custom)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members  ChatMember[]
  messages Message[]

  @@index([type])
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model AiMessage {
  id              String         @id @default(uuid())
  conversationId  String
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String         // 'user' | 'model'
  text            String
  source          String?        // 'rulebook' | 'gemini' | 'system'
  confidence      Int?
  handbookSection String?
  feedback        Int?           // 1 for thumbs up, -1 for thumbs down
  createdAt       DateTime       @default(now())
}

model ChatMember {
  id        String    @id @default(cuid())
  roomId    String
  userId    String
  isAdmin   Boolean   @default(false)
  lastReadAt DateTime?
  joinedAt  DateTime  @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation("ChatMemberUser", fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  roomId         String
  senderId       String
  body           String?
  attachmentUrl  String?
  attachmentType String?
  pinned         Boolean   @default(false)
  priority       String    @default("normal") // normal | important | urgent | emergency | critical
  tags           String?   // comma-separated tags or JSON
  readReceipts   Json?     // JSON array of ReadReceipt { userId, userName, seenAt, device, ipAddress, signature, docUrl }
  createdAt      DateTime  @default(now())
  editedAt       DateTime?

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId, createdAt])
}

// ── Content (وبلاگ/اخبار/آموزش) ─────────────────────────

model Post {
  id            String    @id @default(cuid())
  type          PostType  @default(news)
  title         String
  slug          String    @unique
  excerpt       String?
  body          String
  category      String?
  coverUrl      String?
  mediaUrl      String?
  mediaType     String?
  published     Boolean   @default(false)
  mandatory     Boolean   @default(false)
  status        String    @default("draft") // draft | review | approved | published | archived
  publishAt     DateTime? // زمان انتشار زمان‌بندی‌شده
  reviewedById  String?
  reviewedAt    DateTime?
  archivedAt    DateTime?
  nextReviewAt  DateTime? // یادآوری بازنگری دوره‌ای
  authorId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  author    User           @relation("PostAuthor", fields: [authorId], references: [id])
  reads     PostRead[]
  reactions PostReaction[]
  comments  Comment[]

  @@index([type, status])
  @@index([type, published])
  @@index([authorId])
  @@index([createdAt])
  @@index([status])
}

model PostRead {
  id     String   @id @default(cuid())
  postId String
  userId String
  readAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostReadUser", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostReactionUser", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("CommentUser", fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model Setting {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  description  String?
  type         String   // "number" | "text" | "boolean" | "color" | "select"
  value        String   // JSON serialized value
  defaultValue String   // JSON serialized defaultValue
  category     String   // e.g. "general", "shifts", "tickets", "chat"
  isEnabled    Boolean  @default(true)
  min          Float?
  max          Float?
  options      String?  // JSON options for select type
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ── Notifications ──────────────────────────────────────

enum NotificationType {
  info
  warning
  urgent
  system
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(info)
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ── Feedback ───────────────────────────────────────────

enum FeedbackType {
  criticism
  suggestion
  complaint
  appreciation
}

enum FeedbackStatus {
  submitted
  under_review
  responded
}

model Feedback {
  id          String         @id @default(cuid())
  userId      String?
  type        FeedbackType   @default(suggestion)
  title       String
  body        String
  isAnonymous Boolean        @default(false)
  status      FeedbackStatus @default(submitted)
  reply       String?
  repliedBy   String?
  repliedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ── Attendance ─────────────────────────────────────────

model AttendanceRecord {
  id          String    @id @default(cuid())
  userId      String
  stationId   String?
  checkInGeo  String?
  checkInTime DateTime  @default(now())
  checkOutGeo String?
  checkOutTime DateTime?
  method      String    @default("gps")
  note        String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, checkInTime])
  @@index([stationId])
}

// ── Polls ──────────────────────────────────────────────

model Poll {
  id          String    @id @default(cuid())
  title       String
  description String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator   User         @relation("PollCreator", fields: [createdById], references: [id])
  options   PollOption[]
  votes     PollVote[]

  @@index([isActive])
}

model PollOption {
  id     String     @id @default(cuid())
  pollId String
  label  String

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id       String   @id @default(cuid())
  pollId   String
  optionId String
  userId   String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@index([pollId])
}

// ── Meetings ───────────────────────────────────────────

enum MeetingStatus {
  pending
  approved
  rejected
  rescheduled
}

model MeetingRequest {
  id              String        @id @default(cuid())
  requesterId     String
  targetManagerId String
  title           String
  description     String?
  scheduledAt     DateTime
  durationMinutes Int           @default(30)
  status          MeetingStatus @default(pending)
  note            String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  requester     User @relation("MeetingRequester", fields: [requesterId], references: [id])
  targetManager User @relation("MeetingTarget", fields: [targetManagerId], references: [id])

  @@index([requesterId])
  @@index([targetManagerId])
  @@index([status])
}

// ── Checklists ─────────────────────────────────────────

model ChecklistTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  items       Json     // [{ label: string, required: boolean }]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records ChecklistRecord[]
}

model ChecklistRecord {
  id           String   @id @default(cuid())
  templateId   String
  userId       String
  trainId      String?
  stationId    String?
  items        Json     // [{ label: string, checked: boolean, note?: string }]
  signedAt     DateTime @default(now())
  geoLocation  String?
  createdAt    DateTime @default(now())

  template ChecklistTemplate @relation(fields: [templateId], references: [id])
  user     User              @relation(fields: [userId], references: [id])

  @@index([userId, signedAt])
  @@index([templateId])
}

// ── Knowledge Base ─────────────────────────────────────

model KnowledgeArticle {
  id                   String    @id @default(cuid())
  title                String
  slug                 String    @unique
  body                 String
  category             String?
  tags                 String?   // comma-separated
  attachments          Json?     // [{ url, name, type }]
  version              Int       @default(1)
  validFrom            DateTime?
  validUntil           DateTime?
  ownerId              String?
  confidentialityLevel String    @default("internal") // public | internal | confidential | secret
  relatedPostId        String?   // لینک به دوره آموزشی مرتبط
  relatedQuizPostId    String?   // لینک به آزمون مرتبط
  authorId             String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([createdAt])
  @@index([confidentialityLevel])
}

model KnowledgeFAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  articleId String?  // لینک اختیاری به مقاله دانشنامه
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ── Crisis Management ──────────────────────────────────

enum CrisisLevel {
  normal
  elevated
  high
  critical
}

model CrisisEvent {
  id          String      @id @default(cuid())
  title       String
  description String?
  level       CrisisLevel @default(normal)
  stationId   String?
  activatedBy String
  activatedAt DateTime    @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  activator User @relation("CrisisActivator", fields: [activatedBy], references: [id])

  @@index([activatedBy])
  @@index([level])
  @@index([activatedAt])
}

// ── Gamification ───────────────────────────────────────

model GamificationScore {
  id        String   @id @default(cuid())
  userId    String
  points    Int      @default(0)
  reason    String
  period    String   // e.g. "2026-03"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, period, reason])
  @@index([userId])
  @@index([period])
}

// ── Performance Evaluation & KPIs ──────────────────────

model Competency {
  id          String   @id
  name        String
  weight      Float    @default(1.0)
  direction   String   // "positive" | "negative" | "both"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actionTypes PerformanceActionType[]
}

model PerformanceActionType {
  id           String   @id
  competencyId String
  title        String
  defaultScore Float
  maxSeverity  String   // "L1" | "L2" | "L3"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competency Competency       @relation(fields: [competencyId], references: [id])
  logs       PerformanceLog[]
}

model PerformanceLog {
  id            String   @id @default(cuid())
  employeeId    String
  recordedById  String
  actionTypeId  String
  severity      String   // "L1" | "L2" | "L3"
  scoreValue    Float
  note          String?
  evidenceUrl   String?
  periodId      String   // e.g., "1405-04" (jalali year-month)
  status        String   @default("active") // "active" | "appealed" | "overturned"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee   User                  @relation("PerformanceReceiver", fields: [employeeId], references: [id])
  recordedBy User                  @relation("PerformanceRecorder", fields: [recordedById], references: [id])
  actionType PerformanceActionType @relation(fields: [actionTypeId], references: [id])
  appeals    PerformanceAppeal[]

  @@index([employeeId])
  @@index([recordedById])
  @@index([actionTypeId])
  @@index([periodId])
}

model PerformanceAppeal {
  id           String    @id @default(cuid())
  logId        String
  employeeId   String
  reason       String
  status       String    @default("pending") // "pending" | "approved" | "rejected"
  reviewedById String?
  note         String?   // Review note
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  log        PerformanceLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  employee   User           @relation("PerformanceAppealingUser", fields: [employeeId], references: [id])
  reviewedBy User?          @relation("PerformanceAppealReviewer", fields: [reviewedById], references: [id])

  @@index([logId])
  @@index([employeeId])
}

model ScoreSnapshot {
  id              String   @id @default(cuid())
  employeeId      String
  periodId        String
  rawScore        Float
  normalizedScore Float
  percentile      Float
  createdAt       DateTime @default(now())

  employee User @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, periodId])
  @@index([periodId])
}

model Nomination {
  id               String   @id @default(cuid())
  periodId         String
  employeeId       String
  rank             Int
  tiebreakerReason String?
  status           String   @default("nominated") // "nominated" | "approved"
  createdAt        DateTime @default(now())

  periodEmployee User @relation(fields: [employeeId], references: [id])

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
}

model RosterDay {
  id               String          @id @default(cuid())
  lineCode         String          @default("LINE_1")
  jalaliDate       String          @unique
  gregorianDate    DateTime
  weekday          String?
  title            String?
  schedulingTitle  String?
  processingNumber Int?
  issuedByName     String?
  status           String          @default("DRAFT") // DRAFT | PROCESSING | REVIEW | PUBLISHED | ARCHIVED
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  versions         RosterVersion[]
}

model RosterVersion {
  id               String          @id @default(cuid())
  rosterDayId      String
  versionNo        Int             @default(1)
  fileUrl          String?
  originalFileName String?
  checksum         String?
  status           String          @default("UPLOADED") // UPLOADED | PARSED | VALIDATED | PUBLISHED | REJECTED
  uploadedById     String?
  uploadedAt       DateTime        @default(now())
  publishedById    String?
  publishedAt      DateTime?
  changeReason     String?
  changeSummary    String?

  rosterDay        RosterDay       @relation(fields: [rosterDayId], references: [id], onDelete: Cascade)
  uploadedBy       User?           @relation("RosterVersionUploader", fields: [uploadedById], references: [id])
  publishedBy      User?           @relation("RosterVersionPublisher", fields: [publishedById], references: [id])
  trips            Trip[]

  @@index([rosterDayId])
}

model Trip {
  id                 String           @id @default(cuid())
  rosterVersionId    String
  rowNo              Int
  trainNumber        String?
  direction          String           // TAJRISH_TO_SHAHRREY | SHAHRREY_TO_TAJRISH
  originStation      String?
  destinationStation String?
  departureTime      String?          // HH:mm:ss
  arrivalTime        String?          // HH:mm:ss
  operationalNote    String?
  status             String           @default("NORMAL") // NORMAL | EMPTY | CANCELLED | DEPOT | SPECIAL

  rosterVersion      RosterVersion    @relation(fields: [rosterVersionId], references: [id], onDelete: Cascade)
  assignments        TripAssignment[]

  @@index([rosterVersionId])
}

model TripAssignment {
  id             String           @id @default(cuid())
  tripId         String
  role           String           // H1 | H2 | T | R
  rawName        String?
  matchedUserId  String?
  personnelNo    String?
  matchScore     Float?
  matchStatus    String           @default("UNMATCHED") // AUTO_MATCHED | NEEDS_REVIEW | MANUAL_MATCHED | UNMATCHED
  confirmedById  String?
  confirmedAt    DateTime?
  acknowledgedAt DateTime?        // Confirm Sight
  readyAt        DateTime?
  handoverAt     DateTime?
  disputed       Boolean          @default(false)
  disputeNote    String?

  trip           Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  matchedUser    User?            @relation("TripAssignmentUser", fields: [matchedUserId], references: [id])
  confirmedBy    User?            @relation("TripAssignmentConfirmer", fields: [confirmedById], references: [id])
  tripSwapSourceAssignments TripSwapRequest[] @relation("TripSwapSourceAssignment")
  tripSwapTargetAssignments TripSwapRequest[] @relation("TripSwapTargetAssignment")

  @@index([tripId])
  @@index([matchedUserId])
}

model RosterTemplate {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  sourceType   String   @default("EXCEL") // EXCEL | PDF
  // Excel column mappings (existing)
  rightMapping Json?    // ColumnMapping JSON for Excel right block
  leftMapping  Json?    // ColumnMapping JSON for Excel left block
  // PDF template fields (§۴.۳)
  pageWidth    Int?     // PDF page width in pixels
  pageHeight   Int?     // PDF page height in pixels
  rightBlock   Json?    // { x, y, width, height } — right table block coordinates
  leftBlock    Json?    // { x, y, width, height } — left table block coordinates
  headerZones  Json?    // [{ label, box: {x, y, width, height} }] — metadata extraction zones
  pdfColumns   Json?    // ColumnMapping[] for PDF column positions
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── UI Builder / Server-Driven UI ─────────────────────

model UiMenuItem {
  id                 String   @id @default(cuid())
  parentId           String?
  label              String
  icon               String
  route              String   // target route name or page slug
  orderIndex         Int      @default(0)
  isVisible          Boolean  @default(true)
  requiredPermission String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parent             UiMenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children           UiMenuItem[] @relation("MenuHierarchy")

  @@index([parentId])
  @@index([orderIndex])
  @@map("ui_menu_items")
}

model UiPage {
  id                String          @id @default(cuid())
  slug              String          @unique
  title             String
  layoutType        String          @default("list") // list | detail | dashboard | form
  status            String          @default("draft") // draft | published
  currentVersionId  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  versions          UiPageVersion[]

  @@map("ui_pages")
}

model UiPageVersion {
  id            String   @id @default(cuid())
  pageId        String
  schemaJson    Json     // JSON representing component tree
  versionNumber Int
  createdById   String?
  createdAt     DateTime @default(now())

  page          UiPage   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("ui_page_versions")
}

model UiDashboardWidget {
  id                 String   @id @default(cuid())
  pageId             String?
  widgetType         String   // stat_card | chart | list | banner
  title              String?
  size               String   @default("md") // sm | md | lg
  orderIndex         Int      @default(0)
  isVisible          Boolean  @default(true)
  configJson         Json     // JSON representing configuration
  requiredPermission String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([orderIndex])
  @@map("ui_dashboard_widgets")
}

model UiTheme {
  id                String   @id @default(cuid())
  primaryColor      String   @default("#ae0011") // Default Metro Red
  accentColor       String   @default("#575e70")
  radius            Int      @default(12)
  fontSize          String   @default("md")
  darkModeDefault   Boolean  @default(false)
  logoUrl           String?
  apiBaseUrl        String   @default("https://metro.qzz.io")
  updatedAt         DateTime @updatedAt

  @@map("ui_themes")
}

// ── Leave & Mission Management ─────────────────────────

enum LeaveRequestStatus {
  pending
  approved
  rejected
  cancelled
}

model LeaveRequest {
  id          String             @id @default(cuid())
  userId      String
  type        String             // e.g., 'annual_leave', 'sick_leave', 'mission', 'overtime', 'on_call'
  fromDate    DateTime
  toDate      DateTime
  reason      String?
  amount      Float?             // e.g., 4.5 hours or 2 days
  unit        String?            // 'hours', 'days', 'count'
  calculatedAmount Float?        // After admin multiplier logic
  status      LeaveRequestStatus @default(pending)
  reviewedById String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user       User  @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("LeaveReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([fromDate])
}

// ── AI Gateway & Semantic Cache ─────────────────────────

model AiProvider {
  id                  String    @id @default(cuid())
  name                String    // e.g., "Gemini Flash", "Ollama Local"
  providerType        String    // gemini, openrouter, ollama, grok, custom
  baseUrl             String
  apiKey              String?   // Store encrypted or raw depending on implementation
  modelName           String?
  requestFormat       String    @default("openai_compatible")
  priority            Int       @default(100)
  isActive            Boolean   @default(true)
  maxRetries          Int       @default(2)
  timeoutMs           Int       @default(8000)
  costPer1kTokens     Float     @default(0)
  healthStatus        String    @default("healthy") // healthy, degraded, down
  lastFailureAt       DateTime?
  consecutiveFailures Int       @default(0)
  extraHeaders        String?   // JSON string
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([priority])
}

model AiKnowledgeCache {
  id                 String   @id @default(cuid())
  questionText       String
  questionEmbedding  String   // JSON array of floats as string for SQLite compatibility
  answerText         String
  source             String   // 'ai_generated', 'admin_manual', 'database'
  providerUsed       String?
  hitCount           Int      @default(0)
  confidenceScore    Float?
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  lastUsedAt         DateTime @default(now())
}

// ── Fleet ──────────────────────────────────────────────

model Train {
  id             String      @id @default(cuid())
  trainNumber    String      @unique          // e.g. "110"
  fleetSeries    String?                      // DC01, AC02, etc.
  manufacturer   String?                      // CNR, CRRC, etc.
  wagonCount     Int         @default(7)
  commissionedAt DateTime?                  
  status         TrainStatus @default(active)
  qrToken        String      @unique @default(cuid())  
  notes          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  wagons Wagon[]
  faults FaultReport[]

  @@index([status])
}

model Wagon {
  id         String  @id @default(cuid())
  trainId    String
  wagonCode  String                         // e.g. "110-3"
  position   Int                            // 1..7
  wagonType  String?                        // Mc / Tp / M / T
  isActive   Boolean @default(true)

  train  Train         @relation(fields: [trainId], references: [id])
  faults FaultReport[]

  @@unique([trainId, position])
  @@index([trainId])
}

// ── Fault Catalog ──────────────────────────────────────────────

model FaultCategory {
  id        String  @id @default(cuid())
  code      String  @unique      // BRK, DRS, TRC, HVAC, SIG, BOG, PAN, etc.
  title     String               
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  faultCodes FaultCode[]
}

model FaultCode {
  id              String         @id @default(cuid())
  categoryId      String
  code            String         @unique   // e.g. DRS-004
  title           String                   
  description     String?                  
  defaultPriority TicketPriority @default(medium)
  safetyCritical  Boolean        @default(false)  
  requiresWagon   Boolean        @default(true)   
  operatorGuide   String?                  
  keywords        String?                  
  aliases         String?                  
  embedding       Bytes?                   
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  category FaultCategory @relation(fields: [categoryId], references: [id])
  faults   FaultReport[]

  @@index([categoryId])
}

// ── Fault Report & Workflow ──────────────────────────────────────────────

model FaultReport {
  id             String         @id @default(cuid())
  faultNo        Int            @unique // Managed programmatically to avoid SQLite non-primary autoincrement error
  trainId        String
  wagonId        String?
  faultCodeId    String
  status         FaultStatus    @default(submitted)
  priority       TicketPriority @default(medium)

  // Registration
  reporterId     String
  description    String                    
  locationNote   String?                   
  occurredAt     DateTime                  
  serviceImpact  String?                   // none | delay | evacuated | removed_from_service
  photoUrls      Json?                     
  annotations    Json?                     

  // Review
  reviewerId     String?
  reviewNote     String?
  reviewedAt     DateTime?

  // Repair
  assigneeId     String?                   
  repairStartAt  DateTime?
  repairEndAt    DateTime?
  rootCause      String?                   
  actionsTaken   String?                   
  partsUsed      Json?                     // [{name, qty, partNo?}]

  // Verification/Deferral
  verifierId     String?
  verifiedAt     DateTime?
  closedAt       DateTime?
  deferReason    String?                   
  deferUntil     DateTime?                 

  // Recurrence & SLA
  recurrenceOfId String?                   
  slaDueAt       DateTime?                 
  slaBreached    Boolean        @default(false)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  train        Train        @relation(fields: [trainId], references: [id])
  wagon        Wagon?       @relation(fields: [wagonId], references: [id])
  faultCode    FaultCode    @relation(fields: [faultCodeId], references: [id])
  reporter     User         @relation("FaultReporter", fields: [reporterId], references: [id])
  reviewer     User?        @relation("FaultReviewer", fields: [reviewerId], references: [id])
  assignee     User?        @relation("FaultAssignee", fields: [assigneeId], references: [id])
  verifier     User?        @relation("FaultVerifier", fields: [verifierId], references: [id])
  recurrenceOf FaultReport? @relation("FaultRecurrence", fields: [recurrenceOfId], references: [id])
  recurrences  FaultReport[] @relation("FaultRecurrence")
  logs         FaultLog[]

  @@index([trainId, status])
  @@index([faultCodeId])
  @@index([status])
  @@index([occurredAt])
  @@index([slaDueAt])
}

model FaultLog {
  id         String         @id @default(cuid())
  faultId    String
  actorId    String
  action     FaultLogAction
  fromStatus FaultStatus?
  toStatus   FaultStatus?
  note       String?
  changes    Json?          // {field: {before, after}}
  createdAt  DateTime       @default(now())

  fault FaultReport @relation(fields: [faultId], references: [id], onDelete: Cascade)
  actor User        @relation("FaultLogActor", fields: [actorId], references: [id])

  @@index([faultId])
}

// ── Life Calendar (تقویم زندگی شیفت‌محور) ─────────────

model PersonalEvent {
  id          String            @id @default(cuid())
  userId      String
  type        PersonalEventType @default(event)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean           @default(true)
  color       String?
  location    String?
  isDone      Boolean           @default(false)
  recurrence  Json?             // {freq: yearly|monthly|weekly|daily, interval, until, jalali:true}
  reminders   Json?             // [{minutesBefore: 60}]
  isPrivate   Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation("PersonalEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
}

model Holiday {
  id         String   @id @default(cuid())
  jalaliDate String                         // "1405-01-01"
  title      String
  kind       String   @default("official")  // official | religious | occasion
  isOffDay   Boolean  @default(true)
  recurring  Boolean  @default(true)        // تکرار سالانه جلالی
  hijriBased Boolean  @default(false)       // قمری — ادمین سالانه ایمپورت می‌کند
  color      String?
  isActive   Boolean  @default(true)

  @@index([jalaliDate])
}

model OrgEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean  @default(true)
  audience    Json                           // {roles:[], groups:[], userIds:[]}
  color       String?
  mandatory   Boolean  @default(false)
  createdBy   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([startAt])
}

model CalendarPreference {
  id           String  @id @default(cuid())
  userId       String  @unique
  layers       Json    // {shift:{on:true}, holidays:{on:true}, personal:{on:true}, org:{on:true}, tasks:{on:true}}
  defaultView  String  @default("month")
  weekStart    String  @default("saturday")
  widgetConfig Json?
  icsToken     String? @unique

  user User @relation("CalendarPref", fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String   @id @default(cuid())
  key         String   // "fault-default"
  version     Int
  isActive    Boolean  @default(false)
  definition  Json     // { states:[], transitions:[], rules:[] }
  publishedAt DateTime?
  publishedBy String?
  createdAt   DateTime @default(now())

  @@unique([key, version])
}

