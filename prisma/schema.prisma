generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Enums ──────────────────────────────────────────────

enum UserStatus {
  pending
  active
  suspended
}

enum ShiftCode {
  morning
  evening
  night
  off
  office
}

enum ImportJobStatus {
  pending
  processing
  completed
  failed
}

enum SwapRequestStatus {
  pending
  approved
  rejected
}

enum TicketPriority {
  low
  medium
  high
  critical
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketLogAction {
  created
  status_changed
  assigned
  comment
  priority_changed
}

enum AuditLogAction {
  create
  update
  delete
  login
  logout
  import
  export
}

enum TrainStatus {
  active
  standby
  maintenance
  out_of_service
}

enum FaultStatus {
  submitted
  under_review
  needs_info
  rejected
  approved
  in_repair
  repaired
  verified_closed
  deferred
  reopened
}

enum FaultLogAction {
  created
  status_changed
  edited
  assigned
  comment
  priority_changed
  attachment_added
  sla_breached
  reopened
  deferred
}

enum ChatRoomType {
  direct
  group
}

enum ChatRoomKind {
  general
  operators
  occ
  shift
  station
  custom
  training
  announcement
  emergency
  management
}

enum PersonalEventType {
  event
  birthday
  task
  note
  work_log
  financial
  on_call
  overtime
  leave_sick
  leave_daily
  leave_hourly
  reminder
  other
}

enum PostType {
  news
  blog
  training
  circular
  gallery
  announcement
  directive
  form
}

// ── Models ─────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  personnelCode   String     @unique @map("nationalId")
  name         String
  phone        String?
  email        String?
  passwordHash String
  status       UserStatus @default(pending)
  roleId       String
  customFields Json?
  plateSearch  String     @default("")
  homeUnitId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  role       Role        @relation(fields: [roleId], references: [id])
  homeUnit   OrgUnit?    @relation("UserHomeUnit", fields: [homeUnitId], references: [id])
  importJobs ImportJob[] @relation("ImportActor")

  shifts                     Shift[]                 @relation("ShiftAssignee")
  swapRequestsInit           SwapRequest[]           @relation("SwapRequester")
  catalogs                   TechnicalCatalog[]      @relation("CatalogAuthor")
  swapRequestsTarget         SwapRequest[]           @relation("SwapTarget")
  tripSwapRequestsInit       TripSwapRequest[]       @relation("TripSwapRequester")
  tripSwapRequestsTarget     TripSwapRequest[]       @relation("TripSwapTarget")
  ticketsCreated             Ticket[]                @relation("TicketCreator")
  ticketLogs                 TicketLog[]             @relation("TicketLogActor")
  auditLogs                  AuditLog[]              @relation("AuditActor")
  systemLogs                 SystemLog[]             @relation("SystemLogActor")
  readReceipts               ReadReceipt[]           @relation("ReceiptUser")
  chatMemberships            ChatMember[]            @relation("ChatMemberUser")
  messages                   Message[]               @relation("MessageSender")
  posts                      Post[]                  @relation("PostAuthor")
  postReads                  PostRead[]              @relation("PostReadUser")
  postReactions              PostReaction[]          @relation("PostReactionUser")
  comments                   Comment[]               @relation("CommentUser")
  postAcks                   PostAck[]               @relation("PostAckUser")
  notifications              Notification[]
  feedback                   Feedback[]
  attendance                 AttendanceRecord[]
  notificationDevices        NotificationDevice[]    @relation("UserDevice")
  notificationOutboxes       NotificationOutbox[]    @relation("UserOutbox")
  notificationPreferences    NotificationPreference? @relation("UserPreference")
  pollsCreated               Poll[]                  @relation("PollCreator")
  pollVotes                  PollVote[]
  meetingsInitiated          MeetingRequest[]        @relation("MeetingRequester")
  meetingsTarget             MeetingRequest[]        @relation("MeetingTarget")
  checklistRecords           ChecklistRecord[]
  knowledgeArticles          KnowledgeArticle[]
  crisisEvents               CrisisEvent[]           @relation("CrisisActivator")
  gamificationScores         GamificationScore[]
  performanceLogsReceived    PerformanceLog[]        @relation("PerformanceReceiver")
  performanceLogsRecorded    PerformanceLog[]        @relation("PerformanceRecorder")
  performanceAppeals         PerformanceAppeal[]     @relation("PerformanceAppealingUser")
  performanceAppealsReviewed PerformanceAppeal[]     @relation("PerformanceAppealReviewer")
  scoreSnapshots             ScoreSnapshot[]
  nominations                Nomination[]
  shiftNotes                 ShiftNote[]
  shiftTasks                 ShiftTask[]
  rosterVersionsUploaded     RosterVersion[]         @relation("RosterVersionUploader")
  rosterVersionsPublished    RosterVersion[]         @relation("RosterVersionPublisher")
  tripAssignmentsMatched     TripAssignment[]        @relation("TripAssignmentUser")
  tripAssignmentsConfirmed   TripAssignment[]        @relation("TripAssignmentConfirmer")
  leaveRequests              LeaveRequest[]          @relation("LeaveRequester")
  reviewedLeaves             LeaveRequest[]          @relation("LeaveReviewer")
  aiConversations            AiConversation[]
  faultsReporter             FaultReport[]           @relation("FaultReporter")
  faultsReviewer             FaultReport[]           @relation("FaultReviewer")
  faultsAssignee             FaultReport[]           @relation("FaultAssignee")
  faultsVerifier             FaultReport[]           @relation("FaultVerifier")
  faultLogsActor             FaultLog[]              @relation("FaultLogActor")
  personalEvents             PersonalEvent[]         @relation("PersonalEvents")
  calendarPreference         CalendarPreference?     @relation("CalendarPref")
  formSubmissions            FormSubmission[]        @relation("FormSubmitter")
  formLogsActor              FormLog[]               @relation("FormLogActor")
  formDecisions              FormApproval[]          @relation("FormDecider")
  feedbackMsgSender          FeedbackMessage[]       @relation("FeedbackMsgSender")
  feedbackLogs               FeedbackLog[]           @relation("FeedbackLogActor")
  ideaVotes                  IdeaVote[]
  feedbackAssignee           Feedback[]              @relation("FeedbackAssignee")
  profileChangeRequests      ProfileChangeRequest[]  @relation("ProfileChangeRequester")
  userDocuments              UserDocument[]
  credentials                Credential[]
  userSessions               UserSession[]
  radioLogs                  RadioLog[]              @relation("RadioLogSender")
  enrollments                Enrollment[]
  examAttempts               ExamAttempt[]
  certificates               Certificate[]
  surveysCreated             Survey[]                @relation("SurveyCreator")
  surveyInvitees             SurveyInvitee[]
  surveyResponses            SurveyResponse[]
  myRosterDays               MyRosterDay[]
  fatigueLogs                FatigueLog[]
  sosAlerts                  SOSAlert[]              @relation("SOSReporter")
  incidentReports            IncidentReport[]        @relation("IncidentReporter")
  
  roleAssignments            RoleAssignment[]
  permissionOverrides        PermissionOverride[]
  lifecycleEvents            UserLifecycleEvent[]
  transfersRequested         TransferRequest[]       @relation("TransferRequester")
  transfersTarget            TransferRequest[]       @relation("TransferTarget")
  transfersApproved          TransferRequest[]       @relation("TransferApprover")

  @@index([roleId])
  @@index([status])
  @@index([name])
  @@index([phone])
  @@index([plateSearch])
}

model Role {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String   @map("name")
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  color       String?
  isActive    Boolean  @default(true)
  rank        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  roleAssignments  RoleAssignment[]

  @@map("roles")
}

model CustomFieldDef {
  id           String   @id @default(cuid())
  entityType   String
  name         String
  label        String
  type         String
  options      Json?
  required     Boolean  @default(false)
  defaultValue String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType])
}

model ImportJob {
  id         String          @id @default(cuid())
  fileName   String
  fileType   String
  status     ImportJobStatus @default(pending)
  rowCount   Int             @default(0)
  errorCount Int             @default(0)
  errors     Json?
  actorId    String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  actor User @relation("ImportActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([status])
}

model Shift {
  id        String    @id @default(cuid())
  date      DateTime
  code      ShiftCode
  source    String    @default("manual") // "cycle" | "roster" | "manual"
  note      String?
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User          @relation("ShiftAssignee", fields: [userId], references: [id])
  swapAsSource SwapRequest[] @relation("SwapSourceShift")
  swapAsTarget SwapRequest[] @relation("SwapTargetShift")

  @@unique([userId, date])
  @@index([date])
  @@index([code])
  @@index([source])
}

// ── Shift Cycle Templates (server-side source of truth) ──

model ShiftTemplate {
  id        String   @id @default(cuid())
  name      String
  type      String // "rotational" | "staff"
  length    Int // cycle length in days
  shifts    Json // CycleShiftDetail[] { day, code, label, hours, startTime, endTime }
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ShiftAssignment[]

  @@index([isActive])
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  templateId String
  targetType String // "user" | "group"
  targetId   String // user ID or group key ("A","B","C","Staff")
  anchorDate DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template ShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId])
  @@index([templateId])
}

// ── Shift Notes & Tasks (server-side persisted) ──

model ShiftNote {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model ShiftTask {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  title     String
  time      String
  priority  String   @default("medium") // "low" | "medium" | "high"
  status    String   @default("todo") // "todo" | "in_progress" | "done"
  type      String   @default("personal") // "personal" | "system"
  overtime  Float?
  extraData Json? // kahrizakCount and other custom numeric fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([status])
}

model SwapRequest {
  id            String            @id @default(cuid())
  requesterId   String
  targetId      String
  sourceShiftId String
  targetShiftId String
  status        SwapRequestStatus @default(pending)
  note          String?
  reviewedBy    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requester   User  @relation("SwapRequester", fields: [requesterId], references: [id])
  target      User  @relation("SwapTarget", fields: [targetId], references: [id])
  sourceShift Shift @relation("SwapSourceShift", fields: [sourceShiftId], references: [id])
  targetShift Shift @relation("SwapTargetShift", fields: [targetShiftId], references: [id])

  @@index([requesterId])
  @@index([targetId])
  @@index([sourceShiftId])
  @@index([targetShiftId])
  @@index([status])
}

model TripSwapRequest {
  id                 String            @id @default(cuid())
  requesterId        String
  targetId           String
  sourceAssignmentId String // TripAssignment being swapped by requester
  targetAssignmentId String // TripAssignment being swapped by target
  status             SwapRequestStatus @default(pending)
  note               String?
  reviewedBy         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  requester        User           @relation("TripSwapRequester", fields: [requesterId], references: [id])
  target           User           @relation("TripSwapTarget", fields: [targetId], references: [id])
  sourceAssignment TripAssignment @relation("TripSwapSourceAssignment", fields: [sourceAssignmentId], references: [id])
  targetAssignment TripAssignment @relation("TripSwapTargetAssignment", fields: [targetAssignmentId], references: [id])

  @@index([requesterId])
  @@index([targetId])
  @@index([sourceAssignmentId])
  @@index([targetAssignmentId])
  @@index([status])
}

model SafetyBulletin {
  id        String   @id @default(cuid())
  title     String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readReceipts ReadReceipt[]
}

model ReadReceipt {
  id               String   @id @default(cuid())
  userId           String
  safetyBulletinId String
  readAt           DateTime @default(now())
  device           String?

  user           User           @relation("ReceiptUser", fields: [userId], references: [id])
  safetyBulletin SafetyBulletin @relation(fields: [safetyBulletinId], references: [id])

  @@unique([userId, safetyBulletinId])
  @@index([safetyBulletinId])
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String?
  priority    TicketPriority @default(medium)
  status      TicketStatus   @default(open)
  wagonCode   String?
  photoUrl    String?
  annotations Json?
  creatorId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator User        @relation("TicketCreator", fields: [creatorId], references: [id])
  logs    TicketLog[]

  @@index([creatorId])
  @@index([status])
  @@index([priority])
}

model TicketLog {
  id        String          @id @default(cuid())
  ticketId  String
  actorId   String
  action    TicketLogAction
  note      String?
  createdAt DateTime        @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  actor  User   @relation("TicketLogActor", fields: [actorId], references: [id])

  @@index([ticketId])
  @@index([actorId])
}

model AuditLog {
  id        String         @id @default(cuid())
  actorId   String
  entity    String
  entityId  String
  action    AuditLogAction
  before    Json?
  after     Json?
  reason    String? // دلیل تغییر
  ipAddress String? // آدرس آی‌پی درخواست‌دهنده
  userAgent String? // مشخصات مرورگر / کلاینت
  device    String? // نوع دستگاه: mobile | desktop | tablet
  metadata  Json? // اطلاعات اضافی دلخواه
  createdAt DateTime       @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // info | warn | error | debug
  source    String   // server | client | mobile
  category  String   // e.g. "auth", "uploads", "database", "api"
  message   String
  stack     String?  // stack trace or detailed error message
  metadata  Json?    // any additional info (request body, headers, etc)
  ipAddress String?
  userAgent String?
  actorId   String?
  createdAt DateTime @default(now())

  actor User? @relation("SystemLogActor", fields: [actorId], references: [id])

  @@index([level])
  @@index([source])
  @@index([createdAt])
}

// ── Chat ───────────────────────────────────────────────

model ChatRoom {
  id        String       @id @default(cuid())
  name      String
  type      ChatRoomType @default(group)
  kind      ChatRoomKind @default(custom)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members  ChatMember[]
  messages Message[]

  @@index([type])
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  messages  AiMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model AiMessage {
  id              String         @id @default(uuid())
  conversationId  String
  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String // 'user' | 'model'
  text            String
  source          String? // 'rulebook' | 'gemini' | 'system'
  confidence      Int?
  handbookSection String?
  feedback        Int? // 1 for thumbs up, -1 for thumbs down
  createdAt       DateTime       @default(now())
}

model ChatMember {
  id         String    @id @default(cuid())
  roomId     String
  userId     String
  isAdmin    Boolean   @default(false)
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation("ChatMemberUser", fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  roomId         String
  senderId       String
  body           String?
  attachmentUrl  String?
  attachmentType String?
  pinned         Boolean   @default(false)
  priority       String    @default("normal") // normal | important | urgent | emergency | critical
  tags           String? // comma-separated tags or JSON
  readReceipts   Json? // JSON array of ReadReceipt { userId, userName, seenAt, device, ipAddress, signature, docUrl }
  createdAt      DateTime  @default(now())
  editedAt       DateTime?

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId, createdAt])
}

// ── Content (وبلاگ/اخبار/آموزش) ─────────────────────────

model Post {
  id             String    @id @default(cuid())
  type           PostType  @default(news)
  title          String
  slug           String    @unique
  excerpt        String?
  body           String
  category       String?
  tags           String?
  coverUrl       String?
  mediaUrl       String?
  mediaType      String?
  published      Boolean   @default(false)
  mandatory      Boolean   @default(false)
  hasQuiz        Boolean   @default(false)
  prerequisiteId String?
  status         String    @default("draft") // draft | review | approved | published | archived
  publishAt      DateTime? // زمان انتشار زمان‌بندی‌شده
  reviewedById   String?
  reviewedAt     DateTime?
  archivedAt     DateTime?
  nextReviewAt   DateTime? // یادآوری بازنگری دوره‌ای
  authorId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Announcements Platform fields
  kind          String    @default("news")
  audience      Json?
  surfaces      Json?
  priority      Int       @default(0)
  pinnedUntil   DateTime?
  expiresAt     DateTime?
  ackRequired   Boolean   @default(false)
  ackDeadline   DateTime?
  bannerStyle   Json?
  attachments   Json?
  notifyRuleKey String?

  author    User           @relation("PostAuthor", fields: [authorId], references: [id])
  reads     PostRead[]
  reactions PostReaction[]
  comments  Comment[]
  acks      PostAck[]      @relation("PostAckPost")
  audiences PostAudience[]

  @@index([type, status])
  @@index([type, published])
  @@index([authorId])
  @@index([createdAt])
  @@index([status])
}

model PostRead {
  id     String   @id @default(cuid())
  postId String
  userId String
  readAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostReadUser", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostReactionUser", fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("CommentUser", fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model Setting {
  id           String   @id @default(cuid())
  key          String   @unique
  label        String
  description  String?
  type         String // "number" | "text" | "boolean" | "color" | "select"
  value        String // JSON serialized value
  defaultValue String // JSON serialized defaultValue
  category     String // e.g. "general", "shifts", "tickets", "chat"
  isEnabled    Boolean  @default(true)
  min          Float?
  max          Float?
  options      String? // JSON options for select type
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ── Notifications ──────────────────────────────────────

enum NotificationType {
  info
  warning
  urgent
  system
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(info)
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ── Feedback ───────────────────────────────────────────

enum FeedbackType {
  criticism
  suggestion
  complaint
  appreciation
}

enum FeedbackStatus {
  submitted
  under_review
  responded
}

model Feedback {
  id          String         @id @default(cuid())
  userId      String?
  type        FeedbackType   @default(suggestion)
  title       String
  body        String
  isAnonymous Boolean        @default(false)
  status      FeedbackStatus @default(submitted)
  reply       String?
  repliedBy   String?
  repliedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  feedbackNo     Int       @unique @default(0)
  categoryId     String?
  assigneeId     String?
  assigneeRole   String?
  priority       String    @default("normal")
  formData       Json?
  attachments    Json?
  anonToken      String?   @unique
  slaFirstDue    DateTime?
  slaResolveDue  DateTime?
  slaBreached    Boolean   @default(false)
  satisfaction   Int?
  closedAt       DateTime?
  isPublicIdea   Boolean   @default(false)
  ideaVotesCount Int       @default(0)

  user     User?             @relation(fields: [userId], references: [id])
  category FeedbackCategory? @relation(fields: [categoryId], references: [id])
  messages FeedbackMessage[]
  logs     FeedbackLog[]
  votes    IdeaVote[]
  assignee User?             @relation("FeedbackAssignee", fields: [assigneeId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ── Attendance ─────────────────────────────────────────

model AttendanceRecord {
  id           String    @id @default(cuid())
  userId       String
  stationId    String?
  checkInGeo   String?
  checkInTime  DateTime  @default(now())
  checkOutGeo  String?
  checkOutTime DateTime?
  method       String    @default("gps")
  note         String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, checkInTime])
  @@index([stationId])
}

// ── Identity & Access Management (IAM) ─────────────────

model OrgUnit {
  id        String   @id @default(cuid())
  kind      String   // "line" | "station" | "shift_group" | "unit"
  key       String   @unique // e.g. "st-tajrish", "st-tajrish-shift-a"
  title     String
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]   @relation("UserHomeUnit")
  parent    OrgUnit? @relation("OrgUnitParent", fields: [parentId], references: [id])
  children  OrgUnit[] @relation("OrgUnitParent")

  @@index([parentId])
  @@index([kind])
}

model RoleAssignment {
  id        String    @id @default(cuid())
  userId    String
  roleId    String
  scopeType String    @default("all") // "all" | "region" | "station" | "unit"
  scopeKey  String?
  validFrom DateTime  @default(now())
  validTo   DateTime?
  reason    String?
  grantedBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId, scopeType, scopeKey])
}

model PermissionOverride {
  id        String    @id @default(cuid())
  userId    String
  permKey   String
  effect    String    // "grant" | "deny"
  scopeType String    @default("all")
  scopeKey  String?
  validTo   DateTime?
  reason    String
  grantedBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccessPolicy {
  id        String   @id @default(cuid())
  key       String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserLifecycleEvent {
  id        String   @id @default(cuid())
  userId    String
  kind      String   // "registered" | "approved" | "activated" | "suspended" | "role_changed" | "offboarded"
  detail    Json?
  actorId   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TransferRequest {
  id            String   @id @default(cuid())
  userId        String
  fromUnitId    String?
  toUnitId      String
  effectiveDate DateTime
  status        String   @default("pending") // "pending" | "approved" | "rejected"
  requestedById String
  approvedById  String?
  reason        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  targetUser    User     @relation("TransferTarget", fields: [userId], references: [id], onDelete: Cascade)
  requestedBy   User     @relation("TransferRequester", fields: [requestedById], references: [id])
  approvedBy    User?    @relation("TransferApprover", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([toUnitId])
  @@index([status])
}


// ── Polls ──────────────────────────────────────────────

model Poll {
  id          String    @id @default(cuid())
  title       String
  description String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  audience    Json?
  isAnonymous Boolean @default(false)
  multiSelect Boolean @default(false)
  showResults String  @default("after_vote")
  allowChange Boolean @default(false)
  surfaces    Json?

  creator User         @relation("PollCreator", fields: [createdById], references: [id])
  options PollOption[]
  votes   PollVote[]

  @@index([isActive])
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  label  String

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@index([pollId])
}

// ── Meetings ───────────────────────────────────────────

enum MeetingStatus {
