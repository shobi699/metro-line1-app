  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

// ── AI Assistant Platform ───────────────────────────────

model AiPersona {
  id              String  @id @default(cuid())
  key             String  @unique // "operator" | "supervisor" | ...
  title           String
  icon            String?
  systemPrompt    String
  roleKeys        String // JSON string
  knowledgeCats   String // JSON string
  tools           String // JSON string
  economyModel    String?
  strongModel     String?
  monthlyTokenCap Int?
  isActive        Boolean @default(true)
}

model AiKnowledgeSource {
  id          String    @id @default(cuid())
  title       String
  category    String
  accessRoles String? // JSON string
  fileUrl     String?
  version     Int       @default(1)
  chunkCount  Int       @default(0)
  indexedAt   DateTime?
  isActive    Boolean   @default(true)

  chunks AiChunk[]
}

model AiChunk {
  id        String  @id @default(cuid())
  sourceId  String
  text      String
  embedding String // JSON array of floats as string for SQLite compatibility
  meta      String? // JSON string

  source AiKnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model AiInteraction {
  id         String   @id @default(cuid())
  userId     String
  personaKey String
  layer      String // L0|L1|L2|L3|L4
  provider   String?
  model      String?
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  costEst    Float    @default(0)
  latencyMs  Int
  rating     Int? // 1 / -1
  toolUsed   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([personaKey, layer])
}

// ── Roster Precomputed Snapshots (Roster Platform v2 — فاز ۱: سرعت) ──

model RosterSnapshot {
  id          String   @id @default(cuid())
  rosterDayId String   @unique
  versionNo   Int
  payload     String // JSON — لوحه کامل نرمال‌شده (SQLite compatible)
  etag        String
  builtAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rosterDay RosterDay @relation(fields: [rosterDayId], references: [id], onDelete: Cascade)
}

model MyRosterDay {
  id         String   @id @default(cuid())
  userId     String
  jalaliDate String
  versionNo  Int
  payload    String // JSON — سفرهای شخصی + متادیتا
  etag       String
  builtAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jalaliDate])
  @@index([jalaliDate])
  @@index([userId])
}

// ── Roster Amendments (Roster Platform v2 — فاز ۲: اصلاحیه) ──

model RosterAmendment {
  id           String    @id @default(cuid())
  rosterDayId  String
  seq          Int // اصلاحیه شماره N روز
  kind         String // trip_time | trip_status | crew_replace | crew_add | crew_remove | trip_add | trip_remove | note
  targetTripId String?
  before       String? // JSON — وضعیت قبل
  after        String // JSON — وضعیت بعد
  reason       String // اجباری
  status       String    @default("draft") // draft | pending_approval | approved | applied | rejected
  createdById  String
  approvedById String?
  appliedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rosterDay        RosterDay       @relation(fields: [rosterDayId], references: [id], onDelete: Cascade)
  trip             Trip?           @relation(fields: [tripId], references: [id])
  tripId           String?
  tripAssignment   TripAssignment? @relation(fields: [tripAssignmentId], references: [id])
  tripAssignmentId String?

  @@index([rosterDayId, seq])
  @@index([status])
}

// ── Roster Validation Rules (Roster Platform v2 — فاز ۳: کیفیت) ──

model RosterValidationRule {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "incomplete_crew", "overlap", "fatigue_turnaround"
  label       String // متن فارسی
  description String?
  severity    String   @default("error") // error | warning
  isEnabled   Boolean  @default(true)
  params      String? // JSON — پارامترهای قابل تنظیم
  category    String   @default("general")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model NameAlias {
  id         String   @id @default(cuid())
  rawName    String // نام خام از فایل
  userId     String // کاربر تطبیق‌شده
  confidence Float    @default(100)
  createdAt  DateTime @default(now())

  @@unique([rawName, userId])
  @@index([rawName])
}

// ── Roster Visibility & Amendment Rules (Roster Platform v2 — فاز ۴) ──

model RosterVisibilityMatrix {
  id            String   @id @default(cuid())
  roleKey       String   @unique // operator | supervisor | occ | planner | admin
  visibleCols   String // JSON array: ["trainNumber", "direction", "departureTime", "h1", "h2", ...]
  regionFilter  String? // JSON: ناحیه‌های قابل مشاهده
  showCrewNames Boolean  @default(true)
  showNotes     Boolean  @default(true)
  defaultView   String   @default("timeline") // timeline | table | gantt
  updatedAt     DateTime @updatedAt
}

model RosterAmendmentRule {
  id                   String   @id @default(cuid())
  amendmentKind        String   @unique // trip_time | crew_replace | ...
  requireApproval      Boolean  @default(true)
  approverRoleKey      String? // نقش تایید‌کننده
  maxHoursAfterPublish Int? // مهلت اصلاح
  standardReasons      String? // JSON array — دلایل استاندارد
  updatedAt            DateTime @updatedAt
}

// ── Fatigue Analysis ────────────────────────────────────────

model FatigueLog {
  id                 String   @id @default(cuid())
  userId             String
  sleepHours         Float
  sleepQuality       String // "good" | "fair" | "poor"
  fatigueLevel       Int // 1-5
  hasHeadacheOrColds Boolean
  score              Int
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ── Crisis & Safety Modules ─────────────────────────────────

model SOSAlert {
  id                  String   @id @default(cuid())
  reporterId          String
  reporterShift       String?
  reporterRole        String?
  locationCoordinates String?
  batteryPercentage   Int?
  networkStatus       String?
  audioMemoUrl        String?
  status              String   @default("submitted") // submitted | seen | dispatch | resolved | closed
  timeline            Json? // Array<{ time: string; text: string }>
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reporter User @relation("SOSReporter", fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([status])
}

model IncidentReport {
  id               String   @id @default(cuid())
  title            String
  type             String // accident | near_miss | safety_violation | equipment_failure | delay
  dateTime         DateTime @default(now())
  location         String?
  trainNo          String?
  rootCause        String?
  correctiveAction String?
  description      String?
  status           String   @default("under_review") // under_review | action_taken | closed
  reporterId       String
  timeline         Json? // Array<{ time: string; text: string }>
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reporter User @relation("IncidentReporter", fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([type])
  @@index([status])
}

// ── Technical Catalogs (Live Guide & Flowcharts) ─────────────────

model TechnicalCatalog {
  id          String   @id @default(cuid())
  title       String
  category    String   // e.g. "AC", "DC", "عمومی"
  content     String   // The Mermaid code
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User?    @relation("CatalogAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([authorId])
}

// ── Landing Page (Orbit Gallery) ──────────────────────

model OrbitImage {
  id        String   @id @default(cuid())
  title     String
  caption   String?
  alt       String
  mediaUrl  String
  thumbUrl  String?
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive, sortOrder])
}

model HeroQuote {
  id        String  @id @default(cuid())
  text      String
  author    String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
}

model LandingCta {
  id        String  @id @default(cuid())
  label     String
  href      String
  icon      String?
  variant   String  @default("primary")
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  authOnly  Boolean @default(false)
}

model LandingVersion {
  id          String    @id @default(cuid())
  status      String    @default("DRAFT")
  snapshot    String
  publishedAt DateTime?
  publishedBy String?
  createdAt   DateTime  @default(now())
}






