atus: 'expired', expiryDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв–“/в–Ҳв–’в–Ҳв•Ў' },\n  { id: '4', ownerName: 'в•ӘВәв”ҳГ в–ҲГ®в•Әв–’в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘ в•Әв–“в•ӘВәв•Әв–’в•Әв•Јв–ҲГ®', ownerCode: '17320', plate: { num1: '14', letter: 'в•Әв”Ӯ', num2: '445', city: '77' }, type: 'в”ҳв•ӣв•Әв–’в•ӘВәв–ҲГ®в•ӘВ» в–Ҳв–’в–Ҳв”Ӯв–Ҳв–’', color: 'в”ҳГҘв”ҳГ©в•Әв–’в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®', status: 'active', expiryDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–‘в–Ҳв•Ў/в–Ҳв–“в–Ҳв–‘' },\n  { id: '5', ownerName: 'в•ӘВЎв•ӘВәв”ҳГ в•ӘВ» в•ӘВ¬в”ҳГ©в”ҳГӘв–ҲГ®', ownerCode: '11002', plate: { num1: '45', letter: 'в”ҳГ©', num2: '233', city: '66' }, type: 'в•ӘВ¬в•ӘВәв•Әв–’в•ӘВә в•ӘВәв•ӘВ¬в”ҳГӘв”ҳГ в•ӘВәв•ӘВ¬в–ҲГ®в”ҢвҢҗ', color: 'в•ӘВ«в•ӘВәв”ҢвҢҗв•Әв”Ӯв•ӘВ¬в•Әв–’в–ҲГ® в”ҳГ в•ӘВ¬в•ӘВәв”ҳГӨв–ҲГ®в”ҢвҢҗ', status: 'blocked', expiryDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв••/в–Ҳв–’в–Ҳв–‘' },\n]\n\nconst INITIAL_CAMERA_LOGS: CameraLog[] = [\n  { id: 'LOG-301', time: '01:52:10', cameraLocation: 'в”ҢВ»в–ҲГ®в•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ', plate: { num1: '22', letter: 'в•ӘВҝ', num2: '567', city: '33' }, direction: 'in', status: 'allowed', ownerName: 'в”ҳГ в•ӘВЎв”ҳГ в•ӘВ»в•Әв–’в•Әв•ўв•ӘВә в•Әв•Јв”ҳГӨв”ҳГӘв–ҲГ®' },\n  { id: 'LOG-302', time: '01:45:05', cameraLocation: 'в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ® в”ҳв•ӣв•ӘВәв•Әв–’в”ҢвҢҗв–ҲГ®в”ҳГҘв”ҢВ» в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в•Әв•Ўв•ӘВәв•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ§', plate: { num1: '78', letter: 'в•ӘВј', num2: '123', city: '22' }, direction: 'out', status: 'allowed', ownerName: 'в•Әв”Ӯв–ҲГ®в•ӘВ» в•Әв–’в•Әв•ўв•ӘВә в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘв–ҲГ®' },\n  { id: 'LOG-303', time: '01:30:44', cameraLocation: 'в”ҢВ»в–ҲГ®в•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ', plate: { num1: '99', letter: 'в–ҲГ®', num2: '999', city: '99' }, direction: 'in', status: 'denied' },\n  { id: 'LOG-304', time: '01:10:15', cameraLocation: 'в”ҢВ»в–ҲГ®в•ӘВ¬ в•ӘВјв”ҳГҘв”ҳГӘв•ӘВҝв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ', plate: { num1: '14', letter: 'в•Әв”Ӯ', num2: '445', city: '77' }, direction: 'in', status: 'allowed', ownerName: 'в•ӘВәв”ҳГ в–ҲГ®в•Әв–’в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘ в•Әв–“в•ӘВәв•Әв–’в•Әв•Јв–ҲГ®' },\n]\n\nconst PLATE_LETTERS = ['в•ӘВәв”ҳГӨв”ҳГј', 'в•ӘВҝ', 'в•ӘВј', 'в•ӘВ»', 'в•Әв”Ӯ', 'в•Әв•Ў', 'в•Әв•–', 'в•Әв•Ј', 'в”ҳГ©', 'в”ҳГӨ', 'в”ҳГ ', 'в”ҳГҘ', 'в”ҳГӘ', 'в”ҳГ§', 'в–ҲГ®']\n\ninterface Plate {\n  num1: string\n  letter: string\n  num2: string\n  city: string\n}\n\nfunction IranianPlateDisplay({ plate }: { plate: Plate }) {\n  return (\n    <div className=\"inline-flex items-center border border-slate-700 rounded bg-white text-slate-900 font-bold text-xs h-7 select-none overflow-hidden shrink-0 shadow-sm\" dir=\"ltr\">\n      <div className=\"bg-blue-800 text-white w-4 h-full flex flex-col items-center justify-between py-0.5 px-0.5 border-r border-slate-700\">\n        <span className=\"text-[5px] leading-none\">I.R.</span>\n        <span className=\"text-[5px] leading-none font-sans font-normal\">IRAN</span>\n      </div>\n      <div className=\"px-1.5 font-sans text-sm tracking-tighter\">{toFa(plate.num1)}</div>\n      <div className=\"px-1.5 text-xs font-semibold font-serif text-slate-800\">{plate.letter}</div>\n      <div className=\"px-1.5 font-sans text-sm tracking-tighter\">{toFa(plate.num2)}</div>\n      <div className=\"border-l border-slate-700 h-full flex flex-col items-center justify-center px-1.5 bg-slate-100 text-[8px] leading-none\">\n        <span className=\"text-[6px] text-slate-600 scale-90 mb-0.5\">в•ӘВәв–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ</span>\n        <span className=\"font-sans font-bold text-xs leading-none\">{toFa(plate.city)}</span>\n      </div>\n    </div>\n  )\n}\n\nexport default function LicensePlatesPage() {\n  const [vehicles, setVehicles] = useState<Vehicle[]>(INITIAL_VEHICLES)\n  const [cameraLogs, setCameraLogs] = useState<CameraLog[]>(INITIAL_CAMERA_LOGS)\n  const [searchTerm, setSearchTerm] = useState('')\n  const [showAddForm, setShowAddForm] = useState(false)\n\n  // в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв•Әв–’в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ\n  const [ownerName, setOwnerName] = useState('')\n  const [ownerCode, setOwnerCode] = useState('')\n  const [plateNum1, setPlateNum1] = useState('')\n  const [plateLetter, setPlateLetter] = useState('в•ӘВҝ')\n  const [plateNum2, setPlateNum2] = useState('')\n  const [plateCity, setPlateCity] = useState('')\n  const [carType, setCarType] = useState('')\n  const [carColor, setCarColor] = useState('')\n  const [expiryDate, setExpiryDate] = useState('в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв•Ј')\n\n  // в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ (в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘ в–Ҳв•–)\n  const [autoOpenForAllowed, setAutoOpenForAllowed] = useState(true)\n  const [notifyOnBlocked, setNotifyOnBlocked] = useState(true)\n  const [alertExpiryDays, setAlertExpiryDays] = useState(30)\n  const [successMessage, setSuccessMessage] = useState('')\n\n  const handleAddVehicle = (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!ownerName || !ownerCode || !plateNum1 || !plateNum2 || !plateCity || !carType) {\n      alert('в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•Әв–’в•ӘВә в”ҳв•ӣв•Әв–’ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».')\n      return\n    }\n\n    const newVehicle: Vehicle = {\n      id: `VEH-${vehicles.length + 1}`,\n      ownerName,\n      ownerCode,\n      plate: {\n        num1: plateNum1,\n        letter: plateLetter,\n        num2: plateNum2,\n        city: plateCity,\n      },\n      type: carType,\n      color: carColor || 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў',\n      status: 'active',\n      expiryDate,\n    }\n\n    setVehicles((prev) => [newVehicle, ...prev])\n    setShowAddForm(false)\n    resetForm()\n    setSuccessMessage('в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВҝв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ»в”ҳГӘв•Әв–’в•ӘВҝв–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘ в•Әв”Өв•ӘВ».')\n    setTimeout(() => setSuccessMessage(''), 4000)\n  }\n\n  const resetForm = () => {\n    setOwnerName('')\n    setOwnerCode('')\n    setPlateNum1('')\n    setPlateLetter('в•ӘВҝ')\n    setPlateNum2('')\n    setPlateCity('')\n    setCarType('')\n    setCarColor('')\n  }\n\n  const handleToggleStatus = (id: string) => {\n    setVehicles((prev) =>\n      prev.map((v) => {\n        if (v.id === id) {\n          const nextStatus = v.status === 'active' ? 'blocked' : 'active'\n          return { ...v, status: nextStatus }\n        }\n        return v\n      }),\n    )\n  }\n\n  const handleDeleteVehicle = (id: string) => {\n    if (confirm('в•ӘГів–ҲГ®в•ӘВә в•ӘВәв•Әв–“ в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ в•ӘВәв•Әв•–в”ҳГ в–ҲГ®в”ҳГҘв•ӘВәв”ҳГҘ в•ӘВ»в•ӘВәв•Әв–’в–ҲГ®в•ӘВ»в•ӘЖ’')) {\n      setVehicles((prev) => prev.filter((v) => v.id !== id))\n    }\n  }\n\n  const handleSimulateScan = () => {\n    // в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВәв•Әв”Ӯв”ҢвҢҗв”ҳГҘ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в–ҲГ®в•ӘВә в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§\n    const isRegistered = Math.random() > 0.4\n    const d = new Date()\n    const pad = (v: number) => String(v).padStart(2, '0')\n    const timeString = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`\n\n    let scanLog: CameraLog\n\n    if (isRegistered) {\n      const randomCar = vehicles[Math.floor(Math.random() * vehicles.length)]\n      scanLog = {\n        id: `LOG-${Date.now()}`,\n        time: timeString,\n        cameraLocation: Math.random() > 0.5 ? 'в”ҢВ»в–ҲГ®в•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ' : 'в”ҢВ»в–ҲГ®в•ӘВ¬ в•ӘВјв”ҳГҘв”ҳГӘв•ӘВҝв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ',\n        plate: randomCar.plate,\n        direction: 'in',\n        status: randomCar.status === 'active' ? 'allowed' : 'denied',\n        ownerName: randomCar.ownerName,\n      }\n    } else {\n      const randomLetters = PLATE_LETTERS[Math.floor(Math.random() * PLATE_LETTERS.length)]\n      scanLog = {\n        id: `LOG-${Date.now()}`,\n        time: timeString,\n        cameraLocation: 'в”ҢВ»в–ҲГ®в•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ',\n        plate: {\n          num1: String(Math.floor(Math.random() * 80) + 10),\n          letter: randomLetters,\n          num2: String(Math.floor(Math.random() * 900) + 100),\n          city: String(Math.floor(Math.random() * 80) + 10),\n        },\n        direction: 'in',\n        status: 'denied',\n      }\n    }\n\n    setCameraLogs((prev) => [scanLog, ...prev])\n  }\n\n  const filteredVehicles = vehicles.filter(\n    (v) =>\n      v.ownerName.includes(searchTerm) ||\n      v.ownerCode.includes(searchTerm) ||\n      v.plate.num1.includes(searchTerm) ||\n      v.plate.num2.includes(searchTerm),\n  )\n\n  return (\n    <div className=\"flex min-h-screen flex-col\" dir=\"rtl\">\n      <TopAppBar\n        title=\"в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГӘ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ\"\n        subtitle=\"в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в”ҳГӘв•Әв”Ӯв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГҘв”ҳГ©в”ҳГӨв–ҲГ®в”ҳГ§ в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ® в•ӘВҝв”ҳГ§ в•ӘВ»в”ҳв•ӣв”ҳГӘ в”ҳГӘ в”ҳГҘв•Әв••в•ӘВәв•Әв–’в•ӘВ¬ в•ӘВҝв•Әв–’ в”ҢВ»в–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә\"\n      />\n\n      <main className=\"flex-1 p-4 pt-16 md:p-6 space-y-6 max-w-5xl mx-auto w-full\">\n        {successMessage && (\n          <div className=\"flex items-center gap-2 rounded-lg border border-success/30 bg-success/10 p-3.5 text-xs text-success animate-in fade-in duration-150\">\n            <CheckCircle className=\"size-4 shrink-0\" />\n            <span>{successMessage}</span>\n          </div>\n        )}\n\n        <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-3\">\n          {/* Main Vehicle List */}\n          <div className=\"lg:col-span-2 space-y-6\">\n            <Card className=\"bg-surface/50 backdrop-blur-md border border-border-subtle rounded-lg\">\n              <CardHeader className=\"flex flex-row items-center justify-between pb-3 border-b border-border-subtle/50 gap-4\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                  <Car className=\"size-4 text-accent\" />\n                  в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’\n                </CardTitle>\n                <Button size=\"sm\" className=\"h-8 gap-1 cursor-pointer\" onClick={() => setShowAddForm(!showAddForm)}>\n                  <Plus className=\"size-4\" />\n                  <span>в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</span>\n                </Button>\n              </CardHeader>\n              <CardContent className=\"pt-4\">\n                {/* Search Bar */}\n                <div className=\"relative mb-4\">\n                  <Search className=\"absolute right-3 top-2.5 size-4 text-foreground-muted\" />\n                  <input\n                    type=\"text\"\n                    placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв•ӘГ® в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в–ҲГ®в•ӘВә в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ...\"\n                    value={searchTerm}\n                    onChange={(e) => setSearchTerm(e.target.value)}\n                    className=\"h-9 w-full rounded-lg border border-border bg-surface pr-9 pl-3 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                  />\n                </div>\n\n                {/* Add Vehicle Form (Collapsible) */}\n                {showAddForm && (\n                  <form onSubmit={handleAddVehicle} className=\"border border-border-subtle rounded-lg p-4 bg-surface/60 backdrop-blur-sm space-y-4 mb-4 animate-in fade-in slide-in-from-top-2 duration-150\">\n                    <h4 className=\"text-xs font-bold text-foreground-muted border-b border-border pb-2\">в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳГӘв•Әв”Ӯв–ҲГ®в”ҳГӨв”ҳГ§ в”ҳГҘв”ҳГ©в”ҳГӨв–ҲГ®в”ҳГ§ в”ҳГӘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</h4>\n                    <div className=\"grid grid-cols-1 gap-4 md:grid-cols-2\">\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-semibold text-foreground\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ  в•ӘВ«в•ӘВәв”ҳГҘв”ҳГӘв•ӘВәв•ӘВ»в”ҢВ»в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ *</Label>\n                        <input\n                          type=\"text\"\n                          required\n                          value={ownerName}\n                          onChange={(e) => setOwnerName(e.target.value)}\n                          className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                        />\n                      </div>\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-semibold text-foreground\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® *</Label>\n                        <input\n                          type=\"text\"\n                          required\n                          value={ownerCode}\n                          onChange={(e) => setOwnerCode(e.target.value)}\n                          className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 font-mono\"\n                        />\n                      </div>\n                    </div>\n\n                    {/* Iranian Plate Input Container */}\n                    <div className=\"space-y-1.5\">\n                      <Label className=\"text-xs font-semibold text-foreground\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ в”ҳГӨв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ *</Label>\n                      <div className=\"flex items-center gap-2 border border-border-subtle rounded-lg p-3 bg-surface/80 max-w-md\" dir=\"ltr\">\n                        {/* 2 digits */}\n                        <input\n                          type=\"text\"\n                          required\n                          maxLength={2}\n                          placeholder=\"в–Ҳв–“в–Ҳв–“\"\n                          value={plateNum1}\n                          onChange={(e) => setPlateNum1(e.target.value)}\n                          className=\"w-12 text-center rounded-md border border-border bg-surface px-1 h-9 text-base font-bold font-mono focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                        />\n                        {/* Letter Selector */}\n                        <select\n                          value={plateLetter}\n                          onChange={(e) => setPlateLetter(e.target.value)}\n                          className=\"rounded-md border border-border bg-surface px-2 h-9 text-sm font-bold focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 cursor-pointer\"\n                        >\n                          {PLATE_LETTERS.map((l) => (\n                            <option key={l} value={l}>\n                              {l}\n                            </option>\n                          ))}\n                        </select>\n                        {/* 3 digits */}\n                        <input\n                          type=\"text\"\n                          required\n                          maxLength={3}\n                          placeholder=\"в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ў\"\n                          value={plateNum2}\n                          onChange={(e) => setPlateNum2(e.target.value)}\n                          className=\"w-16 text-center rounded-md border border-border bg-surface px-1 h-9 text-base font-bold font-mono focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                        />\n                        <span className=\"text-xs text-foreground-muted\">- в•ӘВәв–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ</span>\n                        {/* City code */}\n                        <input\n                          type=\"text\"\n                          required\n                          maxLength={2}\n                          placeholder=\"в–Ҳв•ўв–Ҳв•ў\"\n                          value={plateCity}\n                          onChange={(e) => setPlateCity(e.target.value)}\n                          className=\"w-12 text-center rounded-md border border-border bg-surface px-1 h-9 text-base font-bold font-mono focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"grid grid-cols-1 gap-4 md:grid-cols-3\">\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-semibold text-foreground\">в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ *</Label>\n                        <input\n                          type=\"text\"\n                          required\n                          placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ в”ҳв•ӣв”ҢГҝв”ҳГӘ в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў\"\n                          value={carType}\n                          onChange={(e) => setCarType(e.target.value)}\n                          className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                        />\n                      </div>\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-semibold text-foreground\">в•Әв–’в”ҳГҘв”ҢВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ</Label>\n                        <input\n                          type=\"text\"\n                          placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ в”ҳГҘв”ҳГӘв”ҢвҢҗ в”ҳГ в•ӘВ»в•ӘВәв•ӘВ»в–ҲГ®\"\n                          value={carColor}\n                          onChange={(e) => setCarColor(e.target.value)}\n                          className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                        />\n                      </div>\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в”ҳГ в•ӘВјв”ҳГӘв•Әв–“</Label>\n                        <input\n                          type=\"text\"\n                          value={expiryDate}\n                          onChange={(e) => setExpiryDate(e.target.value)}\n                          className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 font-mono text-center\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"flex justify-end gap-2 pt-2 border-t border-border-subtle/50\">\n                      <Button type=\"button\" variant=\"ghost\" size=\"sm\" onClick={() => setShowAddForm(false)} className=\"cursor-pointer\">\n                        в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n                      </Button>\n                      <Button type=\"submit\" size=\"sm\" className=\"cursor-pointer\">\n                        в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘ в•ӘВҝв”ҳГ§ в”ҢВ»в–ҲГ®в•ӘВ¬\n                      </Button>\n                    </div>\n                  </form>\n                )}\n\n                {/* Vehicles Table */}\n                <div className=\"overflow-x-auto border border-border-subtle rounded-lg bg-surface/30\">\n                  <table className=\"w-full text-right border-collapse\">\n                    <thead>\n                      <tr className=\"border-b border-border-subtle bg-background-subtle text-foreground-muted text-xs font-semibold\">\n                        <th className=\"p-3\">в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</th>\n                        <th className=\"p-3\">в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ в”ҳГӨв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§</th>\n                        <th className=\"p-3\">в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ / в•Әв–’в”ҳГҘв”ҢВ»</th>\n                        <th className=\"p-3\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“</th>\n                        <th className=\"p-3\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҢВ»в–ҲГ®в•ӘВ¬</th>\n                        <th className=\"p-3 text-left\">в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-border-subtle text-sm\">\n                      {filteredVehicles.map((v) => (\n                        <tr key={v.id} className=\"hover:bg-surface-hover/70 transition-colors\">\n                          <td className=\"p-3\">\n                            <div className=\"font-semibold text-foreground\">{v.ownerName}</div>\n                            <div className=\"text-xs text-foreground-muted mt-0.5 font-mono\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®: {toFa(v.ownerCode)}</div>\n                          </td>\n                          <td className=\"p-3\">\n                            <IranianPlateDisplay plate={v.plate} />\n                          </td>\n                          <td className=\"p-3 font-medium text-foreground-muted\">\n                            {v.type} ({v.color})\n                          </td>\n                          <td className=\"p-3 font-mono text-xs text-foreground-muted\">{toFa(v.expiryDate)}</td>\n                          <td className=\"p-3\">\n                            <Badge\n                              variant=\"outline\"\n                              className={\n                                v.status === 'active'\n                                  ? 'bg-success/10 text-success border-success/20 rounded-md px-2 py-0.5'\n                                  : v.status === 'expired'\n                                  ? 'bg-warning/10 text-warning border-warning/20 rounded-md px-2 py-0.5'\n                                  : 'bg-critical/10 text-critical border-critical/20 rounded-md px-2 py-0.5'\n                              }\n                            >\n                              {v.status === 'active' ? 'в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•ӘВҝв”ҳГ§ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»' : v.status === 'expired' ? 'в”ҳГ в”ҳГҘв”ҳГ©в•Әв•ўв–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§' : 'в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ»'}\n                            </Badge>\n                          </td>\n                          <td className=\"p-3 text-left space-x-1 space-x-reverse\">\n                            <Button\n                              size=\"sm\"\n                              variant=\"outline\"\n                              className=\"h-8 text-xs cursor-pointer border-border hover:bg-surface-hover\"\n                              onClick={() => handleToggleStatus(v.id)}\n                            >\n                              {v.status === 'active' ? 'в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ» в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ' : 'в•Әв–’в”ҳГјв•Әв•Ј в•ӘВәв”ҳГҘв•Әв”Ӯв•ӘВ»в•ӘВәв•ӘВ»'}\n                            </Button>\n                            <Button\n                              size=\"sm\"\n                              variant=\"ghost\"\n                              className=\"h-8 text-xs text-critical hover:bg-critical/10 cursor-pointer\"\n                              onClick={() => handleDeleteVehicle(v.id)}\n                            >\n                              в•ӘВЎв•Әв–‘в”ҳГј\n                            </Button>\n                          </td>\n                        </tr>\n                      ))}\n                    </tbody>\n                  </table>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n\n          {/* Sidebar Area: Live camera monitor & policy config */}\n          <div className=\"space-y-6\">\n            {/* ANPR Camera Monitor */}\n            <Card className=\"bg-surface/50 backdrop-blur-md border border-border-subtle rounded-lg\">\n              <CardHeader className=\"flex flex-row items-center justify-between pb-3 border-b border-border-subtle/50 gap-4\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                  <Camera className=\"size-4 text-accent\" />\n                  в•ӘВ»в”ҳГӘв•Әв–’в•ӘВҝв–ҲГ®в”ҳГҘ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВ»в”ҳв•ӣв”ҳГӘ\n                </CardTitle>\n                <Button variant=\"ghost\" size=\"icon\" className=\"h-8 w-8 hover:bg-surface-hover cursor-pointer\" onClick={handleSimulateScan}>\n                  <RefreshCw className=\"size-3.5 text-foreground-muted\" />\n                </Button>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-4\">\n                <div className=\"relative aspect-video rounded-lg overflow-hidden border border-border bg-slate-950 flex items-center justify-center group shadow-inner\">\n                  {/* Camera scan simulator visual */}\n                  <div className=\"absolute inset-0 bg-radial-gradient opacity-20 pointer-events-none\" />\n                  <div className=\"absolute top-2 right-2 flex items-center gap-1.5 bg-black/60 px-2 py-1 rounded text-[10px] text-success font-semibold font-mono border border-neutral-800\">\n                    <span className=\"size-1.5 rounded-full bg-success animate-ping\" />\n                    <span>CAM-NORTH_DEPO</span>\n                  </div>\n\n                  {/* Grid effect */}\n                  <div className=\"absolute inset-0 bg-grid-white opacity-5 pointer-events-none\" />\n\n                  {/* License Plate Box */}\n                  <div className=\"border border-success bg-success/5 px-4 py-2.5 rounded-lg text-center backdrop-blur-sm shadow-lg max-w-[200px]\">\n                    <div className=\"text-[10px] text-emerald-400 font-semibold uppercase tracking-wider mb-1\">в•ӘВәв•Әв”Ӯв”ҢвҢҗв”ҳГҘ в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬О“ГҮГ®в•ӘГів”ҳГ в–ҲГ®в•Әв–“</div>\n                    <IranianPlateDisplay plate={{ num1: '22', letter: 'в•ӘВҝ', num2: '567', city: '33' }} />\n                  </div>\n                </div>\n\n                <div className=\"flex justify-center\">\n                  <Button size=\"sm\" variant=\"outline\" className=\"w-full gap-1.5 cursor-pointer border-border hover:bg-surface-hover\" onClick={handleSimulateScan}>\n                    <Car className=\"size-4 text-accent\" />\n                    <span>в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ</span>\n                  </Button>\n                </div>\n\n                <h5 className=\"text-xs font-bold text-foreground-muted border-b border-border pb-1\">в•ӘГів•ӘВ«в•Әв–’в–ҲГ®в”ҳГҘ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҢВ»в–ҲГ®в•ӘВ¬</h5>\n                <div className=\"space-y-2.5 max-h-60 overflow-y-auto pr-1\">\n                  {cameraLogs.map((log) => (\n                    <div key={log.id} className=\"flex items-center justify-between p-2.5 rounded-lg border border-border-subtle bg-surface/30 hover:border-accent/10 transition-colors\">\n                      <div className=\"space-y-1\">\n                        <div className=\"flex items-center gap-1.5\">\n                          <IranianPlateDisplay plate={log.plate} />\n                          <Badge\n                            className={\n                              log.direction === 'in'\n                                ? 'bg-info/10 text-info border-info/20 rounded-md px-1.5 py-0'\n                                : 'bg-neutral-800 text-foreground-muted border-neutral-700 rounded-md px-1.5 py-0'\n                            }\n                          >\n                            {log.direction === 'in' ? 'в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»' : 'в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј'}\n                          </Badge>\n                        </div>\n                        <div className=\"text-[10px] text-foreground-muted flex items-center gap-1\">\n                          <Clock className=\"size-3\" />\n                          <span>{log.cameraLocation} О“ГҮГі {toFa(log.time)}</span>\n                        </div>\n                      </div>\n\n                      <div className=\"text-left\">\n                        {log.status === 'allowed' ? (\n                          <div className=\"flex items-center gap-1 text-success text-xs font-semibold\">\n                            <CheckCircle className=\"size-3.5\" />\n                            <span>в”ҳГ в•ӘВјв•ӘВәв•Әв–“ ({log.ownerName})</span>\n                          </div>\n                        ) : (\n                          <div className=\"flex items-center gap-1 text-critical text-xs font-semibold\">\n                            <XCircle className=\"size-3.5 text-accent\" />\n                            <span>в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ»</span>\n                          </div>\n                        )}\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </CardContent>\n            </Card>\n\n            {/* ANPR Control Panel / Config Rules */}\n            <Card className=\"bg-surface/50 backdrop-blur-md border border-border-subtle rounded-lg\">\n              <CardHeader className=\"border-b border-border-subtle/50 pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                  <Settings className=\"size-4 text-accent\" />\n                  в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬в–ҲГ® в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-4\">\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground\">в•ӘВҝв•ӘВәв•Әв–“ в•Әв”Өв•ӘВ»в”ҳГҘ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв”ҳГҘв•ӘВ» в•ӘВ»в”ҳв•ӣв”ҳГӘ</span>\n                  <input\n                    type=\"checkbox\"\n                    checked={autoOpenForAllowed}\n                    onChange={(e) => setAutoOpenForAllowed(e.target.checked)}\n                    className=\"size-4 accent-accent cursor-pointer\"\n                  />\n                </div>\n\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground\">в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ»</span>\n                  <input\n                    type=\"checkbox\"\n                    checked={notifyOnBlocked}\n                    onChange={(e) => setNotifyOnBlocked(e.target.checked)}\n                    className=\"size-4 accent-accent cursor-pointer\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label className=\"text-xs font-semibold text-foreground\">в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ»в”ҳГ§ в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ (в•Әв–’в”ҳГӘв•Әв–“)</Label>\n                  <input\n                    type=\"number\"\n                    value={alertExpiryDays}\n                    onChange={(e) => setAlertExpiryDays(Number(e.target.value))}\n                    className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 font-mono text-center\"\n                  />\n                </div>\n\n                <div className=\"flex items-center gap-1.5 rounded-lg border border-warning/20 bg-warning/5 p-3 text-xs text-warning leading-relaxed\">\n                  <AlertTriangle className=\"size-4 shrink-0 text-warning\" />\n                  <span>в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГ§в•Әв–’ в–ҲГ®в”ҢвҢҗ в•ӘВәв•Әв–“ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВә в•ӘВҝв”ҳГӨв•ӘВәв”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВҝв•Әв–’ в•Әв–’в”ҳГӘв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҢВ»в–ҲГ®в•ӘВ¬ в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ в”ҳГӘ в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬в”ҳГ в•ӘВәв”ҳГҘ в•Әв•Ўв•ӘВәв•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ§ в•ӘВҝв•ӘВәв•Әв–“в•ӘВ¬в•ӘВәв•ӘВҝ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬.</span>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        </div>\n      </main>\n    </div>\n  )\n}\n\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\live-actions\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Activity' is defined but never used.","line":14,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":14,"endColumn":11,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Activity"},"fix":{"range":[308,320],"text":""},"desc":"Remov