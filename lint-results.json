":"[accessToken, isAdmin, loadAnalytics]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":1,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { toFa } from '@/lib/fa'\nimport {\n  BarChart3,\n  Users,\n  AlertTriangle,\n  CheckCircle,\n  Activity,\n} from 'lucide-react'\n\ninterface AnalyticsData {\n  totalUsers: number\n  activeUsers: number\n  pendingUsers: number\n  totalTickets: number\n  openTickets: number\n  resolvedTickets: number\n  totalBulletins: number\n  readBulletins: number\n  totalShifts: number\n  totalFeedback: number\n  respondedFeedback: number\n  totalChecklists: number\n}\n\nexport default function AnalyticsPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const user = useAuthStore((s) => s.user)\n  const [data, setData] = useState<AnalyticsData | null>(null)\n  const [loading, setLoading] = useState(true)\n\n  const isAdmin = user?.roleKey === 'admin' || user?.roleKey === 'super_admin'\n\n  async function loadAnalytics() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const headers = { Authorization: `Bearer ${accessToken}` }\n      const [usersRes, ticketsRes, bulletinsRes, feedbackRes] = await Promise.all([\n        fetch('/api/users?pageSize=1', { headers }),\n        fetch('/api/tickets', { headers }),\n        fetch('/api/bulletins', { headers }),\n        fetch('/api/feedback', { headers }),\n      ])\n\n      const [usersData, ticketsData, bulletinsData, feedbackData] = await Promise.all([\n        usersRes.ok ? usersRes.json() : { data: { total: 0, active: 0, pending: 0 } },\n        ticketsRes.ok ? ticketsRes.json() : { data: { stats: { total: 0, open: 0, resolved: 0 } } },\n        bulletinsRes.ok ? bulletinsRes.json() : { data: [] },\n        feedbackRes.ok ? feedbackRes.json() : { data: { total: 0, responded: 0 } },\n      ])\n\n      setData({\n        totalUsers: usersData.data?.total ?? 0,\n        activeUsers: usersData.data?.active ?? 0,\n        pendingUsers: usersData.data?.pending ?? 0,\n        totalTickets: ticketsData.data?.stats?.total ?? 0,\n        openTickets: ticketsData.data?.stats?.open ?? 0,\n        resolvedTickets: ticketsData.data?.stats?.resolved ?? 0,\n        totalBulletins: Array.isArray(bulletinsData.data) ? bulletinsData.data.length : 0,\n        readBulletins: 0,\n        totalShifts: 0,\n        totalFeedback: feedbackData.data?.total ?? 0,\n        respondedFeedback: feedbackData.data?.responded ?? 0,\n        totalChecklists: 0,\n      })\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  /* eslint-disable react-hooks/set-state-in-effect */\n  useEffect(() => {\n    if (!isAdmin) return\n    void loadAnalytics()\n  }, [accessToken, isAdmin])\n\n  const metrics = data\n    ? [\n        {\n          title: 'в”ҢвҢҗв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ',\n          value: data.totalUsers,\n          icon: Users,\n          color: 'text-info',\n          bgColor: 'bg-info/10',\n          detail: `${toFa(data.activeUsers)} в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ / ${toFa(data.pendingUsers)} в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’`,\n        },\n        {\n          title: 'в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә',\n          value: data.totalTickets,\n          icon: AlertTriangle,\n          color: 'text-warning',\n          bgColor: 'bg-warning/10',\n          detail: `${toFa(data.openTickets)} в•ӘВҝв•ӘВәв•Әв–“ / ${toFa(data.resolvedTickets)} в•ӘВЎв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§`,\n        },\n        {\n          title: 'в•ӘВҝв•ӘВ«в•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә',\n          value: data.totalBulletins,\n          icon: Activity,\n          color: 'text-accent',\n          bgColor: 'bg-accent/10',\n          detail: `${toFa(data.readBulletins)} в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§`,\n        },\n        {\n          title: 'в•ӘВҝв•ӘВәв•Әв–“в•ӘВ«в”ҳГӘв•Әв–’в•ӘВ»в”ҳГ§в•ӘВә',\n          value: data.totalFeedback,\n          icon: CheckCircle,\n          color: 'text-success',\n          bgColor: 'bg-success/10',\n          detail: `${toFa(data.respondedFeedback)} в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§`,\n        },\n      ]\n    : []\n\n  const kpis = data\n    ? [\n        {\n          label: 'в”ҳГҘв•Әв–’в•ӘВ« в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ«О“ГҮГ®в”ҢВ»в”ҳГӘв–ҲГ®в–ҲГ® в•ӘВҝв”ҳГ§ в•ӘВҝв•ӘВәв•Әв–“в•ӘВ«в”ҳГӘв•Әв–’в•ӘВ»в”ҳГ§в•ӘВә',\n          value: data.totalFeedback > 0 ? Math.round((data.respondedFeedback / data.totalFeedback) * 100) : 0,\n          color: '#34c759',\n        },\n        {\n          label: 'в”ҳГҘв•Әв–’в•ӘВ« в•ӘВЎв”ҳГӨ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә',\n          value: data.totalTickets > 0 ? Math.round((data.resolvedTickets / data.totalTickets) * 100) : 0,\n          color: '#007aff',\n        },\n        {\n          label: 'в”ҳГҘв•Әв–’в•ӘВ« в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§ в•ӘВҝв•ӘВ«в•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә',\n          value: data.totalBulletins > 0 ? Math.round((data.readBulletins / data.totalBulletins) * 100) : 0,\n          color: '#ff9500',\n        },\n      ]\n    : []\n\n  if (!isAdmin) {\n    return (\n      <div className=\"flex flex-1 items-center justify-center p-4\">\n        <p className=\"text-sm text-foreground-muted\">в•Әв”Өв”ҳГ в•ӘВә в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВҝв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в•Әв–’в•ӘВә в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®в•ӘВ»</p>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4\">\n      <div>\n        <h1 className=\"font-headline-lg text-headline-lg-mobile md:text-headline-lg text-foreground flex items-center gap-2\">\n          <BarChart3 className=\"size-6 text-accent\" />\n          в•ӘВ»в•ӘВәв•Әв”Өв•ӘВҝв”ҳГӘв•Әв–’в•ӘВ» в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨв–ҲГ®\n        </h1>\n        <p className=\"text-sm text-foreground-muted mt-1\">\n          в•ӘГів”ҳГ в•ӘВәв•Әв–’ в”ҳГӘ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•ЎО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ \n        </p>\n      </div>\n\n      {loading ? (\n        <div className=\"grid grid-cols-2 gap-4 lg:grid-cols-4\">\n          {Array.from({ length: 4 }).map((_, i) => (\n            <div key={i} className=\"h-32 animate-pulse rounded-lg border border-border bg-background-subtle\" />\n          ))}\n        </div>\n      ) : (\n        <>\n          {/* Metrics Grid */}\n          <div className=\"grid grid-cols-2 gap-4 lg:grid-cols-4\">\n            {metrics.map((m, i) => (\n              <Card key={i}>\n                <CardContent className=\"flex items-start gap-3 p-4\">\n                  <div className={`rounded-lg ${m.bgColor} p-2.5 ${m.color}`}>\n                    <m.icon className=\"size-5\" />\n                  </div>\n                  <div>\n                    <div className=\"text-xl font-semibold\">{toFa(m.value)}</div>\n                    <div className=\"text-xs text-foreground-muted\">{m.title}</div>\n                    <div className=\"mt-1 text-[10px] text-foreground-muted\">{m.detail}</div>\n                  </div>\n                </CardContent>\n              </Card>\n            ))}\n          </div>\n\n          {/* KPIs */}\n          <Card>\n            <CardHeader>\n              <CardTitle className=\"flex items-center gap-2 text-sm font-medium\">\n                <BarChart3 className=\"size-4\" />\n                в•Әв”Өв•ӘВәв•ӘВ«в•Әв•ЎО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» (KPI)\n              </CardTitle>\n            </CardHeader>\n            <CardContent>\n              <div className=\"space-y-4\">\n                {kpis.map((kpi, i) => (\n                  <div key={i}>\n                    <div className=\"mb-1 flex items-center justify-between text-sm\">\n                      <span>{kpi.label}</span>\n                      <span className=\"font-mono\">{toFa(kpi.value)}%</span>\n                    </div>\n                    <div className=\"h-2 overflow-hidden rounded-full bg-background-subtle\">\n                      <div\n                        className=\"h-full rounded-full transition-all\"\n                        style={{ width: `${kpi.value}%`, backgroundColor: kpi.color }}\n                      />\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Quick Stats */}\n          <div className=\"grid gap-4 md:grid-cols-3\">\n            <Card>\n              <CardHeader>\n                <CardTitle className=\"text-sm font-medium\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</CardTitle>\n              </CardHeader>\n              <CardContent className=\"space-y-2\">\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground-muted\">в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ</span>\n                  <Badge className=\"bg-success/15 text-success\">{toFa(data?.activeUsers ?? 0)}</Badge>\n                </div>\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ»</span>\n                  <Badge className=\"bg-warning/15 text-warning\">{toFa(data?.pendingUsers ?? 0)}</Badge>\n                </div>\n              </CardContent>\n            </Card>\n\n            <Card>\n              <CardHeader>\n                <CardTitle className=\"text-sm font-medium\">в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв•ӘВәв•Әв–“</CardTitle>\n              </CardHeader>\n              <CardContent className=\"space-y-2\">\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground-muted\">в•ӘВҝв•ӘВәв•Әв–“</span>\n                  <Badge className=\"bg-critical/15 text-critical\">{toFa(data?.openTickets ?? 0)}</Badge>\n                </div>\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground-muted\">в•ӘВЎв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§</span>\n                  <Badge className=\"bg-success/15 text-success\">{toFa(data?.resolvedTickets ?? 0)}</Badge>\n                </div>\n              </CardContent>\n            </Card>\n\n            <Card>\n              <CardHeader>\n                <CardTitle className=\"text-sm font-medium\">в•ӘВҝв•ӘВәв•Әв–“в•ӘВ«в”ҳГӘв•Әв–’в•ӘВ»в”ҳГ§в•ӘВә</CardTitle>\n              </CardHeader>\n              <CardContent className=\"space-y-2\">\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground-muted\">в”ҢвҢҗв”ҳГӨ</span>\n                  <Badge className=\"bg-info/15 text-info\">{toFa(data?.totalFeedback ?? 0)}</Badge>\n                </div>\n                <div className=\"flex items-center justify-between text-sm\">\n                  <span className=\"text-foreground-muted\">в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§</span>\n                  <Badge className=\"bg-success/15 text-success\">{toFa(data?.respondedFeedback ?? 0)}</Badge>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        </>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\biometrics\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\bulletins\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fata