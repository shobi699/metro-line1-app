\n  HardDrive,\n  UserCheck,\n  Video,\n  Award,\n  Mic,\n} from 'lucide-react'\n\ninterface NavItem {\n  label: string\n  href: string\n  icon: React.ElementType\n  roles?: string[]\n}\n\ninterface NavSubgroup {\n  id: string\n  label: string\n  icon: React.ElementType\n  items: NavItem[]\n  roles?: string[]\n}\n\ninterface NavSection {\n  title: string\n  roles?: string[]\n  groups: NavSubgroup[]\n}\n\n// в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨ в”ҳГӘ в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨв•ӘВәв”ҳГҜ в•Әв•–в•ӘВҝв”ҳГ©в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГ в”ҳГҘв”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГӘв”ҳв•ӣв•Әв–’в•ӘВәв”ҳв•ӣ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ\nconst NAVIGATION_SECTIONS: NavSection[] = [\n  {\n    title: 'в”ҳГ в–ҲГ®в•Әв–“ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®',\n    groups: [\n      {\n        id: 'desk',\n        label: 'в•ӘВәв”ҳГ в”ҳГӘв•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®',\n        icon: LayoutDashboard,\n        items: [\n          { label: 'в•ӘВ»в•ӘВәв•Әв”Өв•ӘВҝв”ҳГӘв•Әв–’в•ӘВ» в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®', href: '/dashboard', icon: LayoutDashboard },\n          { label: 'в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГҘв•ӘВәв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ', href: '/notifications', icon: Bell },\n          { label: 'в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®', href: '/profile', icon: User },\n          { label: 'в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в•ӘВҝв•Әв–’в•ӘВ¬в•Әв–’в”ҳГ§в•ӘВә (в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§)', href: '/leaderboard', icon: Trophy },\n          { label: 'в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳГӘ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»', href: '/performance', icon: Award },\n          { label: 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВҝв•ӘВәв•Әв–“в•ӘВ«в”ҳГӘв•Әв–’в•ӘВ» в”ҳГӘ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ ', href: '/feedback', icon: MessageSquare },\n        ]\n      },\n      {\n        id: 'shifts-op',\n        label: 'в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬ в”ҳГӘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә',\n        icon: Calendar,\n        items: [\n          { label: 'в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГӘ в•ӘВ¬в”ҳГ©в”ҳГӘв–ҲГ®в”ҳГ  в”ҳГ в”ҳГҘ', href: '/shifts', icon: Calendar },\n          { label: 'в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв•Јв”ҳГӘв–ҲГ®в•Әв•ў в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬', href: '/swap/inbox', icon: ArrowLeftRight },\n          { label: 'в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’ в”ҳГӘ в•Әв•‘в–ҲГ®в•ӘВәв•ӘВҝ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ»', href: '/attendance', icon: UserCheck },\n          { label: 'в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’', href: '/checklists', icon: ClipboardCheck },\n          { label: 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® в”ҳГӘ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГҘв”ҢВ»', href: '/tickets', icon: AlertTriangle },\n        ]\n      },\n      {\n        id: 'comms',\n        label: 'в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ в”ҳГӘ в”ҳГ§в”ҳГ в–ҲГ®в•ӘВәв•Әв–’',\n        icon: MessageCircle,\n        items: [\n          { label: 'в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ©О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘ', href: '/chat', icon: MessageCircle },\n          { label: 'в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ®', href: '/comms/conference', icon: Mic },\n          { label: 'в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®в”ҳГ  в•ӘВ¬в”ҳГүв•ӘВ¬в•Әв–’в•ӘВә', href: '/comms/radio', icon: Radio },\n          { label: 'в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ', href: '/directory', icon: Users },\n          { label: 'в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» AI', href: '/ai', icon: Bot },\n        ]\n      }\n    ]\n  },\n  {\n    title: 'в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“ в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҳГӘ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’',\n    roles: ['admin', 'super_admin', 'operator'],\n    groups: [\n      {\n        id: 'occ-menu',\n        label: 'в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ® OCC',\n        icon: Activity,\n        roles: ['admin', 'super_admin', 'operator'],\n        items: [\n          { label: 'в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГӘ в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®в•ӘВ¬в”ҳГӘв•Әв–’в–ҲГ®в”ҳГҘв”ҢВ»', href: '/occ', icon: Activity, roles: ['admin', 'super_admin', 'operator'] },\n          { label: 'в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГ  в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® PA', href: '/pa', icon: Radio, roles: ['admin', 'super_admin'] },\n          { label: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘ в”ҳГӘ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’', href: '/crisis', icon: Shield, roles: ['admin', 'super_admin'] },\n        ]\n      }\n    ]\n  },\n  {\n    title: 'в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ',\n    groups: [\n      {\n        id: 'learning-menu',\n        label: 'в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в”ҳГӘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә',\n        icon: GraduationCap,\n        items: [\n          { label: 'в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®', href: '/content', icon: Newspaper },\n          { label: 'в”ҢВ»в•ӘВәв”ҳГӨв•Әв–’в–ҲГ® в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®', href: '/learning/gallery', icon: Video },\n          { label: 'в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳГӘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГҘ', href: '/learning/exams', icon: Award },\n          { label: 'в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§', href: '/knowledge', icon: BookOpen },\n        ]\n      }\n    ]\n  },\n  {\n    title: 'в”ҳв•ӣв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§',\n    roles: ['admin', 'super_admin'],\n    groups: [\n      {\n        id: 'admin-users',\n        label: 'в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГӘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ®',\n        icon: Users,\n        roles: ['admin', 'super_admin'],\n        items: [\n          { label: 'в”ҳв•ӣв–ҲГ®в•Әв”Өв•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§', href: '/admin/live-actions', icon: Activity },\n          { label: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГӘ в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә', href: '/admin/users', icon: Users },\n          { label: 'в•Әв•Ўв”ҳГј в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГ в•ӘВ»в•ӘВәв•Әв–’в”ҢвҢҗ', href: '/admin/documents-queue', icon: UserCheck },\n          { label: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВҝв•ӘВәв–ҲГ®в”ҳГӘв”ҳГ в•ӘВ¬в•Әв–’в–ҲГ®в”ҢвҢҗ', href: '/admin/biometrics', icon: ShieldCheck },\n        ]\n      },\n      {\n        id: 'admin-roster',\n        label: 'в•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•Әв–’в–ҲГ®в•Әв–“в–ҲГ® в”ҳГӘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬',\n        icon: Calendar,\n        roles: ['admin', 'super_admin'],\n        items: [\n          { label: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә', href: '/admin/shifts', icon: Calendar },\n          { label: 'в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§', href: '/roster/upload', icon: FileSpreadsheet },\n          { label: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә', href: '/checklists', icon: ClipboardCheck },\n        ]\n      },\n      {\n        id: 'admin-training',\n        label: 'в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в”ҳГӘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘в–ҲГ®в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә',\n        icon: GraduationCap,\n        roles: ['admin', 'super_admin'],\n        items: [\n          { label: 'в•ӘВҝв•ӘВ«в•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®', href: '/admin/bulletins', icon: ShieldCheck },\n          { label: 'в•ӘВҝв•ӘВәв”ҳГҘв”ҢвҢҗ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә', href: '/admin/exams-editor', icon: Settings },\n        ]\n      },\n      {\n        id: 'admin-reports',\n        label: 'в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®в•ӘВ¬в”ҳГӘв•Әв–’в–ҲГ®в”ҳГҘв”ҢВ» в”ҳГӘ в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә',\n        icon: BarChart3,\n        roles: ['admin', 'super_admin'],\n        items: [\n          { label: 'в•ӘВ»в•ӘВәв•Әв”Өв•ӘВҝв”ҳГӘв•Әв–’в•ӘВ» в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨв–ҲГ®', href: '/admin/analytics', icon: BarChart3 },\n          { label: 'в”ҳв•ӣв–ҲГ®в”ҢвҢҗв•Әв–’в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҢвҢҗв•ӘВәв•ӘВ¬в•ӘВәв”ҳГӨв”ҳГӘв”ҢВ» в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»', href: '/admin/performance-config', icon: Award },\n          { label: 'в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»', href: '/admin/performance-appeals', icon: FileSpreadsheet },\n          { label: 'в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГӘ в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§ в•ӘВҝв•Әв–’в”ҳГ©', href: '/admin/infrastructure', icon: HardDrive },\n          { label: 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВә в”ҳГӘ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ', href: '/admin/license-plates', icon: Settings },\n          { label: 'в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ', href: '/admin/operator-licenses', icon: ShieldCheck },\n          { label: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ', href: '/admin/settings', icon: Settings },\n        ]\n      }\n    ]\n  }\n]\n\nconst roleLabels: Record<string, string> = {\n  super_admin: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ»',\n  admin: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’',\n  operator: 'в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’',\n  user: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ / в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ',\n}\n\nexport function Sidebar() {\n  const pathname = usePathname()\n  const user = useAuthStore((s) => s.user)\n  const logout = useAuthStore((s) => s.logout)\n\n  const [expandedGroups, setExpandedGroups] = useState<Record<string, boolean>>(() => {\n    const initial: Record<string, boolean> = {}\n    NAVIGATION_SECTIONS.forEach((section) => {\n      section.groups.forEach((group) => {\n        const hasActiveChild = group.items.some(\n          (item) => pathname === item.href || pathname.startsWith(item.href + '/'),\n        )\n        if (hasActiveChild) {\n          initial[group.id] = true\n        }\n      })\n    })\n    return initial\n  })\n\n  const toggleGroup = (groupId: string) => {\n    setExpandedGroups((prev) => ({\n      ...prev,\n      [groupId]: !prev[groupId],\n    }))\n  }\n\n  // в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә\n  const checkRole = (roles?: string[]) => {\n    if (!roles) return true\n    return roles.includes(user?.roleKey ?? '')\n  }\n\n  return (\n    <aside className=\"hidden w-64 shrink-0 border-s border-border-subtle bg-surface-container-low lg:flex lg:flex-col\" dir=\"rtl\">\n      {/* User Profile Section */}\n      <div className=\"flex flex-col items-center gap-3 border-b border-border-subtle px-5 py-5\">\n        <div className=\"flex size-16 items-center justify-center rounded-full border-2 border-accent bg-surface-container-high overflow-hidden\">\n          {user?.customFields?.avatar ? (\n            // eslint-disable-next-line @next/next/no-img-element\n            <img src={user.customFields.avatar} alt={user.name} className=\"size-full object-cover\" />\n          ) : (\n            <User className=\"size-7 text-foreground-muted\" />\n          )}\n        </div>\n        <div className=\"text-center\">\n          <div className=\"truncate text-sm font-semibold text-foreground\">\n            {user?.name ?? 'в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’'}\n          </div>\n          <div className=\"truncate text-xs text-foreground-muted mt-0.5\">\n            {roleLabels[user?.roleKey ?? ''] ?? user?.roleKey}\n          </div>\n        </div>\n      </div>\n\n      {/* Navigation */}\n      <nav className=\"flex-1 space-y-5 overflow-y-auto px-3 py-4\" aria-label=\"в”ҳГ в”ҳГҘв”ҳГӘв–ҲГ® в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®\">\n        {NAVIGATION_SECTIONS.map((section, idx) => {\n          // в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө в•ӘВ»в•Әв–’ в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВҝв•ӘВ«в•Әв”Ө\n          if (section.roles && !section.roles.includes(user?.roleKey ?? '')) {\n            return null\n          }\n\n          // в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГҘв”ҳГ©в•Әв”Ө в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’\n          const visibleGroups = section.groups.filter((group) => checkRole(group.roles))\n          if (visibleGroups.length === 0) return null\n\n          return (\n            <div key={idx} className=\"space-y-1.5\">\n              {/* в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® */}\n              <div className=\"text-[10px] font-bold text-foreground-muted/65 px-3 uppercase tracking-wider\">\n                {section.title}\n              </div>\n\n              {/* в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в•ӘВәв•Әв”Өв”ҳГӘ */}\n              <div className=\"space-y-1\">\n                {visibleGroups.map((group) => {\n                  const isExpanded = !!expandedGroups[group.id]\n                  const groupHasActiveChild = group.items.some(\n                    (item) => pathname === item.href || pathname.startsWith(item.href + '/'),\n                  )\n\n                  // в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в•ӘГів–ҲГ®в•ӘВ¬в”ҳГ О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“\n                  const visibleItems = group.items.filter((item) => checkRole(item.roles))\n                  if (visibleItems.length === 0) return null\n\n                  return (\n                    <div key={group.id} className=\"rounded-lg overflow-hidden\">\n                      {/* в•ӘВ»в”ҢвҢҗв”ҳГ в”ҳГ§ в”ҳГ§в•ӘВ»в•Әв–’ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВ¬в•ӘВәв•Әв”Өв”ҳГӘ */}\n                      <button\n                        onClick={() => toggleGroup(group.id)}\n                        className={cn(\n                          'flex items-center justify-between w-full px-3 py-2 text-sm rounded-lg transition-all scale-[0.98] active:scale-95',\n                          groupHasActiveChild\n                            ? 'text-foreground font-semibold bg-surface-container-high/40'\n                            : 'text-foreground-muted hover:bg-surface-container-highest hover:text-foreground',\n                        )}\n                      >\n                        <div className=\"flex items-center gap-2.5\">\n                          <group.icon className=\"size-4 shrink-0\" />\n                          <span>{group.label}</span>\n                        </div>\n                        {isExpanded ? (\n                          <ChevronDown className=\"size-3.5 text-foreground-muted\" />\n                        ) : (\n                          <ChevronLeft className=\"size-3.5 text-foreground-muted\" />\n                        )}\n                      </button>\n\n                      {/* в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•Әв–“в–ҲГ®в•Әв–’в”ҳГ в”ҳГҘв”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ */}\n                      {isExpanded && (\n                        <div className=\"mr-3 mt-0.5 border-r border-border-subtle/50 pr-2.5 space-y-0.5 transition-all\">\n                          {visibleItems.map((item) => {\n                            const active = pathname === item.href || pathname.startsWith(item.href + '/')\n                            return (\n                              <Link\n                                key={item.href}\n                                href={item.href}\n                                aria-current={active ? 'page' : undefined}\n                                className={cn(\n                                  'flex items-center gap-2 rounded-lg px-2.5 py-1.5 text-xs transition-all scale-[0.98] active:scale-95',\n                                  active\n                                    ? 'bg-accent/10 text-accent font-bold'\n                                    : 'text-foreground-muted hover:bg-surface-container-highest hover:text-foreground',\n                                )}\n                              >\n                                <item.icon className=\"size-3.5 shrink-0\" />\n                                <span>{item.label}</span>\n                              </Link>\n                            )\n                          })}\n                        </div>\n                      )}\n                    </div>\n                  )\n                })}\n              </div>\n            </div>\n          )\n        })}\n      </nav>\n\n      {/* Footer */}\n      <div className=\"border-t border-border-subtle p-3\">\n        <div className=\"mb-2 flex items-center justify-between\">\n          <ThemeToggle />\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            className=\"gap-2\"\n            onClick={() => {\n              logout()\n              window.location.href = '/login'\n            }}\n          >\n            <LogOut className=\"size-4\" />\n            в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј\n          </Button>\n        </div>\n      </div>\n    </aside>\n  )\n}\n\nexport function MobileHeader() {\n  const user = useAuthStore((s) => s.user)\n  const logout = useAuthStore((s) => s.logout)\n\n  return (\n    <header className=\"flex h-16 items-center justify-between border-b border-border-subtle bg-surface-container px-4 lg:hidden\">\n      <span className=\"font-headline-md text-headline-md font-bold text-accent\">\n        в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ«в•Әв•– в–Ҳв–’\n      </span>\n      <div className=\"flex items-center gap-2\">\n        <Link\n          href=\"/notifications\"\n          className=\"relative rounded-md p-2 text-foreground-muted hover:bg-surface-hover active:scale-95 transition-all duration-150\"\n        >\n          <Bell className=\"size-5\" />\n        </Link>\n        <ThemeToggle />\n        <span className=\"max-w-[80px] truncate text-xs text-foreground-muted\">\n          {user?.name}\n        </span>\n        <Button\n          variant=\"ghost\"\n          size=\"icon-sm\"\n          aria-label=\"в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј\"\n          className=\"active:scale-95 transition-all duration-150\"\n          onClick={() => {\n            logout()\n            window.location.href = '/login'\n          }}\n        >\n          <LogOut className=\"size-4\" />\n        </Button>\n      </div>\n    </header>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\skeleton.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\station-map-selector.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\status-pip.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\system-health-pips.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\system-health-widget.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\theme-provider.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\theme-toggle.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\ticket-form.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'aiMatchedKeywords' is assigned a value but never used.","line":44,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":44,"endColumn":27}],"suppressedMessages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":364,"column":17,"nodeType":"JSXOpeningElement","endLine":370,"endColumn":19,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useCallback, useEffect, useRef, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { usePrivateConfig } from '@/features/auth/use-private-config'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { cn } from '@/lib/utils'\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from '@/components/ui/dialog'\nimport { Upload, Camera, MapPin } from 'lucide-react'\n\ninterface Annotation {\n  x: number\n  y: number\n  text: string\n}\n\ninterface TicketFormProps {\n  onCreated: () => void\n}\n\nexport function TicketForm({ onCreated }: TicketFormProps) {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const [open, setOpen] = useState(false)\n  const [title, setTitle] = useState('')\n  const [description, setDescription] = useState('')\n  const [priority, setPriority] = useState<string>('medium')\n  const [wagonCode, setWagonCode] = useState('')\n  const [photo, setPhoto] = useState<File | null>(null)\n  const [photoPreview, setPhotoPreview] = useState<string | null>(null)\n  const [annotations, setAnnotations] = useState<Annotation[]>([])\n  const [loading, setLoading] = useState(false)\n  const [error, setError] = useState('')\n  const [allowNoWagon, setAllowNoWagon] = useState(true)\n  const [aiPredictedPriority, setAiPredictedPriority] = useState<string>('')\n  const [aiReason, setAiReason] = useState<string>('')\n  const [aiMatchedKeywords, setAiMatchedKeywords] = useState<string[]>([])\n  const [isAnalyzing, setIsAnalyzing] = useState(false)\n  const imgRef = useRef<HTMLImageElement>(null)\n  const inputRef = useRef<HTMLInputElement>(null)\n\n  async function fetchWithAuth(url: string, init?: RequestInit) {\n    const currentToken = useAuthStore.getState().accessToken\n    const rToken = useAuthStore.getState().refreshToken\n\n    const headers = new Headers(init?.headers)\n    if (currentToken) {\n      headers.set('Authorization', `Bearer ${currentToken}`)\n    }\n\n    let res = await fetch(url, { ...init, headers })\n\n    if (res.status === 401 && rToken) {\n      try {\n        const refreshRes = await fetch('/api/auth/refresh', {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify({ refreshToken: rToken }),\n        })\n        if (refreshRes.ok) {\n          const payload = await refreshRes.json()\n          const newAccess = payload.accessToken\n          const newRefresh = payload.refreshToken\n          if (newAccess && newRefresh) {\n            useAuthStore.getState().setAuth(\n              useAuthStore.getState().user!,\n              newAccess,\n              newRefresh\n            )\n            headers.set('Authorization', `Bearer ${newAccess}`)\n            res = await fetch(url, { ...init, headers })\n          }\n        }\n      } catch {\n        // token refresh failed silently\n      }\n    }\n    return res\n  }\n\n  useEffect(() => {\n    if (!title.trim()) {\n      setAiPredictedPriority('')\n      setAiReason('')\n      setAiMatchedKeywords([])\n      return\n    }\n\n    const timer = setTimeout(async () => {\n      setIsAnalyzing(true)\n      try {\n        const res = await fetchWithAuth('/api/tickets/analyze', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n          },\n          body: JSON.stringify({ title, description }),\n        })\n        if (res.ok) {\n          const payload = await res.json()\n          if (payload?.data) {\n            const { priority: predicted, matchedKeywords, reasons } = payload.data\n            setAiPredictedPriority(predicted)\n            setAiMatchedKeywords(matchedKeywords || [])\n            setAiReason(reasons?.[0] || '')\n\n            // Auto-select priority if there are matched keywords\n            if (matchedKeywords && matchedKeywords.length > 0) {\n              setPriority(predicted)\n            }\n          }\n        }\n      } catch {\n        // ignore\n      } finally {\n        setIsAnalyzing(false)\n      }\n    }, 400)\n\n    return () => clearTimeout(timer)\n  }, [title, description, accessToken])\n\n  const privateConfig = usePrivateConfig()\n\n  useEffect(() => {\n    if (privateConfig?.allowNoWagon !== undefined) {\n      setAllowNoWagon(privateConfig.allowNoWagon)\n    }\n  }, [privateConfig])\n\n  const handlePhoto = useCallback((file: File) => {\n    setPhoto(file)\n    const reader = new FileReader()\n    reader.onload = (e) => setPhotoPreview(e.target?.result as string)\n    reader.readAsDataURL(file)\n  }, [])\n\n  function handleImageClick(e: React.MouseEvent<HTMLImageElement>) {\n    if (!imgRef.current) return\n    const rect = imgRef.current.getBoundingClientRect()\n    const x = ((e.clientX - rect.left) / rect.width) * 100\n    const y = ((e.clientY - rect.top) / rect.height) * 100\n    const text = prompt('в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎ в”ҳГҘв”ҳГ©в•Әв•–в”ҳГ§:')\n    if (text) {\n      setAnnotations((prev) => [...prev, { x, y, text }])\n    }\n  }\n\n  async function handleSubmit() {\n    if (!title.trim()) {\n      setError('в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬')\n      return\n    }\n\n    if (!allowNoWagon && !wagonCode.trim()) {\n      setError('в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в”ҢвҢҗв•ӘВ» в”ҳГӘв•ӘВәв”ҢВ»в”ҳГҘ/в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“ в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬')\n      return\n    }\n\n    setLoading(true)\n    setError('')\n\n    try {\n      let photoUrl = ''\n      if (photo) {\n        const formData = new FormData()\n        formData.append('file', photo)\n\n        const uploadRes = await fetchWithAuth('/api/uploads', {\n          method: 'POST',\n          body: formData,\n        })\n\n        if (!uploadRes.ok) {\n          const errData = await uploadRes.json()\n          setError(errData.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘГів”ҳв•ӣв”ҳГӨв”ҳГӘв•ӘВ» в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ®')\n          setLoading(false)\n          return\n        }\n\n        const uploadData = await uploadRes.json()\n        photoUrl = uploadData.data.url\n      }\n\n      const res = await fetchWithAuth('/api/tickets', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          title,\n          description: description || undefined,\n          priority,\n          wagonCode: wagonCode || undefined,\n          photoUrl: photoUrl || undefined,\n          annotations: annotations.length > 0 ? annotations : undefined,\n        }),\n      })\n\n      if (!res.ok) {\n        const data = await res.json()\n        setError(data.error)\n        return\n      }\n\n      setOpen(false)\n      setTitle('')\n      setDescription('')\n      setPriority('medium')\n      setWagonCode('')\n      setPhoto(null)\n      setPhotoPreview(null)\n      setAnnotations([])\n      setAiPredictedPriority('')\n      setAiReason('')\n      setAiMatchedKeywords([])\n      onCreated()\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  return (\n    <Dialog open={open} onOpenChange={setOpen}>\n      <DialogTrigger render={<Button size=\"sm\" />}>\n        <Camera className=\"ms-2 size-4\" />\n        в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n      </DialogTrigger>\n      <DialogContent className=\"max-w-lg\">\n        <DialogHeader>\n          <DialogTitle>в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ®</DialogTitle>\n        </DialogHeader>\n        <div className=\"space-y-4\">\n          {error && (\n            <div role=\"alert\" className=\"rounded-md bg-destructive/10 p-3 text-sm text-destructive\">\n              {error}\n            </div>\n          )}\n\n          <div className=\"space-y-2\">\n            <Label htmlFor=\"title\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ *</Label>\n            <Input\n              id=\"title\"\n              value={title}\n              onChange={(e) => setTitle(e.target.value)}\n              placeholder=\"в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬\"\n            />\n          </div>\n\n          <div className=\"space-y-2\">\n            <Label htmlFor=\"description\">в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв•ӘВәв•ӘВ¬</Label>\n            <textarea\n              id=\"description\"\n              value={description}\n              onChange={(e) => setDescription(e.target.value)}\n              className=\"h-20 w-full rounded-lg border border-border bg-surface px-3 py-2 text-sm\"\n              placeholder=\"в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв•ӘВәв•ӘВ¬ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ®\"\n            />\n          </div>\n\n          <div className=\"space-y-3\">\n            <div className=\"flex items-center justify-between\">\n              <Label htmlFor=\"ticketPriority\">в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВәв”ҳГӘв”ҳГӨв”ҳГӘв–ҲГ®в•ӘВ¬</Label>\n              {isAnalyzing && (\n                <span className=\"text-[10px] text-accent animate-pulse flex items-center gap-1 font-mono\">\n                  <span className=\"size-1.5 rounded-full bg-accent animate-ping\" />\n                  в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨ в”ҳГ в•ӘВ¬в”ҳГҘ...\n                </span>\n              )}\n            </div>\n            <div className=\"grid grid-cols-4 gap-2\">\n              {[\n                { value: 'critical', label: 'в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®', checked: 'peer-checked:bg-critical/15 peer-checked:border-critical peer-checked:text-critical' },\n                { value: 'high', label: 'в•Әв•Јв”ҳГ в•ӘВ»в”ҳГ§', checked: 'peer-checked:bg-warning/15 peer-checked:border-warning peer-checked:text-warning' },\n                { value: 'medium', label: 'в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®', checked: 'peer-checked:bg-info/15 peer-checked:border-info peer-checked:text-info' },\n                { value: 'low', label: 'в”ҢвҢҗв”ҳГ О“ГҮГ®в•ӘВәв”ҳГ§в”ҳГ в–ҲГ®в•ӘВ¬', checked: 'peer-checked:bg-surface-container-high peer-checked:border-outline peer-checked:text-foreground-muted' },\n              ].map((p) => (\n                <label key={p.value} className=\"cursor-pointer relative block\">\n                  <input\n                    type=\"radio\"\n                    name=\"priority\"\n                    value={p.value}\n                    checked={priority === p.value}\n                    onChange={(e) => setPriority(e.target.value)}\n                    className=\"peer sr-only\"\n                  />\n                  <div className={cn(\n                    'h-14 flex items-center justify-center border border-outline rounded-lg bg-surface transition-colors active:inner-shadow relative overflow-hidden',\n                    p.checked,\n                  )}>\n                    <span className=\"font-label-md text-xs md:text-sm\">{p.label}</span>\n                  </div>\n                  {aiPredictedPriority === p.value && (\n                    <span className=\"absolute -top-1.5 start-1/2 -translate-x-1/2 bg-accent text-[8px] text-accent-foreground px-1 py-0.5 rounded-full font-bold animate-pulse scale-90 whitespace-nowrap shadow-sm\">\n                      в”ҳв•ӣв–ҲГ®в•Әв”Өв”ҳГҘв”ҳГ§в•ӘВәв•ӘВ» AI\n                    </span>\n                  )}\n                </label>\n              ))}\n            </div>\n\n            {aiPredictedPriority && (\n              <div className={cn(\n                \"p-3 rounded-lg border text-xs flex flex-col gap-1 transition-all duration-300 animate-in fade-in slide-in-from-top-1 bg-surface-container-high/40 backdrop-blur-sm\",\n                aiPredictedPriority === 'critical' ? 'border-critical/30 text-critical bg-critical/5' :\n                  aiPredictedPriority === 'high' ? 'border-warning/30 text-warning bg-warning/5' :\n                    aiPredictedPriority === 'medium' ? 'border-info/30 text-info bg-info/5' :\n                      'border-border text-foreground-muted bg-surface/5'\n              )}>\n                <div className=\"flex items-center gap-1.5 font-semibold\">\n                  <span className=\"relative flex h-2 w-2\">\n                    <span className={cn(\n                      \"animate-ping absolute inline-flex h-full w-full rounded-full opacity-75\",\n                      aiPredictedPriority === 'critical' ? 'bg-critical' :\n                        aiPredictedPriority === 'high' ? 'bg-warning' :\n                          aiPredictedPriority === 'medium' ? 'bg-info' :\n                            'bg-foreground-muted'\n                    )}></span>\n                    <span className={cn(\n                      \"relative inline-flex rounded-full h-2 w-2\",\n                      aiPredictedPriority === 'critical' ? 'bg-critical' :\n                        aiPredictedPriority === 'high' ? 'bg-warning' :\n                          aiPredictedPriority === 'medium' ? 'bg-info' :\n                            'bg-foreground-muted'\n                    )}></span>\n                  </span>\n                  <span>в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в•ӘВәв”ҳГӘв”ҳГӨв”ҳГӘв–ҲГ®в•ӘВ¬ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® (AI):</span>\n                  <span className=\"font-bold underline\">\n                    {aiPredictedPriority === 'critical' ? 'в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®' :\n                      aiPredictedPriority === 'high' ? 'в•Әв•Јв”ҳГ в•ӘВ»в”ҳГ§' :\n                        aiPredictedPriority === 'medium' ? 'в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®' : 'в”ҢвҢҗв”ҳГ О“ГҮГ®в•ӘВәв”ҳГ§в”ҳГ в–ҲГ®в•ӘВ¬'}\n                  </span>\n                </div>\n                {aiReason && <p className=\"text-[11px] leading-relaxed opacity-90\">{aiReason}</p>}\n              </div>\n            )}\n          </div>\n\n          <div className=\"space-y-2\">\n            <Label>в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ / в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ</Label>\n            <input\n              ref={inputRef}\n              type=\"file\"\n              accept=\"image/*\"\n              capture=\"environment\"\n              className=\"hidden\"\n              onChange={(e) => {\n                const f = e.target.files?.[0]\n                if (f) handlePhoto(f)\n              }}\n            />\n            {photoPreview ? (\n              <div className=\"relative\">\n                {/* eslint-disable-next-line @next/next/no-img-element */}\n                <img\n                  ref={imgRef}\n                  src={photoPreview}\n                  alt=\"preview\"\