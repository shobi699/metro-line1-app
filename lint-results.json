 the initialization of 'messages' in its own useMemo() Hook.","line":228,"column":9,"nodeType":"VariableDeclarator","endLine":228,"endColumn":74},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'messages' conditional could make the dependencies of useMemo Hook (at line 255) change on every render. To fix this, wrap the initialization of 'messages' in its own useMemo() Hook.","line":228,"column":9,"nodeType":"VariableDeclarator","endLine":228,"endColumn":74},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":266,"column":56,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":266,"endColumn":59,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[8915,8918],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[8915,8918],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":276,"column":97,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":276,"endColumn":100,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[9666,9669],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[9666,9669],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { Suspense, useEffect, useState, useMemo } from 'react'\nimport { useSearchParams, useRouter } from 'next/navigation'\nimport { useAuthStore } from '@/features/auth'\nimport { useChatStore } from '@/features/chat'\nimport { ChatRoomList } from '@/components/shared/chat-room-list'\nimport { ChatThread } from '@/components/shared/chat-thread'\nimport { MessageComposer } from '@/components/shared/message-composer'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Textarea } from '@/components/ui/textarea'\nimport { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle } from '@/components/ui/dialog'\nimport { Badge } from '@/components/ui/badge'\nimport { cn } from '@/lib/utils'\nimport { toFa } from '@/lib/fa'\nimport {\n  ArrowRight,\n  MessagesSquare,\n  Search,\n  Plus,\n  Pin,\n  Info,\n  X,\n  User,\n  Users,\n  Hash,\n  Check,\n  Lock,\n  Volume2,\n  Activity,\n  MessageCircle\n} from 'lucide-react'\n\ninterface UserOption {\n  id: string\n  name: string\n  nationalId: string\n  role: { name: string; key: string }\n  customFields?: Record<string, any> | null\n}\n\nfunction ChatView() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const currentUser = useAuthStore((s) => s.user)\n  const searchParams = useSearchParams()\n  const router = useRouter()\n  const dmUserId = searchParams.get('dm')\n\n  // Chat Store states\n  const rooms = useChatStore((s) => s.rooms)\n  const activeRoomId = useChatStore((s) => s.activeRoomId)\n  const messagesByRoom = useChatStore((s) => s.messagesByRoom)\n  const roomSettings = useChatStore((s) => s.roomSettings)\n  const roomReactions = useChatStore((s) => s.roomReactions)\n  const roomIsAdmin = useChatStore((s) => s.roomIsAdmin)\n  const loadingRooms = useChatStore((s) => s.loadingRooms)\n  const loadingMessages = useChatStore((s) => s.loadingMessages)\n  const loadRooms = useChatStore((s) => s.loadRooms)\n  const selectRoom = useChatStore((s) => s.selectRoom)\n  const sendMessage = useChatStore((s) => s.sendMessage)\n  const openDirect = useChatStore((s) => s.openDirect)\n  const connect = useChatStore((s) => s.connect)\n  const disconnect = useChatStore((s) => s.disconnect)\n  const connected = useChatStore((s) => s.connected)\n  const toggleReaction = useChatStore((s) => s.toggleReaction)\n  const updateSettings = useChatStore((s) => s.updateSettings)\n\n  // Layout & UI States\n  const [showThreadMobile, setShowThreadMobile] = useState(false)\n  const [roomSearchQuery, setRoomSearchQuery] = useState('')\n  const [roomFilterType, setRoomFilterType] = useState<'all' | 'direct' | 'group'>('all')\n  const [msgSearchQuery, setMsgSearchQuery] = useState('')\n  const [showMsgSearch, setShowMsgSearch] = useState(false)\n  const [showDetailsPanel, setShowDetailsPanel] = useState(false)\n\n  // Modals\n  const [isNewChatOpen, setIsNewChatOpen] = useState(false)\n  const [usersList, setUsersList] = useState<UserOption[]>([])\n  const [userSearchQuery, setUserSearchQuery] = useState('')\n  const [loadingUsers, setLoadingUsers] = useState(false)\n\n  // Member Filtering States\n  const [filterRole, setFilterRole] = useState('')\n  const [filterGroup, setFilterGroup] = useState('')\n  const [filterStation, setFilterStation] = useState('')\n\n  // Group Builder Form\n  const [groupName, setGroupName] = useState('')\n  const [groupKind, setGroupKind] = useState('custom')\n  const [selectedMembers, setSelectedMembers] = useState<string[]>([])\n  const [creatingGroup, setCreatingGroup] = useState(false)\n\n  // 1. Connect and fetch rooms\n  useEffect(() => {\n    if (!accessToken) return\n    loadRooms(accessToken)\n    connect(accessToken)\n    return () => disconnect()\n  }, [accessToken, loadRooms, connect, disconnect])\n\n  // 2. Open direct chat on URL command ?dm=\n  useEffect(() => {\n    if (!accessToken || !dmUserId) return\n    let cancelled = false\n    openDirect(accessToken, dmUserId).then((roomId) => {\n      if (cancelled || !roomId) return\n      selectRoom(accessToken, roomId)\n      setShowThreadMobile(true)\n      router.replace('/chat')\n    })\n    return () => {\n      cancelled = true\n    }\n  }, [accessToken, dmUserId, openDirect, selectRoom, router])\n\n  // Fetch users when the dialog opens\n  useEffect(() => {\n    if (!isNewChatOpen || !accessToken) return\n    setLoadingUsers(true)\n    fetch('/api/users?pageSize=100', {\n      headers: { Authorization: `Bearer ${accessToken}` },\n    })\n      .then((res) => (res.ok ? res.json() : { data: { users: [] } }))\n      .then((payload) => {\n        setUsersList(payload.data?.users ?? [])\n      })\n      .catch(() => {})\n      .finally(() => setLoadingUsers(false))\n  }, [isNewChatOpen, accessToken])\n\n  // Select room handler\n  function handleSelectRoom(roomId: string) {\n    if (!accessToken) return\n    selectRoom(accessToken, roomId)\n    setShowThreadMobile(true)\n    setMsgSearchQuery('')\n    setShowMsgSearch(false)\n  }\n\n  // Send message handler\n  async function handleSend(body: string, attachment?: { url: string; type: string }) {\n    if (!accessToken || !activeRoomId) return false\n    return sendMessage(accessToken, activeRoomId, body, attachment)\n  }\n\n  // Pin/Unpin message handler\n  async function handlePinMessage(messageId: string, pinned: boolean) {\n    if (!accessToken || !activeRoomId) return\n    try {\n      const res = await fetch(`/api/chat/rooms/${activeRoomId}/pin`, {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({ messageId, pinned }),\n      })\n      if (res.ok) {\n        selectRoom(accessToken, activeRoomId)\n      } else {\n        const err = await res.json()\n        alert(err.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬ в•Әв”Ӯв”ҳГҘв•ӘВјв•ӘВәв”ҳГ© в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ ')\n      }\n    } catch {\n      // pin message failed silently\n    }\n  }\n\n  // Create group room handler\n  async function handleCreateGroup() {\n    if (!accessToken || !groupName.trim()) return\n    setCreatingGroup(true)\n    try {\n      const res = await fetch('/api/chat/rooms', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          name: groupName,\n          kind: groupKind,\n          memberIds: selectedMembers,\n        }),\n      })\n\n      if (res.ok) {\n        const data = await res.json()\n        setGroupName('')\n        setGroupKind('custom')\n        setSelectedMembers([])\n        setIsNewChatOpen(false)\n        loadRooms(accessToken)\n        selectRoom(accessToken, data.data.id)\n      } else {\n        const err = await res.json()\n        alert(err.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»')\n      }\n    } catch {\n      // create group failed silently\n    } finally {\n      setCreatingGroup(false)\n    }\n  }\n\n  // Trigger direct chat creation\n  async function handleStartDirectChat(userId: string) {\n    if (!accessToken) return\n    setIsNewChatOpen(false)\n    const roomId = await openDirect(accessToken, userId)\n    if (roomId) {\n      selectRoom(accessToken, roomId)\n      setShowThreadMobile(true)\n    }\n  }\n\n  // Toggle user group member selection\n  function toggleMemberSelection(userId: string) {\n    setSelectedMembers((prev) =>\n      prev.includes(userId) ? prev.filter((id) => id !== userId) : [...prev, userId],\n    )\n  }\n\n  // Data Selectors\n  const activeRoom = rooms.find((r) => r.id === activeRoomId) ?? null\n  const messages = activeRoomId ? messagesByRoom[activeRoomId] ?? [] : []\n\n  // Filtered rooms in the sidebar\n  const filteredRooms = useMemo(() => {\n    return rooms.filter((r) => {\n      const matchesSearch = r.name.toLowerCase().includes(roomSearchQuery.toLowerCase())\n      const matchesFilter =\n        roomFilterType === 'all'\n          ? true\n          : roomFilterType === 'direct'\n          ? r.type === 'direct'\n          : r.type === 'group'\n      return matchesSearch && matchesFilter\n    })\n  }, [rooms, roomSearchQuery, roomFilterType])\n\n  // Filtered messages inside thread search\n  const filteredMessages = useMemo(() => {\n    if (!msgSearchQuery.trim()) return messages\n    return messages.filter((m) =>\n      m.body?.toLowerCase().includes(msgSearchQuery.toLowerCase()),\n    )\n  }, [messages, msgSearchQuery])\n\n  // Pinned messages list\n  const pinnedMessages = useMemo(() => {\n    return messages.filter((m) => m.pinned)\n  }, [messages])\n\n  const latestPinned = pinnedMessages[pinnedMessages.length - 1] ?? null\n\n  const isUserAdmin = currentUser?.roleKey === 'admin' || currentUser?.roleKey === 'super_admin'\n\n  // Filter users lists in dialog\n  const filteredUsers = useMemo(() => {\n    return usersList.filter((u) => {\n      const matchesSearch = u.name.toLowerCase().includes(userSearchQuery.toLowerCase())\n      const matchesRole = filterRole ? u.role?.key === filterRole : true\n      const uFields = u.customFields as Record<string, any> | null\n      const matchesGroup = filterGroup ? uFields?.group === filterGroup : true\n      const matchesStation = filterStation ? uFields?.station === filterStation : true\n      return matchesSearch && matchesRole && matchesGroup && matchesStation && u.id !== currentUser?.id\n    })\n  }, [usersList, userSearchQuery, filterRole, filterGroup, filterStation, currentUser])\n\n  const activeSettings = activeRoomId ? roomSettings[activeRoomId] || { readOnly: false, blockAttachments: false, maxLength: 1000 } : { readOnly: false, blockAttachments: false, maxLength: 1000 }\n  const isRoomAdmin = activeRoomId ? roomIsAdmin[activeRoomId] || false : false\n\n  const handleUpdateSetting = async (key: 'readOnly' | 'blockAttachments' | 'maxLength', value: any) => {\n    if (!accessToken || !activeRoomId) return\n    const newSettings = {\n      ...activeSettings,\n      [key]: value\n    }\n    await updateSettings(accessToken, activeRoomId, newSettings)\n  }\n\n\n  return (\n    <div className=\"flex min-h-0 flex-1 overflow-hidden bg-background\">\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* SIDEBAR: ROOM LIST */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <aside\n        className={cn(\n          'flex w-full flex-col border-e border-border lg:w-80 bg-surface-container-low/40',\n          showThreadMobile ? 'hidden lg:flex' : 'flex',\n        )}\n      >\n        {/* Sidebar Header */}\n        <div className=\"flex flex-col gap-3 shrink-0 border-b border-border p-4\">\n          <div className=\"flex items-center justify-between\">\n            <h1 className=\"text-base font-bold text-foreground flex items-center gap-1.5\">\n              <MessageCircle className=\"size-5 text-accent\" />\n              в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’\n            </h1>\n            \n            {/* Live SSE Status */}\n            <div className=\"flex items-center gap-1.5 bg-neutral-900/40 px-2 py-0.5 rounded border border-border-subtle\">\n              <span className={cn(\n                \"relative flex h-2 w-2 rounded-full\",\n                connected ? \"bg-success\" : \"bg-warning\"\n              )}>\n                {connected && (\n                  <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-success/80 opacity-75\"></span>\n                )}\n              </span>\n              <span className=\"text-[10px] font-bold text-foreground-muted\">\n                {connected ? 'OCC в•ӘВҝв•Әв–’в•ӘВ«в•Әв•–' : 'в•ӘГів”ҳГјв”ҳГӨв•ӘВәв–ҲГ®в”ҳГҘ'}\n              </span>\n            </div>\n          </div>\n\n          {/* Search and Action Bar */}\n          <div className=\"flex gap-2\">\n            <div className=\"relative flex-1\">\n              <Search className=\"absolute right-2.5 top-2.5 size-4 text-foreground-muted\" />\n              <Input\n                placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в”ҢВ»в”ҳГјв•ӘВ¬в”ҢВ»в”ҳГӘв”ҳГ§в•ӘВә...\"\n                value={roomSearchQuery}\n                onChange={(e) => setRoomSearchQuery(e.target.value)}\n                className=\"h-9 pr-8 text-xs bg-neutral-950/20\"\n              />\n            </div>\n            <Button\n              size=\"icon\"\n              variant=\"outline\"\n              onClick={() => setIsNewChatOpen(true)}\n              className=\"h-9 w-9 shrink-0 active:scale-95 transition-transform\"\n              title=\"в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\"\n            >\n              <Plus className=\"size-4\" />\n            </Button>\n          </div>\n\n          {/* Filters pills */}\n          <div className=\"flex gap-1.5 p-0.5 bg-neutral-950/30 rounded-lg border border-border-subtle/50 text-[11px]\">\n            <button\n              onClick={() => setRoomFilterType('all')}\n              className={cn(\n                \"flex-1 py-1 rounded-md text-center transition-all font-semibold\",\n                roomFilterType === 'all' ? \"bg-accent text-accent-foreground shadow\" : \"text-foreground-muted hover:text-foreground\"\n              )}\n            >\n              в”ҳГ§в”ҳГ в”ҳГ§ ({toFa(rooms.length)})\n            </button>\n            <button\n              onClick={() => setRoomFilterType('direct')}\n              className={cn(\n                \"flex-1 py-1 rounded-md text-center transition-all font-semibold\",\n                roomFilterType === 'direct' ? \"bg-accent text-accent-foreground shadow\" : \"text-foreground-muted hover:text-foreground\"\n              )}\n            >\n              в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ®\n            </button>\n            <button\n              onClick={() => setRoomFilterType('group')}\n              className={cn(\n                \"flex-1 py-1 rounded-md text-center transition-all font-semibold\",\n                roomFilterType === 'group' ? \"bg-accent text-accent-foreground shadow\" : \"text-foreground-muted hover:text-foreground\"\n              )}\n            >\n              в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә\n            </button>\n          </div>\n        </div>\n\n        {/* Room List scroll section */}\n        <div className=\"min-h-0 flex-1 overflow-y-auto\">\n          <ChatRoomList\n            rooms={filteredRooms}\n            activeRoomId={activeRoomId}\n            onSelect={handleSelectRoom}\n            loading={loadingRooms}\n          />\n        </div>\n      </aside>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* CHAT CONTAINER */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <section\n        className={cn(\n          'min-h-0 flex-1 flex-col relative',\n          showThreadMobile ? 'flex' : 'hidden lg:flex',\n        )}\n      >\n        {activeRoom ? (\n          <>\n            {/* Chat Thread Header */}\n            <div className=\"flex h-14 shrink-0 items-center justify-between border-b border-border bg-surface-container-low/30 px-4\">\n              <div className=\"flex items-center gap-2\">\n                <Button\n                  variant=\"ghost\"\n                  size=\"icon\"\n                  className=\"lg:hidden\"\n                  aria-label=\"в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв”Өв•ӘВ¬\"\n                  onClick={() => setShowThreadMobile(false)}\n                >\n                  <ArrowRight className=\"size-4\" />\n                </Button>\n                <div className=\"flex flex-col text-right\">\n                  <span className=\"text-sm font-bold flex items-center gap-1.5\">\n                    {activeRoom.type === 'group' ? (\n                      <Users className=\"size-4 text-accent\" />\n                    ) : (\n                      <User className=\"size-4 text-foreground-muted\" />\n                    )}\n                    {activeRoom.name}\n                  </span>\n                  {activeRoom.type === 'group' && (\n                    <span className=\"text-[10px] text-foreground-muted\">\n                      {toFa(activeRoom.memberCount)} в•Әв•Јв•Әв•ўв”ҳГӘ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ | в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’\n                    </span>\n                  )}\n                </div>\n              </div>\n\n              {/* Chat Window Actions */}\n              <div className=\"flex items-center gap-2\">\n                {/* Search in message thread */}\n                {showMsgSearch ? (\n                  <div className=\"flex items-center gap-1 bg-neutral-950/20 border border-border-subtle rounded-lg px-2 h-8 w-44 md:w-56\">\n                    <Search className=\"size-3.5 text-foreground-muted shrink-0\" />\n                    <input\n                      placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ О“ГҮГ®в”ҳГ§в•ӘВә...\"\n                      value={msgSearchQuery}\n                      onChange={(e) => setMsgSearchQuery(e.target.value)}\n                      className=\"bg-transparent border-none outline-none text-[11px] w-full text-foreground\"\n                    />\n                    <button\n                      onClick={() => {\n                        setMsgSearchQuery('')\n                        setShowMsgSearch(false)\n                      }}\n                      className=\"text-foreground-muted hover:text-foreground active:scale-90\"\n                    >\n                      <X className=\"size-3.5\" />\n                    </button>\n                  </div>\n                ) : (\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon-xs\"\n                    onClick={() => setShowMsgSearch(true)}\n                    className=\"h-8 w-8 text-foreground-muted hover:text-foreground\"\n                    title=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в•ӘВ»в•Әв–’ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ О“ГҮГ®в”ҳГ§в•ӘВә\"\n                  >\n                    <Search className=\"size-4\" />\n                  </Button>\n                )}\n\n                {/* Details toggle */}\n                <Button\n                  variant=\"ghost\"\n                  size=\"icon-xs\"\n                  onClick={() => setShowDetailsPanel(!showDetailsPanel)}\n                  className={cn(\n                    \"h-8 w-8 text-foreground-muted hover:text-foreground\",\n                    showDetailsPanel && \"bg-neutral-900/40 text-accent\"\n                  )}\n                  title=\"в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘ\"\n                >\n                  <Info className=\"size-4\" />\n                </Button>\n              </div>\n            </div>\n\n            {/* Pinned Message Banner */}\n            {latestPinned && (\n              <div className=\"flex items-center justify-between bg-warning/5 border-b border-warning/10 px-4 py-2 text-xs text-warning animate-fade-in shrink-0\">\n                <div className=\"flex items-center gap-2 flex-1 min-w-0\">\n                  <Pin className=\"size-3.5 text-warning shrink-0 fill-warning\" />\n                  <div className=\"flex-1 min-w-0\">\n                    <span className=\"font-bold block text-[10px] text-warning/80\">в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ  в•Әв”Ӯв”ҳГҘв•ӘВјв•ӘВәв”ҳГ© в•Әв”Өв•ӘВ»в”ҳГ§:</span>\n                    <span className=\"truncate block text-foreground/90 font-medium\">{latestPinned.body || 'в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬ в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®'}</span>\n                  </div>\n                </div>\n                <div className=\"flex items-center gap-2 ml-2\">\n                  <button\n                    onClick={() => handlePinMessage(latestPinned.id, false)}\n                    className=\"p-1 hover:text-foreground text-warning/80\"\n                    title=\"в•ӘВҝв•Әв–’в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬в”ҳГҘ в•Әв”Ӯв”ҳГҘв•ӘВјв•ӘВәв”ҳГ©\"\n                  >\n                    <X className=\"size-3.5\" />\n                  </button>\n                </div>\n              </div>\n            )}\n\n            {/* Messages Thread list */}\n            <ChatThread\n              messages={filteredMessages}\n              currentUserId={currentUser?.id ?? ''}\n              loading={loadingMessages}\n              onPin={handlePinMessage}\n              reactions={activeRoomId ? roomReactions[activeRoomId] : undefined}\n              onReact={(messageId, emoji) => {\n                if (accessToken && activeRoomId) {\n                  toggleReaction(accessToken, activeRoomId, messageId, emoji)\n                }\n              }}\n            />\n\n            {/* Composer */}\n            <MessageComposer\n              token={accessToken ?? ''}\n              onSend={handleSend}\n              disabled={activeSettings.readOnly && !isRoomAdmin}\n              blockAttachments={activeSettings.blockAttachments && !isRoomAdmin}\n              maxLength={activeSettings.maxLength}\n            />\n          </>\n        ) : (\n          <div className=\"flex flex-1 flex-col items-center justify-center gap-3 text-foreground-muted bg-neutral-950/5\">\n            <div className=\"flex size-16 items-center justify-center rounded-full bg-surface-container-high border border-border-subtle\">\n              <MessagesSquare className=\"size-8 text-foreground-muted\" />\n            </div>\n            <div className=\"text-center space-y-1\">\n              <p className=\"text-sm font-bold text-foreground\">в–ҲГ®в”ҢвҢҗ в”ҢВ»в”ҳГјв•ӘВ¬в”ҢВ»в”ҳГӘ в•Әв–’в•ӘВә в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘГів•Әв•‘в•ӘВәв•Әв–“ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ О“ГҮГ®в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»</p>\n              <p className=\"text-xs text-foreground-muted\">\n                в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ©О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ® в–ҲГ®в•ӘВә в”ҢВ»в”ҳГјв•ӘВ¬в”ҢВ»в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•ӘВҝв•ӘВәOCC в”ҳГӘ в•Әв”Ӯв•ӘВәв–ҲГ®в•Әв–’ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•Әв–’в•ӘВә в•ӘВҝв•ӘВәв•Әв–“ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n              </p>\n            </div>\n            <Button size=\"sm\" onClick={() => setIsNewChatOpen(true)} className=\"mt-2 text-xs\">\n              в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n            </Button>\n          </div>\n        )}\n      </section>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* RIGHT SIDE DETAILS DRAWER */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {activeRoom && showDetailsPanel && (\n        <aside className=\"hidden md:flex w-64 flex-col border-s border-border bg-surface-container-low/20 shrink-0\">\n          <div className=\"flex h-14 shrink-0 items-center justify-between border-b border-border px-4\">\n            <h3 className=\"text-xs font-bold text-foreground\">в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®в•ӘВәв•ӘВ¬ в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘ</h3>\n            <Button\n              variant=\"ghost\"\n              size=\"icon-xs\"\n              onClick={() => setShowDetailsPanel(false)}\n              className=\"h-7 w-7\"\n            >\n              <X className=\"size-4\" />\n            </Button>\n          </div>\n\n          <div className=\"p-4 space-y-5 overflow-y-auto flex-1 text-right\" dir=\"rtl\">\n            {/* Room Avatar & Name */}\n            <div className=\"flex flex-col items-center justify-center text-center gap-2 py-4 border-b border-border-subtle/55\">\n              <div className=\"size-16 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center text-accent\">\n                {activeRoom.type === 'group' ? (\n                  <Users className=\"size-8\" />\n                ) : (\n                  <User className=\"size-8\" />\n                )}\n              </div>\n              <span className=\"font-bold text-sm mt-1 text-foreground block\">{activeRoom.name}</span>\n              <Badge variant=\"outline\" className=\"text-[9px] bg-neutral-900/40\">\n                {activeRoom.type === 'group' ? 'в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’' : 'в”ҢВ»в”ҳГјв•ӘВ¬в”ҢВ»в”ҳГӘ в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘ'}\n              </Badge>\n            </div>\n\n            {/* Room Metadata */}\n            <div className=\"space-y-3\">\n              <span className=\"text-[11px] font-bold text-accent block\">в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•Әв–’в”ҳГӘв”ҳГ :</span>\n              <div className=\"space-y-2 text-xs\">\n                <div className=\"flex justify-between items-center py-1 border-b border-border-subtle/30\">\n                  <span className=\"text-foreground-muted\">в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ©:</span>\n                  <span className=\"font-mono text-[10px] select-all\">{activeRoom.id}</span>\n                </div>\n                {activeRoom.type === 'group' && (\n                  <>\n                    <div className=\"flex justify-between items-center py-1 border-b border-border-subtle/30\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•ӘВәв•Әв•Јв•Әв•ўв•ӘВә:</span>\n                      <span className=\"font-bold\">{toFa(activeRoom.memberCount)} в”ҳГҘв”ҳГјв•Әв–’</span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-1 border-b border-border-subtle/30\">\n                      <span className=\"text-foreground-muted\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ:</span>\n                      <span className=\"font-semibold text-accent\">{activeRoom.kind}</span>\n                    </div>\n                  </>\n                )}\n                <div className=\"flex justify-between items-center py-1 border-b border-border-subtle/30\">\n                  <span className=\"text-foreground-muted\">в•ӘГів•ӘВ«в•Әв–’в–ҲГ®в”ҳГҘ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬:</span>\n                  <span className=\"font-mono text-[10px]\">\n                    {activeRoom.lastMessage ? toFa(activeRoom.lastMessage.createdAt.split('T')[0]) : 'О“ГҮГ¶'}\n                  </span>\n                </div>\n              </div>\n            </div>\n\n            {/* Room Settings and Restrictions (only for room administrators) */}\n            {isRoomAdmin && activeRoom.type === 'group' && (\n              <div className=\"space-y-3 border-t border-border-subtle/55 pt-4\">\n                <span className=\"text-[11px] font-bold text-accent block\">в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГӘ в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ»в–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ:</span>\n                <div className=\"space-y-3 text-xs bg-neutral-950/20 p-2.5 rounded-lg border border-border-subtle/30\">\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"text-foreground-muted\">в”ҳГјв”ҳГ©в•Әв•– в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ  в•ӘВҝв”ҳГјв•Әв–’в•Әв”Ӯв•ӘВ¬в•ӘВ»:</span>\n                    <input\n                      type=\"checkbox\"\n                      checked={activeSettings.readOnly}\n                      onChange={(e) => handleUpdateSetting('readOnly', e.target.checked)}\n                      className=\"rounded border-border bg-neutral-950 text-accent focus:ring-accent size-4 cursor-pointer\"\n                    />\n                  </div>\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"text-foreground-muted\">в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ:</span>\n                    <input\n                      type=\"checkbox\"\n                      checked={activeSettings.blockAttachments}\n                      onChange={(e) => handleUpdateSetting('blockAttachments', e.target.checked)}\n                      className=\"rounded border-border bg-neutral-950 text-accent focus:ring-accent size-4 cursor-pointer\"\n                    />\n                  </div>\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"text-foreground-muted\">в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ :</span>\n                    <select\n                      value={activeSettings.maxLength}\n                      onChange={(e) => handleUpdateSetting('maxLength', Number(e.target.value))}\n                      className=\"rounded border border-border bg-neutral-950 px-1 py-0.5 text-xs text-foreground focus:outline-none cursor-pointer\"\n                    >\n                      <option value={100}>в–Ҳв–’в–Ҳв–‘в–Ҳв–‘</option>\n                      <option value={500}>в–Ҳв•Ўв–Ҳв–‘в–Ҳв–‘</option>\n                      <option value={1000}>в–Ҳв–’в–Ҳв–‘в–Ҳв–‘в–Ҳв–‘</option>\n                      <option value={5000}>в–Ҳв•Ўв–Ҳв–‘в–Ҳв–‘в–Ҳв–‘</option>\n                    </select>\n                  </div>\n                </div>\n              </div>\n            )}\n\n            {/* Pinned messages lists inside drawer */}\n            <div className=\"space-y-2\">\n              <div className=\"flex items-center justify-between\">\n                <span className=\"text-[11px] font-bold text-accent block\">в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГҘв•ӘВјв•ӘВәв”ҳГ© в•Әв”Өв•ӘВ»в”ҳГ§ ({toFa(pinnedMessages.length)}):</span>\n              </div>\n              \n              {pinnedMessages.length === 0 ? (\n                <p className=\"text-[10px] text-foreground-muted text-center py-4 border border-dashed border-border-subtle rounded-md\">\n                  в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ  в”ҳв•ӣв–ҲГ®в”ҳГҘ в•Әв”Өв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»\n                </p>\n              ) : (\n                <div className=\"space-y-1.5 max-h-48 overflow-y-auto\">\n                  {pinnedMessages.map((m) => (\n                    <div key={m.id} className=\"p-2 bg-neutral-950/20 rounded border border-border-subtle text-[10px] space-y-1 relative group\">\n                      <div className=\"flex justify-between text-[9px] text-accent/80 font-bold\">\n                        <span>в”ҳГјв•Әв–’в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в”ҳГ§: {m.senderName}</span>\n                        {isUserAdmin && (\n                          <button\n                            onClick={() => handlePinMessage(m.id, false)}\n                            className=\"text-foreground-muted hover:text-critical font-normal opacity-0 group-hover:opacity-100 transition-opacity\"\n                            title=\"в•ӘВЎв•Әв–‘в”ҳГј в”ҳв•ӣв–ҲГ®в”ҳГҘ\"\n                          >\n                            в•ӘВЎв•Әв–‘в”ҳГј в”ҳв•ӣв–ҲГ®в”ҳГҘ\n                          </button>\n                        )}\n                      </div>\n                      <p className=\"text-foreground/90 leading-relaxed\">{m.body || 'в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬ в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®'}</p>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          </div>\n        </aside>\n      )}\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* MODAL: NEW DIALOG / GROUP CONVERSATION */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <Dialog open={isNewChatOpen} onOpenChange={setIsNewChatOpen}>\n        <DialogContent className=\"max-w-md bg-surface-container-low border border-border text-foreground\" dir=\"rtl\">\n          <DialogHeader className=\"text-right\">\n            <DialogTitle className=\"text-base font-bold\">в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</DialogTitle>\n            <DialogDescription className=\"text-xs text-foreground-muted\">\n              в•ӘВҝв•ӘВә в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в–ҲГ®в”ҢвҢҗв–ҲГ® в•ӘВәв•Әв–“ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҳГҘ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘ в•Әв–’в•ӘВә в•ӘГів•Әв•‘в•ӘВәв•Әв–“ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ» в–ҲГ®в•ӘВә в–ҲГ®в”ҢвҢҗ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®в•ӘВ».\n            </DialogDescription>\n          </DialogHeader>\n\n          {/* User Search Input */}\n          <div className=\"relative mt-2\">\n            <Search className=\"absolute right-2.5 top-2.5 size-4 text-foreground-muted\" />\n            <Input\n              placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҳГҘ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГҘв•ӘВәв”ҳГ ...\"\n              value={userSearchQuery}\n              onChange={(e) => setUserSearchQuery(e.target.value)}\n              className=\"pr-8 text-xs bg-neutral-950/20\"\n            />\n          </div>\n\n          {/* Smart Member Filters */}\n          <div className=\"grid grid-cols-3 gap-2 mt-2\">\n            <div className=\"space-y-1\">\n              <Label className=\"text-[9px] font-semibold text-foreground-muted\">в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в”ҳГҘв”ҳГ©в•Әв”Ө:</Label>\n              <select\n                value={filterRole}\n                onChange={(e) => setFilterRole(e.target.value)}\n                className=\"w-full h-8 rounded-md border border-border bg-neutral-950 px-1 py-0.5 text-[10px] text-foreground focus:outline-none cursor-pointer\"\n              >\n                <option value=\"\">в”ҳГ§в”ҳГ в”ҳГ§ в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә</option>\n                <option value=\"super_admin\">в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ»</option>\n                <option value=\"admin\">в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’</option>\n                <option value=\"operator\">в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ / в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’</option>\n              </select>\n            </div>\n            <div className=\"space-y-1\">\n              <Label className=\"text-[9px] font-semibold text-foreground-muted\">в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬:</Label>\n              <select\n                value={filterGroup}\n                onChange={(e) => setFilterGroup(e.target.value)}\n                className=\"w-full h-8 rounded-md border border-border bg-neutral-950 px-1 py-0.5 text-[10px] text-foreground focus:outline-none cursor-pointer\"\n              >\n                <option value=\"\">в”ҳГ§в”ҳГ в”ҳГ§ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә</option>\n                <option value=\"A\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ A</option>\n                <option value=\"B\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ B</option>\n                <option value=\"C\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ C</option>\n                <option value=\"Staff\">в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®</option>\n              </select>\n            </div>\n            <div className=\"space-y-1\">\n              <Label className=\"text-[9px] font-semibold text-foreground-muted\">в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§:</Label>\n              <select\n                value={filterStation}\n                onChange={(e) => setFilterStation(e.target.value)}\n                className=\"w-full h-8 rounded-md border border-border bg-neutral-950 px-1 py-0.5 text-[10px] text-foreground focus:outline-none cursor-pointer\"\n              >\n                <option value=\"\">в”ҳГ§в”ҳГ в”ҳГ§ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә</option>\n                <option value=\"tajrish\">в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө</option>\n                <option value=\"haft_tir\">в”ҳГ§в”ҳГјв•ӘВ¬ в•ӘВ¬в–ҲГ®в•Әв–’</option>\n                <option value=\"darvazeh_dowlat\">в•ӘВ»в•Әв–’в”ҳГӘв•ӘВәв•Әв–“в”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГӨв•ӘВ¬</option>\n                <option value=\"imam_khomeini\">в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ®</option>\n                <option value=\"shahr_e_rey\">в•Әв”Өв”ҳГ§в•Әв–’ в•Әв–’в–ҲГ®</option>\n                <option value=\"kahrizak\">в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ</option>\n                <option value=\"depot\">в•ӘВ»в”ҳв•ӣв”ҳГӘ в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ</option>\n              </select>\n            </div>\n          </div>\n\n          {/* Quick Select Buttons (only for admin) */}\n          {isUserAdmin && (\n            <div className=\"flex justify-between items-center mt-2 bg-neutral-900/40 p-2 rounded-lg border border-border-subtle/50\">\n              <span className=\"text-[10px] text-foreground-muted\">в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в”ҳГ в”ҳГҘв•Әв•–в•ӘВҝв”ҳГ©: {toFa(filteredUsers.length)} в”ҳГҘв”ҳГјв•Әв–’</span>\n              <Button\n                type=\"button\"\n                variant=\"outline\"\n                size=\"sm\"\n                className=\"h-7 text-[10px] px-2\"\n                onClick={() => {\n                  const newSelections = Array.from(new Set([...selectedMembers, ...filteredUsers.map(u => u.id)]))\n                  setSelectedMembers(newSelections)\n                }}\n              >\n                в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГ§в”ҳГ в”ҳГ§ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в•Әв”Өв•ӘВ»в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә\n              </Button>\n            </div>\n          )}\n\n          <div className=\"mt-4 space-y-4\">\n            {/* Tabs for Direct Chat vs Group Chat */}\n            <div className=\"flex border-b border-border-subtle text-xs\">\n              <button\n                type=\"button\"\n                className=\"px-4 py-2 border-b-2 border-accent text-accent font-bold\"\n              >\n                в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВ«в•Әв•– в–Ҳв–’ (в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ®)\n              </button>\n              {isUserAdmin && (\n                <div className=\"px-4 py-2 text-foreground-muted text-[10px] flex items-center gap-1\">\n                  <Lock className=\"size-3 text-accent\" />\n                  в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ (в•ӘВ»в•Әв–’ в”ҳв•ӣв”ҳГҘв”ҳГӨ в•Әв–“в–ҲГ®в•Әв–’в–ҲГ®в”ҳГҘ)\n                </div>\n              )}\n            </div>\n\n            {/* User List selection block */}\n            <div className=\"max-h-52 overflow-y-auto space-y-1.5 pr-1\">\n              {loadingUsers ? (\n                <div className=\"flex flex-col items-center py-6 gap-2 text-foreground-muted\">\n                  <div className=\"size-5 animate-spin rounded-full border-2 border-foreground-muted/30 border-t-accent\" />\n                  <span className=\"text-[10px]\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв•ӘВ»в”ҳГҘ в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ...</span>\n                </div>\n              ) : filteredUsers.length === 0 ? (\n                <p className=\"text-xs text-foreground-muted text-center py-4\">в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв•ӘВә в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГҘв•ӘВәв”ҳГ  в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».</p>\n              ) : (\n                filteredUsers.map((u) => (\n                  <div\n                    key={u.id}\n                    className=\"flex items-center justify-between p-2 rounded-lg bg-neutral-950/10 border border-border-subtle/50 hover:bg-neutral-950/20 transition-colors\"\n                  >\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"size-7.5 rounded-full bg-accent/15 border border-accent/25 flex items-center justify-center text-[11px] font-bold text-accent\">\n                        {u.name.substring(0, 1)}\n                      </div>\n                      <div className=\"flex flex-col text-right\">\n                        <span className=\"text-xs font-bold\">{u.name}</span>\n                        <span className=\"text-[9px] text-foreground-muted\">{u.role.name}</span>\n                      </div>\n                    </div>\n                    \n                    <div className=\"flex gap-1\">\n                      {/* DM Button */}\n                      <Button\n                        size=\"sm\"\n                        variant=\"ghost\"\n                        onClick={() => handleStartDirectChat(u.id)}\n                        className=\"h-7 text-[10px]\"\n                      >\n                        в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ \n                      </Button>\n\n                      {/* Select as Group Member (Only for Admin) */}\n                      {isUserAdmin && (\n                        <Button\n                          size=\"sm\"\n                          variant={selectedMembers.includes(u.id) ? \"default\" : \"outline\"}\n                          onClick={() => toggleMemberSelection(u.id)}\n                          className=\"h-7 px-2.5\"\n                        >\n                          {selectedMembers.includes(u.id) ? (\n                            <Check className=\"size-3.5\" />\n                          ) : (\n                            <Plus className=\"size-3.5 text-foreground-muted\" />\n                          )}\n                        </Button>\n                      )}\n                    </div>\n                  </div>\n                ))\n              )}\n            </div>\n\n            {/* Admin Group Builder Form */}\n            {isUserAdmin && (\n              <div className=\"border-t border-border-subtle/70 pt-4 space-y-3 bg-neutral-950/15 p-3 rounded-lg border\">\n                <span className=\"text-xs font-bold text-accent flex items-center gap-1.5\">\n                  <Lock className=\"size-3.5\" />\n                  в”ҳв•ӣв”ҳГҘв”ҳГӨ в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» (в”ҳГ в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ў в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ)\n                </span>\n                \n                <div className=\"space-y-1 text-right\">\n                  <Label className=\"text-[10px] font-semibold text-foreground-muted\">в”ҳГҘв•ӘВәв”ҳГ  в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§:</Label>\n                  <Input\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ»в–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘ в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ\"\n                    value={groupName}\n                    onChange={(e) => setGroupName(e.target.value)}\n                    className=\"h-8.5 text-xs bg-neutral-950/20\"\n                  />\n                </div>\n\n                <div className=\"space-y-1 text-right\">\n                  <Label className=\"text-[10px] font-semibold text-foreground-muted\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ / в•ӘВЎв”ҳГӘв•Әв–“в”ҳГ§ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬:</Label>\n                  <select\n                    value={groupKind}\n                    onChange={(e) => setGroupKind(e.target.value)}\n                    className=\"w-full h-8.5 rounded-md border border-border bg-neutral-950 px-2 py-1 text-xs text-foreground focus:outline-none\"\n                  >\n                    <option value=\"general\">в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® (General)</option>\n                    <option value=\"operators\">в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ (Operators)</option>\n                    <option value=\"occ\">в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГӘ OCC</option>\n                    <option value=\"shift\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® (Shifts)</option>\n                    <option value=\"station\">в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§в–ҲГ® (Stations)</option>\n                    <option value=\"custom\">в•Әв”Ӯв”ҳГјв•ӘВәв•Әв–’в•Әв”Өв–ҲГ® (Custom)</option>\n                  </select>\n                </div>\n\n                {selectedMembers.length > 0 && (\n                  <p className=\"text-[9px] text-green-500 font-bold\">\n                    в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» {toFa(selectedMembers.length)} в•Әв•Јв•Әв•ўв”ҳГӘ в•ӘВҝв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГҘ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВәв•Әв•ўв•ӘВәв”ҳГјв”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в”ҳГҘв•ӘВ» в•Әв”Өв•ӘВ».\n                  </p>\n                )}\n\n                <Button\n                  onClick={handleCreateGroup}\n                  disabled={creatingGroup || !groupName.trim()}\n                  className=\"w-full h-8 text-[11px]\"\n                >\n                  в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГӘ в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ®\n                </Button>\n              </div>\n            )}\n          </div>\n        </DialogContent>\n      </Dialog>\n    </div>\n  )\n}\n\nexport default function ChatPage() {\n  return (\n    <Suspense fallback={null}>\n      <ChatView />\n    </Suspense>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\checklists\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AlertTriangle' is defined but never used.","line":22,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":22,"endColumn":16,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AlertTriangle"},"fix":{"range":[721,739],"text":""},"desc":"Remove unused variable \"AlertTriangle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'user' is assigned a value but never used.","line":69,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":69,"endColumn":13},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadData'. Either include it or remove the dependency array.","line":132,"column":6,"nodeType":"ArrayExpression","endLine":132,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadData]","fix":{"range":[4092,4105],"text":"[accessToken, loadData]"}}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'origIdx' is defined but never used.","line":455,"column":40,"nodeType":"Identifier","messageId":"unusedVar","endLine":455,"endColumn":47}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription, CardFooter } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Textarea } from '@/components/ui/textarea'\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\nimport { toFa, jalali } from '@/lib/fa'\nimport { cn } from '@/lib/utils'\nimport { \n  ClipboardCheck, \n  CheckCircle, \n  History, \n  Shield, \n  Plus, \n  Trash, \n  Info, \n  AlertTriangle, \n  Train, \n  Wrench, \n  Lock,\n  ChevronRight,\n  MapPin,\n  Check,\n  X\n} from 'lucide-react'\n\ninterface ChecklistItem {\n  label: string\n  required: boolean\n}\n\ninterface Template {\n  id: string\n  name: string\n  description: string | null\n  items: ChecklistItem[]\n}\n\ninterface ChecklistRecord {\n  id: string\n  templateId: string\n  items: Array<{ label: string; checked: boolean; note?: string }>\n  signedAt: string\n  trainId: string | null\n  stationId: string | null\n  geoLocation: string | null\n  template?: { name: string }\n  user?: { name: string }\n}\n\nconst LINE1_STATIONS = [\n  'в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө',\n  'в”ҳГ©в”ҳГӨв”ҳГ§в”ҢвҢҗ',\n  'в”ҳГ§в”ҳГјв•ӘВ¬ в•ӘВ¬в–ҲГ®в•Әв–’',\n  'в•ӘВ»в•Әв–’в”ҳГӘв•ӘВәв•Әв–“в”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГӨв•ӘВ¬',\n  'в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ®',\n  'в•Әв”Өв”ҳГ§в•Әв–’ в•Әв–’в–ҲГ®',\n  'в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ',\n  'в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ'\n]\n\nexport default function ChecklistsPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const user = useAuthStore((s) => s.user)\n  \n  const [templates, setTemplates] = useState<Template[]>([])\n  const [history, setHistory] = useState<ChecklistRecord[]>([])\n  const [loading, setLoading] = useState(true)\n  const [activeTemplate, setActiveTemplate] = useState<Template | null>(null)\n  \n  // Checklist filling states\n  const [checkedItems, setCheckedItems] = useState<Record<number, boolean>>({})\n  const [itemNotes, setItemNotes] = useState<Record<number, string>>({})\n  const [trainId, setTrainId] = useState('')\n  const [stationId, setStationId] = useState('в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ')\n  const [submitting, setSubmitting] = useState(false)\n  \n  const [activeTab, setActiveTab] = useState<'fill' | 'history' | 'admin'>('fill')\n  const [isAdminSimulated, setIsAdminSimulated] = useState(true)\n\n  // Template creation states (Admin)\n  const [newTemplateName, setNewTemplateName] = useState('')\n  const [newTemplateDescription, setNewTemplateDescription] = useState('')\n  const [newTemplateItems, setNewTemplateItems] = useState<ChecklistItem[]>([\n    { label: 'в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘ в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•ӘВәв•Әв–’в”ҢвҢҗв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГ©в•Әв•–в•ӘВәв•Әв–’', required: true },\n    { label: 'в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГјв•Әв”Өв•ӘВәв•Әв–’ в”ҳГ в•ӘВ«в•ӘВәв•Әв–“в”ҳГҘ в•ӘВҝв•ӘВәв•ӘВ» в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ® (в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в–Ҳв•–.в–Ҳв•Ў в•ӘВҝв•ӘВәв•Әв–’)', required: true },\n    { label: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ® в”ҳГӘ в•ӘВ«в•Әв•– в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв–ҲГ® в•Әв”Ӯв–ҲГ®в”ҳГ  в•ӘВҝв•ӘВә OCC', required: true },\n    { label: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҢвҢҗв•ӘВәв•Әв–’в”ҢвҢҗв•Әв–’в•ӘВ» в•Әв•Ўв•ӘВЎв–ҲГ®в•ӘВЎ в”ҢГҘв•Әв–’в•ӘВәв•Әв•‘О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨ в”ҢвҢҗв•ӘВәв•ӘВҝв–ҲГ®в”ҳГҘ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®', required: true },\n    { label: 'в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•ӘВҝв•ӘВәв•Әв–“ в”ҳГӘ в•ӘВҝв•Әв”Ӯв•ӘВ¬в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГҘ в•ӘВ»в•Әв–’в•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВәв•Әв–“ в”ҳГ§в•Әв–’ в•ӘВ»в”ҳГӘ в•Әв”Ӯв”ҳГ в•ӘВ¬', required: true },\n    { label: 'в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ¬в”ҳГ§в”ҳГӘв–ҲГ®в”ҳГ§ в”ҳГ в•Әв•–в•ӘВҝв”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв•ӘВҝв–ҲГ®в”ҳГҘ в”ҳГӘ в•Әв”Ӯв•ӘВәв”ҳГӨв”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВәв”ҳГјв•Әв–’в•ӘВәв”ҳГҘ', required: false },\n    { label: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҳГјв–ҲГ®в•Әв–“в–ҲГ®в”ҢвҢҗв–ҲГ® в”ҢвҢҗв”ҳв•ӣв•Әв”Ӯв”ҳГӘв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•–в”ҳГјв•ӘВәв–ҲГ® в•ӘВЎв•Әв–’в–ҲГ®в”ҳГ© в”ҢвҢҗв•ӘВәв•ӘВҝв–ҲГ®в”ҳГҘ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’', required: false }\n  ])\n  const [newItemLabel, setNewItemLabel] = useState('')\n  const [newItemRequired, setNewItemRequired] = useState(true)\n  const [creatingTemplate, setCreatingTemplate] = useState(false)\n\n  async function loadData() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const [templatesRes, historyRes] = await Promise.all([\n        fetch('/api/checklists', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        }),\n        fetch('/api/checklists?view=history', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        }),\n      ])\n\n      if (templatesRes.ok) {\n        const data = await templatesRes.json()\n        setTemplates(data.data ?? [])\n      }\n      if (historyRes.ok) {\n        const data = await historyRes.json()\n        setHistory(data.data ?? [])\n      }\n    } catch {\n      // checklist data load failed silently\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    void loadData()\n  }, [accessToken])\n\n  // Submit filled checklist (Operator)\n  async function handleSubmitChecklist() {\n    if (!accessToken || !activeTemplate) return\n    setSubmitting(true)\n    try {\n      const items = activeTemplate.items.map((item, i) => ({\n        label: item.label,\n        checked: checkedItems[i] ?? false,\n        note: itemNotes[i] || '',\n      }))\n\n      const res = await fetch('/api/checklists', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          templateId: activeTemplate.id,\n          trainId: trainId.trim() ? trainId : null,\n          stationId: stationId,\n          items,\n        }),\n      })\n\n      if (res.ok) {\n        setActiveTemplate(null)\n        setCheckedItems({})\n        setItemNotes({})\n        setTrainId('')\n        setActiveTab('history')\n        loadData()\n      }\n    } catch {\n      // submit checklist failed silently\n    } finally {\n      setSubmitting(false)\n    }\n  }\n\n  // Create new checklist template (Admin)\n  async function handleCreateTemplate() {\n    if (!accessToken || !newTemplateName.trim()) return\n    if (newTemplateItems.length === 0) return\n    setCreatingTemplate(true)\n    try {\n      const res = await fetch('/api/checklists', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          action: 'create_template',\n          name: newTemplateName,\n          description: newTemplateDescription,\n          items: newTemplateItems,\n        }),\n      })\n\n      if (res.ok) {\n        setNewTemplateName('')\n        setNewTemplateDescription('')\n        setNewTemplateItems([\n          { label: 'в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘ в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•ӘВәв•Әв–’в”ҢвҢҗв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГ©в•Әв•–в•ӘВәв•Әв–’', required: true },\n          { label: 'в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГјв•Әв”Өв•ӘВәв•Әв–’ в”ҳГ в•ӘВ«в•ӘВәв•Әв–“в”ҳГҘ в•ӘВҝв•ӘВәв•ӘВ» в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ® (в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в–Ҳв•–.в–Ҳв•Ў в•ӘВҝв•ӘВәв•Әв–’)', required: true },\n          { label: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ® в”ҳГӘ в•ӘВ«в•Әв•– в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв–ҲГ® в•Әв”Ӯв–ҲГ®в”ҳГ  в•ӘВҝв•ӘВә OCC', required: true }\n        ])\n        setActiveTab('fill')\n        loadData()\n      }\n    } catch {\n      // create template failed silently\n    } finally {\n      setCreatingTemplate(false)\n    }\n  }\n\n  function handleAddNewItem() {\n    if (!newItemLabel.trim()) return\n    setNewTemplateItems([\n      ...newTemplateItems,\n      { label: newItemLabel, required: newItemRequired }\n    ])\n    setNewItemLabel('')\n    setNewItemRequired(true)\n  }\n\n  function handleRemoveItem(idx: number) {\n    setNewTemplateItems(newTemplateItems.filter((_, i) => i !== idx))\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 md:p-6 text-foreground antialiased selection:bg-accent selection:text-accent-foreground\">\n      {/* Header and Simulator */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-border-subtle pb-4 gap-4\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg-mobile md:text-headline-lg flex items-center gap-2\">\n            <ClipboardCheck className=\"size-8 text-accent\" />\n            в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ (Pre-Departure)\n          </h1>\n          <p className=\"text-sm text-foreground-muted mt-1\">\n            в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в–ҲГ®в”ҢвҢҗв”ҳв•ӣв•ӘВәв•Әв–’в”ҢГҘв”ҳГ§ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВҝв•ӘВәв•Әв–“в•Әв–’в•Әв”Ӯв–ҲГ® в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”Ө в•ӘВәв•Әв–“ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ»в•Әв–’ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ\n          </p>\n        </div>\n\n        {/* Admin Simulation Toggle */}\n        <div className=\"flex items-center gap-2 bg-surface-container-low border border-border-subtle p-2 rounded-lg\">\n          <Shield className={cn(\"size-5\", isAdminSimulated ? \"text-accent animate-pulse\" : \"text-foreground-muted\")} />\n          <span className=\"text-xs font-semibold\">в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в”ҳГҘв”ҳГ©в•Әв”Ө в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬:</span>\n          <Button\n            size=\"sm\"\n            variant={isAdminSimulated ? \"default\" : \"outline\"}\n            onClick={() => {\n              const target = !isAdminSimulated\n              setIsAdminSimulated(target)\n              if (!target && activeTab === 'admin') {\n                setActiveTab('fill')\n              }\n            }}\n            className=\"h-8 text-xs\"\n          >\n            {isAdminSimulated ? \"в•ӘВәв•ӘВ»в”ҳГ в–ҲГ®в”ҳГҘ / в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  (в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ)\" : \"в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•Әв•Јв•ӘВәв•ӘВ»в–ҲГ® / в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’\"}\n          </Button>\n        </div>\n      </div>\n\n      {/* Tabs selectors */}\n      <div className=\"flex border-b border-border-subtle\">\n        <button\n          onClick={() => setActiveTab('fill')}\n          className={cn(\n            \"px-4 py-2 text-sm font-medium border-b-2 transition-all flex items-center gap-2\",\n            activeTab === 'fill'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <ClipboardCheck className=\"size-4\" />\n          в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬\n        </button>\n        <button\n          onClick={() => setActiveTab('history')}\n          className={cn(\n            \"px-4 py-2 text-sm font-medium border-b-2 transition-all flex items-center gap-2\",\n            activeTab === 'history'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <History className=\"size-4\" />\n          в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в”ҳГӘ в•ӘГів•Әв–’в•Әв”Өв–ҲГ®в”ҳГӘ в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Өв•ӘВәв•ӘВ¬\n        </button>\n        {isAdminSimulated && (\n          <button\n            onClick={() => setActiveTab('admin')}\n            className={cn(\n              \"px-4 py-2 text-sm font-medium border-b-2 transition-all flex items-center gap-2\",\n              activeTab === 'admin'\n                ? \"border-accent text-accent\"\n                : \"border-transparent text-foreground-muted hover:text-foreground\"\n            )}\n          >\n            <Lock className=\"size-4\" />\n            в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в”ҳГӘ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВ¬в•Әв”Ӯв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВә (в•ӘВәв•ӘВ»в”ҳГ в–ҲГ®в”ҳГҘ)\n          </button>\n        )}\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* TAB 1: FILL CHECKLIST */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {activeTab === 'fill' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\n          {/* Main Workspace Area (lg: col-span-8) */}\n          <div className=\"lg:col-span-8 space-y-4\">\n            {loading ? (\n              <div className=\"space-y-3\">\n                {Array.from({ length: 2 }).map((_, i) => (\n                  <div key={i} className=\"h-28 animate-pulse rounded-lg border border-border bg-neutral-900/30\" />\n                ))}\n              </div>\n            ) : activeTemplate ? (\n              <Card className=\"border-accent/20 bg-surface-container-low/60 backdrop-blur\">\n                <CardHeader className=\"border-b border-border-subtle/30 bg-accent/5 pb-3\">\n                  <div className=\"flex items-center justify-between\">\n                    <div>\n                      <CardTitle className=\"text-base font-bold flex items-center gap-2\">\n                        <ClipboardCheck className=\"size-5 text-accent\" />\n                        {activeTemplate.name}\n                      </CardTitle>\n                      {activeTemplate.description && (\n                        <CardDescription className=\"text-xs mt-1\">\n                          {activeTemplate.description}\n                        </CardDescription>\n                      )}\n                    </div>\n                    <Button\n                      variant=\"ghost\"\n                      size=\"sm\"\n                      onClick={() => {\n                        setActiveTemplate(null)\n                        setCheckedItems({})\n                        setItemNotes({})\n                        setTrainId('')\n                      }}\n                      className=\"text-foreground-muted hover:text-foreground text-xs\"\n                    >\n                      в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј в”ҳГӘ в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв”Өв•ӘВ¬\n                    </Button>\n                  </div>\n                </CardHeader>\n                <CardContent className=\"space-y-6 pt-4\">\n                  {/* Train and Station Metadata Row */}\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 bg-neutral-950/40 p-4 rounded-lg border border-border-subtle\">\n                    <div className=\"space-y-1.5\">\n                      <Label className=\"text-xs font-semibold flex items-center gap-1.5\">\n                        <Train className=\"size-4 text-accent\" />\n                        в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•Әв–’в•ӘВәв”ҳГ  в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ / в”ҳГӘв•ӘВәв”ҢВ»в”ҳГҘ:\n                      </Label>\n                      <Input\n                        placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в–Ҳв–’в–Ҳв–‘в–Ҳв”Ө\"\n                        value={trainId}\n                        onChange={(e) => setTrainId(e.target.value)}\n                        className=\"h-9 text-xs bg-neutral-950/20\"\n                      />\n                    </div>\n                    <div className=\"space-y-1.5\">\n                      <Label className=\"text-xs font-semibold flex items-center gap-1.5\">\n                        <MapPin className=\"size-4 text-accent\" />\n                        в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в”ҳГ в•ӘВҝв•ӘВ»в•ӘВә в•Әв”Ӯв–ҲГ®в•Әв–’:\n                      </Label>\n                      <Select value={stationId} onValueChange={(val) => setStationId(val ?? '')}>\n                        <SelectTrigger className=\"h-9 text-xs bg-neutral-950/20\">\n                          <SelectValue />\n                        </SelectTrigger>\n                        <SelectContent>\n                          {LINE1_STATIONS.map((st) => (\n                            <SelectItem key={st} value={st} className=\"text-xs\">\n                              в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ {st}\n                            </SelectItem>\n                          ))}\n                        </SelectContent>\n                      </Select>\n                    </div>\n                  </div>\n\n                  {/* Checklist Items list */}\n                  <div className=\"space-y-3\">\n                    <Label className=\"text-xs font-bold text-foreground\">в•ӘВ¬в•Әв”Ӯв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’:</Label>\n                    \n                    {activeTemplate.items.map((item, i) => {\n                      const isChecked = checkedItems[i] ?? false\n                      return (\n                        <div\n                          key={i}\n                          className={cn(\n                            \"flex flex-col sm:flex-row sm:items-center justify-between p-3 rounded-lg border gap-3 transition-all\",\n                            isChecked \n                              ? \"bg-success/5 border-success/30\" \n                              : item.required \n                              ? \"bg-critical/5 border-critical/20\"\n                              : \"bg-neutral-950/20 border-border-subtle\"\n                          )}\n                        >\n                          {/* Checkbox and Label */}\n                          <label className=\"flex items-center gap-3 cursor-pointer flex-1 select-none\">\n                            <input\n                              type=\"checkbox\"\n                              checked={isChecked}\n                              onChange={(e) =>\n                                setCheckedItems({ ...checkedItems, [i]: e.target.checked })\n                              }\n                              className=\"size-4.5 accent-accent shrink-0 rounded border-border-subtle bg-neutral-950\"\n                            />\n                            <div className=\"space-y-0.5\">\n                              <span className={cn(\"text-xs font-medium\", isChecked && \"line-through text-foreground-muted\")}>\n                                {item.label}\n                              </span>\n                              <div className=\"flex gap-2\">\n                                <Badge className={cn(\n                                  \"text-[9px] px-1 py-0.5\",\n                                  item.required \n                                    ? \"bg-critical/15 text-critical border-critical/20\" \n                                    : \"bg-neutral-800 text-neutral-400 border-neutral-700\"\n                                )}>\n                                  {item.required ? 'в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ®' : 'в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®'}\n                                </Badge>\n                              </div>\n                            </div>\n                          </label>\n\n                          {/* Technical Defect Note Input */}\n                          <div className=\"w-full sm:w-60 flex items-center gap-1.5 bg-neutral-950/30 border border-border-subtle/50 px-2 rounded-md h-8.5\">\n                            <Wrench className=\"size-3.5 text-foreground-muted shrink-0\" />\n                            <input\n                              placeholder=\"в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҳГҘв”ҳГ©в•Әв•Ў в”ҳГјв”ҳГҘв–ҲГ® / в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎ...\"\n                              value={itemNotes[i] || ''}\n                              onChange={(e) => setItemNotes({ ...itemNotes, [i]: e.target.value })}\n                              className=\"bg-transparent border-0 outline-none text-[11px] text-foreground flex-1 h-full w-full\"\n                            />\n                          </div>\n                        </div>\n                      )\n                    })}\n                  </div>\n                </CardContent>\n                <CardFooter className=\"border-t border-border-subtle/20 pt-4 flex flex-col sm:flex-row items-center justify-between gap-3 bg-neutral-950/20 rounded-b-lg\">\n                  <div className=\"flex items-center gap-1.5 text-[11px] text-foreground-muted\">\n                    <Info className=\"size-4 text-accent shrink-0\" />\n                    <span>в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в”ҳГ в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» <span className=\"text-critical font-bold\">в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ®</span> в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГҘ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ» в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬.</span>\n                  </div>\n                  \n                  <Button\n                    onClick={handleSubmitChecklist}\n                    disabled={\n                      submitting ||\n                      activeTemplate.items\n                        .filter((item) => item.required)\n                        .some((_, i) => !checkedItems[\n                          activeTemplate.items.findIndex(\n                            (origItem, origIdx) => origItem.label === activeTemplate.items.filter(item => item.required)[i].label\n                          )\n                        ])\n                    }\n                    className=\"w-full sm:w-auto h-9 text-xs\"\n                  >\n                    <CheckCircle className=\"size-4 me-1.5\" />\n                    в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬\n                  </Button>\n                </CardFooter>\n              </Card>\n            ) : templates.length === 0 ? (\n              <Card className=\"border-dashed border-border-subtle bg-neutral-950/10\">\n                <CardContent className=\"flex flex-col items-center justify-center py-16\">\n                  <ClipboardCheck className=\"mb-3 size-12 text-foreground-muted\" />\n                  <p className=\"text-sm font-semibold text-foreground-muted\">\n                    в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                  </p>\n                  {isAdminSimulated && (\n                    <Button variant=\"outline\" size=\"sm\" onClick={() => setActiveTab('admin')} className=\"mt-3\">\n                      в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬ в•ӘВәв”ҳГӘв”ҳГӨв–ҲГ®в”ҳГҘ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ\n                    </Button>\n                  )}\n                </CardContent>\n              </Card>\n            ) : (\n              <div className=\"space-y-3\">\n                {templates.map((t) => (\n                  <Card\n                    key={t.id}\n                    className=\"cursor-pointer transition-all hover:bg-neutral-900/40 border border-border-subtle hover:border-accent/30 bg-surface-container-low/50\"\n                    onClick={() => setActiveTemplate(t)}\n                  >\n                    <CardContent className=\"flex items-center justify-between p-4.5\">\n                      <div className=\"space-y-1\">\n                        <div className=\"text-sm font-bold text-foreground flex items-center gap-2\">\n                          <ClipboardCheck className=\"size-4.5 text-accent\" />\n                          {t.name}\n                        </div>\n                        {t.description && (\n                          <div className=\"text-xs text-foreground-muted\">\n                            {t.description}\n                          </div>\n                        )}\n                        <div className=\"text-[10px] text-foreground-muted flex gap-2 pt-1\">\n                          <Badge variant=\"outline\" className=\"text-[9px] bg-neutral-950/20\">\n                            {toFa(t.items.length)} в•ӘГів–ҲГ®в•ӘВ¬в”ҳГ  в•ӘВҝв•ӘВәв•Әв–“в•Әв–’в•Әв”Ӯв–ҲГ®\n                          </Badge>\n                          <Badge variant=\"outline\" className=\"text-[9px] bg-critical/5 text-critical border-critical/10\">\n                            {toFa(t.items.filter(i => i.required).length)} в•ӘГів–ҲГ®в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ®\n                          </Badge>\n                        </div>\n                      </div>\n                      <ChevronRight className=\"size-5 text-foreground-muted shrink-0\" />\n                    </CardContent>\n                  </Card>\n                ))}\n              </div>\n            )}\n          </div>\n\n          {/* Info Panel (lg: col-span-4) */}\n          <div className=\"lg:col-span-4 space-y-4\">\n            <Card className=\"border border-border-subtle bg-surface-container-low/30\">\n              <CardHeader className=\"pb-2\">\n                <CardTitle className=\"text-xs font-bold text-foreground flex items-center gap-1.5\">\n                  <Info className=\"size-4 text-accent\" />\n                  в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳв•ӣв–ҲГ®в•Әв”Ө в•ӘВәв•Әв–“ в•Әв”Ӯв–ҲГ®в•Әв–’\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"text-xs text-foreground-muted space-y-2 leading-6 text-right\">\n                <p>\n                  в”ҳГ в•Әв•–в•ӘВәв•ӘВҝв”ҳГ© в•ӘВҝв”ҳГҘв•ӘВ» в–Ҳв”Ө-в–Ҳв–’в–Ҳв–“ в•ӘГів–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘв•ӘГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ в”ҳГӘв•Әв••в”ҳГјв”ҳГҘв•ӘВ» в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј в•ӘВәв•Әв–“ в•ӘВ«в•Әв•– в•ӘВ»в”ҳв•ӣв”ҳГӘ в–ҲГ®в•ӘВә в•ӘВ¬в•Әв•Јв”ҳГӘв–ҲГ®в•Әв•ў в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в•ӘВҝв•ӘВәв•ӘВ»в”ҳГӨв–ҲГ® (в”ҳГ§в”ҳГ в”ҢГҘв”ҳГӘв”ҳГҘ в•ӘВ»в•Әв–’в”ҳГӘв•ӘВәв•Әв–“в”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГӨв•ӘВ¬ в”ҳГӘ в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ®)в•ӘГ® в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в”ҳГ в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГ в”ҳГҘв•ӘВ»в•Әв–’в•ӘВј в•ӘВ»в•Әв–’ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•Әв–’в•ӘВә в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в”ҳГҘв•ӘВ».\n                </p>\n                <p className=\"border-t border-border-subtle/50 pt-2 font-semibold text-critical\">\n                  в”ҳГҘв”ҢвҢҗв•ӘВәв•ӘВ¬ в•ӘВЎв–ҲГ®в•ӘВәв•ӘВ¬в–ҲГ®:\n                </p>\n                <ul className=\"list-disc pr-4 space-y-1 text-[11px]\">\n                  <li>в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВҪв”ҳГҘв•ӘВә в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬.</li>\n                  <li>в”ҳГјв•Әв”Өв•ӘВәв•Әв–’ в”ҳГ в•ӘВ«в•ӘВәв•Әв–“в”ҳГҘ в•ӘВҝв•ӘВәв•ӘВ» в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ® в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в•Әв–’в”ҳГӘв–ҲГ® в–Ҳв•–.в–Ҳв•Ў в•ӘВҝв•ӘВәв•Әв–’ в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ».</li>\n                  <li>в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“ в”ҳГ§в•Әв–’в”ҢВ»в”ҳГӘв”ҳГҘв”ҳГ§ в”ҳГҘв”ҳГ©в•Әв•Ў в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв”ҳГӨв”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ®в•ӘГ® в”ҳГ в•Әв–’в•ӘВәв•ӘВ¬в•ӘВҝ в•Әв–’в•ӘВә в”ҳГјв”ҳГӘв•Әв–’в•ӘВәв”ҳГҜ в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВәв•ӘВ»в•Әв–’ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘ в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ» в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘВ»в•Әв–’ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳГҘв”ҳГ©в•Әв•Ў в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».</li>\n                </ul>\n              </CardContent>\n            </Card>\n          </div>\n        </div>\n      )}\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* TAB 2: HISTORY ARCHIVE */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {activeTab === 'history' && (\n        <div className=\"space-y-4\">\n          {loading ? (\n            <div className=\"space-y-3\">\n              {Array.from({ length: 3 }).map((_, i) => (\n                <div key={i} className=\"h-20 animate-pulse rounded-lg border border-border bg-neutral-900/30\" />\n              ))}\n            </div>\n          ) : history.length === 0 ? (\n            <Card className=\"border-dashed border-border-subtle bg-neutral-950/10\">\n              <CardContent className=\"flex flex-col items-center justify-center py-16\">\n                <History className=\"mb-3 size-12 text-foreground-muted\" />\n                <p className=\"text-sm font-semibold text-foreground-muted\">\n                  в”ҳГ§в–ҲГ®в”ҢГҘ в•Әв”Ӯв•ӘВәв•ӘВҝв”ҳГ©в”ҳГ§ в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Өв–ҲГ® в•ӘВ¬в•ӘВә в”ҢвҢҗв”ҳГҘв”ҳГӘв”ҳГҘ в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                </p>\n              </CardContent>\n            </Card>\n          ) : (\n            <div className=\"space-y-4\">\n              {history.map((record) => {\n                const totalItems = record.items.length\n                const checkedCount = record.items.filter(i => i.checked).length\n                const defectCount = record.items.filter(i => i.note && i.note.trim()).length\n\n                return (\n                  <Card key={record.id} className=\"border border-border-subtle bg-surface-container-low/50\">\n                    <CardContent className=\"p-4.5 space-y-3\">\n                      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-border-subtle/30 pb-2\">\n                        <div className=\"space-y-0.5 text-right\">\n                          <div className=\"text-sm font-bold text-foreground\">\n                            {record.template?.name ?? 'в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}\n                          </div>\n                          <div className=\"text-[11px] text-foreground-muted flex flex-wrap gap-x-3 gap-y-1\">\n                            <span>в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’: {record.user?.name ?? 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}</span>\n                            <span>О“ГҮГі</span>\n                            <span>в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в•ӘВҪв•ӘВҝв•ӘВ¬: {toFa(jalali(record.signedAt))}</span>\n                            {record.trainId && (\n                              <>\n                                <span>О“ГҮГі</span>\n                                <span className=\"font-semibold text-accent\">в•Әв–’в•ӘВәв”ҳГ  в”ҳГ©в•Әв•–в•ӘВәв•Әв–’: {toFa(record.trainId)}</span>\n                              </>\n                            )}\n                            {record.stationId && (\n                              <>\n                                <span>О“ГҮГі</span>\n                                <span>в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј: {record.stationId}</span>\n                              </>\n                            )}\n                          </div>\n                        </div>\n                        <div className=\"flex items-center gap-2 shrink-0\">\n                          {defectCount > 0 && (\n                            <Badge className=\"bg-warning/15 text-warning border-warning/20\">\n                              {toFa(defectCount)} в”ҳГҘв”ҳГ©в•Әв•Ў в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§\n                            </Badge>\n                          )}\n                          <Badge className=\"bg-success/15 text-success border-success/20\">\n                            в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§ ({toFa(checkedCount)} в•ӘВәв•Әв–“ {toFa(totalItems)})\n                          </Badge>\n                        </div>\n                      </div>\n\n                      {/* Items grid details */}\n                      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-2 text-xs\">\n                        {record.items.map((item, i) => (\n                          <div\n                            key={i}\n                            className={cn(\n                              \"p-2.5 rounded-md border flex flex-col gap-1.5 justify-center\",\n                              item.checked \n                                ? \"bg-success/5 border-success/10\" \n                                : \"bg-critical/5 border-critical/10\"\n                            )}\n                          >\n                            <div className=\"flex items-center justify-between gap-2\">\n                              <span className=\"font-medium text-[11px]\">\n                                {item.label}\n                              </span>\n                              <span className={cn(\n                                \"size-4.5 rounded-full flex items-center justify-center text-[10px] shrink-0 font-bold\",\n                                item.checked ? \"bg-success/20 text-success\" : \"bg-critical/20 text-critical\"\n                              )}>\n                                {item.checked ? <Check className=\"size-3\" /> : <X className=\"size-3\" />}\n                              </span>\n                            </div>\n                            {item.note && item.note.trim() ? (\n                              <div className=\"bg-warning/10 border border-warning/20 p-1.5 rounded text-[10px] text-warning flex items-start gap-1\">\n                                <Wrench className=\"size-3 mt-0.5 shrink-0\" />\n                                <span>в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҳГҘв”ҳГ©в•Әв•Ў: {item.note}</span>\n                              </div>\n                            ) : null}\n                          </div>\n                        ))}\n                      </div>\n                    </CardContent>\n                  </Card>\n                )\n              })}\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* TAB 3: ADMIN TEMPLATE BUILDER */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {activeTab === 'admin' && isAdminSimulated && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\n          {/* Editor Form (lg: col-span-7) */}\n          <div className=\"lg:col-span-7\">\n            <Card className=\"border border-border-subtle bg-surface-container-low/60 backdrop-blur\">\n              <CardHeader>\n                <CardTitle className=\"text-base font-bold flex items-center gap-2\">\n                  <Lock className=\"size-5 text-accent\" />\n                  в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬\n                </CardTitle>\n                <CardDescription className=\"text-xs\">\n                  в–ҲГ®в”ҢвҢҗ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в•ӘВҝв•ӘВәв•Әв–“в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВЎв•ӘВәв”ҳГӘв–ҲГ® в•ӘВ¬в•Әв”Ӯв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в–ҲГ®в•ӘВә в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                </CardDescription>\n              </CardHeader>\n              <CardContent className=\"space-y-4\">\n                {/* Meta details */}\n                <div className=\"space-y-2 text-right\">\n                  <Label className=\"text-xs font-semibold\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬:</Label>\n                  <Input\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв•Јв”ҳГӨв–ҲГ®в”ҳГ© в”ҳГӘ в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв”ҳГ \"\n                    value={newTemplateName}\n                    onChange={(e) => setNewTemplateName(e.target.value)}\n                    className=\"h-10 text-sm bg-neutral-950/20\"\n                  />\n                </div>\n                <div className=\"space-y-2 text-right\">\n                  <Label className=\"text-xs font-semibold\">в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®):</Label>\n                  <Textarea\n                    placeholder=\"в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в”ҢвҢҗв”ҳГӨв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬...\"\n                    value={newTemplateDescription}\n                    onChange={(e) => setNewTemplateDescription(e.target.value)}\n                    className=\"min-h-16 text-xs bg-neutral-950/20\"\n                  />\n                </div>\n\n                {/* Subtask list */}\n                <div className=\"space-y-3 border-t border-border-subtle/50 pt-4\">\n                  <Label className=\"text-xs font-bold text-accent block\">в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв”Ӯв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ:</Label>\n                  \n                  {newTemplateItems.length === 0 ? (\n                    <p className=\"text-xs text-foreground-muted text-center py-4 bg-neutral-950/10 rounded border border-dashed border-border-subtle\">\n                      в•ӘВ¬в•Әв”Ӯв”ҢвҢҗв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘВәв•Әв–“ в”ҳГјв•Әв–’в”ҳГ  в•Әв–“в–ҲГ®в•Әв–’ в•ӘВәв•Әв•ўв•ӘВәв”ҳГјв”ҳГ§ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </p>\n                  ) : (\n                    <div className=\"space-y-2 max-h-56 overflow-y-auto pr-1\">\n                      {newTemplateItems.map((item, idx) => (\n                        <div key={idx} className=\"flex items-center justify-between p-2.5 bg-neutral-950/30 border border-border-subtle rounded-md text-xs\">\n                          <div className=\"flex items-center gap-2\">\n                            <span className=\"font-bold text-foreground-muted text-[10px]\">{toFa(idx + 1)}.</span>\n                            <span className=\"font-medium text-foreground\">{item.label}</span>\n                            <Badge className={cn(\n                              \"text-[8px] px-1 py-0\",\n                              item.required \n                                ? \"bg-critical/15 text-critical border-critical/20\" \n                                : \"bg-neutral-800 text-neutral-400 border-neutral-700\"\n                            )}>\n                              {item.required ? 'в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ®' : 'в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®'}\n                            </Badge>\n                          </div>\n                          <Button\n                            variant=\"ghost\"\n                            size=\"icon-xs\"\n                            onClick={() => handleRemoveItem(idx)}\n                            className=\"text-foreground-muted hover:text-critical size-7\"\n                          >\n                            <Trash className=\"size-3.5\" />\n                          </Button>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n                </div>\n\n                {/* Item creator input */}\n                <div className=\"bg-neutral-950/40 p-3 rounded-lg border border-border-subtle space-y-3\">\n                  <span className=\"text-xs font-bold text-foreground block\">в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в•ӘВ¬в•Әв”Ӯв”ҢвҢҗ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ:</span>\n                  <Input\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВҝв”ҳГӘв”ҳГ© в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® (в•Әв”Ӯв”ҳГӘв•ӘВ¬ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’)\"\n                    value={newItemLabel}\n                    onChange={(e) => setNewItemLabel(e.target.value)}\n                    className=\"h-8.5 text-xs bg-neutral-950/20\"\n                  />\n                  <div className=\"flex items-center justify-between\">\n                    <label className=\"flex items-center gap-2 cursor-pointer select-none\">\n                      <input\n                        type=\"checkbox\"\n                        checked={newItemRequired}\n                        onChange={(e) => setNewItemRequired(e.target.checked)}\n                        className=\"size-4\"\n                      />\n                      <span className=\"text-xs text-foreground-muted font-medium\">в”ҳГ в”ҳГӘв•Әв–’в•ӘВ» в•ӘВҝв•ӘВәв•Әв–“в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® (Required) в•ӘВәв•Әв”Ӯв•ӘВ¬</span>\n                    </label>\n                    <Button type=\"button\" size=\"sm\" onClick={handleAddNewItem} className=\"h-8 text-xs\">\n                      <Plus className=\"size-3.5 me-1\" />\n                      в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в•ӘВҝв”ҳГ§ в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬\n                    </Button>\n                  </div>\n                </div>\n              </CardContent>\n              <CardFooter className=\"border-t border-border-subtle/20 pt-4 flex justify-end\">\n                <Button\n                  onClick={handleCreateTemplate}\n                  disabled={creatingTemplate || !newTemplateName.trim() || newTemplateItems.length === 0}\n                  className=\"w-full sm:w-auto h-9 text-xs\"\n                >\n                  в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬\n                </Button>\n              </CardFooter>\n            </Card>\n          </div>\n\n          {/* Quick templates info (lg: col-span-5) */}\n          <div className=\"lg:col-span-5 space-y-4\">\n            <Card className=\"border border-border-subtle bg-surface-container-low/30\">\n              <CardHeader className=\"pb-2\">\n                <CardTitle className=\"text-xs font-bold text-foreground flex items-center gap-1.5\">\n                  <Shield className=\"size-4 text-accent\" />\n                  в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГҘв•Әв••в•ӘВәв•Әв–’в•ӘВ¬ в”ҳГӘ в”ҳГ в”ҳГ в–ҲГ®в•Әв–“в–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"text-xs text-foreground-muted space-y-2 leading-6 text-right\">\n                <p>\n                  в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в”ҳГјв”ҳГӘв•Әв–’в•ӘВәв”ҳГҜ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ в”ҳГ©в•ӘВәв•ӘВҝв”ҳГӨ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГӘ в•ӘВәв•ӘВјв•Әв–’в•ӘВә в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•ӘВҝв”ҳГӘв•ӘВ».\n                </p>\n                <p>\n                  в”ҳГ§в•Әв–’ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬в–ҲГ® в•Әв–’в•ӘВә в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҢвҢҗв”ҳГҘв•ӘВ»в•ӘГ® в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ в•Әв–’в•ӘВәв”ҳГ  в”ҳГ©в•Әв•–в•ӘВәв•Әв–’в•ӘГ® в”ҳГҘв”ҳГ©в•ӘВәв–ҲГ®в•Әв•Ў в•ӘВәв•ӘВЎв•ӘВ¬в”ҳГ в•ӘВәв”ҳГӨв–ҲГ® в”ҳГӘ в•ӘГів–ҲГ®О“ГҮГ®в•ӘВ»в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВ»в•Әв–’ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’ в”ҳГӨв•ӘВәв”ҢВ» в”ҳГ в”ҳГ в–ҲГ®в•Әв–“в–ҲГ® (`AuditLog`) в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГҘв•ӘВәв•Әв••в•Әв–’в–ҲГ®в”ҳГҘ OCC в”ҳГ©в•ӘВәв•ӘВҝв”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                </p>\n              </CardContent>\n            </Card>\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\comms\\conference\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'User' is defined but never used.","line":22,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":22,"endColumn":7,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"User"},"fix":{"range":[369,377],"text":""},"desc":"Remove unused variable \"User\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Info' is defined but never used.","line":23,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":23,"endColumn":7,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Info"},"fix":{"range":[377,385],"text":""},"desc":"Remove unused variable \"Info\"."}]},{"ruleId"