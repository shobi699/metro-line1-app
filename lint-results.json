to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":714,"column":17,"nodeType":"JSXOpeningElement","endLine":718,"endColumn":19,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState, useRef, useMemo } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { useShiftsStore } from '@/features/shifts'\nimport { getShiftForUserAndDate } from '@/lib/cycle-math'\nimport dayjs from 'dayjs'\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs'\nimport { toFa, jalali, faTime } from '@/lib/fa'\nimport { cn } from '@/lib/utils'\nimport { \n  User, \n  Shield, \n  Phone, \n  Mail, \n  Calendar, \n  KeyRound, \n  Pencil, \n  CheckCircle2, \n  AlertCircle, \n  Upload, \n  Loader2, \n  Contact, \n  Briefcase, \n  Award, \n  Clock, \n  Activity, \n  Check, \n  Camera, \n  MapPin, \n  Palette, \n  ClipboardList,\n  Car,\n  Trash2,\n  AlertTriangle,\n  GraduationCap,\n  Layers,\n  Map,\n  X\n} from 'lucide-react'\n\ninterface FullProfile {\n  id: string\n  nationalId: string\n  name: string\n  phone: string | null\n  email: string | null\n  status: string\n  role: {\n    name: string\n    key: string\n  }\n  customFields: Record<string, unknown> | null\n}\n\ninterface AuditLog {\n  id: string\n  actorId: string\n  entity: string\n  entityId: string\n  action: string\n  before: unknown\n  after: unknown\n  createdAt: string\n}\n\ninterface Vehicle {\n  id: string\n  plateNum1: string\n  plateLetter: string\n  plateNum2: string\n  plateCity: string\n  carPlate: string\n  carType: string\n  carColor: string\n  carLicenseExpiry: string\n  status: 'pending' | 'approved' | 'rejected'\n}\n\nconst ROLE_LABEL: Record<string, string> = {\n  super_admin: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в”ҢвҢҗв”ҳГӨ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n  admin: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬',\n  operator: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’',\n}\n\nconst AVAILABILITY_LABELS: Record<string, { label: string; color: string; desc: string }> = {\n  online: { label: 'в•ӘГів”ҳГ в•ӘВәв•ӘВ»в”ҳГ§ в•ӘВҝв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’', color: 'bg-green-500 text-green-500', desc: 'в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в–ҲГ®в•ӘВә в•ӘГів”ҳГ в•ӘВәв•ӘВ»в”ҳГ§ в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в”ҳГ в•ӘВәв”ҳГ в”ҳГӘв•Әв–’в–ҲГ®в•ӘВ¬' },\n  busy: { label: 'в”ҳГ в•Әв”Өв•Әв•‘в”ҳГӘв”ҳГӨ', color: 'bg-red-500 text-red-500', desc: 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВәв•ӘВјв•Әв–’в•ӘВәв–ҲГ® в”ҳГ в•ӘВәв”ҳГ в”ҳГӘв•Әв–’в–ҲГ®в•ӘВ¬ в–ҲГ®в•ӘВә в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®' },\n  on_shift: { label: 'в•ӘВ»в•Әв–’ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®', color: 'bg-blue-500 text-blue-500', desc: 'в”ҳГ в•Әв”Өв•Әв•‘в”ҳГӘв”ҳГӨ в•ӘВҝв”ҳГ§ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬ в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ® в•Әв•–в•ӘВҝв”ҳГ© в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв–’в”ҳГӘв•Әв–“в•ӘВәв”ҳГҘв”ҳГ§' },\n  offline: { label: 'в•ӘВ«в•ӘВәв•Әв–’в•ӘВј в•ӘВәв•Әв–“ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ / в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬', color: 'bg-neutral-500 text-neutral-400', desc: 'в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГӘ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј в•ӘВәв•Әв–“ в•ӘВ»в”ҳв•ӣв”ҳГӘ / в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§' },\n}\n\nconst DEFAULT_THEME_COLORS = [\n  { name: 'в”ҳГ©в•Әв–’в”ҳГ в•Әв–“ (в•ӘВҝв•Әв–’в”ҳГҘв•ӘВ» в•ӘВ«в•Әв•– в–Ҳв–’)', hex: '#e53935' },\n  { name: 'в•ӘГів•ӘВҝв–ҲГ® (в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“в–ҲГ®)', hex: '#007aff' },\n  { name: 'в•Әв”Ӯв•ӘВҝв•Әв–“ (в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®)', hex: '#34c759' },\n  { name: 'в”ҳГҘв•ӘВәв•Әв–’в”ҳГҘв•ӘВјв–ҲГ® (в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’)', hex: '#ff9500' },\n  { name: 'в•ӘВ«в•ӘВәв”ҢвҢҗв•Әв”Ӯв•ӘВ¬в•Әв–’в–ҲГ® (в•Әв”Ӯв•Әв–’в•ӘВ»)', hex: '#8e8e93' },\n  { name: 'в•ӘВҝв”ҳГҘв”ҳГјв•Әв”Ө (в”ҳГ в•ӘВ»в•Әв–’в”ҳГҘ)', hex: '#af52de' },\n]\n\nconst PLATE_LETTERS = ['в•ӘВәв”ҳГӨв”ҳГј', 'в•ӘВҝ', 'в•ӘВј', 'в•ӘВ»', 'в•Әв”Ӯ', 'в•Әв•Ў', 'в•Әв•–', 'в•Әв•Ј', 'в”ҳГ©', 'в”ҳГӨ', 'в”ҳГ ', 'в”ҳГҘ', 'в”ҳГӘ', 'в”ҳГ§', 'в–ҲГ®']\n\nexport default function ProfilePage() {\n  const user = useAuthStore((s) => s.user)\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const { assignments, templates } = useShiftsStore()\n  \n  const [profile, setProfile] = useState<FullProfile | null>(null)\n  const [auditLogs, setAuditLogs] = useState<AuditLog[]>([])\n  const [loading, setLoading] = useState(true)\n  const [logsLoading, setLogsLoading] = useState(false)\n  const [saving, setSaving] = useState(false)\n  const [savingVehicle, setSavingVehicle] = useState(false)\n  const [updatingField, setUpdatingField] = useState<string | null>(null)\n  const [error, setError] = useState('')\n  const [success, setSuccess] = useState('')\n\n  // Editable Contact states\n  const [phone, setPhone] = useState('')\n  const [email, setEmail] = useState('')\n  const [avatar, setAvatar] = useState('')\n  \n  // Custom states for sidebar direct picker sync\n  const [availability, setAvailability] = useState('online')\n  const [themeColor, setThemeColor] = useState('#e53935')\n\n  // Personal Fields editable state (User can edit ALL personnel data)\n  const [fatherName, setFatherName] = useState('')\n  const [idNumber, setIdNumber] = useState('')\n  const [birthDate, setBirthDate] = useState('')\n  const [age, setAge] = useState('')\n  const [birthPlace, setBirthPlace] = useState('')\n  const [maritalStatus, setMaritalStatus] = useState('')\n  const [insuranceNo, setInsuranceNo] = useState('')\n  const [education, setEducation] = useState('')\n  \n  // Organizational / Job Info Fields (Editable now)\n  const [post, setPost] = useState('')\n  const [shift, setShift] = useState('')\n  const [shiftType, setShiftType] = useState('')\n  const [startLocation, setStartLocation] = useState('')\n  const [hireDate, setHireDate] = useState('')\n  const [personnelNo, setPersonnelNo] = useState('')\n  const [group, setGroup] = useState('A')\n\n  // Qualifications & Percents (Editable now)\n  const [drivingStatus, setDrivingStatus] = useState('')\n  const [licenseClass1Date, setLicenseClass1Date] = useState('')\n  const [licenseClass2Date, setLicenseClass2Date] = useState('')\n  const [medicalExamValidity, setMedicalExamValidity] = useState('')\n  const [driverPercent, setDriverPercent] = useState('')\n  const [coDriverPercent, setCoDriverPercent] = useState('')\n  const [traineeDriverPercent, setTraineeDriverPercent] = useState('')\n  \n  // Additional contacts\n  const [address, setAddress] = useState('')\n  const [phone3, setPhone3] = useState('')\n  const [phone4, setPhone4] = useState('')\n\n  // Dynamic phone numbers list (User can register any number of phones)\n  const [additionalPhones, setAdditionalPhones] = useState<string[]>([])\n\n  // Dynamic vehicles list (User can register any number of vehicles)\n  const [vehicles, setVehicles] = useState<Vehicle[]>([])\n\n  // Vehicle permit form states (for adding a new vehicle)\n  const [plateNum1, setPlateNum1] = useState('')\n  const [plateLetter, setPlateLetter] = useState('в•ӘВҝ')\n  const [plateNum2, setPlateNum2] = useState('')\n  const [plateCity, setPlateCity] = useState('')\n  const [carType, setCarType] = useState('')\n  const [carColor, setCarColor] = useState('')\n  const [carLicenseExpiry, setCarLicenseExpiry] = useState('в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв•Ј')\n  const [isAddingVehicle, setIsAddingVehicle] = useState(false)\n\n  // Uploading state\n  const [uploading, setUploading] = useState(false)\n  const fileInputRef = useRef<HTMLInputElement>(null)\n\n  const todayShift = useMemo(() => {\n    if (!profile) return null\n    const userIdForShift = profile.id === user?.id ? 'current' : profile.id\n    const userGroup = (profile.customFields?.group as string) || undefined\n    return getShiftForUserAndDate(userIdForShift, dayjs(), assignments, templates, undefined, userGroup)\n  }, [profile, user, assignments, templates])\n\n  const getCustomField = (key: string): string => {\n    if (!profile?.customFields) return ''\n    return String(profile.customFields[key] || '')\n  }\n\n  const getFieldStatus = (key: string): 'pending' | 'approved' | 'rejected' => {\n    if (!profile?.customFields) return 'approved'\n    return (profile.customFields[`${key}_status`] as 'pending' | 'approved' | 'rejected') || 'approved'\n  }\n\n  async function loadProfile() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const res = await fetch('/api/profile', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        const prof = data.data as FullProfile\n        setProfile(prof)\n        setPhone(prof.phone || '')\n        setEmail(prof.email || '')\n        setAvailability((prof.customFields?.availability as string) || 'online')\n        setThemeColor((prof.customFields?.themeColor as string) || '#e53935')\n        setAvatar((prof.customFields?.avatar as string) || '')\n\n        // Personal identification fields\n        setFatherName((prof.customFields?.fatherName as string) || '')\n        setIdNumber((prof.customFields?.idNumber as string) || '')\n        setBirthDate((prof.customFields?.birthDate as string) || '')\n        setAge((prof.customFields?.age as string) || '')\n        setBirthPlace((prof.customFields?.birthPlace as string) || '')\n        setMaritalStatus((prof.customFields?.maritalStatus as string) || '')\n        setInsuranceNo((prof.customFields?.insuranceNo as string) || '')\n        setEducation((prof.customFields?.education as string) || '')\n\n        // Job & Org fields\n        setPersonnelNo((prof.customFields?.personnelNo as string) || '')\n        setGroup((prof.customFields?.group as string) || 'A')\n        setPost((prof.customFields?.post as string) || '')\n        setShift((prof.customFields?.shift as string) || '')\n        setShiftType((prof.customFields?.shiftType as string) || '')\n        setStartLocation((prof.customFields?.startLocation as string) || '')\n        setHireDate((prof.customFields?.hireDate as string) || '')\n\n        // Safety & Qualifications\n        setDrivingStatus((prof.customFields?.drivingStatus as string) || '')\n        setLicenseClass1Date((prof.customFields?.licenseClass1Date as string) || '')\n        setLicenseClass2Date((prof.customFields?.licenseClass2Date as string) || '')\n        setMedicalExamValidity((prof.customFields?.medicalExamValidity as string) || '')\n        setDriverPercent((prof.customFields?.driverPercent as string) || '')\n        setCoDriverPercent((prof.customFields?.coDriverPercent as string) || '')\n        setTraineeDriverPercent((prof.customFields?.traineeDriverPercent as string) || '')\n\n        // Address & Other phone numbers\n        setAddress((prof.customFields?.address as string) || '')\n        setPhone3((prof.customFields?.phone3 as string) || '')\n        setPhone4((prof.customFields?.phone4 as string) || '')\n\n        // Dynamic phone numbers list\n        setAdditionalPhones((prof.customFields?.additionalPhones as string[]) || [])\n\n        // Dynamic vehicles list\n        setVehicles((prof.customFields?.vehicles as Vehicle[]) || [])\n      }\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  async function loadAuditLogs() {\n    if (!accessToken) return\n    setLogsLoading(true)\n    try {\n      const res = await fetch('/api/profile/audit-logs', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setAuditLogs(data.data || [])\n      }\n    } catch {\n      // silent\n    } finally {\n      setLogsLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    void loadProfile()\n    void loadAuditLogs()\n  }, [accessToken])\n\n  // Direct instant field update handler (for theme color, availability, avatar)\n  const handleUpdateDirectField = async (key: string, value: string) => {\n    if (!accessToken || !profile) return\n    setError('')\n    setUpdatingField(key)\n    try {\n      const payload = {\n        phone,\n        email,\n        avatar: key === 'avatar' ? value : avatar,\n        availability: key === 'availability' ? value : availability,\n        themeColor: key === 'themeColor' ? value : themeColor,\n        vehicles,\n      }\n      \n      const res = await fetch('/api/profile', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify(payload),\n      })\n\n      const data = await res.json()\n      if (res.ok) {\n        setProfile(data.data)\n        if (key === 'themeColor') setThemeColor(value)\n        if (key === 'availability') setAvailability(value)\n        if (key === 'avatar') setAvatar(value)\n        void loadAuditLogs()\n      } else {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»')\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${msg}`)\n    } finally {\n      setUpdatingField(null)\n    }\n  }\n\n  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0]\n    if (!file || !accessToken) return\n\n    setUploading(true)\n    setError('')\n\n    const formData = new FormData()\n    formData.append('file', file)\n\n    try {\n      const res = await fetch('/api/uploads', {\n        method: 'POST',\n        headers: { Authorization: `Bearer ${accessToken}` },\n        body: formData,\n      })\n\n      const data = await res.json()\n\n      if (res.ok) {\n        const fileUrl = data.data.url\n        await handleUpdateDirectField('avatar', fileUrl)\n      } else {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’')\n      }\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’ в”ҳГ§в”ҳГҘв”ҢВ»в•ӘВәв”ҳГ  в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ')\n    } finally {\n      setUploading(false)\n      if (fileInputRef.current) fileInputRef.current.value = ''\n    }\n  }\n\n  // Save the full Edit Form (Contact details + ALL personal details + dynamic phones list)\n  const handleSaveForm = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!accessToken) return\n    setSaving(true)\n    setError('')\n    setSuccess('')\n\n    try {\n      const res = await fetch('/api/profile', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          phone,\n          email,\n          availability,\n          themeColor,\n          avatar,\n          \n          // Personal fields\n          fatherName,\n          idNumber,\n          birthDate,\n          age,\n          birthPlace,\n          maritalStatus,\n          insuranceNo,\n          education,\n          \n          // Job details\n          post,\n          shift,\n          shiftType,\n          startLocation,\n          hireDate,\n          personnelNo,\n          group,\n\n          // Safety & Qualifications\n          drivingStatus,\n          licenseClass1Date,\n          licenseClass2Date,\n          medicalExamValidity,\n          driverPercent,\n          coDriverPercent,\n          traineeDriverPercent,\n\n          // Contacts\n          address,\n          phone3,\n          phone4,\n          \n          // Dynamic lists\n          additionalPhones: additionalPhones.filter(p => p.trim() !== ''),\n          vehicles,\n        }),\n      })\n\n      const data = await res.json()\n\n      if (res.ok) {\n        setProfile(data.data)\n        setSuccess('в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ» в”ҳГӘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ§в”ҳГӘв–ҲГ®в•ӘВ¬в–ҲГ® в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в•ӘВҝв”ҳГ§ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘ в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ».');\n        window.scrollTo({ top: 0, behavior: 'smooth' })\n        void loadProfile()\n        void loadAuditLogs()\n      } else {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬')\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${msg}`)\n    } finally {\n      setSaving(false)\n    }\n  }\n\n  // Vehicle Permits List Action Handlers\n  const handleAddVehicleToList = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!accessToken) return\n    if (!plateNum1 || !plateLetter || !plateNum2 || !plateCity || !carType) {\n      setError('в”ҳв•ӣв•Әв–’ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГӘ в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬.')\n      return\n    }\n\n    setSavingVehicle(true)\n    setError('')\n    setSuccess('')\n\n    const combinedPlate = `${plateNum1} ${plateLetter} ${plateNum2} в•ӘВәв–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ ${plateCity}`\n    const newVehicle: Vehicle = {\n      id: `VEH-${crypto.randomUUID()}`,\n      plateNum1,\n      plateLetter,\n      plateNum2,\n      plateCity,\n      carPlate: combinedPlate,\n      carType,\n      carColor,\n      carLicenseExpiry,\n      status: 'pending' // automatically pending for manager review\n    }\n\n    const updatedVehicles = [...vehicles, newVehicle]\n\n    try {\n      const res = await fetch('/api/profile', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          vehicles: updatedVehicles,\n          phone,\n          email,\n          availability,\n          themeColor,\n          avatar,\n          fatherName,\n          idNumber,\n          birthDate,\n          age,\n          birthPlace,\n          maritalStatus,\n          insuranceNo,\n          additionalPhones: additionalPhones.filter(p => p.trim() !== ''),\n        }),\n      })\n\n      const data = await res.json()\n\n      if (res.ok) {\n        setProfile(data.data)\n        setVehicles(updatedVehicles)\n        setSuccess('в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВјв”ҳГ§в•ӘВ¬ в•Әв•Ўв•ӘВ»в”ҳГӘв•Әв–’ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВ»в”ҳв•ӣв”ҳГӘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘ в•Әв”Өв•ӘВ».')\n        setIsAddingVehicle(false)\n        resetVehicleForm()\n        void loadAuditLogs()\n      } else {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ')\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${msg}`)\n    } finally {\n      setSavingVehicle(false)\n    }\n  }\n\n  const handleRemoveVehicle = async (id: string) => {\n    if (!accessToken) return\n    if (!confirm('в•ӘГів–ҲГ®в•ӘВә в•ӘВәв•Әв–“ в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ в”ҳГӘ в•ӘВәв•ӘВҝв•Әв•–в•ӘВәв”ҳГӨ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘГів”ҳГҘ в•ӘВәв•Әв•–в”ҳГ в–ҲГ®в”ҳГҘв•ӘВәв”ҳГҘ в•ӘВ»в•ӘВәв•Әв–’в–ҲГ®в•ӘВ»в•ӘЖ’')) return\n\n    setError('')\n    setSuccess('')\n    const updatedVehicles = vehicles.filter(v => v.id !== id)\n\n    try {\n      const res = await fetch('/api/profile', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          vehicles: updatedVehicles,\n          phone,\n          email,\n          availability,\n          themeColor,\n          avatar,\n          fatherName,\n          idNumber,\n          birthDate,\n          age,\n          birthPlace,\n          maritalStatus,\n          insuranceNo,\n          additionalPhones: additionalPhones.filter(p => p.trim() !== ''),\n        }),\n      })\n\n      const data = await res.json()\n\n      if (res.ok) {\n        setProfile(data.data)\n        setVehicles(updatedVehicles)\n        setSuccess('в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВЎв•Әв–‘в”ҳГј в”ҳГӘ в•ӘВәв•ӘВҝв•Әв•–в•ӘВәв”ҳГӨ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘВҝв”ҳГ§ в”ҢВ»в–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГ  в•Әв”Өв•ӘВ».')\n        void loadAuditLogs()\n      } else {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВЎв•Әв–‘в”ҳГј в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ')\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${msg}`)\n    }\n  }\n\n  const resetVehicleForm = () => {\n    setPlateNum1('')\n    setPlateLetter('в•ӘВҝ')\n    setPlateNum2('')\n    setPlateCity('')\n    setCarType('')\n    setCarColor('')\n    setCarLicenseExpiry('в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв•Ј')\n  }\n\n  // Dynamic phone handlers\n  const handleAdditionalPhoneChange = (index: number, val: string) => {\n    const updated = [...additionalPhones]\n    updated[index] = val\n    setAdditionalPhones(updated)\n  }\n\n  const handleAddPhoneField = () => {\n    setAdditionalPhones([...additionalPhones, ''])\n  }\n\n  const handleRemoveAdditionalPhone = (index: number) => {\n    setAdditionalPhones(additionalPhones.filter((_, i) => i !== index))\n  }\n\n  // Helper to render field validation state badges in profile view\n  const renderFieldBadge = (key: string) => {\n    const status = getFieldStatus(key)\n    if (status === 'pending') {\n      return (\n        <Badge variant=\"outline\" className=\"text-[9px] px-1.5 py-0 bg-yellow-500/10 text-yellow-300 border-yellow-500/20 mr-2 flex items-center gap-0.5\">\n          <AlertTriangle className=\"size-2.5 shrink-0\" />\n          <span>в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»</span>\n        </Badge>\n      )\n    }\n    if (status === 'rejected') {\n      return (\n        <Badge variant=\"outline\" className=\"text-[9px] px-1.5 py-0 bg-red-500/10 text-red-400 border-red-500/20 mr-2 flex items-center gap-0.5\">\n          <X className=\"size-2.5 shrink-0\" />\n          <span>в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ / в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§</span>\n        </Badge>\n      )\n    }\n    return null\n  }\n\n  // Audit timeline description Farsi translator\n  const translateAuditLog = (log: AuditLog) => {\n    const isSelf = log.actorId === profile?.id\n    const entity = log.entity\n    const action = log.action\n\n    if (action === 'login') return 'в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в”ҳГ в”ҳГӘв”ҳГјв”ҳГ© в•ӘВҝв”ҳГ§ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬'\n    if (action === 'logout') return 'в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј в•ӘВәв•Әв–“ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬'\n\n    if (entity === 'User') {\n      if (action === 'update') {\n        return isSelf ? 'в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГӘ в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ®О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в•Әв”Өв”ҳГ в•ӘВә' : 'в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•– в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬'\n      }\n      return 'в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®'\n    }\n\n    if (entity === 'Ticket') {\n      if (action === 'create') return 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬ в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГ  в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“в•ӘВәв•ӘВ¬'\n      if (action === 'update') return 'в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ'\n    }\n\n    if (entity === 'SwapRequest') {\n      if (action === 'create') return 'в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВ»в•Әв–’ в•ӘВ¬в”ҳГ©в”ҳГӘв–ҲГ®в”ҳГ '\n      if (action === 'update') return 'в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬'\n    }\n\n    if (entity === 'RosterFile') {\n      if (action === 'create') return 'в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в”ҳГ в•ӘВәв”ҳГ§в•ӘВәв”ҳГҘв”ҳГ§'\n    }\n\n    // Default formatting\n    const entityFarsi: Record<string, string> = {\n      User: 'в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®',\n      Ticket: 'в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ®',\n      SwapRequest: 'в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®',\n      Bulletin: 'в•ӘВҝв•ӘВ«в•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®',\n      RosterFile: 'в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®',\n    }\n\n    const actionFarsi: Record<string, string> = {\n      create: 'в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ»',\n      update: 'в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ®',\n      delete: 'в•ӘВЎв•Әв–‘в”ҳГј',\n    }\n\n    const item = entityFarsi[entity] || entity\n    const op = actionFarsi[action] || action\n    return `${op} ${item} в•ӘВ»в•Әв–’ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§`\n  }\n\n  if (loading) {\n    return (\n      <div role=\"status\" className=\"flex flex-1 flex-col items-center justify-center p-12\">\n        <Loader2 className=\"size-10 animate-spin text-primary\" />\n        <p className=\"text-sm text-foreground-muted mt-4\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•Әв”Өв”ҳГ в•ӘВә...</p>\n      </div>\n    )\n  }\n\n  if (!profile) {\n    return (\n      <div className=\"flex flex-1 flex-col items-center justify-center gap-3 p-8\">\n        <AlertCircle className=\"size-12 text-critical\" />\n        <p className=\"text-sm text-foreground-muted\">в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®</p>\n      </div>\n    )\n  }\n\n  const initials = profile.name\n    .split(' ')\n    .map((w) => w[0])\n    .join('')\n    .slice(0, 2)\n\n  const activeTheme = themeColor\n  const activeAvailability = availability\n  const availabilityInfo = AVAILABILITY_LABELS[activeAvailability] || { label: 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў', color: 'bg-neutral-500 text-neutral-400', desc: '' }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 md:p-6\" dir=\"rtl\">\n      {/* Banner / Header Card */}\n      <Card className=\"relative overflow-hidden border-border-subtle bg-surface-container-low\">\n        {/* Decorative Theme Color Background Mesh */}\n        <div \n          className=\"absolute top-0 right-0 w-full h-32 md:h-44 transition-all duration-300 opacity-20\" \n          style={{ \n            backgroundImage: `radial-gradient(circle at 10% 20%, ${activeTheme} 0%, transparent 50%), radial-gradient(circle at 90% 80%, ${activeTheme} 0%, transparent 60%)` \n          }}\n        />\n        <div \n          className=\"absolute top-0 right-0 w-full h-1.5 transition-all duration-300\" \n          style={{ backgroundColor: activeTheme }}\n        />\n\n        <CardContent className=\"relative flex flex-col md:flex-row items-center md:items-end gap-5 p-6 pt-16 md:pt-24 z-10\">\n          {/* Floating Avatar Container */}\n          <div className=\"relative shrink-0 -mt-10 md:mt-0\">\n            <div className=\"relative group rounded-full overflow-hidden border-4 border-background bg-surface-container-high shadow-xl size-24 md:size-32 transition-all\">\n              {avatar ? (\n                // eslint-disable-next-line @next/next/no-img-element\n                <img \n                  src={avatar} \n                  alt={profile.name} \n                  className=\"size-full object-cover\"\n                />\n              ) : (\n                <div \n                  className=\"flex size-full items-center justify-center font-headline-lg text-2xl md:text-4xl\"\n                  style={{ color: activeTheme }}\n                >\n                  {initials}\n                </div>\n              )}\n              {/* Click overlay to upload avatar */}\n              <button\n                type=\"button\"\n                onClick={() => fileInputRef.current?.click()}\n                className=\"absolute inset-0 bg-black/60 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-white gap-1\"\n                disabled={uploading}\n              >\n                {uploading ? (\n                  <Loader2 className=\"size-5 animate-spin\" />\n                ) : (\n                  <>\n                    <Camera className=\"size-5 text-white/90\" />\n                    <span className=\"text-[10px] font-medium font-sans\">в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’</span>\n                  </>\n                )}\n              </button>\n            </div>\n            <input \n              type=\"file\" \n              ref={fileInputRef} \n              onChange={handleFileUpload} \n              accept=\"image/*\" \n              className=\"hidden\" \n            />\n            {/* Realtime Status Indicator Ring */}\n            <div \n              className={cn(\n                \"absolute bottom-1 right-1 size-5 rounded-full border-4 border-surface-container-low shadow-md\",\n                availabilityInfo.color.split(' ')[0]\n              )} \n            />\n          </div>\n\n          {/* User Basic HR Details */}\n          <div className=\"flex-1 text-center md:text-right space-y-2 pb-1\">\n            <div className=\"flex flex-col md:flex-row items-center gap-2.5 justify-center md:justify-start\">\n              <h2 className=\"font-headline-lg text-2xl md:text-3xl text-foreground font-bold\">{profile.name}</h2>\n              <Badge variant=\"outline\" className=\"px-2.5 py-0.5 border-primary/20 text-primary bg-primary/5 font-semibold text-xs rounded-full\">\n                {profile.role ? (ROLE_LABEL[profile.role.key] || profile.role.name) : 'в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ'}\n              </Badge>\n            </div>\n            <div className=\"flex flex-wrap items-center justify-center md:justify-start gap-x-4 gap-y-1.5 text-sm text-foreground-muted\">\n              <span className=\"flex items-center gap-1.5\">\n                <Contact className=\"size-4 opacity-75\" />\n                <span>в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®: <span className=\"font-data-mono\">{toFa(profile.nationalId)}</span></span>\n              </span>\n              <span className=\"hidden md:inline text-border-subtle\">О“ГҮГі</span>\n              <span className=\"flex items-center gap-1.5\">\n                <Briefcase className=\"size-4 opacity-75\" />\n                <span>в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®: <span className=\"font-data-mono\">{toFa(getCustomField('personnelNo') || 'О“ГҮГ¶')}</span></span>\n              </span>\n            </div>\n          </div>\n\n          {/* Shift status shortcut */}\n          {todayShift && (\n            <div className=\"shrink-0 flex flex-col items-center md:items-end gap-1.5 pt-4 md:pt-0\">\n              <span className=\"text-xs text-foreground-muted\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв”ҳГ в•Әв–’в”ҳГӘв•Әв–“ в•Әв”Өв”ҳГ в•ӘВә:</span>\n              <div className=\"flex items-center gap-2 bg-surface-container-high px-3 py-1.5 rounded-lg border border-border/80\">\n                <Clock className=\"size-4 text-primary\" />\n                <Badge variant=\"outline\" className={cn(\n                  \"text-xs px-2.5 py-0.5\",\n                  todayShift.shift?.code === 'morning' && \"bg-amber-500/20 text-amber-300 border-amber-500/30\",\n                  todayShift.shift?.code === 'evening' && \"bg-sky-500/20 text-sky-300 border-sky-500/30\",\n                  todayShift.shift?.code === 'night' && \"bg-indigo-500/20 text-indigo-300 border-indigo-500/30\",\n                  todayShift.shift?.code === 'office' && \"bg-purple-500/20 text-purple-300 border-purple-500/30\",\n                  todayShift.shift?.code === 'off' && \"bg-neutral-800 text-neutral-400 border-neutral-700\"\n                )}>\n                  {todayShift.shift?.label || 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}\n                </Badge>\n                <span className=\"text-xs text-foreground-muted font-sans font-medium\">({todayShift.templateName})</span>\n              </div>\n            </div>\n          )}\n        </CardContent>\n      </Card>\n\n      {/* Main Responsive Grid Layout */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-10 gap-6\">\n        \n        {/* Right Sidebar Column - Interactive controls (3/10) */}\n        <div className=\"lg:col-span-3 flex flex-col gap-6\">\n          {/* Availability Status switcher card */}\n          <Card className=\"border-border/60 shadow-sm\">\n            <CardHeader className=\"p-4 pb-2\">\n              <CardTitle className=\"text-base font-semibold flex items-center gap-2\">\n                <Activity className=\"size-4\" style={{ color: activeTheme }} />\n                в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®\n              </CardTitle>\n              <CardDescription className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГјв•Әв•Јв”ҳГӨв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВјв”ҳГ§в•ӘВ¬ в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ»в–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ® (OCC) в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"p-4 pt-2 space-y-3\">\n              <div className=\"flex flex-col gap-2\">\n                {Object.entries(AVAILABILITY_LABELS).map(([k, v]) => {\n                  const isActive = activeAvailability === k\n                  return (\n                    <button\n                      key={k}\n                      type=\"button\"\n                      disabled={updatingField === 'availability'}\n                      onClick={() => handleUpdateDirectField('availability', k)}\n                      className={cn(\n                        \"w-full text-right p-3 rounded-lg border text-sm flex items-center justify-between transition-all hover:bg-surface-container-high/40 cursor-pointer\",\n                        isActive \n                          ? \"border-primary/40 bg-surface-container-high font-semibold shadow-inner\" \n                          : \"border-border/40 bg-surface-container-low\"\n                      )}\n                    >\n                      <div className=\"flex items-center gap-2.5\">\n                        <span className={cn(\"size-2.5 rounded-full shrink-0\", v.color.split(' ')[0])} />\n                        <div className=\"flex flex-col text-right\">\n                          <span>{v.label}</span>\n                          <span className=\"text-[10px] text-foreground-muted font-normal mt-0.5 leading-tight\">{v.desc}</span>\n                        </div>\n                      </div>\n                      {isActive && (\n                        updatingField === 'availability' ? (\n                          <Loader2 className=\"size-4 animate-spin text-primary\" />\n                        ) : (\n                          <Check className=\"size-4 text-primary shrink-0\" />\n                        )\n                      )}\n                    </button>\n                  )\n                })}\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Theme Color Circle Picker card */}\n          <Card className=\"border-border/60 shadow-sm\">\n            <CardHeader className=\"p-4 pb-2\">\n              <CardTitle className=\"text-base font-semibold flex items-center gap-2\">\n                <Palette className=\"size-4\" style={{ color: activeTheme }} />\n                в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ®О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв••в•ӘВәв”ҳГ§в•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®\n              </CardTitle>\n              <CardDescription className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                в•Әв–’в”ҳГҘв”ҢВ» в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘ в”ҳГ в”ҳГӘв•Әв–’в•ӘВ»в•Әв•Јв”ҳГӨв•ӘВәв”ҳГ©в”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГ в•ӘВЎв–ҲГ®в•Әв•– в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"p-4 pt-2\">\n              <div className=\"grid grid-cols-6 gap-2 mt-1\">\n                {DEFAULT_THEME_COLORS.map((color) => {\n                  const isSelected = activeTheme.toLowerCase() === color.hex.toLowerCase()\n                  return (\n                    <button\n                      key={color.hex}\n                      type=\"button\"\n                      title={color.name}\n                      disabled={updatingField === 'themeColor'}\n                      className={cn(\n                        \"aspect-square rounded-full border-2 transition-all relative flex items-center justify-center hover:scale-105 active:scale-95 shadow-sm cursor-pointer\",\n                        isSelected ? \"scale-110 border-white ring-2 ring-primary/20\" : \"border-transparent opacity-80\"\n                      )}\n                      style={{ \n                        backgroundColor: color.hex, \n                      }}\n                      onClick={() => handleUpdateDirectField('themeColor', color.hex)}\n                    >\n                      {isSelected && (\n                        updatingField === 'themeColor' ? (\n                          <Loader2 className=\"size-3.5 animate-spin text-white\" />\n                        ) : (\n                          <span className=\"size-2 rounded-full bg-white shadow\" />\n                        )\n                      )}\n                    </button>\n                  )\n                })}\n              </div>\n            </CardContent>\n          </Card>\n        </div>\n\n        {/* Left main area - Tabs dashboard (7/10) */}\n        <div className=\"lg:col-span-7 flex flex-col\">\n          <Tabs defaultValue=\"personnel\" className=\"w-full flex flex-col flex-1\">\n            \n            {/* Tabs List Navigation */}\n            <TabsList className=\"bg-surface-container-high border border-border/80 w-full md:w-auto self-start mb-4\">\n              <TabsTrigger value=\"personnel\" className=\"data-active:shadow-sm gap-2\">\n                <ClipboardList className=\"size-4\" />\n                <span>в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®</span>\n              </TabsTrigger>\n              <TabsTrigger value=\"vehicle\" className=\"data-active:shadow-sm gap-2\">\n                <Car className=\"size-4\" />\n                <span>в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВә ({toFa(vehicles.length)})</span>\n              </TabsTrigger>\n              <TabsTrigger value=\"edit\" className=\"data-active:shadow-sm gap-2\">\n                <Pencil className=\"size-4\" />\n                <span>в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГӘ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬</span>\n              </TabsTrigger>\n              <TabsTrigger value=\"timeline\" className=\"data-active:shadow-sm gap-2\">\n                <Activity className=\"size-4\" />\n                <span>в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә</span>\n              </TabsTrigger>\n            </TabsList>\n\n            {/* Tab 1: Personnel File details (with dynamic field verification badges) */}\n            <TabsContent value=\"personnel\" className=\"space-y-6 animate-in fade-in-50 duration-200\">\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                \n                {/* 1. Identification Fields */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-3 border-b border-border/40\">\n                    <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                      <User className=\"size-4\" style={{ color: activeTheme }} />\n                      в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГӘ в”ҳГјв•Әв–’в•ӘВ»в–ҲГ®\n                    </CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"p-4 py-2 divide-y divide-border/30\">\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono\">{toFa(profile.nationalId)}</span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•ӘВ»в•Әв–’</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('fatherName') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('fatherName')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('idNumber') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('idNumber')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('birthDate') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('birthDate')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•Әв”Ӯв”ҳГҘ</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('age') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('age')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҳГ в•ӘВЎв”ҳГӨ в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('birthPlace') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('birthPlace')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘВәв”ҳГ§в”ҳГӨ / в”ҳГјв•Әв–’в•Әв–“в”ҳГҘв•ӘВ»в•ӘВәв”ҳГҘ</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('maritalStatus') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('maritalStatus')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВ«в”ҳГӘв”ҳГҘв–ҲГ® / в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВҝв–ҲГ®в”ҳГ в”ҳГ§</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('insuranceNo') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('insuranceNo')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в•ӘВЎв•Әв•Ўв–ҲГ®в”ҳГӨв•ӘВәв•ӘВ¬</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('education') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('education')}\n                      </span>\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 2. Organizational Fields */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-3 border-b border-border/40\">\n                    <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                      <Briefcase className=\"size-4\" style={{ color: activeTheme }} />\n                      в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ®\n                    </CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"p-4 py-2 divide-y divide-border/30\">\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('personnelNo') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('personnelNo')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('post') || (profile.role ? ROLE_LABEL[profile.role.key] : 'О“ГҮГ¶')}\n                        {renderFieldBadge('post')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҢвҢҗв•ӘВ» в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('group') === 'Staff' ? 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® / в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®' : `в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ ${getCustomField('group') || 'A'}`}\n                        {renderFieldBadge('group')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҳГҘв•ӘВәв”ҳГ  в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('shift') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('shift')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('shiftType') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('shiftType')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВҝв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('startLocation') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('startLocation')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ  / в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('hireDate') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('hireDate')}\n                      </span>\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 3. Qualifications & Safety */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-3 border-b border-border/40\">\n                    <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                      <Award className=\"size-4\" style={{ color: activeTheme }} />\n                      в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв•ӘГ® в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬\n                    </CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"p-4 py-2 divide-y divide-border/30\">\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’</span>\n                      <span className=\"font-semibold text-foreground flex items-center\">\n                        {getCustomField('drivingStatus') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('drivingStatus')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('licenseClass1Date') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('licenseClass1Date')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('licenseClass2Date') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('licenseClass2Date')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв”ҳГ§ в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('medicalExamValidity') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('medicalExamValidity')}\n                      </span>\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 4. Operations Percentages */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-3 border-b border-border/40\">\n                    <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                      <Shield className=\"size-4\" style={{ color: activeTheme }} />\n                      в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГ§в”ҳГ  в”ҢвҢҗв•ӘВәв•Әв–’в”ҢвҢҗв•Әв–’в•ӘВ» в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®\n                    </CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"p-4 py-2 divide-y divide-border/30\">\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        в”ҳВ¬{toFa(getCustomField('driverPercent') || '0')}\n                        {renderFieldBadge('driverPercent')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в”ҢвҢҗв”ҳГ в”ҢвҢҗ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        в”ҳВ¬{toFa(getCustomField('coDriverPercent') || '0')}\n                        {renderFieldBadge('coDriverPercent')}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm\">\n                      <span className=\"text-foreground-muted\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        в”ҳВ¬{toFa(getCustomField('traineeDriverPercent') || '0')}\n                        {renderFieldBadge('traineeDriverPercent')}\n                      </span>\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 5. Additional Contacts Info */}\n                <Card className=\"border-border/60 shadow-sm md:col-span-2\">\n                  <CardHeader className=\"p-4 pb-3 border-b border-border/40\">\n                    <CardTitle className=\"text-sm font-semibold flex items-center gap-2 text-foreground\">\n                      <MapPin className=\"size-4\" style={{ color: activeTheme }} />\n                      в•Әв”Ӯв•ӘВәв–ҲГ®в•Әв–’ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в”ҳГӘ в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ\n                    </CardTitle>\n                  </CardHeader>\n                  <CardContent className=\"p-4 grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1\">\n                    <div className=\"flex justify-between items-center py-2.5 text-sm border-b border-border/30\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВәв”ҳГӘв”ҳГӨ</span>\n                      <span className=\"font-data-mono font-semibold text-foreground\">{toFa(profile.phone || 'О“ГҮГ¶')}</span>\n                    </div>\n                    <div className=\"flex justify-between items-center py-2.5 text-sm border-b border-border/30\">\n                      <span className=\"text-foreground-muted\">в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground\">{profile.email || 'О“ГҮГ¶'}</span>\n                    </div>\n                    \n                    {/* Render dynamic phone numbers */}\n                    {additionalPhones.map((ph, idx) => (\n                      <div key={idx} className=\"flex justify-between items-center py-2.5 text-sm border-b border-border/30\">\n                        <span className=\"text-foreground-muted\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ {toFa(idx + 2)}</span>\n                        <span className=\"font-data-mono font-semibold text-foreground\">{toFa(ph)}</span>\n                      </div>\n                    ))}\n\n                    <div className=\"flex justify-between items-center py-2.5 text-sm border-b border-border/30\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в–Ҳв”Ӯ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('phone3') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('phone3')}\n                      </span>\n                    </div>\n\n                    <div className=\"flex justify-between items-center py-2.5 text-sm border-b border-border/30\">\n                      <span className=\"text-foreground-muted\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в–Ҳв”Ө в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®</span>\n                      <span className=\"font-semibold text-foreground font-data-mono flex items-center\">\n                        {toFa(getCustomField('phone4') || 'О“ГҮГ¶')}\n                        {renderFieldBadge('phone4')}\n                      </span>\n                    </div>\n                    \n                    <div className=\"flex justify-between items-center py-2.5 text-sm border-b border-border/30 md:border-0 md:col-span-2\">\n                      <span className=\"text-foreground-muted shrink-0 me-4\">в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬в–ҲГ® в”ҳГ в•ӘВЎв”ҳГӨ в•Әв”Ӯв”ҢвҢҗв”ҳГӘв”ҳГҘв•ӘВ¬</span>\n                      <span className=\"font-semibold text-foreground text-left md:text-right flex items-center\">\n                        {getCustomField('address') || 'О“ГҮГ¶'}\n                        {renderFieldBadge('address')}\n                      </span>\n                    </div>\n                  </CardContent>\n                </Card>\n              </div>\n            </TabsContent>\n\n            {/* Tab 2: Vehicles Permit Registration (Support ANY number of vehicles) */}\n            <TabsContent value=\"vehicle\" className=\"space-y-6 animate-in fade-in-50 duration-200\">\n              \n              {/* Header Action Card */}\n              <div className=\"flex justify-between items-center bg-surface-container-high/40 p-4 rounded-lg border border-border/50\">\n                <div className=\"text-right\">\n                  <h3 className=\"font-semibold text-foreground text-sm flex items-center gap-1.5\">\n                    <Car className=\"size-4\" style={{ color: activeTheme }} />\n                    в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’\n                  </h3>\n                  <p className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                    в•Әв”Өв”ҳГ в•ӘВә в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•ӘВ»в”ҳГӨв•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в•ӘВ»в•Әв–’ в”ҳв•ӣв•ӘВәв•Әв–’в”ҢвҢҗв–ҲГ®в”ҳГҘв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘ в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ в”ҳГӘ в•Әв•Ўв•ӘВәв•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ§ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                  </p>\n                </div>\n                {!isAddingVehicle && (\n                  <Button \n                    size=\"sm\" \n                    onClick={() => { resetVehicleForm(); setIsAddingVehicle(true); }}\n                    className=\"gap-1.5 h-9 shrink-0 cursor-pointer\"\n                  >\n                    <span>+ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</span>\n                  </Button>\n                )}\n              </div>\n\n              {/* Add New Vehicle Form Card */}\n              {isAddingVehicle && (\n                <Card className=\"border-border/60 shadow-sm bg-surface-container-low/20 animate-in slide-in-from-top-2 duration-200\">\n                  <CardHeader className=\"p-4 pb-2 border-b border-border/30 flex flex-row items-center justify-between\">\n                    <CardTitle className=\"text-sm font-semibold\">в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳГӘв•Әв”Ӯв–ҲГ®в”ҳГӨв”ҳГ§ в”ҳГҘв”ҳГ©в”ҳГӨв–ҲГ®в”ҳГ§ в”ҳГӘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</CardTitle>\n                    <Button \n                      variant=\"outline\" \n                      size=\"sm\" \n                      onClick={() => setIsAddingVehicle(false)}\n                      className=\"h-8 w-8 p-0\"\n                    >\n                      <X className=\"size-4\" />\n                    </Button>\n                  </CardHeader>\n                  <CardContent className=\"p-6\">\n                    <form onSubmit={handleAddVehicleToList} className=\"space-y-6\">\n                      \n                      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                        <div className=\"flex flex-col gap-1.5\">\n                          <Label className=\"text-right text-xs font-semibold text-foreground\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ  в•ӘВ«в•ӘВәв”ҳГҘв”ҳГӘв•ӘВәв•ӘВ»в”ҢВ»в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ *</Label>\n                          <Input\n                            value={profile.name}\n                            disabled\n                            className=\"bg-surface-container-high text-foreground-muted cursor-not-allowed opacity-80\"\n                          />\n                        </div>\n                        <div className=\"flex flex-col gap-1.5\">\n                          <Label className=\"text-right text-xs font-semibold text-foreground\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® *</Label>\n                          <Input\n                            value={getCustomField('personnelNo') || 'О“ГҮГ¶'}\n                            disabled\n                            className=\"bg-surface-container-high text-foreground-muted cursor-not-allowed opacity-80 font-mono text-left\"\n                          />\n                        </div>\n                      </div>\n\n                      {/* Plate Number Inputs */}\n                      <div className=\"flex flex-col gap-2\">\n                        <Label className=\"text-right text-xs font-semibold text-foreground\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ в”ҳГӨв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ *</Label>\n                        \n                        <div className=\"flex items-center justify-center gap-3 bg-surface-container-high/40 p-4 rounded-lg border border-border/50 max-w-xl mx-auto\" dir=\"ltr\">\n                          \n                          {/* 1. Left 2 Digits */}\n                          <input\n                            type=\"text\"\n                            maxLength={2}\n                            value={plateNum1}\n                            onChange={(e) => setPlateNum1(e.target.value.replace(/\\D/g, ''))}\n                            placeholder=\"в–Ҳв•ўв–Ҳв•ў\"\n                            className=\"h-10 w-16 border border-input bg-background text-foreground text-center font-bold text-lg rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent\"\n                            required\n                          />\n\n                          {/* 2. Plate Letter Selection */}\n                          <select\n                            value={plateLetter}\n                            onChange={(e) => setPlateLetter(e.target.value)}\n                            className=\"h-10 w-20 border border-input bg-background text-foreground text-center font-bold rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent cursor-pointer\"\n                          >\n                            {PLATE_LETTERS.map((letter) => (\n                              <option key={letter} value={letter} className=\"bg-popover text-foreground\">\n                                {letter}\n                              </option>\n                            ))}\n                          </select>\n\n                          {/* 3. Middle 3 Digits */}\n                          <input\n                            type=\"text\"\n                            maxLength={3}\n                            value={plateNum2}\n                            onChange={(e) => setPlateNum2(e.target.value.replace(/\\D/g, ''))}\n                            placeholder=\"в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ў\"\n                            className=\"h-10 w-20 border border-input bg-background text-foreground text-center font-bold text-lg rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent\"\n                            required\n                          />\n\n                          {/* 4. Separator Text */}\n                          <span className=\"text-sm font-semibold text-foreground-muted px-1\" dir=\"rtl\">\n                            в•ӘВәв–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ -\n                          </span>\n\n                          {/* 5. Right City 2 Digits */}\n                          <input\n                            type=\"text\"\n                            maxLength={2}\n                            value={plateCity}\n                            onChange={(e) => setPlateCity(e.target.value.replace(/\\D/g, ''))}\n                            placeholder=\"в–Ҳв–“в–Ҳв–“\"\n                            className=\"h-10 w-16 border border-input bg-background text-foreground text-center font-bold text-lg rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent\"\n                            required\n                          />\n                        </div>\n                      </div>\n\n                      {/* Car Type & Color */}\n                      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n                        \n                        {/* Car Type */}\n                        <div className=\"flex flex-col gap-1.5\">\n                          <Label htmlFor=\"car_type\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ *</Label>\n                          <Input\n                            id=\"car_type\"\n                            value={carType}\n                            onChange={(e) => setCarType(e.target.value)}\n                            placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ в”ҳв•ӣв”ҢГҝв”ҳГӘ в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў\"\n                            required\n                          />\n                        </div>\n\n                        {/* Car Color */}\n                        <div className=\"flex flex-col gap-1.5\">\n                          <Label htmlFor=\"car_color\" className=\"text-right text-xs font-semibold text-foreground\">в•Әв–’в”ҳГҘв”ҢВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ</Label>\n                          <Input\n                            id=\"car_color\"\n                            value={carColor}\n                            onChange={(e) => setCarColor(e.target.value)}\n                            placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ в”ҳГҘв”ҳГӘв”ҢвҢҗ в”ҳГ в•ӘВ»в•ӘВәв•ӘВ»в–ҲГ®\"\n                          />\n                        </div>\n\n                        {/* License Expiry Date */}\n                        <div className=\"flex flex-col gap-1.5\">\n                          <Label htmlFor=\"car_expiry\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в”ҳГ в•ӘВјв”ҳГӘв•Әв–“</Label>\n                          <Input\n                            id=\"car_expiry\"\n                            value={carLicenseExpiry}\n                            onChange={(e) => setCarLicenseExpiry(e.target.value)}\n                            placeholder=\"в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв•Ј\"\n                            className=\"font-mono text-center\"\n                          />\n                        </div>\n\n                      </div>\n\n                      {/* Footer Actions buttons */}\n                      <div className=\"flex justify-end gap-2 pt-4 border-t border-border/40\">\n                        <Button\n                          type=\"button\"\n                          variant=\"outline\"\n                          size=\"sm\"\n                          onClick={() => setIsAddingVehicle(false)}\n                          disabled={savingVehicle}\n                        >\n                          в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n                        </Button>\n                        <Button \n                          type=\"submit\" \n                          size=\"sm\"\n                          disabled={savingVehicle}\n                          className=\"gap-2 cursor-pointer\"\n                        >\n                          {savingVehicle ? (\n                            <>\n                              <Loader2 className=\"size-3.5 animate-spin\" />\n                              <span>в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬...</span>\n                            </>\n                          ) : (\n                            <>\n                              <CheckCircle2 className=\"size-3.5\" />\n                              <span>в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘ в•ӘВҝв”ҳГ§ в”ҢВ»в–ҲГ®в•ӘВ¬</span>\n                            </>\n                          )}\n                        </Button>\n                      </div>\n                    </form>\n                  </CardContent>\n                </Card>\n              )}\n\n              {/* Vehicles Grid List */}\n              {vehicles.length === 0 ? (\n                <div className=\"flex flex-col items-center justify-center p-12 text-foreground-muted gap-2 border border-dashed border-border/60 rounded-lg\">\n                  <Car className=\"size-10 opacity-30\" />\n                  <span className=\"text-sm font-medium\">в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ®в–ҲГ® в•ӘВ¬в•ӘВәв”ҢвҢҗв”ҳГҘв”ҳГӘв”ҳГҘ в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в•Әв”Өв”ҳГ в•ӘВә в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬</span>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 gap-4\">\n                  {vehicles.map((v) => {\n                    const isPending = v.status === 'pending'\n                    const isRejected = v.status === 'rejected'\n                    const isApproved = v.status === 'approved' || !v.status\n\n                    return (\n                      <Card key={v.id} className=\"border-border/60 shadow-sm relative overflow-hidden\">\n                        <CardContent className=\"p-4 flex flex-col md:flex-row items-center justify-between gap-6\">\n                          \n                          {/* Visual plate and Status badge */}\n                          <div className=\"flex flex-col items-center gap-2\">\n                            {/* Realistic Iranian Plate */}\n                            <div className=\"relative w-60 h-12 bg-white border border-neutral-300 rounded shadow flex items-center justify-between font-sans overflow-hidden select-none\" dir=\"ltr\">\n                              {/* Blue section (left) */}\n                              <div className=\"w-8 h-full bg-[#003399] flex flex-col items-center justify-between py-1 text-white text-[7px] font-bold\">\n                                <div className=\"flex flex-col gap-0.5 items-center\">\n                                  <div className=\"w-3 h-0.5 bg-[#FF0000]\" />\n                                  <div className=\"w-3 h-0.5 bg-[#FFFFFF]\" />\n                                  <div className=\"w-3 h-0.5 bg-[#009933]\" />\n                                </div>\n                                <div className=\"flex flex-col items-center text-[6px]\">\n                                  <span>I.R.</span>\n                                  <span>IRAN</span>\n                                </div>\n                              </div>\n                              \n                              {/* Left Plate Numbers */}\n                              <div className=\"flex-1 flex items-center justify-center gap-1.5 text-xl font-bold text-neutral-800 tracking-tight\">\n                                <span>{toFa(v.plateNum1)}</span>\n                                <span className=\"text-base font-normal\">{v.plateLetter}</span>\n                                <span>{toFa(v.plateNum2)}</span>\n                              </div>\n                              \n                              {/* Right Box (City Code) */}\n                              <div className=\"w-10 h-full border-l border-neutral-300 flex flex-col items-center justify-center bg-white text-neutral-800\">\n                                <span className=\"text-[7px] text-neutral-500 font-semibold -mb-0.5\">в•ӘВәв–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ</span>\n                                <span className=\"text-base font-bold tracking-tight\">{toFa(v.plateCity)}</span>\n                              </div>\n                            </div>\n\n                            {/* Status label */}\n                            {isPending && (\n                              <Badge className=\"bg-yellow-500/20 text-yellow-300 border border-yellow-500/30 px-2 py-0.5 font-semibold text-[10px] rounded-full\">\n                                в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ\n                              </Badge>\n                            )}\n                            {isApproved && (\n                              <Badge className=\"bg-success/20 text-success border border-success/30 px-2 py-0.5 font-semibold text-[10px] rounded-full\">\n                                в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ» в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•ӘВ»в”ҳв•ӣв”ҳГӘ\n                              </Badge>\n                            )}\n                            {isRejected && (\n                              <Badge className=\"bg-red-500/20 text-red-400 border border-red-500/30 px-2 py-0.5 font-semibold text-[10px] rounded-full\">\n                                в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ / в”ҳГјв•ӘВәв”ҳГ©в•ӘВ» в”ҳГ в•ӘВјв”ҳГӘв•Әв–“\n                              </Badge>\n                            )}\n                          </div>\n\n                          {/* Details details */}\n                          <div className=\"flex-1 grid grid-cols-2 md:grid-cols-3 gap-2.5 text-xs w-full text-right\">\n                            <div>\n                              <span className=\"text-foreground-muted block\">в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ:</span>\n                              <span className=\"font-semibold text-foreground mt-0.5 block\">{v.carType}</span>\n                            </div>\n                            <div>\n                              <span className=\"text-foreground-muted block\">в•Әв–’в”ҳГҘв”ҢВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ:</span>\n                              <span className=\"font-semibold text-foreground mt-0.5 block\">{v.carColor || 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}</span>\n                            </div>\n                            <div>\n                              <span className=\"text-foreground-muted block\">в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ»:</span>\n                              <span className=\"font-semibold text-foreground font-data-mono mt-0.5 block\">{toFa(v.carLicenseExpiry || 'О“ГҮГ¶')}</span>\n                            </div>\n                          </div>\n\n                          {/* Delete Action button */}\n                          <div className=\"shrink-0 flex items-center\">\n                            <Button\n                              variant=\"outline\"\n                              size=\"sm\"\n                              className=\"text-red-400 border-red-500/10 hover:bg-red-500/10 hover:border-red-500/20 h-8 gap-1 cursor-pointer\"\n                              onClick={() => handleRemoveVehicle(v.id)}\n                            >\n                              <Trash2 className=\"size-3.5\" />\n                              <span>в•ӘВЎв•Әв–‘в”ҳГј</span>\n                            </Button>\n                          </div>\n\n                        </CardContent>\n                      </Card>\n                    )\n                  })}\n                </div>\n              )}\n            </TabsContent>\n\n            {/* Tab 3: Edit Profile details & dynamic phone numbers (User can edit ALL personnel data) */}\n            <TabsContent value=\"edit\" className=\"animate-in fade-in-50 duration-200 space-y-6\">\n              \n              <form onSubmit={handleSaveForm} className=\"space-y-6\">\n                \n                {/* 1. Contact details & Dynamic phone list */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-2 border-b border-border/30\">\n                    <CardTitle className=\"text-base font-semibold\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в”ҳГ в•ӘВәв•Әв”Ӯ в”ҳГӘ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®</CardTitle>\n                    <CardDescription className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                      в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в”ҳГӘ в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"p-6 space-y-4\">\n                    \n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                      \n                      {/* Email */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"email\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•ӘВәв”ҳГӨв”ҢвҢҗв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв–ҲГ®в”ҢвҢҗ (в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ)</Label>\n                        <Input\n                          id=\"email\"\n                          type=\"email\"\n                          value={email}\n                          onChange={(e) => setEmail(e.target.value)}\n                          placeholder=\"example@mail.com\"\n                          className=\"font-mono text-left\"\n                        />\n                      </div>\n\n                      {/* Phone Numbers List Container (User requested any number of phones) */}\n                      <div className=\"space-y-3\">\n                        <div className=\"flex flex-col gap-1.5\">\n                          <Label htmlFor=\"phone\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВәв”ҳГӘв”ҳГӨ *</Label>\n                          <Input\n                            id=\"phone\"\n                            value={phone}\n                            onChange={(e) => setPhone(e.target.value)}\n                            placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в–Ҳв–‘в–Ҳв•Јв–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ўв–Ҳв•–в–Ҳв••в–Ҳв•Ј\"\n                            className=\"font-mono text-left\"\n                            required\n                          />\n                        </div>\n\n                        {/* Render additional phone inputs dynamically */}\n                        {additionalPhones.map((ph, idx) => (\n                          <div key={idx} className=\"flex flex-col gap-1.5 animate-in slide-in-from-top-1 duration-150\">\n                            <Label className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ {toFa(idx + 2)}</Label>\n                            <div className=\"flex gap-2\">\n                              <Input\n                                value={ph}\n                                onChange={(e) => handleAdditionalPhoneChange(idx, e.target.value)}\n                                placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в–Ҳв–‘в–Ҳв•Јв–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ўв–Ҳв•–в–Ҳв••в–Ҳв•Ј\"\n                                className=\"font-mono text-left flex-1\"\n                              />\n                              <Button \n                                type=\"button\" \n                                variant=\"outline\" \n                                size=\"sm\" \n                                className=\"shrink-0 text-red-400 border-red-500/20 hover:bg-red-500/10 cursor-pointer h-10 px-3\"\n                                onClick={() => handleRemoveAdditionalPhone(idx)}\n                              >\n                                <Trash2 className=\"size-4\" />\n                              </Button>\n                            </div>\n                          </div>\n                        ))}\n\n                        <Button\n                          type=\"button\"\n                          variant=\"outline\"\n                          size=\"sm\"\n                          className=\"mt-1 self-start gap-1 text-primary border-primary/20 hover:bg-primary/5 cursor-pointer text-xs\"\n                          onClick={handleAddPhoneField}\n                        >\n                          + в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n                        </Button>\n                      </div>\n\n                      {/* Address */}\n                      <div className=\"flex flex-col gap-1.5 md:col-span-2\">\n                        <Label htmlFor=\"address\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬в–ҲГ® в”ҳГ в•ӘВЎв”ҳГӨ в•Әв”Ӯв”ҢвҢҗв”ҳГӘв”ҳГҘв•ӘВ¬</Label>\n                        <Input\n                          id=\"address\"\n                          value={address}\n                          onChange={(e) => setAddress(e.target.value)}\n                          placeholder=\"в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬в–ҲГ® в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨ в•ӘВҝв”ҳГ§ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•Әв”Өв”ҳГ§в•Әв–’ в”ҳГӘ в•ӘВ«в–ҲГ®в•ӘВәв•ӘВҝв•ӘВәв”ҳГҘ\"\n                        />\n                      </div>\n\n                      {/* Phone 3 */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"phone3\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в–ҲГ®в•ӘВә в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в–Ҳв”Ӯ</Label>\n                        <Input\n                          id=\"phone3\"\n                          value={phone3}\n                          onChange={(e) => setPhone3(e.target.value)}\n                          placeholder=\"в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в–ҲГ®в•ӘВә в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВ»в–ҲГ®в”ҢВ»в•Әв–’\"\n                          className=\"font-mono text-left\"\n                        />\n                      </div>\n\n                      {/* Phone 4 */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"phone4\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в–ҲГ®в•ӘВә в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в–Ҳв”Ө</Label>\n                        <Input\n                          id=\"phone4\"\n                          value={phone4}\n                          onChange={(e) => setPhone4(e.target.value)}\n                          placeholder=\"в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в–ҲГ®в•ӘВә в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВ»в–ҲГ®в”ҢВ»в•Әв–’\"\n                          className=\"font-mono text-left\"\n                        />\n                      </div>\n\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 2. Personal identification fields (ALL of them are editable now!) */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-2 border-b border-border/30\">\n                    <CardTitle className=\"text-base font-semibold\">в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГӘ в”ҳГјв•Әв–’в•ӘВ»в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</CardTitle>\n                    <CardDescription className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                      в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•ӘВЎв”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"p-6\">\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                      \n                      {/* Father Name */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"father_name\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•ӘВ»в•Әв–’</Label>\n                        <Input\n                          id=\"father_name\"\n                          value={fatherName}\n                          onChange={(e) => setFatherName(e.target.value)}\n                          placeholder=\"в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•ӘВ»в•Әв–’\"\n                        />\n                      </div>\n\n                      {/* ID Number */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"id_number\" className=\"text-right text-xs font-semibold text-foreground\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</Label>\n                        <Input\n                          id=\"id_number\"\n                          value={idNumber}\n                          onChange={(e) => setIdNumber(e.target.value)}\n                          placeholder=\"в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§\"\n                          className=\"font-mono text-right\"\n                        />\n                      </div>\n\n                      {/* Birth Date */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"birth_date\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»</Label>\n                        <Input\n                          id=\"birth_date\"\n                          value={birthDate}\n                          onChange={(e) => setBirthDate(e.target.value)}\n                          placeholder=\"в–Ҳв–’в–Ҳв”Ӯв–Ҳв•–в–Ҳв–‘/в–Ҳв–‘в–Ҳв•Ў/в–Ҳв–’в–Ҳв–“\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* Age */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"age\" className=\"text-right text-xs font-semibold text-foreground\">в•Әв”Ӯв”ҳГҘ</Label>\n                        <Input\n                          id=\"age\"\n                          value={age}\n                          onChange={(e) => setAge(e.target.value)}\n                          placeholder=\"в•Әв”Ӯв”ҳГҘ\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* Birth Place */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"birth_place\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГ в•ӘВЎв”ҳГӨ в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»</Label>\n                        <Input\n                          id=\"birth_place\"\n                          value={birthPlace}\n                          onChange={(e) => setBirthPlace(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВЎв”ҳГӨ в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»\"\n                        />\n                      </div>\n\n                      {/* Marital Status */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"marital_status\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘВәв”ҳГ§в”ҳГӨ / в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в”ҳГјв•Әв–’в•Әв–“в”ҳГҘв•ӘВ»</Label>\n                        <Input\n                          id=\"marital_status\"\n                          value={maritalStatus}\n                          onChange={(e) => setMaritalStatus(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: в”ҳГ в•ӘВ¬в•ӘВәв”ҳГ§в”ҳГӨ - в–Ҳв–“ в”ҳГјв•Әв–’в•Әв–“в”ҳГҘв•ӘВ»\"\n                        />\n                      </div>\n\n                      {/* Insurance No */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"insurance_no\" className=\"text-right text-xs font-semibold text-foreground\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВ«в”ҳГӘв”ҳГҘв–ҲГ® / в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВҝв–ҲГ®в”ҳГ в”ҳГ§</Label>\n                        <Input\n                          id=\"insurance_no\"\n                          value={insuranceNo}\n                          onChange={(e) => setInsuranceNo(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: O в”ҳГ в•ӘВҪв•ӘВҝв•ӘВ¬ - в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВҝв–ҲГ®в”ҳГ в”ҳГ§ в–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ў\"\n                        />\n                      </div>\n\n                      {/* Education */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"education\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•ӘВ¬в•ӘВЎв•Әв•Ўв–ҲГ®в”ҳГӨв–ҲГ®</Label>\n                        <Input\n                          id=\"education\"\n                          value={education}\n                          onChange={(e) => setEducation(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ в”ҳГӘ в•Әв–’в•Әв”Өв•ӘВ¬в”ҳГ§ в•ӘВ¬в•ӘВЎв•Әв•Ўв–ҲГ®в”ҳГӨв–ҲГ®\"\n                        />\n                      </div>\n\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 3. Job & Org details (Editable now!) */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-2 border-b border-border/30\">\n                    <CardTitle className=\"text-base font-semibold\">в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ® в”ҳГӘ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</CardTitle>\n                    <CardDescription className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                      в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®в•ӘВәв•ӘВ¬ в”ҳГ в•Әв–’в•ӘВҝв”ҳГӘв•Әв•– в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬в•ӘГ® в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГ в•ӘВЎв”ҳГӨ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв•Әв–’ в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҳГӨв•Әв–“в”ҳГӘв”ҳГ  в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"p-6\">\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                      \n                      {/* Personnel No */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"personnel_no\" className=\"text-right text-xs font-semibold text-foreground\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®</Label>\n                        <Input\n                          id=\"personnel_no\"\n                          value={personnelNo}\n                          onChange={(e) => setPersonnelNo(e.target.value)}\n                          placeholder=\"в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®\"\n                          className=\"font-mono text-left\"\n                        />\n                      </div>\n\n                      {/* Post */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"post\" className=\"text-right text-xs font-semibold text-foreground\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®</Label>\n                        <Input\n                          id=\"post\"\n                          value={post}\n                          onChange={(e) => setPost(e.target.value)}\n                          placeholder=\"в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬\"\n                        />\n                      </div>\n\n                      {/* Group */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"group\" className=\"text-right text-xs font-semibold text-foreground\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬</Label>\n                        <select\n                          id=\"group\"\n                          value={group}\n                          onChange={(e) => setGroup(e.target.value)}\n                          className=\"h-10 w-full rounded-lg border border-border bg-surface px-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent cursor-pointer\"\n                        >\n                          <option value=\"A\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВәв”ҳГӨв”ҳГј (A)</option>\n                          <option value=\"B\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВҝ (B)</option>\n                          <option value=\"C\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВј (C)</option>\n                          <option value=\"D\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВ» (D)</option>\n                          <option value=\"Staff\">в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® / в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®</option>\n                        </select>\n                      </div>\n\n                      {/* Shift Name */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"shift_name\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГҘв•ӘВәв”ҳГ  в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®</Label>\n                        <Input\n                          id=\"shift_name\"\n                          value={shift}\n                          onChange={(e) => setShift(e.target.value)}\n                          placeholder=\"в”ҳГҘв•ӘВәв”ҳГ  в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®\"\n                        />\n                      </div>\n\n                      {/* Shift Type */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"shift_type\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®</Label>\n                        <Input\n                          id=\"shift_type\"\n                          value={shiftType}\n                          onChange={(e) => setShiftType(e.target.value)}\n                          placeholder=\"в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®\"\n                        />\n                      </div>\n\n                      {/* Start Location */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"start_location\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВҝв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’</Label>\n                        <Input\n                          id=\"start_location\"\n                          value={startLocation}\n                          onChange={(e) => setStartLocation(e.target.value)}\n                          placeholder=\"в”ҳГҘв•ӘВәв”ҳГ  в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј\"\n                        />\n                      </div>\n\n                      {/* Hire Date */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"hire_date\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ  / в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ®</Label>\n                        <Input\n                          id=\"hire_date\"\n                          value={hireDate}\n                          onChange={(e) => setHireDate(e.target.value)}\n                          placeholder=\"в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ \"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* 4. Safety & Qualifications (Editable now!) */}\n                <Card className=\"border-border/60 shadow-sm\">\n                  <CardHeader className=\"p-4 pb-2 border-b border-border/30\">\n                    <CardTitle className=\"text-base font-semibold\">в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв•ӘГ® в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГ§в”ҳГ  в”ҢвҢҗв•ӘВәв•Әв–’в”ҢвҢҗв•Әв–’в•ӘВ»</CardTitle>\n                    <CardDescription className=\"text-xs text-foreground-muted mt-1 leading-normal\">\n                      в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГ в•Әв–’в•ӘВҝв”ҳГӘв•Әв•– в•ӘВҝв”ҳГ§ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГӘ в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГ§в”ҳГ в–ҲГ®в”ҳГ§ в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ в•ӘВәв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"p-6\">\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                      \n                      {/* Driving Status */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"driving_status\" className=\"text-right text-xs font-semibold text-foreground\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’</Label>\n                        <Input\n                          id=\"driving_status\"\n                          value={drivingStatus}\n                          onChange={(e) => setDrivingStatus(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ\"\n                        />\n                      </div>\n\n                      {/* Medical validity */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"medical_validity\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв”ҳГ§ в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ®</Label>\n                        <Input\n                          id=\"medical_validity\"\n                          value={medicalExamValidity}\n                          onChange={(e) => setMedicalExamValidity(e.target.value)}\n                          placeholder=\"в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ®\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* License Class 1 */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"license_class1\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’</Label>\n                        <Input\n                          id=\"license_class1\"\n                          value={licenseClass1Date}\n                          onChange={(e) => setLicenseClass1Date(e.target.value)}\n                          placeholder=\"в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* License Class 2 */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"license_class2\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“</Label>\n                        <Input\n                          id=\"license_class2\"\n                          value={licenseClass2Date}\n                          onChange={(e) => setLicenseClass2Date(e.target.value)}\n                          placeholder=\"в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* Driver Percent */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"driver_percent\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’</Label>\n                        <Input\n                          id=\"driver_percent\"\n                          value={driverPercent}\n                          onChange={(e) => setDriverPercent(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в–Ҳв–’в–Ҳв–‘в–Ҳв–‘\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* Co-Driver Percent */}\n                      <div className=\"flex flex-col gap-1.5\">\n                        <Label htmlFor=\"co_driver_percent\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в”ҢвҢҗв”ҳГ в”ҢвҢҗ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</Label>\n                        <Input\n                          id=\"co_driver_percent\"\n                          value={coDriverPercent}\n                          onChange={(e) => setCoDriverPercent(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в–Ҳв•Ўв–Ҳв–‘\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                      {/* Trainee Driver Percent */}\n                      <div className=\"flex flex-col gap-1.5 md:col-span-2\">\n                        <Label htmlFor=\"trainee_percent\" className=\"text-right text-xs font-semibold text-foreground\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®</Label>\n                        <Input\n                          id=\"trainee_percent\"\n                          value={traineeDriverPercent}\n                          onChange={(e) => setTraineeDriverPercent(e.target.value)}\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в–Ҳв•Ўв–Ҳв–‘\"\n                          className=\"font-mono text-center\"\n                        />\n                      </div>\n\n                    </div>\n                  </CardContent>\n                </Card>\n\n                {/* Error Alerts inside form */}\n                {error && (\n                  <div className=\"rounded-lg border border-critical/20 bg-critical/10 p-3 text-xs text-critical flex items-center gap-2\">\n                    <AlertCircle className=\"size-4 shrink-0\" />\n                    <span>{error}</span>\n                  </div>\n                )}\n\n                {success && (\n                  <div className=\"rounded-lg border border-success/20 bg-success/10 p-3 text-xs text-success flex items-center gap-2\">\n                    <CheckCircle2 className=\"size-4 shrink-0\" />\n                    <span>{success}</span>\n                  </div>\n                )}\n\n                {/* Form Submit Action */}\n                <div className=\"flex justify-end gap-2 pt-4 border-t border-border/40\">\n                  <Button \n                    type=\"submit\" \n                    size=\"sm\"\n                    disabled={saving}\n                    className=\"gap-2 cursor-pointer\"\n                  >\n                    {saving ? (\n                      <>\n                        <Loader2 className=\"size-3.5 animate-spin\" />\n                        <span>в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»в–ҲГ®в”ҳГ§...</span>\n                      </>\n                    ) : (\n                      <>\n                        <CheckCircle2 className=\"size-3.5\" />\n                        <span>в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘ в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»</span>\n                      </>\n                    )}\n                  </Button>\n                </div>\n              </form>\n            </TabsContent>\n\n            {/* Tab 4: Activity Timeline */}\n            <TabsContent value=\"timeline\" className=\"animate-in fade-in-50 duration-200\">\n              <Card className=\"border-border/60 shadow-sm\">\n                <CardHeader className=\"flex flex-row items-center justify-between p-4 pb-3\">\n                  <div className=\"space-y-1 text-right\">\n                    <CardTitle className=\"text-base font-semibold\">в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®</CardTitle>\n                    <CardDescription className=\"text-xs text-foreground-muted leading-normal\">\n                      в•ӘГів•ӘВ«в•Әв–’в–ҲГ®в”ҳГҘ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВәв•ӘГ® в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в”ҳГӘ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ»в•Әв–’ в”ҳв•ӣв”ҳГҘв”ҳГӨ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в•Әв”Өв”ҳГ в•ӘВә.\n                    </CardDescription>\n                  </div>\n                  <Button \n                    variant=\"outline\" \n                    size=\"sm\" \n                    onClick={loadAuditLogs}\n                    disabled={logsLoading}\n                    className=\"gap-1.5 h-8 shrink-0 cursor-pointer\"\n                  >\n                    {logsLoading ? (\n                      <Loader2 className=\"size-3.5 animate-spin\" />\n                    ) : (\n                      <Activity className=\"size-3.5\" />\n                    )}\n                    <span>в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ®</span>\n                  </Button>\n                </CardHeader>\n                <CardContent className=\"p-4 pt-1\">\n                  {logsLoading && auditLogs.length === 0 ? (\n                    <div className=\"flex flex-col items-center justify-center p-8 text-foreground-muted gap-2\">\n                      <Loader2 className=\"size-6 animate-spin text-primary\" />\n                      <span className=\"text-xs\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВә...</span>\n                    </div>\n                  ) : auditLogs.length === 0 ? (\n                    <div className=\"flex flex-col items-center justify-center p-12 text-foreground-muted gap-2 border border-dashed border-border/60 rounded-lg\">\n                      <Clock className=\"size-8 opacity-40\" />\n                      <span className=\"text-xs font-medium\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Өв–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»</span>\n                    </div>\n                  ) : (\n                    <div className=\"relative border-r border-border/80 pr-4 mr-2 py-4 space-y-6\">\n                      {auditLogs.map((log) => {\n                        const dateStr = jalali(log.createdAt)\n                        const timeStr = faTime(log.createdAt)\n                        \n                        return (\n                          <div key={log.id} className=\"relative\">\n                            {/* Point on timeline */}\n                            <div className=\"absolute -right-[21px] top-1.5 size-2.5 rounded-full border bg-background\" style={{ borderColor: activeTheme }} />\n\n                            {/* Row structure */}\n                            <div className=\"flex flex-col md:flex-row md:items-start justify-between gap-2 border border-border/40 bg-surface-container-low/30 rounded-lg p-3 hover:bg-surface-container-low/60 transition-colors\">\n                              <div className=\"space-y-1.5 text-right\">\n                                <p className=\"text-sm font-semibold text-foreground\">\n                                  {translateAuditLog(log)}\n                                </p>\n                                <div className=\"flex flex-wrap items-center gap-2\">\n                                  <Badge variant=\"outline\" className=\"text-[10px] px-1.5 py-0\">\n                                    {log.entity}\n                                  </Badge>\n                                  <span className=\"text-[10px] text-foreground-muted font-sans\">\n                                    в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§: <span className=\"font-data-mono\">{log.id.slice(0, 8)}</span>\n                                  </span>\n                                </div>\n                              </div>\n                              \n                              <div className=\"flex items-center gap-1.5 justify-end shrink-0 text-xs text-foreground-muted font-data-mono bg-surface px-2 py-0.5 rounded border border-border/40\">\n                                <span>{dateStr}</span>\n                                <span>-</span>\n                                <span>{timeStr}</span>\n                              </div>\n                            </div>\n                          </div>\n                        )\n                      })}\n                    </div>\n                  )}\n                </CardContent>\n              </Card>\n            </TabsContent>\n          </Tabs>\n        </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\roster\\upload\\page.tsx","messages":[{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from 'react-hooks/set-state-in-effect').","line":80,"column":3,"severity":1,"nodeType":null,"fix":{"range":[2068,2120],"text":" "}},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadHistory'. Either include it or remove the dependency array.","line":85,"column":6,"nodeType":"ArrayExpression","endLine":85,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadHistory]","fix":{"range":[2200,2213],"text":"[accessToken, loadHistory]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":1,"source":"'use client'\n\nimport { useState, useEffect } from 'react'\nimport { FileDrop } from '@/components/shared/file-drop'\nimport { toFa } from '@/lib/fa'\nimport { useAuthStore } from '@/features/auth'\nimport { \n  UploadCloud, \n  Sparkles, \n  FileText, \n  CheckCircle2, \n  Archive, \n  AlertTriangle, \n  Check, \n  HelpCircle,\n  Clock,\n  Loader2\n} from 'lucide-react'\n\ninterface ImportResult {\n  rosterFileId: string\n  successCount: number\n  errorCount: number\n  totalRows: number\n  errors: Array<{ row: number; nationalId: string; reason: string }>\n  needsReview: boolean\n  rows?: Array<{ nationalId: string; name: string; date: string; code: string }>\n}\n\ninterface RosterHistoryItem {\n  id: string\n  fileName: string\n  period: string\n  createdAt: string\n  uploader: {\n    name: string\n  }\n}\n\nexport default function RosterUploadPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const [loading, setLoading] = useState(false)\n  const [confirmLoading, setConfirmLoading] = useState(false)\n  const [result, setResult] = useState<ImportResult | null>(null)\n  const [rosterFileId, setRosterFileId] = useState<string | null>(null)\n  const [history, setHistory] = useState<RosterHistoryItem[]>([])\n  \n  // Roster Metadata fields\n  const [directiveNumber, setDirectiveNumber] = useState('DIR-1403-04-01')\n  const [directiveSubject, setDirectiveSubject] = useState('')\n  const [mandatoryReceipt, setMandatoryReceipt] = useState(true)\n\n  // Notification status\n  const [notification, setNotification] = useState<{\n    type: 'success' | 'error'\n    text: string\n  } | null>(null)\n\n  useEffect(() => {\n    if (notification) {\n      const timer = setTimeout(() => setNotification(null), 4000)\n      return () => clearTimeout(timer)\n    }\n  }, [notification])\n\n  async function loadHistory() {\n    try {\n      const res = await fetch('/api/roster/upload', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setHistory(data.data || [])\n      }\n    } catch {\n      // silent\n    }\n  }\n\n  /* eslint-disable react-hooks/set-state-in-effect */\n  useEffect(() => {\n    if (accessToken) {\n      void loadHistory()\n    }\n  }, [accessToken])\n\n  async function handleUpload(file: File) {\n    setLoading(true)\n    setResult(null)\n    setRosterFileId(null)\n    try {\n      const formData = new FormData()\n      formData.append('file', file)\n      formData.append('directiveNumber', directiveNumber)\n      formData.append('directiveSubject', directiveSubject)\n      formData.append('mandatoryReceipt', String(mandatoryReceipt))\n\n      const res = await fetch('/api/roster/upload', {\n        method: 'POST',\n        headers: { Authorization: `Bearer ${accessToken}` },\n        body: formData,\n      })\n\n      const data = await res.json()\n      if (res.ok && data.data) {\n        setResult(data.data)\n        setRosterFileId(data.data.rosterFileId)\n        setNotification({\n          type: 'success',\n          text: 'в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в”ҳГӘ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ». в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГҘ в•ӘВ»в”ҢвҢҗв”ҳГ в”ҳГ§ в”¬ВҪв•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’в”¬в•— в•Әв–’в•ӘВә в•ӘВҝв•Әв–“в”ҳГҘв–ҲГ®в•ӘВ».',\n        })\n        loadHistory()\n      } else {\n        setResult({\n          rosterFileId: '',\n          successCount: 0,\n          errorCount: 1,\n          totalRows: 0,\n          errors: [{ row: 0, nationalId: '', reason: data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ' }],\n          needsReview: false,\n          rows: [],\n        })\n      }\n    } catch {\n      setResult({\n        rosterFileId: '',\n        successCount: 0,\n        errorCount: 1,\n        totalRows: 0,\n        errors: [{ row: 0, nationalId: '', reason: 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в–ҲГ® в•ӘВ»в•Әв–’ в•ӘГів”ҳв•ӣв”ҳГӨв”ҳГӘв•ӘВ» в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ' }],\n        needsReview: false,\n        rows: [],\n      })\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  // Handle Roster Confirmation\n  async function handleConfirmRoster() {\n    if (!accessToken || !rosterFileId) return\n    setConfirmLoading(true)\n    try {\n      const res = await fetch(`/api/roster/upload/${rosterFileId}/confirm`, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n      })\n      const data = await res.json()\n      if (res.ok) {\n        setNotification({\n          type: 'success',\n          text: data.message || 'в•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в”ҳГ в”ҳГҘв•ӘВ¬в•Әв”Өв•Әв–’ в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ».',\n        })\n        setResult(null)\n        setRosterFileId(null)\n        loadHistory()\n      } else {\n        setNotification({\n          type: 'error',\n          text: data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬',\n        })\n      }\n    } catch {\n      setNotification({\n        type: 'error',\n        text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•Әв–’в”ҳГ©в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’',\n      })\n    } finally {\n      setConfirmLoading(false)\n    }\n  }\n\n  const shiftLabels: Record<string, string> = {\n    morning: 'в•Әв•Ўв•ӘВҝв•ӘВЎ',\n    evening: 'в•Әв•Јв•Әв•Ўв•Әв–’',\n    night: 'в•Әв”Өв•ӘВҝ',\n    off: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬',\n  }\n\n  const shiftColors: Record<string, string> = {\n    morning: 'bg-success/15 text-success border-success/30',\n    evening: 'bg-info/15 text-info border-info/30',\n    night: 'bg-surface-container-highest text-foreground-muted border-outline-variant',\n    off: 'bg-background-subtle text-foreground-muted border-border-subtle border-dashed',\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-6 max-w-7xl mx-auto w-full\" dir=\"rtl\">\n      {/* Page Header */}\n      <div className=\"flex justify-between items-end border-b border-border pb-4\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg-mobile md:text-headline-lg text-foreground flex items-center gap-2\">\n            <UploadCloud className=\"size-6 text-accent\" />\n            в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘в–ҲГ®в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә\n          </h1>\n          <p className=\"text-sm text-foreground-muted mt-1\">\n            в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ®в•ӘГ® в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ\n          </p>\n        </div>\n      </div>\n\n      {/* Notifications */}\n      {notification && (\n        <div\n          className={`p-4 rounded-xl border text-sm animate-in fade-in duration-200 ${\n            notification.type === 'success'\n              ? 'bg-success/15 border-success/30 text-success'\n              : 'bg-critical/15 border-critical/30 text-critical'\n          }`}\n        >\n          {notification.text}\n        </div>\n      )}\n\n      {/* Bento Grid Layout */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Left Column: Upload & Directive Details */}\n        <div className=\"lg:col-span-1 space-y-6\">\n          \n          {/* File Upload Zone */}\n          <div className=\"bg-surface border border-outline-variant rounded-xl p-5 shadow-sm\">\n            <h2 className=\"text-base font-semibold text-foreground mb-4 flex items-center gap-2\">\n              <UploadCloud className=\"size-5 text-accent\" />\n              в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§\n            </h2>\n            \n            <FileDrop\n              accept=\".xlsx,.xls\"\n              onFile={handleUpload}\n              disabled={loading || confirmLoading}\n            />\n\n            <button\n              onClick={() => {}}\n              disabled={loading || confirmLoading}\n              className=\"w-full mt-4 bg-accent text-accent-foreground font-medium text-sm py-2.5 rounded-lg hover:bg-accent-hover transition-colors flex items-center justify-center gap-2 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed\"\n            >\n              <Sparkles className=\"size-4 animate-pulse\" />\n              в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ»\n            </button>\n          </div>\n\n          {/* Directive Details */}\n          <div className=\"bg-surface border border-outline-variant rounded-xl p-5 shadow-sm\">\n            <h2 className=\"text-base font-semibold text-foreground mb-4 flex items-center gap-2\">\n              <FileText className=\"size-5 text-critical\" />\n              в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®в•ӘВәв•ӘВ¬ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘в–ҲГ®в”ҳГ§\n            </h2>\n            \n            <div className=\"space-y-4\">\n              <div>\n                <label className=\"block text-xs font-semibold text-foreground-muted mb-1.5\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘в–ҲГ®в”ҳГ§</label>\n                <input\n                  type=\"text\"\n                  value={directiveNumber}\n                  onChange={(e) => setDirectiveNumber(e.target.value)}\n                  className=\"w-full bg-surface-container-low border border-outline-variant rounded-lg px-3 py-2 text-sm text-foreground font-mono focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all\"\n                />\n              </div>\n\n              <div>\n                <label className=\"block text-xs font-semibold text-foreground-muted mb-1.5\">в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в•ӘВәв•ӘВҝв”ҳГӨв•ӘВәв•Әв•‘в–ҲГ®в”ҳГ§</label>\n                <input\n                  type=\"text\"\n                  placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§ в•Әв”Ӯв”ҳГӘв”ҳГ  в•ӘГів•Әв–‘в•Әв–’\"\n                  value={directiveSubject}\n                  onChange={(e) => setDirectiveSubject(e.target.value)}\n                  className=\"w-full bg-surface-container-low border border-outline-variant rounded-lg px-3 py-2 text-sm text-foreground focus:border-accent focus:ring-1 focus:ring-accent outline-none transition-all\"\n                />\n              </div>\n\n              <div className=\"flex items-center justify-between mt-4 p-3 bg-surface-container-low/50 border border-outline-variant/80 rounded-lg\">\n                <span className=\"text-xs font-semibold text-foreground\">в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв–’в•ӘГұв–ҲГ®в•ӘВ¬ в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ®</span>\n                <label className=\"relative inline-flex items-center cursor-pointer\">\n                  <input\n                    type=\"checkbox\"\n                    checked={mandatoryReceipt}\n                    onChange={(e) => setMandatoryReceipt(e.target.checked)}\n                    className=\"sr-only peer\"\n                  />\n                  <div className=\"w-9 h-5 bg-surface-container-high peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-surface-container-low after:content-[''] after:absolute after:top-[2px] after:right-[2px] after:bg-foreground-muted after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-accent peer-checked:after:bg-accent-foreground\"></div>\n                </label>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Right Column: Extraction Preview & History */}\n        <div className=\"lg:col-span-2 space-y-6\">\n          \n          {/* Extraction Preview */}\n          <div className=\"bg-surface-container border border-outline-variant rounded-xl flex flex-col shadow-sm overflow-hidden min-h-[300px]\">\n            <div className=\"p-4 border-b border-outline-variant bg-surface-container/60 flex justify-between items-center\">\n              <div>\n                <h2 className=\"text-base font-semibold text-foreground\">в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј</h2>\n                <p className=\"text-xs text-foreground-muted mt-0.5\">в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•Әв–’в•ӘВ»в–ҲГ®в”ҳГјО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•ӘВ»в•ӘВәв•Әв–“в•Әв”Ө в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”Ө в•ӘВәв•Әв–“ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ®</p>\n              </div>\n              \n              {result && (\n                <div className=\"flex gap-2\">\n                  <button \n                    onClick={() => {\n                      setResult(null)\n                      setRosterFileId(null)\n                    }}\n                    disabled={confirmLoading}\n                    className=\"px-3 py-1.5 border border-outline-variant rounded-lg text-xs text-foreground hover:bg-surface-container-high transition-colors cursor-pointer\"\n                  >\n                    в”ҳв•ӣв•ӘВәв”ҢвҢҗ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ\n                  </button>\n                  <button \n                    onClick={handleConfirmRoster}\n                    disabled={confirmLoading}\n                    className=\"px-3 py-1.5 bg-accent text-accent-foreground rounded-lg text-xs font-medium hover:bg-accent-hover transition-colors shadow-sm flex items-center gap-1 cursor-pointer\"\n                  >\n                    {confirmLoading ? (\n                      <Loader2 className=\"size-3.5 animate-spin\" />\n                    ) : (\n                      <Check className=\"size-3.5\" />\n                    )}\n                    в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ®\n                  </button>\n                </div>\n              )}\n            </div>\n\n            {loading ? (\n              <div className=\"flex-1 flex flex-col items-center justify-center p-8 text-center\">\n                <div className=\"size-8 border-4 border-accent/20 border-t-accent rounded-full animate-spin mb-3\"></div>\n                <p className=\"text-sm text-foreground-muted font-medium\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в”ҳв•ӣв•Әв–’в•ӘВ»в•ӘВәв•Әв–“в•Әв”Ө в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§...</p>\n                <p className=\"text-xs text-foreground-muted mt-1\">в•ӘВ¬в•Әв•–в•ӘВҝв–ҲГ®в”ҳГ© в”ҢвҢҗв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в”ҳГӘ в”ҢвҢҗв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§</p>\n              </div>\n            ) : result ? (\n              <div className=\"flex-1 flex flex-col\">\n                {/* Result Statistics */}\n                <div className=\"grid grid-cols-3 divide-x divide-x-reverse divide-outline-variant border-b border-outline-variant bg-surface-container-low/20\">\n                  <div className=\"p-3 text-center\">\n                    <div className=\"text-lg font-bold text-foreground\">{toFa(result.totalRows)}</div>\n                    <div className=\"text-[10px] text-foreground-muted font-medium mt-0.5\">в”ҢвҢҗв”ҳГӨ в•Әв–’в•ӘВ»в–ҲГ®в”ҳГјО“ГҮГ®в”ҳГ§в•ӘВә</div>\n                  </div>\n                  <div className=\"p-3 text-center\">\n                    <div className=\"text-lg font-bold text-success\">{toFa(result.successCount)}</div>\n                    <div className=\"text-[10px] text-foreground-muted font-medium mt-0.5\">в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©</div>\n                  </div>\n                  <div className=\"p-3 text-center\">\n                    <div className=\"text-lg font-bold text-critical\">{toFa(result.errorCount)}</div>\n                    <div className=\"text-[10px] text-foreground-muted font-medium mt-0.5\">в•ӘВ»в•ӘВәв•Әв–’в•ӘВәв–ҲГ® в•ӘВ«в•Әв•–в•ӘВә</div>\n                  </div>\n                </div>\n\n                {/* Successful Rows Table */}\n                {result.rows && result.rows.length > 0 && (\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-right border-collapse\">\n                      <thead className=\"bg-surface-container-low/40 border-b border-outline-variant\">\n                        <tr>\n                          <th className=\"px-4 py-2 text-xs font-semibold text-foreground-muted\">в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®</th>\n                          <th className=\"px-4 py-2 text-xs font-semibold text-foreground-muted\">в”ҳГҘв•ӘВәв”ҳГ </th>\n                          <th className=\"px-4 py-2 text-xs font-semibold text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«</th>\n                          <th className=\"px-4 py-2 text-xs font-semibold text-foreground-muted\">в”ҢвҢҗв•ӘВ» в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-outline-variant bg-surface-container/10\">\n                        {result.rows.map((row, idx) => (\n                          <tr key={idx} className=\"hover:bg-surface-container-high/40 transition-colors\">\n                            <td className=\"px-4 py-2.5 text-xs text-foreground font-mono\">{toFa(row.nationalId)}</td>\n                            <td className=\"px-4 py-2.5 text-xs text-foreground\">{row.name || 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}</td>\n                            <td className=\"px-4 py-2.5 text-xs text-foreground font-mono\">{toFa(row.date)}</td>\n                            <td className=\"px-4 py-2.5 text-xs\">\n                              <span className={`inline-block px-2 py-0.5 text-[10px] font-bold border rounded-sm ${shiftColors[row.code] ?? ''}`}>\n                                {shiftLabels[row.code] || row.code}\n                              </span>\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n\n                {/* Error Rows Report */}\n                {result.errors.length > 0 && (\n                  <div className=\"p-4 bg-critical/5 border-t border-outline-variant\">\n                    <h3 className=\"text-xs font-semibold text-red-400 mb-2 flex items-center gap-1\">\n                      <AlertTriangle className=\"size-4\" />\n                      в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в•ӘВ«в•Әв•–в•ӘВәв”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј (в•Әв–’в•ӘВ»в–ҲГ®в”ҳГјО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГ в•ӘВ¬в•Әв•Јв”ҳГ§в•ӘВ» в•ӘВҝв”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГҘв•ӘВ»)\n                    </h3>\n                    <div className=\"max-h-48 overflow-y-auto space-y-1.5 pr-1\">\n                      {result.errors.map((err, idx) => (\n                        <div key={idx} className=\"flex items-start gap-2 bg-critical/10 border border-critical/20 rounded-lg p-2.5 text-xs text-critical\">\n                          <span className=\"font-mono bg-critical/10 border border-critical/30 px-1.5 py-0.5 rounded text-[10px]\">\n                            в•Әв–’в•ӘВ»в–ҲГ®в”ҳГј {toFa(err.row)}\n                          </span>\n                          <span className=\"flex-1 leading-relaxed\">{err.reason}</span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                )}\n              </div>\n            ) : (\n              <div className=\"flex-1 flex flex-col items-center justify-center p-8 text-center\">\n                <div className=\"size-12 rounded-full bg-surface-container-low flex items-center justify-center border border-outline-variant text-foreground-muted mb-3\">\n                  <HelpCircle className=\"size-6\" />\n                </div>\n                <p className=\"text-sm text-foreground-muted font-medium\">в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨв–ҲГ® в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬</p>\n                <p className=\"text-xs text-foreground-muted mt-1\">в–ҲГ®в”ҢвҢҗ в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ в•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в”ҳв•ӣв”ҳГҘв”ҳГӨ в•Әв”Ӯв”ҳГ в•ӘВ¬ в”ҢГҘв”ҳв•ӣ в•ӘВҝв”ҢвҢҗв•Әв”Өв–ҲГ®в•ӘВ» в–ҲГ®в•ӘВә в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»</p>\n              </div>\n            )}\n          </div>\n\n          {/* History/Archive */}\n          <div className=\"bg-surface border border-outline-variant rounded-xl p-5 shadow-sm\">\n            <div className=\"flex justify-between items-center mb-4\">\n              <h2 className=\"text-base font-semibold text-foreground flex items-center gap-2\">\n                <Clock className=\"size-5 text-critical\" />\n                в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§\n              </h2>\n            </div>\n            \n            <div className=\"space-y-3\">\n              {history.length > 0 ? (\n                history.map((item, idx) => (\n                  <div key={item.id} className=\"flex items-center justify-between p-3 border border-outline-variant rounded-lg hover:bg-surface-container-low/50 transition-colors bg-surface-container-low/10\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"w-9 h-9 bg-surface-container-high rounded flex items-center justify-center text-foreground-muted border border-outline-variant/50\">\n                        <FileText className=\"size-4\" />\n                      </div>\n                      <div>\n                        <p className=\"text-sm font-semibold text-foreground\">{item.fileName}</p>\n                        <div className=\"flex items-center gap-2 mt-1 text-[10px] text-foreground-muted\">\n                          <span>в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’: {item.uploader.name}</span>\n                          <span>О“ГҮГі</span>\n                          <span className=\"font-mono\">{toFa(new Date(item.createdAt).toLocaleDateString('fa-IR'))}</span>\n                        </div>\n                      </div>\n                    </div>\n                    <div>\n                      {idx === 0 ? (\n                        <span className=\"px-2 py-0.5 bg-success/15 text-success border border-success/30 rounded text-[10px] font-bold flex items-center gap-1\">\n                          <CheckCircle2 className=\"size-3\" /> в”ҳГ в”ҳГҘв•ӘВ¬в•Әв”Өв•Әв–’ в•Әв”Өв•ӘВ»в”ҳГ§\n                        </span>\n                      ) : (\n                        <span className=\"px-2 py-0.5 bg-surface-container-high text-foreground-muted border border-outline-variant rounded text-[10px] font-bold flex items-center gap-1\">\n                          <Archive className=\"size-3\" /> в•ӘВҝв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГҘв–ҲГ®\n                        </span>\n                      )}\n                    </div>\n                  </div>\n                ))\n              ) : (\n                <p className=\"text-xs text-foreground-muted text-center py-4\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГ©в•ӘВҝв”ҳГӨв•ӘВәв”ҳГҜ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n              )}\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\shifts\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\swap\\inbox\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'toFa' is defined but never used.","line":12,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":12,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"toFa"},"fix":{"range":[356,361],"text":""},"desc":"Remove unused variable \"toFa\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Button } from '@/components/ui/button'\nimport { Badge } from '@/components/ui/badge'\nimport {\n  Card,\n  CardContent,\n} from '@/components/ui/card'\nimport { ArrowLeftRight, Clock, User, Calendar, Check, X, Inbox } from 'lucide-react'\nimport { toFa, jalali, faTime } from '@/lib/fa'\n\ninterface SwapRequest {\n  id: string\n  status: string\n  note: string | null\n  createdAt: string\n  requester: { id: string; name: string; nationalId: string }\n  target: { id: string; name: string; nationalId: string }\n  sourceShift: { id: string; date: string; code: string }\n  targetShift: { id: string; date: string; code: string }\n}\n\nconst STATUS_LABELS: Record<string, string> = {\n  pending: 'в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»',\n  approved: 'в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§',\n  rejected: 'в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§',\n}\n\nconst STATUS_CLASSES: Record<string, string> = {\n  pending: 'bg-warning/10 text-warning border-warning/20',\n  approved: 'bg-success/10 text-success border-success/20',\n  rejected: 'bg-accent/10 text-accent border-accent/20',\n}\n\nconst SHIFT_LABELS: Record<string, string> = {\n  morning: 'в•Әв•Ўв•ӘВҝв•ӘВЎ',\n  evening: 'в•Әв•Јв•Әв•Ўв•Әв–’',\n  night: 'в•Әв”Өв•ӘВҝ',\n  off: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬',\n}\n\nconst SHIFT_CLASSES: Record<string, string> = {\n  morning: 'bg-success/15 text-success border-success/30',\n  evening: 'bg-info/15 text-info border-info/30',\n  night: 'bg-neutral-800 text-foreground-muted border-neutral-700',\n  off: 'bg-background-subtle text-foreground-muted border-border-subtle',\n}\n\nexport default function SwapInboxPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const user = useAuthStore((s) => s.user)\n  const [requests, setRequests] = useState<SwapRequest[]>([])\n  const [loading, setLoading] = useState(true)\n  const [actionLoading, setActionLoading] = useState<string | null>(null)\n  const [error, setError] = useState<string | null>(null)\n\n  useEffect(() => {\n    async function load() {\n      try {\n        const res = await fetch('/api/swap-requests/inbox', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        })\n        if (res.ok) {\n          const data = await res.json()\n          setRequests(data.data)\n        }\n      } catch {\n        // silent\n      } finally {\n        setLoading(false)\n      }\n    }\n    load()\n  }, [accessToken])\n\n  async function handleAccept(swapRequestId: string) {\n    setActionLoading(swapRequestId)\n    setError(null)\n    try {\n      const res = await fetch('/api/swap-requests/accept', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ swapRequestId }),\n      })\n      if (res.ok) {\n        setRequests((prev) => prev.filter((r) => r.id !== swapRequestId))\n      } else {\n        const data = await res.json()\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®')\n      }\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setActionLoading(null)\n    }\n  }\n\n  async function handleApprove(swapRequestId: string, decision: 'approved' | 'rejected') {\n    setActionLoading(swapRequestId)\n    setError(null)\n    try {\n      const res = await fetch('/api/swap-requests/approve', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ swapRequestId, decision }),\n      })\n      if (res.ok) {\n        setRequests((prev) => prev.filter((r) => r.id !== swapRequestId))\n      } else {\n        const data = await res.json()\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВ¬в•Әв•Ўв”ҳГ в–ҲГ®в”ҳГ  в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®')\n      }\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setActionLoading(null)\n    }\n  }\n\n  const isAdmin = user?.roleKey === 'admin' || user?.roleKey === 'super_admin'\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 max-w-5xl mx-auto w-full\" dir=\"rtl\">\n      <div>\n        <h1 className=\"text-lg font-semibold tracking-tight text-foreground flex items-center gap-2\">\n          <ArrowLeftRight className=\"size-5 text-accent\" />\n          в•Әв•Ўв”ҳГҘв•ӘВ»в”ҳГӘв”ҳГ© в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә\n        </h1>\n        <p className=\"text-sm text-foreground-muted mt-1\">\n          в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в•Әв•Јв”ҳГӘв–ҲГ®в•Әв•ў в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГӘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв•– в–Ҳв–’\n        </p>\n      </div>\n\n      {error && (\n        <div className=\"bg-critical/10 border border-critical/20 text-critical px-4 py-3 rounded-lg text-sm flex items-center justify-between gap-2 animate-in fade-in slide-in-from-top-1 duration-150\">\n          <span>{error}</span>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            className=\"h-auto py-1 px-2 hover:bg-critical/20 text-critical hover:text-critical cursor-pointer\"\n            onClick={() => setError(null)}\n          >\n            в•ӘВҝв•Әв”Ӯв•ӘВ¬в”ҳГҘ\n          </Button>\n        </div>\n      )}\n\n      {loading ? (\n        <div className=\"rounded-lg border border-border p-12 text-center bg-surface/30 backdrop-blur-md\">\n          <Clock className=\"size-8 mx-auto text-foreground-muted animate-pulse mb-3\" />\n          <p className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә...</p>\n        </div>\n      ) : requests.length === 0 ? (\n        <div className=\"rounded-lg border border-border-subtle p-12 text-center bg-surface/30 backdrop-blur-md flex flex-col items-center justify-center\">\n          <Inbox className=\"size-10 text-foreground-muted mb-3 opacity-40\" />\n          <p className=\"text-sm text-foreground-muted font-medium\">\n            в•Әв•Ўв”ҳГҘв•ӘВ»в”ҳГӘв”ҳГ© в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»в–ҲГ® в•ӘВ«в•ӘВәв”ҳГӨв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬\n          </p>\n          <p className=\"text-xs text-foreground-muted mt-1\">\n            в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв•Јв”ҳГӘв–ҲГ®в•Әв•ў в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»в–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в–ҲГ®в•ӘВә в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ».\n          </p>\n        </div>\n      ) : (\n        <div className=\"space-y-4\">\n          {requests.map((req) => (\n            <Card key={req.id} className=\"bg-surface/50 backdrop-blur-md border border-border-subtle hover:border-accent/30 transition-all duration-150 rounded-lg\">\n              <CardContent className=\"p-4 md:p-5\">\n                <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n                  <div className=\"space-y-3 flex-1\">\n                    {/* User Info Header */}\n                    <div className=\"flex items-center gap-2 flex-wrap\">\n                      <div className=\"flex items-center gap-1.5 text-sm font-semibold bg-neutral-800/40 px-2.5 py-1 rounded-md border border-border-subtle\">\n                        <User className=\"size-4 text-accent\" />\n                        <span>{req.requester.name}</span>\n                      </div>\n                      <span className=\"text-xs text-foreground-muted\">в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв•Јв”ҳГӘв–ҲГ®в•Әв•ў в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВҝв•ӘВә</span>\n                      <div className=\"flex items-center gap-1.5 text-sm font-semibold bg-neutral-800/40 px-2.5 py-1 rounded-md border border-border-subtle\">\n                        <User className=\"size-4 text-foreground-muted\" />\n                        <span>{req.target.name}</span>\n                      </div>\n                    </div>\n\n                    {/* Shift Swap Comparison Detail */}\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 bg-background-subtle/40 p-3.5 rounded-lg border border-border-subtle max-w-2xl\">\n                      {/* Source Shift */}\n                      <div className=\"space-y-1.5\">\n                        <span className=\"text-[10px] text-foreground-muted block\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГӘв•ӘВәв”ҢВ»в•Әв–‘в•ӘВәв•Әв–’ в•Әв”Өв•ӘВ»в”ҳГ§ (в”ҳГ в•ӘВҝв•ӘВ»в•ӘВә):</span>\n                        <div className=\"flex items-center gap-2\">\n                          <Badge variant=\"outline\" className={`rounded-md px-2 py-0.5 text-xs font-semibold ${SHIFT_CLASSES[req.sourceShift.code]}`}>\n                            {SHIFT_LABELS[req.sourceShift.code]}\n                          </Badge>\n                          <span className=\"text-xs font-mono text-foreground font-semibold flex items-center gap-1.5\">\n                            <Calendar className=\"size-3.5 text-foreground-muted\" />\n                            {jalali(req.sourceShift.date)}\n                          </span>\n                        </div>\n                      </div>\n\n                      {/* Target Shift */}\n                      <div className=\"space-y-1.5 border-t sm:border-t-0 sm:border-r border-border-subtle pt-2.5 sm:pt-0 sm:pr-4\">\n                        <span className=\"text-[10px] text-foreground-muted block\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ (в”ҳГ в”ҳГ©в•Әв•Ўв•ӘВ»):</span>\n                        <div className=\"flex items-center gap-2\">\n                          <Badge variant=\"outline\" className={`rounded-md px-2 py-0.5 text-xs font-semibold ${SHIFT_CLASSES[req.targetShift.code]}`}>\n                            {SHIFT_LABELS[req.targetShift.code]}\n                          </Badge>\n                          <span className=\"text-xs font-mono text-foreground font-semibold flex items-center gap-1.5\">\n                            <Calendar className=\"size-3.5 text-foreground-muted\" />\n                            {jalali(req.targetShift.date)}\n                          </span>\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Note if exists */}\n                    {req.note && (\n                      <div className=\"bg-surface/70 p-3 rounded-lg border border-border-subtle text-xs text-foreground-muted leading-relaxed max-w-2xl\">\n                        <span className=\"font-semibold text-foreground block mb-1\">в•Әв•Јв”ҳГӨв•ӘВ¬ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®:</span>\n                        {req.note}\n                      </div>\n                    )}\n\n                    {/* Meta creation details */}\n                    <div className=\"flex items-center gap-1.5 text-[10px] text-foreground-muted font-mono pt-1\">\n                      <Clock className=\"size-3\" />\n                      <span>в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в•ӘВҪв•ӘВҝв•ӘВ¬: {jalali(req.createdAt)} {faTime(req.createdAt)}</span>\n                    </div>\n                  </div>\n\n                  {/* Right Side: Status Badge and Actions */}\n                  <div className=\"flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-4 border-t md:border-t-0 border-border-subtle pt-3.5 md:pt-0\">\n                    <Badge variant=\"outline\" className={`rounded-md px-2.5 py-1 text-xs font-semibold ${STATUS_CLASSES[req.status] || 'bg-neutral-800 text-foreground-muted border-border'}`}>\n                      {STATUS_LABELS[req.status] || req.status}\n                    </Badge>\n\n                    {/* Actions Panel */}\n                    <div className=\"flex gap-2\">\n                      {req.status === 'pending' && (\n                        <>\n                          {req.target.id === user?.id && (\n                            <Button\n                              size=\"sm\"\n                              onClick={() => handleAccept(req.id)}\n                              disabled={actionLoading === req.id}\n                              className=\"bg-success hover:bg-success/90 text-white font-medium gap-1 h-8 rounded-md cursor-pointer\"\n                            >\n                              <Check className=\"size-3.5\" />\n                              в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®\n                            </Button>\n                          )}\n                          {isAdmin && (\n                            <>\n                              <Button\n                                size=\"sm\"\n                                variant=\"outline\"\n                                onClick={() => handleApprove(req.id, 'approved')}\n                                disabled={actionLoading === req.id}\n                                className=\"border-success/30 hover:bg-success/15 hover:text-success text-success gap-1 h-8 rounded-md cursor-pointer\"\n                              >\n                                <Check className=\"size-3.5\" />\n                                в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВәв•ӘВ»в”ҳГ в–ҲГ®в”ҳГҘ\n                              </Button>\n                              <Button\n                                size=\"sm\"\n                                variant=\"destructive\"\n                                onClick={() => handleApprove(req.id, 'rejected')}\n                                disabled={actionLoading === req.id}\n                                className=\"gap-1 h-8 rounded-md cursor-pointer\"\n                              >\n                                <X className=\"size-3.5\" />\n                                в•Әв–’в•ӘВ»\n                              </Button>\n                            </>\n                          )}\n                        </>\n                      )}\n                    </div>\n                  </div>\n                </div>\n              </CardContent>\n            </Card>\n          ))}\n        </div>\n      )}\n    </div>\n  )\n}\n\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\swap\\page.tsx","messages":[{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from 'react-hooks/set-state-in-effect').","line":100,"column":3,"severity":1,"nodeType":null,"fix":{"range":[3031,3083],"text":" "}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":1,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useRouter } from 'next/navigation'\nimport { useAuthStore } from '@/features/auth'\nimport { Button } from '@/components/ui/button'\nimport { Label } from '@/components/ui/label'\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card'\nimport { toFa, jalali } from '@/lib/fa'\nimport { ArrowLeftRight, Send, AlertTriangle, CheckCircle, FileText } from 'lucide-react'\n\ninterface UserOption {\n  id: string\n  name: string\n  nationalId: string\n}\n\ninterface ShiftOption {\n  id: string\n  date: string\n  code: string\n}\n\ninterface RuleViolation {\n  rule: string\n  message: string\n}\n\nconst SHIFT_LABELS: Record<string, string> = {\n  morning: 'в•Әв•Ўв•ӘВҝв•ӘВЎ',\n  evening: 'в•Әв•Јв•Әв•Ўв•Әв–’',\n  night: 'в•Әв”Өв•ӘВҝ',\n  off: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (OFF)',\n}\n\nexport default function CreateSwapRequestPage() {\n  const router = useRouter()\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const currentUser = useAuthStore((s) => s.user)\n  const isAuthenticated = useAuthStore((s) => s.isAuthenticated)\n\n  const [myShifts, setMyShifts] = useState<ShiftOption[]>([])\n  const [colleagues, setColleagues] = useState<UserOption[]>([])\n  const [selectedColleagueId, setSelectedColleagueId] = useState('')\n  const [colleagueShifts, setColleagueShifts] = useState<ShiftOption[]>([])\n\n  const [selectedMyShiftId, setSelectedMyShiftId] = useState('')\n  const [selectedColleagueShiftId, setSelectedColleagueShiftId] = useState('')\n  const [note, setNote] = useState('')\n\n  const [loading, setLoading] = useState(false)\n  const [fetchingShifts, setFetchingShifts] = useState(false)\n  const [error, setError] = useState('')\n  const [violations, setViolations] = useState<RuleViolation[]>([])\n  const [success, setSuccess] = useState(false)\n\n  // Fetch my shifts & colleague list\n  useEffect(() => {\n    if (!isAuthenticated) {\n      router.push('/login')\n      return\n    }\n\n    async function loadInitialData() {\n      try {\n        const [myShiftsRes, usersRes] = await Promise.all([\n          fetch('/api/shifts/me', {\n            headers: { Authorization: `Bearer ${accessToken}` },\n          }),\n          fetch('/api/users?pageSize=100', {\n            headers: { Authorization: `Bearer ${accessToken}` },\n          }),\n        ])\n\n        if (myShiftsRes.ok && usersRes.ok) {\n          const myShiftsData = await myShiftsRes.json()\n          const usersData = await usersRes.json()\n\n          // Only keep shifts that are not 'off'\n          setMyShifts(\n            (myShiftsData.data || []).filter((s: ShiftOption) => s.code !== 'off')\n          )\n\n          // Filter out current user from colleague list\n          setColleagues(\n            (usersData.data?.users || []).filter(\n              (u: UserOption) => u.id !== currentUser?.id\n            )\n          )\n        }\n      } catch {\n        setError('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•ӘВәв”ҳГӘв”ҳГӨв–ҲГ®в”ҳГ§')\n      }\n    }\n\n    loadInitialData()\n  }, [accessToken, currentUser?.id, isAuthenticated, router])\n\n  // Fetch shifts for selected colleague\n  /* eslint-disable react-hooks/set-state-in-effect */\n  useEffect(() => {\n    if (!selectedColleagueId) {\n      setColleagueShifts([])\n      return\n    }\n\n    async function loadColleagueShifts() {\n      setFetchingShifts(true)\n      setColleagueShifts([])\n      try {\n        // Fetch all shifts and filter by selected user\n        const res = await fetch('/api/shifts', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        })\n        if (res.ok) {\n          const data = await res.json()\n          const filtered = (data.data || []).filter(\n            (s: ShiftOption & { user: { id: string } }) => s.user.id === selectedColleagueId && s.code !== 'off'\n          )\n          setColleagueShifts(filtered)\n        }\n      } catch {\n        setError('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’')\n      } finally {\n        setFetchingShifts(false)\n      }\n    }\n\n    loadColleagueShifts()\n  }, [selectedColleagueId, accessToken])\n\n  async function handleSubmit(e: React.FormEvent) {\n    e.preventDefault()\n    setError('')\n    setViolations([])\n    setSuccess(false)\n\n    if (!selectedMyShiftId || !selectedColleagueId || !selectedColleagueShiftId) {\n      setError('в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•Әв–’в•ӘВә в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»')\n      return\n    }\n\n    setLoading(true)\n\n    try {\n      const res = await fetch('/api/swap-requests', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          targetUserId: selectedColleagueId,\n          sourceShiftId: selectedMyShiftId,\n          targetShiftId: selectedColleagueShiftId,\n          note: note || undefined,\n        }),\n      })\n\n      const data = await res.json()\n\n      if (res.status === 422) {\n        setViolations(data.violations || [])\n        setError('в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВә в•ӘВҝв•ӘВә в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в•Әв•‘в•ӘВәв–ҲГ®в•Әв–’в•ӘВ¬ в•ӘВ»в•ӘВәв•Әв–’в•ӘВ»')\n        return\n      }\n\n      if (!res.ok) {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬')\n        return\n      }\n\n      setSuccess(true)\n      setSelectedMyShiftId('')\n      setSelectedColleagueId('')\n      setSelectedColleagueShiftId('')\n      setNote('')\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 max-w-xl mx-auto w-full\" dir=\"rtl\">\n      <div className=\"flex items-center justify-between\">\n        <h1 className=\"text-lg font-semibold tracking-tight text-foreground flex items-center gap-2\">\n          <ArrowLeftRight className=\"size-5 text-accent\" />\n          в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬\n        </h1>\n        <Button variant=\"outline\" size=\"sm\" onClick={() => router.push('/swap/inbox')} className=\"cursor-pointer\">\n          в•Әв•Ўв”ҳГҘв•ӘВ»в”ҳГӘв”ҳГ© в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә\n        </Button>\n      </div>\n\n      <Card className=\"w-full bg-surface/50 backdrop-blur-md border border-border-subtle rounded-lg\">\n        <CardHeader className=\"pb-3 border-b border-border-subtle/50\">\n          <CardTitle className=\"text-sm font-semibold flex items-center gap-1.5 text-foreground\">\n            <Send className=\"size-4 text-accent\" />\n            в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n          </CardTitle>\n          <CardDescription className=\"text-xs text-foreground-muted\">\n            в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в”ҳГӘв•Әв–’в•ӘВ» в”ҳГҘв•Әв••в•Әв–’ в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•ӘВҝв•ӘВә в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ». в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в•ӘВҝв”ҳГ§ в•Әв•–в”ҳГӘв•Әв–’ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в”ҳГҘв•ӘВ» в•Әв”Өв•ӘВ».\n          </CardDescription>\n        </CardHeader>\n        <CardContent className=\"pt-4\">\n          <form onSubmit={handleSubmit} className=\"space-y-4\">\n            {error && (\n              <div role=\"alert\" className=\"rounded-md bg-accent/10 border border-accent/20 p-3 text-xs text-accent flex items-start gap-2 animate-in fade-in duration-150\">\n                <AlertTriangle className=\"size-4 shrink-0 mt-0.5\" />\n                <span>{error}</span>\n              </div>\n            )}\n\n            {success && (\n              <div className=\"rounded-md bg-success/10 border border-success/20 p-3 text-xs text-success flex items-start gap-2 animate-in fade-in duration-150\">\n                <CheckCircle className=\"size-4 shrink-0 mt-0.5\" />\n                <span>в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ» в”ҳГӘ в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВ¬.</span>\n              </div>\n            )}\n\n            {violations.length > 0 && (\n              <div className=\"space-y-1.5 rounded-md border border-accent/20 bg-accent/5 p-3 text-xs text-accent animate-in fade-in duration-150\">\n                <span className=\"font-semibold flex items-center gap-1\">\n                  <AlertTriangle className=\"size-3.5\" />\n                  в”ҳГ в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҳГҘв”ҳГ©в•Әв•ў в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®:\n                </span>\n                <ul className=\"list-inside list-disc space-y-0.5 pe-4 text-foreground-muted\">\n                  {violations.map((v, i) => (\n                    <li key={i} className=\"text-[11px]\">{v.message}</li>\n                  ))}\n                </ul>\n              </div>\n            )}\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"myShift\" className=\"text-xs font-semibold text-foreground\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в”ҳГҘ *</Label>\n              <select\n                id=\"myShift\"\n                value={selectedMyShiftId}\n                onChange={(e) => setSelectedMyShiftId(e.target.value)}\n                className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 cursor-pointer\"\n                required\n              >\n                <option value=\"\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в”ҳГҘ</option>\n                {myShifts.map((s) => (\n                  <option key={s.id} value={s.id}>\n                    {jalali(s.date)} О“ГҮГ¶ {SHIFT_LABELS[s.code]}\n                  </option>\n                ))}\n              </select>\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"colleague\" className=\"text-xs font-semibold text-foreground\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ *</Label>\n              <select\n                id=\"colleague\"\n                value={selectedColleagueId}\n                onChange={(e) => setSelectedColleagueId(e.target.value)}\n                className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 cursor-pointer\"\n                required\n              >\n                <option value=\"\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’</option>\n                {colleagues.map((c) => (\n                  <option key={c.id} value={c.id}>\n                    {c.name} (в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®: {toFa(c.nationalId)})\n                  </option>\n                ))}\n              </select>\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"colleagueShift\" className=\"text-xs font-semibold text-foreground\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ *</Label>\n              <select\n                id=\"colleagueShift\"\n                value={selectedColleagueShiftId}\n                onChange={(e) => setSelectedColleagueShiftId(e.target.value)}\n                className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer\"\n                disabled={!selectedColleagueId || fetchingShifts}\n                required\n              >\n                <option value=\"\">\n                  {fetchingShifts ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә...' : 'в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’'}\n                </option>\n                {colleagueShifts.map((s) => (\n                  <option key={s.id} value={s.id}>\n                    {jalali(s.date)} О“ГҮГ¶ {SHIFT_LABELS[s.code]}\n                  </option>\n                ))}\n              </select>\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"note\" className=\"text-xs font-semibold text-foreground flex items-center gap-1\">\n                <FileText className=\"size-3.5 text-foreground-muted\" />\n                в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв•ӘВәв•ӘВ¬ (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)\n              </Label>\n              <textarea\n                id=\"note\"\n                value={note}\n                onChange={(e) => setNote(e.target.value)}\n                className=\"h-20 w-full rounded-lg border border-border bg-surface px-3 py-2 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150 text-right resize-none\"\n                placeholder=\"в•Әв•Јв”ҳГӨв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®...\"\n                maxLength={500}\n              />\n            </div>\n\n            <Button type=\"submit\" className=\"w-full cursor-pointer mt-2\" disabled={loading}>\n              {loading ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬...' : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®'}\n            </Button>\n          </form>\n        </CardContent>\n      </Card>\n    </div>\n  )\n}\n\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\tickets\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(auth)\\forgot-password\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'router' is assigned a value but never used.","line":20,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":20,"endColumn":15}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useState, useEffect } from 'react'\nimport { useRouter } from 'next/navigation'\nimport Link from 'next/link'\nimport {\n  Lock,\n  Eye,\n  EyeOff,\n  Fingerprint,\n  Phone,\n  KeyRound,\n  ArrowLeft,\n  ArrowRight,\n  Train,\n  CheckCircle2,\n} from 'lucide-react'\n\nexport default function ForgotPasswordPage() {\n  const router = useRouter()\n  const [step, setStep] = useState(1) // 1: Send OTP, 2: Verify OTP, 3: Reset Password, 4: Success\n  const [nationalId, setNationalId] = useState('')\n  const [phone, setPhone] = useState('')\n  const [code, setCode] = useState('')\n  const [password, setPassword] = useState('')\n  const [confirmPassword, setConfirmPassword] = useState('')\n  const [resetToken, setResetToken] = useState('')\n  \n  const [showPassword, setShowPassword] = useState(false)\n  const [error, setError] = useState('')\n  const [infoMessage, setInfoMessage] = useState('')\n  const [loading, setLoading] = useState(false)\n  \n  const [appName, setAppName] = useState('в•ӘВ«в•Әв•–О“ГҮГ® в–ҲГ®в•ӘВәв•Әв–’')\n  const [brandColor, setBrandColor] = useState('')\n  const [debugOtpCode, setDebugOtpCode] = useState('')\n\n  useEffect(() => {\n    fetch('/api/config')\n      .then((res) => res.json())\n      .then((data) => {\n        if (data.data?.appName) setAppName(data.data.appName)\n        if (data.data?.brandColor) setBrandColor(data.data.brandColor)\n      })\n      .catch(() => {})\n  }, [])\n\n  // Step 1: Send OTP\n  async function handleSendOtp(e: React.FormEvent) {\n    e.preventDefault()\n    setError('')\n    setInfoMessage('')\n    setDebugOtpCode('')\n    setLoading(true)\n\n    try {\n      const res = await fetch('/api/auth/otp/send', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ nationalId, phone }),\n      })\n\n      const data = await res.json()\n\n      if (!res.ok) {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҢвҢҗв•ӘВ» в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»')\n        return\n      }\n\n      setInfoMessage(data.message)\n      if (data.debugOtp) {\n        setDebugOtpCode(data.debugOtp)\n      }\n      setStep(2)\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${message}`)\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  // Step 2: Verify OTP\n  async function handleVerifyOtp(e: React.FormEvent) {\n    e.preventDefault()\n    setError('')\n    setInfoMessage('')\n    setLoading(true)\n\n    try {\n      const res = await fetch('/api/auth/otp/verify', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ nationalId, code }),\n      })\n\n      const data = await res.json()\n\n      if (!res.ok) {\n        setError(data.error || 'в”ҢвҢҗв•ӘВ» в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГ в•Әв•Јв•ӘВ¬в•ӘВҝв•Әв–’ в”ҳГҘв–ҲГ®в•Әв”Ӯв•ӘВ¬')\n        return\n      }\n\n      setResetToken(data.token)\n      setStep(3)\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${message}`)\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  // Step 3: Reset Password\n  async function handleResetPassword(e: React.FormEvent) {\n    e.preventDefault()\n    setError('')\n    setLoading(true)\n\n    if (password !== confirmPassword) {\n      setError('в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в”ҳГӘ в•ӘВ¬в”ҢвҢҗв•Әв–’в•ӘВәв•Әв–’ в•ӘГів”ҳГҘ в”ҳГ§в”ҳГ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ® в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в”ҳГҘв•ӘВ»')\n      setLoading(false)\n      return\n    }\n\n    try {\n      const res = await fetch('/api/auth/reset-password', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ token: resetToken, password }),\n      })\n\n      const data = await res.json()\n\n      if (!res.ok) {\n        setError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’')\n        return\n      }\n\n      setStep(4)\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err)\n      setError(`в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’: ${message}`)\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  return (\n    <div className=\"relative min-h-screen w-full flex items-center justify-center overflow-hidden\" dir=\"rtl\">\n      {/* Background */}\n      <div className=\"absolute inset-0 z-0\">\n        <div\n          className=\"absolute inset-0 scale-105 bg-cover bg-center\"\n          style={{\n            backgroundImage: \"url('https://lh3.googleusercontent.com/aida-public/AB6AXuBrL3E_mh6FZzjFwGI_YGzltX-rQHwPMP_TVSvlIkAM6IfOmJK7xqrxn1sTf5vmJC4dza7R-rntBcL5fwOTHDhcEGFUd0-MYpcDgNEDrBkrOFkGgP0oDqaJpJbygNX7cZ1NiLHAXreAnVA9dhbMpA3lOH8dvzEDx0lwiS3tkcFjyHIN16fx15covGYiK_h-9DIIARvUllvt5AsKqYCM3TcM654NV-mwRmzT465vDEckFNiHUHcytdDrUe5B1fAEokpWJQY2LTWFDSQ')\",\n            filter: 'brightness(0.25) contrast(1.1)',\n          }}\n        />\n        <div className=\"absolute inset-0 bg-background/80 mix-blend-multiply\" />\n        <div className=\"absolute inset-0 bg-gradient-to-t from-background via-background/60 to-transparent\" />\n      </div>\n\n      {/* Forgot Password Container */}\n      <div className=\"relative z-10 w-full max-w-md px-6 py-12 animate-[fadeInUp_0.6s_ease-out]\">\n        <style>{`\n          @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n          }\n        `}</style>\n        <div className=\"rounded-xl border border-border bg-surface-container/90 p-8 shadow-lg backdrop-blur-md\">\n          {/* Header */}\n          <div className=\"flex flex-col items-center justify-center gap-2 text-center\">\n            <div\n              className=\"mb-2 flex size-14 items-center justify-center rounded-full shadow-md transition-transform duration-300 hover:scale-105\"\n              style={brandColor ? { backgroundColor: brandColor } : undefined}\n            >\n              <Train className=\"size-7 text-accent-foreground\" />\n            </div>\n            <h1 className=\"text-2xl font-bold tracking-tight text-foreground\">\n              в•ӘВҝв•ӘВәв•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’\n            </h1>\n            <p className=\"text-xs font-semibold uppercase tracking-widest text-foreground-muted\">\n              в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® {appName}\n            </p>\n          </div>\n\n          {/* Messages */}\n          {error && (\n            <div role=\"alert\" aria-live=\"polite\" className=\"mt-4 rounded-lg border border-critical/20 bg-critical/10 p-3.5 text-xs leading-relaxed text-critical\">\n              {error}\n            </div>\n          )}\n\n          {infoMessage && (\n            <div className=\"mt-4 rounded-lg border border-accent/20 bg-accent/10 p-3.5 text-xs leading-relaxed text-accent\">\n              {infoMessage}\n            </div>\n          )}\n\n          {/* Step 1: Send OTP Form */}\n          {step === 1 && (\n            <form onSubmit={handleSendOtp} className=\"mt-6 flex flex-col gap-4\">\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"text-xs font-semibold text-foreground-muted\" htmlFor=\"nationalId\">\n                  в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®\n                </label>\n                <div className=\"relative\">\n                  <span className=\"absolute right-3 top-1/2 -translate-y-1/2 text-foreground-muted\">\n                    <Fingerprint className=\"size-4\" />\n                  </span>\n                  <input\n                    className=\"h-10 w-full rounded-lg border border-border bg-background pe-10 ps-3 text-sm text-foreground transition-colors placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring font-mono text-right\"\n                    id=\"nationalId\"\n                    type=\"text\"\n                    placeholder=\"в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ® в–Ҳв–’в–Ҳв–‘ в•Әв–’в”ҳГ©в”ҳГ в–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»\"\n                    maxLength={10}\n                    value={nationalId}\n                    onChange={(e) => setNationalId(e.target.value)}\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"text-xs font-semibold text-foreground-muted\" htmlFor=\"phone\">\n                  в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳГ в”ҳГӘв•ӘВҝв•ӘВәв–ҲГ®в”ҳГӨ\n                </label>\n                <div className=\"relative\">\n                  <span className=\"absolute right-3 top-1/2 -translate-y-1/2 text-foreground-muted\">\n                    <Phone className=\"size-4\" />\n                  </span>\n                  <input\n                    className=\"h-10 w-full rounded-lg border border-border bg-background pe-10 ps-3 text-sm text-foreground transition-colors placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring font-mono text-right\"\n                    id=\"phone\"\n                    type=\"text\"\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: 09123456789\"\n                    maxLength={11}\n                    value={phone}\n                    onChange={(e) => setPhone(e.target.value)}\n                    required\n                  />\n                </div>\n              </div>\n\n              <button\n                className=\"mt-2 flex h-11 w-full items-center justify-center gap-2 rounded-lg bg-accent text-sm font-semibold text-accent-foreground transition-all hover:bg-accent-hover active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-surface disabled:cursor-not-allowed disabled:opacity-50\"\n                type=\"submit\"\n                disabled={loading}\n              >\n                {loading ? (\n                  <>\n                    <span className=\"size-4 animate-spin rounded-full border-2 border-accent-foreground/30 border-t-accent-foreground\" />\n                    <span>в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ...</span>\n                  </>\n                ) : (\n                  <>\n                    <span>в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҢвҢҗв•ӘВ» в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ в”ҢвҢҗв–ҲГ®</span>\n                    <ArrowRight className=\"size-4\" />\n                  </>\n                )}\n              </button>\n            </form>\n          )}\n\n          {/* Step 2: Verify OTP Form */}\n          {step === 2 && (\n            <form onSubmit={handleVerifyOtp} className=\"mt-6 flex flex-col gap-4\">\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"text-xs font-semibold text-foreground-muted\" htmlFor=\"code\">\n                  в”ҢвҢҗв•ӘВ» в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в–ҲГ®в”ҢвҢҗв•ӘВҝв•ӘВәв•Әв–’ в”ҳГ в•Әв•Ўв•Әв–’в”ҳГј в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ в”ҢвҢҗв–ҲГ®\n                </label>\n                <div className=\"relative\">\n                  <span className=\"absolute right-3 top-1/2 -translate-y-1/2 text-foreground-muted\">\n                    <KeyRound className=\"size-4\" />\n                  </span>\n                  <input\n                    className=\"h-10 w-full rounded-lg border border-border bg-background pe-10 ps-3 text-sm text-foreground transition-colors placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring font-mono text-center tracking-widest\"\n                    id=\"code\"\n                    type=\"text\"\n                    placeholder=\"в”ҢвҢҗв•ӘВ» в–Ҳв•ў в•Әв–’в”ҳГ©в”ҳГ в–ҲГ®\"\n                    maxLength={6}\n                    value={code}\n                    onChange={(e) => setCode(e.target.value)}\n                    required\n                    autoFocus\n                  />\n                </div>\n              </div>\n\n              {debugOtpCode && (\n                <div className=\"rounded-lg border border-yellow-500/20 bg-yellow-500/10 p-3 text-center\">\n                  <p className=\"text-xs text-yellow-500\">\n                    в”ҢвҢҗв•ӘВ» в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘВ»в–ҲГ®в•ӘВҝв•ӘВәв”ҢВ» в•Әв”Ӯв•Әв–’в–ҲГ®в•Әв•Ј: <strong>{debugOtpCode}</strong>\n                  </p>\n                </div>\n              )}\n\n              <div className=\"flex gap-2 mt-2\">\n                <button\n                  className=\"flex h-11 w-1/3 items-center justify-center gap-1 rounded-lg border border-border bg-background text-sm font-semibold text-foreground transition-all hover:bg-surface-hover active:scale-[0.98]\"\n                  type=\"button\"\n                  onClick={() => setStep(1)}\n                  disabled={loading}\n                >\n                  <ArrowLeft className=\"size-4\" />\n                  <span>в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв”Өв•ӘВ¬</span>\n                </button>\n                <button\n                  className=\"flex h-11 w-2/3 items-center justify-center gap-2 rounded-lg bg-accent text-sm font-semibold text-accent-foreground transition-all hover:bg-accent-hover active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-surface disabled:cursor-not-allowed disabled:opacity-50\"\n                  type=\"submit\"\n                  disabled={loading}\n                >\n                  {loading ? (\n                    <span className=\"size-4 animate-spin rounded-full border-2 border-accent-foreground/30 border-t-accent-foreground\" />\n                  ) : (\n                    <span>в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҢвҢҗв•ӘВ» в”ҳГӘ в•ӘВәв•ӘВ»в•ӘВәв”ҳГ в”ҳГ§</span>\n                  )}\n                </button>\n              </div>\n            </form>\n          )}\n\n          {/* Step 3: Reset Password Form */}\n          {step === 3 && (\n            <form onSubmit={handleResetPassword} className=\"mt-6 flex flex-col gap-4\">\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"text-xs font-semibold text-foreground-muted\" htmlFor=\"password\">\n                  в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n                </label>\n                <div className=\"relative\">\n                  <span className=\"absolute right-3 top-1/2 -translate-y-1/2 text-foreground-muted\">\n                    <Lock className=\"size-4\" />\n                  </span>\n                  <input\n                    className=\"h-10 w-full rounded-lg border border-border bg-background pe-10 ps-10 text-sm text-foreground transition-colors placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring font-mono\"\n                    id=\"password\"\n                    type={showPassword ? 'text' : 'password'}\n                    placeholder=\"О“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГі\"\n                    value={password}\n                    onChange={(e) => setPassword(e.target.value)}\n                    required\n                    autoFocus\n                  />\n                  <button\n                    className=\"absolute left-3 top-1/2 -translate-y-1/2 text-foreground-muted transition-colors hover:text-foreground focus:outline-none\"\n                    type=\"button\"\n                    onClick={() => setShowPassword(!showPassword)}\n                  >\n                    {showPassword ? <EyeOff className=\"size-4\" /> : <Eye className=\"size-4\" />}\n                  </button>\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5\">\n                <label className=\"text-xs font-semibold text-foreground-muted\" htmlFor=\"confirmPassword\">\n                  в•ӘВ¬в”ҢвҢҗв•Әв–’в•ӘВәв•Әв–’ в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n                </label>\n                <div className=\"relative\">\n                  <span className=\"absolute right-3 top-1/2 -translate-y-1/2 text-foreground-muted\">\n                    <Lock className=\"size-4\" />\n                  </span>\n                  <input\n                    className=\"h-10 w-full rounded-lg border border-border bg-background pe-10 ps-3 text-sm text-foreground transition-colors placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring font-mono\"\n                    id=\"confirmPassword\"\n                    type={showPassword ? 'text' : 'password'}\n                    placeholder=\"О“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГіО“ГҮГі\"\n                    value={confirmPassword}\n                    onChange={(e) => setConfirmPassword(e.target.value)}\n                    required\n                  />\n                </div>\n              </div>\n\n              <button\n                className=\"mt-2 flex h-11 w-full items-center justify-center gap-2 rounded-lg bg-accent text-sm font-semibold text-accent-foreground transition-all hover:bg-accent-hover active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-surface disabled:cursor-not-allowed disabled:opacity-50\"\n                type=\"submit\"\n                disabled={loading}\n              >\n                {loading ? (\n                  <>\n                    <span className=\"size-4 animate-spin rounded-full border-2 border-accent-foreground/30 border-t-accent-foreground\" />\n                    <span>в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•Әв–’в”ҳГ в•Әв–“...</span>\n                  </>\n                ) : (\n                  <span>в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</span>\n                )}\n              </button>\n            </form>\n          )}\n\n          {/* Step 4: Success Message */}\n          {step === 4 && (\n            <div className=\"mt-6 flex flex-col items-center justify-center text-center gap-4 animate-[scaleUp_0.4s_ease-out]\">\n              <style>{`\n                @keyframes scaleUp {\n                  from { opacity: 0; transform: scale(0.9); }\n                  to { opacity: 1; transform: scale(1); }\n                }\n              `}</style>\n              <CheckCircle2 className=\"size-16 text-success\" />\n              <div className=\"flex flex-col gap-1\">\n                <h3 className=\"text-lg font-bold text-foreground\">\n                  в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•Әв–’в”ҳГ в•Әв–“ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в•Әв”Өв•ӘВ»\n                </h3>\n                <p className=\"text-xs text-foreground-muted leading-relaxed\">\n                  в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•Әв”Өв”ҳГ в•ӘВә в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ». в•ӘВәв”ҢвҢҗв”ҳГҘв”ҳГӘв”ҳГҘ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в•ӘВ» в•ӘВҝв•ӘВә в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•Әв”Өв”ҳГӘв–ҲГ®в•ӘВ».\n                </p>\n              </div>\n\n              <Link\n                href=\"/login\"\n                className=\"mt-2 flex h-11 w-full items-center justify-center rounded-lg bg-accent text-sm font-semibold text-accent-foreground transition-all hover:bg-accent-hover active:scale-[0.98]\"\n              >\n                в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§\n              </Link>\n            </div>\n          )}\n\n          {/* Login Link */}\n          {step !== 4 && (\n            <div className=\"mt-5 border-t border-border-subtle pt-5 text-center\">\n              <p className=\"text-xs font-medium text-foreground-muted\">\n                в–ҲГ®в•ӘВә в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГјв•ӘВЎв”ҳГ§{' '}\n                <Link href=\"/login\" className=\"font-bold text-accent hover:underline transition-colors\">\n                  в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ \n                </Link>{' '}\n                в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ».\n              </p>\n            </div>\n          )}\n        </div>\n\n        {/* Footer */}\n        <div className=\"mt-6 text-center\">\n          <p className=\"font-mono text-[10px] uppercase tracking-widest text-foreground-muted/50\">\n            в”ҳГҘв•Әв”Ӯв•ӘВ«в”ҳГ§ в–Ҳв–’.в–Ҳв–’.в–Ҳв–‘ (в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬в–ҲГ®)\n          </p>\n        </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(auth)\\login\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"