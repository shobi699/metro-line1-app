/admin/settings', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${useAuthStore.getState().accessToken}`,\n        },\n        body: JSON.stringify({\n          updates: [\n            {\n              key: 'directory.visible_fields',\n              value: tempVisibleFields.join(','),\n            },\n          ],\n        }),\n      })\n\n      if (res.ok) {\n        // Immediately apply changes locally so cards update without waiting for refetch\n        setVisibleFields([...tempVisibleFields])\n        setRefreshKey((k) => k + 1)\n        alert('в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВЎв•Әв–’в–ҲГ®в”ҳГ  в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ® в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•Әв”Өв•ӘВ».')\n      } else {\n        const data = await res.json()\n        alert(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬')\n      }\n    } catch {\n      alert('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setSavingPrivacy(false)\n    }\n  }\n\n  // Excel Import\n  async function handleImport(file: File) {\n    setImportLoading(true)\n    try {\n      const formData = new FormData()\n      formData.append('file', file)\n\n      const res = await fetch('/api/import/users', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${useAuthStore.getState().accessToken}`,\n        },\n        body: formData,\n      })\n\n      const data = await res.json()\n      setImportResult(data.data)\n      setRefreshKey((k) => k + 1)\n    } catch {\n      setImportResult(null)\n    } finally {\n      setImportLoading(false)\n    }\n  }\n\n  function handleDownloadErrorReport(errorReportUrl: string) {\n    const link = document.createElement('a')\n    link.href = errorReportUrl\n    link.download = 'error-report.xlsx'\n    link.click()\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col bg-[#13151a] text-foreground text-right\" dir=\"rtl\">\n      \n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* HEADER: Title & Search */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"border-b border-outline-variant bg-[#1c1e24] px-6 py-6 md:px-8\">\n        <div className=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-4\">\n          <div>\n            <h1 className=\"text-xl font-bold text-white mb-1.5 flex items-center gap-2\">\n              <Users className=\"size-6 text-red-500\" />\n              в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n            </h1>\n            <p className=\"text-foreground-muted text-xs\">\n              в”ҳв•ӣв•ӘВәв–ҲГ®в•Әв”Ө в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’в•ӘГ® в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в–ҲГ® в”ҳГӘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГјв•ӘВәв•Әв–’в•Әв”Өв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ\n            </p>\n          </div>\n\n          {/* Tab Switcher for Admin */}\n          {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n            <div className=\"flex bg-neutral-950 p-1 rounded-xl border border-neutral-800\">\n              <button\n                onClick={() => setActiveTab('directory')}\n                className={cn(\n                  'px-4 py-1.5 rounded-lg text-xs font-bold transition-all',\n                  activeTab === 'directory'\n                    ? 'bg-red-600 text-white shadow-md'\n                    : 'text-foreground-muted hover:text-white'\n                )}\n              >\n                в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n              </button>\n              <button\n                onClick={() => setActiveTab('customFields')}\n                className={cn(\n                  'px-4 py-1.5 rounded-lg text-xs font-bold transition-all',\n                  activeTab === 'customFields'\n                    ? 'bg-red-600 text-white shadow-md'\n                    : 'text-foreground-muted hover:text-white'\n                )}\n              >\n                в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ®\n              </button>\n            </div>\n          )}\n\n          {activeTab === 'directory' && (\n            <div className=\"flex flex-col sm:flex-row gap-2 w-full md:w-auto\">\n              {/* General Search */}\n              <div className=\"w-full sm:w-72 relative\">\n                <Search className=\"absolute end-3 top-1/2 -translate-y-1/2 text-foreground-muted size-4\" />\n                <input\n                  type=\"text\"\n                  placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ в•ӘГ® в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®в•ӘГ® в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ...\"\n                  value={q}\n                  onChange={(e) => {\n                    setQ(e.target.value)\n                    setPage(1)\n                  }}\n                  className=\"w-full ps-4 end-0 pe-10 py-2.5 bg-neutral-950 border border-neutral-800 rounded-xl focus:border-red-500 focus:ring-1 focus:ring-red-500 outline-none text-xs text-white placeholder:text-neutral-500\"\n                />\n              </div>\n\n              {/* Plate Search О“ГҮГ¶ graphical */}\n              <div className=\"w-full sm:w-64 relative\">\n                <div className=\"absolute end-2.5 top-1/2 -translate-y-1/2 pointer-events-none\">\n                  {/* Mini plate icon */}\n                  <div dir=\"ltr\" className=\"inline-flex items-stretch rounded-[3px] border border-neutral-600 bg-white overflow-hidden h-5 opacity-60\">\n                    <div className=\"flex items-center justify-center bg-[#003DA5] w-4\">\n                      <span className=\"text-white text-[5px] font-bold leading-none\">IR</span>\n                    </div>\n                    <div className=\"flex items-center px-1\">\n                      <Car className=\"size-2.5 text-neutral-400\" />\n                    </div>\n                  </div>\n                </div>\n                <input\n                  type=\"text\"\n                  placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в•ӘВҝв•ӘВә в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ...\"\n                  value={plateSearch}\n                  onChange={(e) => {\n                    setPlateSearch(e.target.value)\n                    setPage(1)\n                  }}\n                  className=\"w-full ps-4 end-0 pe-12 py-2.5 bg-neutral-950 border border-neutral-800 rounded-xl focus:border-red-500 focus:ring-1 focus:ring-red-500 outline-none text-xs text-white placeholder:text-neutral-500\"\n                />\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {activeTab === 'directory' ? (\n        <>\n          {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n          {/* STATS WIDGETS */}\n          {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n          <div className=\"px-6 pt-6 md:px-8 max-w-7xl mx-auto w-full\">\n            <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n              <div className=\"bg-[#1c1e24] border border-[#262930] p-4 rounded-2xl flex items-center justify-between\">\n                <div>\n                  <span className=\"text-[10px] text-foreground-muted block font-bold\">в”ҢвҢҗв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’</span>\n                  <span className=\"text-xl font-bold text-white mt-1 block\">{toFa(stats.total)} в”ҳГҘв”ҳГјв•Әв–’</span>\n                </div>\n                <div className=\"bg-red-500/10 p-2.5 rounded-xl text-red-500 border border-red-500/20\">\n                  <Users className=\"size-5\" />\n                </div>\n              </div>\n\n              <div className=\"bg-[#1c1e24] border border-[#262930] p-4 rounded-2xl flex items-center justify-between\">\n                <div>\n                  <span className=\"text-[10px] text-foreground-muted block font-bold\">в•ӘВЎв•ӘВәв•Әв•ўв•Әв–’в–ҲГ®в”ҳГҘ в•ӘВ»в•Әв–’ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВәв”ҳГ в•Әв–’в”ҳГӘв•Әв–“</span>\n                  <span className=\"text-xl font-bold text-emerald-500 mt-1 block\">{toFa(stats.active)} в”ҳГҘв”ҳГјв•Әв–’</span>\n                </div>\n                <div className=\"bg-emerald-500/10 p-2.5 rounded-xl text-emerald-500 border border-emerald-500/20\">\n                  <CheckCircle2 className=\"size-5\" />\n                </div>\n              </div>\n\n              <div className=\"bg-[#1c1e24] border border-[#262930] p-4 rounded-2xl flex items-center justify-between\">\n                <div>\n                  <span className=\"text-[10px] text-foreground-muted block font-bold\">в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВәв•ӘВ»в”ҳГ в–ҲГ®в”ҳГҘ</span>\n                  <span className=\"text-xl font-bold text-amber-500 mt-1 block\">{toFa(stats.pending)} в”ҳГҘв”ҳГјв•Әв–’</span>\n                </div>\n                <div className=\"bg-amber-500/10 p-2.5 rounded-xl text-amber-500 border border-amber-500/20\">\n                  <Clock className=\"size-5\" />\n                </div>\n              </div>\n\n              <div className=\"bg-[#1c1e24] border border-[#262930] p-4 rounded-2xl flex items-center justify-between\">\n                <div>\n                  <span className=\"text-[10px] text-foreground-muted block font-bold\">в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ© в–ҲГ®в•ӘВә в”ҳГ в”ҳГӘв”ҳГ©в•ӘВ¬</span>\n                  <span className=\"text-xl font-bold text-neutral-400 mt-1 block\">{toFa(stats.suspended)} в”ҳГҘв”ҳГјв•Әв–’</span>\n                </div>\n                <div className=\"bg-neutral-800/50 p-2.5 rounded-xl text-neutral-400 border border-neutral-800\">\n                  <AlertTriangle className=\"size-5\" />\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n          {/* CONTENT: Filters & List */}\n          {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n          <div className=\"p-6 md:p-8 max-w-7xl mx-auto flex flex-col md:flex-row gap-6 w-full flex-1\">\n            {/* Sidebar Filters */}\n            <aside className=\"w-full md:w-64 shrink-0 space-y-4\">\n              <div className=\"bg-[#1c1e24] border border-[#262930] rounded-2xl p-4 sticky top-24\">\n                <h3 className=\"text-xs font-bold text-white mb-4 border-b border-neutral-800 pb-2\">\n                  в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГҘв”ҳГ©в•Әв”Ө\n                </h3>\n                <ul className=\"space-y-1.5 text-xs\">\n                  {CATEGORIES.map((cat) => {\n                    const isActive = roleFilter === cat.key\n                    return (\n                      <li key={cat.key}>\n                        <button\n                          onClick={() => {\n                            setRoleFilter(cat.key)\n                            setPage(1)\n                          }}\n                          className={cn(\n                            'w-full flex items-center justify-between px-3 py-2 rounded-xl transition-all',\n                            isActive\n                              ? 'bg-red-500/10 border border-red-500/20 text-red-500 font-bold'\n                              : 'text-foreground hover:bg-neutral-900'\n                          )}\n                        >\n                          <span className=\"flex items-center gap-2\">\n                            <cat.icon className=\"size-4 shrink-0\" />\n                            {cat.label}\n                          </span>\n                        </button>\n                      </li>\n                    )\n                  })}\n                </ul>\n\n\n\n                <h3 className=\"text-xs font-bold text-white mt-6 mb-4 border-b border-neutral-800 pb-2\">\n                  в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬\n                </h3>\n                <div className=\"flex flex-wrap gap-1.5\">\n                  {[\n                    { key: '', label: 'в”ҳГ§в”ҳГ в”ҳГ§' },\n                    { key: 'active', label: 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ' },\n                    { key: 'pending', label: 'в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’' },\n                    { key: 'suspended', label: 'в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©' },\n                  ].map((s) => (\n                    <button\n                      key={s.key}\n                      onClick={() => {\n                        setStatusFilter(s.key)\n                        setPage(1)\n                      }}\n                      className={cn(\n                        'px-2.5 py-1 rounded-lg text-[10px] font-bold border transition-all',\n                        statusFilter === s.key\n                          ? 'bg-red-500/10 border-red-500/20 text-red-500'\n                          : 'bg-[#13151a] border-neutral-800 text-foreground hover:text-white'\n                      )}\n                    >\n                      {s.label}\n                    </button>\n                  ))}\n                </div>\n\n                {/* Import/Export */}\n                <div className=\"mt-6 pt-4 border-t border-neutral-800 space-y-2\">\n                  <Button\n                    variant=\"outline\"\n                    size=\"sm\"\n                    className=\"w-full gap-2 border-neutral-800 hover:bg-neutral-900 text-xs font-bold\"\n                    onClick={() => window.open('/api/export/users', '_blank')}\n                  >\n                    <Download className=\"size-3.5\" />\n                    в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ® в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                  </Button>\n\n                  {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n                    <Dialog open={importDialogOpen} onOpenChange={setImportDialogOpen}>\n                      <DialogTrigger\n                        render={<Button size=\"sm\" className=\"w-full gap-2 bg-red-600 hover:bg-red-700 text-xs font-bold\" />}\n                      >\n                        <Upload className=\"size-3.5\" />\n                        в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ\n                      </DialogTrigger>\n                      <DialogContent className=\"bg-[#1c1e24] border-[#262930] text-right\" dir=\"rtl\">\n                        <DialogHeader>\n                          <DialogTitle className=\"text-white text-sm font-bold\">в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВәв•Әв–“ в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ</DialogTitle>\n                        </DialogHeader>\n                        <div className=\"space-y-4 text-xs\">\n                          <FileDrop\n                            accept=\".xlsx,.xls\"\n                            onFile={handleImport}\n                            disabled={importLoading}\n                          />\n                          {importLoading && (\n                            <p className=\"text-neutral-400\">\n                              в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в”ҳв•ӣв•Әв–’в•ӘВ»в•ӘВәв•Әв–“в•Әв”Ө в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГӘ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬ в•Әв–’в•ӘВ»в–ҲГ®в”ҳГјО“ГҮГ®в”ҳГ§в•ӘВә...\n                            </p>\n                          )}\n                          {importResult && (\n                            <div className=\"space-y-2 rounded-xl border border-neutral-800 p-4 bg-black/20\">\n                              <p className=\"text-white font-semibold\">\n                                в”ҢвҢҗв”ҳГӨ в•Әв–’в•ӘВ»в–ҲГ®в”ҳГјО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•ӘВ»в•ӘВәв•Әв–“в•Әв”Ө в•Әв”Өв•ӘВ»в”ҳГ§: {toFa(importResult.totalRows)}\n                              </p>\n                              <p className=\"text-emerald-500\">\n                                в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГ в”ҳГӘв”ҳГјв”ҳГ© в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§: {toFa(importResult.successCount)}\n                              </p>\n                              {importResult.errorCount > 0 && (\n                                <div className=\"space-y-2 mt-2 pt-2 border-t border-neutral-800\">\n                                  <p className=\"text-red-500 font-semibold\">\n                                    в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•ӘВ«в•Әв•–в•ӘВәв”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ» в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§: {toFa(importResult.errorCount)}\n                                  </p>\n                                  {importResult.errorReportUrl && (\n                                    <Button\n                                      variant=\"outline\"\n                                      size=\"sm\"\n                                      onClick={() =>\n                                        handleDownloadErrorReport(\n                                          importResult.errorReportUrl!,\n                                        )\n                                      }\n                                      className=\"border-red-500/20 text-red-400 hover:bg-red-500/10 text-[10px] h-8\"\n                                    >\n                                      <Download className=\"me-1.5 size-3.5\" />\n                                      в•ӘВ»в•ӘВәв”ҳГҘв”ҳГӨв”ҳГӘв•ӘВ» в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в•ӘВ«в•Әв•–в•ӘВәв”ҳГ§в•ӘВә\n                                    </Button>\n                                  )}\n                                </div>\n                              )}\n                            </div>\n                          )}\n                        </div>\n                      </DialogContent>\n                    </Dialog>\n                  )}\n                </div>\n              </div>\n\n              {/* OCC hotline card */}\n              <div className=\"bg-red-500/5 border border-red-500/20 rounded-2xl p-4 mt-4 space-y-3\">\n                <div className=\"flex items-center gap-2 text-red-500 font-bold text-xs\">\n                  <span className=\"relative flex h-2 w-2\">\n                    <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75\"></span>\n                    <span className=\"relative inline-flex rounded-full h-2 w-2 bg-red-600\"></span>\n                  </span>\n                  в•ӘВ«в•Әв•– в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» (OCC)\n                </div>\n                <p className=\"text-[10px] text-foreground-muted leading-relaxed\">\n                  в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ  в•ӘВҝв•ӘВә в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ® в”ҳГӘ в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв”ҢГҘв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ в•ӘВјв”ҳГ§в•ӘВ¬ в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ»в–ҲГ® в•ӘВЎв”ҳГӘв•ӘВәв•ӘВ»в•ӘВҪ\n                </p>\n                <div className=\"flex items-center justify-between bg-black/40 p-2.5 rounded-xl border border-neutral-800\">\n                  <span className=\"text-white font-mono font-bold tracking-wider text-xs\">\n                    {toFa(occPhone)}\n                  </span>\n                  <a\n                    href={`tel:${occPhone}`}\n                    className=\"bg-red-600 hover:bg-red-700 text-white p-1.5 rounded-lg transition-colors cursor-pointer\"\n                    title=\"в•ӘВ¬в”ҳГ в•ӘВәв•Әв”Ӯ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®\"\n                  >\n                    <Phone className=\"size-3.5\" />\n                  </a>\n                </div>\n              </div>\n            </aside>\n\n            {/* Grid Personnel */}\n            <div className=\"flex-1 min-w-0\">\n              {loading ? (\n                <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                  {Array.from({ length: 6 }).map((_, i) => (\n                    <div\n                      key={i}\n                      className=\"h-44 animate-pulse rounded-2xl border border-neutral-800 bg-[#1c1e24]\"\n                    />\n                  ))}\n                </div>\n              ) : users.length === 0 ? (\n                <div className=\"rounded-2xl border border-neutral-800 p-12 text-center bg-[#1c1e24]\">\n                  <p className=\"text-xs text-foreground-muted\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в•ӘВ»в•Әв–’ в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».</p>\n                </div>\n              ) : (\n                <>\n                  <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                    {users.map((u) => (\n                      <PersonnelCard\n                        key={u.id}\n                        user={u}\n                        currentUserId={user?.id}\n                        visibleFields={visibleFields ?? undefined}\n                        onMessage={(userId) => router.push(`/chat?dm=${userId}`)}\n                        onProfile={(usr) => setSelectedDetailUser(usr)}\n                      />\n                    ))}\n                  </div>\n\n                  {/* Pagination */}\n                  {totalPages > 1 && (\n                    <div className=\"flex items-center justify-center gap-2 mt-6\">\n                      <Button\n                        variant=\"outline\"\n                        size=\"sm\"\n                        disabled={page === 1}\n                        onClick={() => setPage((p) => Math.max(1, p - 1))}\n                        className=\"text-xs font-bold\"\n                      >\n                        в”ҳГ©в•ӘВҝв”ҳГӨв–ҲГ®\n                      </Button>\n                      <span className=\"text-xs text-foreground-muted\">\n                        в•Әв•Ўв”ҳГјв•ӘВЎв”ҳГ§ {toFa(page)} в•ӘВәв•Әв–“ {toFa(totalPages)}\n                      </span>\n                      <Button\n                        variant=\"outline\"\n                        size=\"sm\"\n                        disabled={page === totalPages}\n                        onClick={() => setPage((p) => Math.min(totalPages, p + 1))}\n                        className=\"text-xs font-bold\"\n                      >\n                        в•ӘВҝв•Әв•Јв•ӘВ»в–ҲГ®\n                      </Button>\n                    </div>\n                  )}\n                </>\n              )}\n            </div>\n          </div>\n        </>\n      ) : (\n        // О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n        // CUSTOM FIELDS & PRIVACY MANAGER (ADMIN ONLY)\n        // О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n        <div className=\"p-6 md:p-8 max-w-7xl mx-auto flex flex-col lg:flex-row gap-6 w-full flex-1\">\n          <div className=\"w-full lg:w-96 shrink-0 space-y-6\">\n            {/* Form for Creating Dynamic Fields */}\n            <form onSubmit={handleCreateField} className=\"bg-[#1c1e24] border border-[#262930] rounded-2xl p-6 space-y-4\">\n              <h2 className=\"text-sm font-bold text-white mb-4 flex items-center gap-1.5\">\n                <Plus className=\"size-4 text-red-500\" />\n                в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n              </h2>\n\n              {fieldError && (\n                <div className=\"p-3 bg-red-500/10 border border-red-500/20 text-red-500 text-xs rounded-xl\">\n                  {fieldError}\n                </div>\n              )}\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-bold text-neutral-400 block\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» (в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ® - в–ҲГ®в”ҢвҢҗв•ӘВ¬в•ӘВә):</label>\n                <input\n                  type=\"text\"\n                  placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: fatherName\"\n                  value={newFieldName}\n                  onChange={(e) => setNewFieldName(e.target.value)}\n                  className=\"w-full bg-neutral-950 border border-neutral-800 rounded-xl px-3 py-2 text-xs text-white focus:border-red-500 outline-none font-mono\"\n                  dir=\"ltr\"\n                />\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-bold text-neutral-400 block\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» (в•ӘВҝв•Әв–’в”ҢГҘв•Әв”Ӯв•ӘВҝ):</label>\n                <input\n                  type=\"text\"\n                  placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•ӘВ»в•Әв–’\"\n                  value={newFieldLabel}\n                  onChange={(e) => setNewFieldLabel(e.target.value)}\n                  className=\"w-full bg-neutral-950 border border-neutral-800 rounded-xl px-3 py-2 text-xs text-white focus:border-red-500 outline-none\"\n                />\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-bold text-neutral-400 block\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»:</label>\n                <select\n                  value={newFieldType}\n                  onChange={(e) => setNewFieldType(e.target.value as any)}\n                  className=\"w-full bg-neutral-950 border border-neutral-800 rounded-xl px-3 py-2 text-xs text-white focus:border-red-500 outline-none\"\n                >\n                  <option value=\"text\">в”ҳГ в•ӘВ¬в”ҳГҘ (Text)</option>\n                  <option value=\"number\">в•Әв•Јв•ӘВ»в•ӘВ» (Number)</option>\n                  <option value=\"date\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« (Date)</option>\n                  <option value=\"boolean\">в•ӘВҝв”ҳГӨв”ҳГ§/в•ӘВ«в–ҲГ®в•Әв–’ (Boolean)</option>\n                  <option value=\"select\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝв–ҲГ® (Select)</option>\n                </select>\n              </div>\n\n              {newFieldType === 'select' && (\n                <div className=\"space-y-1\">\n                  <label className=\"text-[10px] font-bold text-neutral-400 block\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә (в•ӘВјв•ӘВ»в•ӘВә в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВәв”ҳГ в•ӘВә):</label>\n                  <input\n                    type=\"text\"\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§в–Ҳв–’, в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§в–Ҳв–“\"\n                    value={newFieldOptions}\n                    onChange={(e) => setNewFieldOptions(e.target.value)}\n                    className=\"w-full bg-neutral-950 border border-neutral-800 rounded-xl px-3 py-2 text-xs text-white focus:border-red-500 outline-none\"\n                  />\n                </div>\n              )}\n\n              <div className=\"flex items-center justify-between bg-neutral-950/45 p-3 rounded-xl border border-neutral-850\">\n                <label className=\"text-xs text-neutral-300 cursor-pointer\">в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬:</label>\n                <input\n                  type=\"checkbox\"\n                  checked={newFieldRequired}\n                  onChange={(e) => setNewFieldRequired(e.target.checked)}\n                  className=\"accent-red-600 size-4 cursor-pointer\"\n                />\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-bold text-neutral-400 block\">в•ӘВ¬в•Әв–’в•ӘВ¬в–ҲГ®в•ӘВҝ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө (в”ҳГӘв•Әв–“в”ҳГҘ):</label>\n                <input\n                  type=\"number\"\n                  value={newFieldSort}\n                  onChange={(e) => setNewFieldSort(Number(e.target.value))}\n                  className=\"w-full bg-neutral-950 border border-neutral-800 rounded-xl px-3 py-2 text-xs text-white focus:border-red-500 outline-none\"\n                />\n              </div>\n\n              <Button\n                type=\"submit\"\n                className=\"w-full bg-red-600 hover:bg-red-700 text-xs font-bold h-10 rounded-xl text-white active:scale-95 transition-all\"\n              >\n                в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ\n              </Button>\n            </form>\n\n            {/* Privacy Settings Panel */}\n            <div className=\"bg-[#1c1e24] border border-[#262930] rounded-2xl p-6 space-y-4\">\n              <h2 className=\"text-sm font-bold text-white mb-2 flex items-center gap-1.5\">\n                <Shield className=\"size-4 text-red-500\" />\n                в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВЎв•Әв–’в–ҲГ®в”ҳГ  в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ® в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ\n              </h2>\n              <p className=\"text-[10px] text-foreground-muted leading-relaxed\">\n                в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ» в”ҢГҘв”ҳГ§ в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬в–ҲГ® в•ӘВ»в•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВ¬ в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•Әв•Јв•ӘВәв•ӘВ»в–ҲГ® (в•Әв•‘в–ҲГ®в•Әв–’ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’) в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в•Әв”Өв”ҳГӘв•ӘВ». в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҳГ§в”ҳГ в”ҳГӘв•ӘВәв•Әв–’в”ҳГ§ в•ӘВҝв”ҳГ§ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВ»в•ӘВәв•Әв–’в”ҳГҘв•ӘВ».\n              </p>\n\n              <div className=\"space-y-2.5 pt-2 max-h-60 overflow-y-auto\">\n                <h3 className=\"text-[10px] font-bold text-neutral-400 border-b border-neutral-850 pb-1\">в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ :</h3>\n                \n                <label className=\"flex items-center justify-between p-2 rounded-xl bg-neutral-950/20 border border-neutral-800 cursor-pointer select-none\">\n                  <span className=\"text-xs text-white\">в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®</span>\n                  <input\n                    type=\"checkbox\"\n                    checked={tempVisibleFields.includes('nationalId')}\n                    onChange={() => handleToggleVisibleField('nationalId')}\n                    className=\"accent-red-600 size-4 cursor-pointer\"\n                  />\n                </label>\n\n                <label className=\"flex items-center justify-between p-2 rounded-xl bg-neutral-950/20 border border-neutral-800 cursor-pointer select-none\">\n                  <span className=\"text-xs text-white\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§</span>\n                  <input\n                    type=\"checkbox\"\n                    checked={tempVisibleFields.includes('phone')}\n                    onChange={() => handleToggleVisibleField('phone')}\n                    className=\"accent-red-600 size-4 cursor-pointer\"\n                  />\n                </label>\n\n                <label className=\"flex items-center justify-between p-2 rounded-xl bg-neutral-950/20 border border-neutral-800 cursor-pointer select-none\">\n                  <span className=\"text-xs text-white\">в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ</span>\n                  <input\n                    type=\"checkbox\"\n                    checked={tempVisibleFields.includes('email')}\n                    onChange={() => handleToggleVisibleField('email')}\n                    className=\"accent-red-600 size-4 cursor-pointer\"\n                  />\n                </label>\n\n                <label className=\"flex items-center justify-between p-2 rounded-xl bg-neutral-950/20 border border-neutral-800 cursor-pointer select-none\">\n                  <span className=\"text-xs text-white\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ</span>\n                  <input\n                    type=\"checkbox\"\n                    checked={tempVisibleFields.includes('vehicles')}\n                    onChange={() => handleToggleVisibleField('vehicles')}\n                    className=\"accent-red-600 size-4 cursor-pointer\"\n                  />\n                </label>\n\n                <h3 className=\"text-[10px] font-bold text-neutral-400 border-b border-neutral-850 pb-1 pt-2\">в”ҳГӘв–ҲГ®в”ҢГҝв”ҢВ»в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВә:</h3>\n                \n                {fieldDefs.length === 0 ? (\n                  <p className=\"text-[10px] text-neutral-500 italic\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ®в–ҲГ® в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n                ) : (\n                  fieldDefs.map((def) => {\n                    const isChecked = tempVisibleFields.includes(def.name)\n                    return (\n                      <label key={def.id} className=\"flex items-center justify-between p-2 rounded-xl bg-neutral-950/20 border border-neutral-800 cursor-pointer select-none\">\n                        <span className=\"text-xs text-white\">{def.label}</span>\n                        <input\n                          type=\"checkbox\"\n                          checked={isChecked}\n                          onChange={() => handleToggleVisibleField(def.name)}\n                          className=\"accent-red-600 size-4 cursor-pointer\"\n                        />\n                      </label>\n                    )\n                  })\n                )}\n              </div>\n\n              <Button\n                onClick={handleSavePrivacySettings}\n                disabled={savingPrivacy}\n                className=\"w-full bg-red-600 hover:bg-red-700 text-xs font-bold h-10 rounded-xl text-white active:scale-95 transition-all mt-2\"\n              >\n                {savingPrivacy ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§...' : 'в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВЎв•Әв–’в–ҲГ®в”ҳГ  в•ӘВ«в•Әв•Ўв”ҳГӘв•Әв•Ўв–ҲГ®'}\n              </Button>\n            </div>\n          </div>\n\n          {/* Field Definitions List */}\n          <div className=\"flex-1 bg-[#1c1e24] border border-[#262930] rounded-2xl p-6\">\n            <h2 className=\"text-sm font-bold text-white mb-4 flex items-center gap-1.5\">\n              <Settings2 className=\"size-4 text-red-500\" />\n              в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n            </h2>\n\n            {fieldsLoading ? (\n              <p className=\"text-xs text-neutral-400\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВ¬в•Әв•Јв•ӘВәв•Әв–’в–ҲГ®в”ҳГј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВә...</p>\n            ) : fieldDefs.length === 0 ? (\n              <div className=\"border border-dashed border-neutral-800 rounded-xl p-8 text-center text-xs text-neutral-500\">\n                в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в”ҳГ в•ӘВҪв”ҳГӨ в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв•ӘГ® в”ҳв•ӣв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в”ҳГӘ в•Әв•‘в–ҲГ®в•Әв–’в”ҳГ§ в•Әв–’в•ӘВә в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n              </div>\n            ) : (\n              <div className=\"space-y-3\">\n                {fieldDefs.map((def) => (\n                  <div\n                    key={def.id}\n                    className=\"p-4 bg-neutral-950/20 rounded-xl border border-neutral-800/80 flex items-center justify-between gap-4\"\n                  >\n                    <div className=\"space-y-1\">\n                      <div className=\"flex items-center gap-2\">\n                        <span className=\"text-xs font-bold text-white\">\n                          {def.label}\n                        </span>\n                        <Badge variant=\"outline\" className=\"text-[8px] px-1.5 py-0.5 border-neutral-800 font-mono text-neutral-400\">\n                          {def.name}\n                        </Badge>\n                        {def.required && (\n                          <span className=\"text-[8px] bg-red-500/10 text-red-400 border border-red-500/20 px-1 py-0.5 rounded\">\n                            в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ®\n                          </span>\n                        )}\n                      </div>\n                      <p className=\"text-[10px] text-neutral-500\">\n                        в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§: {def.type} {def.options && def.options.length > 0 ? `(${def.options.join(', ')})` : ''}\n                      </p>\n                    </div>\n\n                    <button\n                      onClick={() => handleDeleteField(def.id)}\n                      className=\"text-neutral-500 hover:text-red-500 p-1.5 rounded transition-all\"\n                      title=\"в•ӘВЎв•Әв–‘в”ҳГј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»\"\n                    >\n                      <Trash2 className=\"size-4\" />\n                    </button>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n        </div>\n      )}\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* DIALOG: Personnel Detail View */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {selectedDetailUser && (\n        <Dialog open={!!selectedDetailUser} onOpenChange={(open) => !open && setSelectedDetailUser(null)}>\n          <DialogContent className=\"bg-[#1c1e24] border-[#262930] w-full max-w-lg p-6 text-right\" dir=\"rtl\">\n            <DialogHeader className=\"border-b border-neutral-800 pb-3 flex flex-row justify-between items-center\">\n              <DialogTitle className=\"text-sm font-bold text-white flex items-center gap-2\">\n                <User className=\"size-4 text-red-500\" />\n                в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВ¬ в•ӘВ¬в”ҳГјв•Әв•Ўв–ҲГ®в”ҳГӨв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ: {selectedDetailUser.name}\n              </DialogTitle>\n            </DialogHeader>\n\n            <div className=\"space-y-5 text-xs py-2\">\n              \n              {/* Main Badge Card */}\n              <div className=\"bg-neutral-950/40 p-4 rounded-xl border border-neutral-850 flex items-center gap-4\">\n                <div className=\"size-14 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500 text-lg font-bold\">\n                  {selectedDetailUser.name.substring(0, 1)}\n                </div>\n                <div className=\"space-y-1\">\n                  <h3 className=\"text-xs font-bold text-white\">{selectedDetailUser.name}</h3>\n                  <span className=\"text-[10px] text-foreground-muted block\">{selectedDetailUser.role.name}</span>\n                </div>\n                <div className=\"ms-auto flex flex-col items-end gap-1.5\">\n                  <Badge className={cn(\n                    'text-[9px] font-bold px-2 py-0.5 border',\n                    selectedDetailUser.status === 'active'\n                      ? 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400'\n                      : selectedDetailUser.status === 'pending'\n                      ? 'bg-amber-500/10 border-amber-500/20 text-amber-400'\n                      : 'bg-neutral-800 border-neutral-700 text-neutral-400'\n                  )}>\n                    {selectedDetailUser.status === 'active' ? 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ' : selectedDetailUser.status === 'pending' ? 'в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’' : 'в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©'}\n                  </Badge>\n                </div>\n              </div>\n\n              {/* Personal Info Grid */}\n              {(() => {\n                const isAdmin = user?.roleKey === 'admin' || user?.roleKey === 'super_admin'\n                const isOwnProfile = selectedDetailUser.id === user?.id\n                const showSensitive = isAdmin || isOwnProfile\n                // Safe fallback when visibleFields hasn't loaded from config yet\n                const allowedModalFields = visibleFields ?? ['phone', 'email', 'personnelNo', 'post', 'shift', 'shiftType', 'group', 'startLocation', 'vehicles']\n                \n                return (\n                  <>\n                    <div className=\"grid grid-cols-2 gap-3\">\n                      {(showSensitive || allowedModalFields.includes('nationalId')) && (\n                        <div className=\"bg-neutral-950/20 p-3 rounded-xl border border-neutral-850\">\n                          <span className=\"text-[10px] text-foreground-muted block mb-1\">в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’:</span>\n                          <span className=\"font-mono text-white font-semibold\">{toFa(selectedDetailUser.nationalId)}</span>\n                        </div>\n                      )}\n                      {(showSensitive || allowedModalFields.includes('phone')) && selectedDetailUser.phone && (\n                        <a\n                          href={`tel:${selectedDetailUser.phone}`}\n                          className=\"p-3 rounded-xl border border-green-500/25 bg-gradient-to-l from-green-500/10 to-emerald-600/5 hover:border-green-400/50 transition-all group/ph cursor-pointer block\"\n                        >\n                          <span className=\"text-[10px] text-green-500/70 block mb-1 flex items-center gap-1\">\n                            <Phone className=\"size-3\" />\n                            в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§:\n                          </span>\n                          <span dir=\"ltr\" className=\"font-mono text-green-400 font-bold tracking-wide group-hover/ph:text-green-300 transition-colors\">\n                            {toFa(selectedDetailUser.phone.replace(/(\\d{4})(\\d{3})(\\d{4})/, '$1-$2-$3'))}\n                          </span>\n                        </a>\n                      )}\n                      {(showSensitive || allowedModalFields.includes('email')) && selectedDetailUser.email && (\n                        <a\n                          href={`mailto:${selectedDetailUser.email}`}\n                          className=\"p-3 rounded-xl border border-blue-500/20 bg-gradient-to-l from-blue-500/8 to-sky-600/5 hover:border-blue-400/40 transition-all col-span-2 cursor-pointer block\"\n                        >\n                          <span className=\"text-[10px] text-blue-400/70 block mb-1 flex items-center gap-1\">\n                            <Mail className=\"size-3\" />\n                            в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ:\n                          </span>\n                          <span dir=\"ltr\" className=\"font-mono text-blue-300/90 font-semibold\">{selectedDetailUser.email}</span>\n                        </a>\n                      )}\n                    </div>\n\n                    {/* Dynamic Custom Fields Row */}\n                    <div className=\"space-y-2 border-t border-neutral-800 pt-4\">\n                      <h4 className=\"text-[10px] font-bold text-red-500 flex items-center gap-1\">\n                        <Layers className=\"size-3.5\" />\n                        в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГӘ в”ҳГӘв–ҲГ®в”ҢГҝв”ҢВ»в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                      </h4>\n                      \n                      {(() => {\n                        const allowedDetailFields = fieldDefs.filter((def) => {\n                          if (def.name === 'vehicles') return false // rendered separately\n                          const value = selectedDetailUser.customFields?.[def.name]\n                          if (value === undefined || value === null || value === '') return false\n                          return showSensitive || allowedModalFields.includes(def.name)\n                        })\n\n                        if (allowedDetailFields.length === 0) {\n                          return (\n                            <p className=\"text-[10px] text-neutral-500 italic\">\n                              в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ® в”ҳГӘ в”ҳГӘв–ҲГ®в”ҢГҝв”ҢВ»в–ҲГ® в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ».\n                            </p>\n                          )\n                        }\n\n                        return (\n                          <div className=\"grid grid-cols-2 gap-3 mt-2\">\n                            {allowedDetailFields.map((def) => {\n                              const value = selectedDetailUser.customFields?.[def.name]\n                              let displayVal = String(value)\n                              if (def.type === 'boolean') {\n                                displayVal = value ? 'в•ӘВҝв”ҳГӨв”ҳГ§' : 'в•ӘВ«в–ҲГ®в•Әв–’'\n                              }\n\n                              return (\n                                <div key={def.name} className=\"p-2.5 bg-neutral-950/30 rounded-xl border border-neutral-850 flex justify-between items-center\">\n                                  <span className=\"text-[10px] text-foreground-muted\">{def.label}:</span>\n                                  <span className=\"font-bold text-white\">{toFa(displayVal)}</span>\n                                </div>\n                              )\n                            })}\n                          </div>\n                        )\n                      })()}\n\n                      {/* Vehicle Plates (graphical) */}\n                      {(() => {\n                        const canShowVehiclesDetail = true\n                        const detailVehicles = (selectedDetailUser.customFields?.vehicles as any[]) || []\n                        if (!canShowVehiclesDetail || detailVehicles.length === 0) return null\n                        return (\n                          <div className=\"mt-3 space-y-2\">\n                            <h5 className=\"text-[10px] font-bold text-neutral-400 flex items-center gap-1\">\n                              <Car className=\"size-3\" />\n                              в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§\n                            </h5>\n                            <div className=\"flex flex-wrap gap-2\">\n                              {detailVehicles.map((v: Record<string, unknown>, idx: number) => (\n                                <VehiclePlateFromData key={idx} vehicle={v} size=\"md\" />\n                              ))}\n                            </div>\n                          </div>\n                        )\n                      })()}\n                    </div>\n                  </>\n                )\n              })()}\n\n              {/* Actions Footer */}\n              <div className=\"flex gap-2 pt-4 border-t border-neutral-850 justify-end\">\n                <Button\n                  variant=\"outline\"\n                  onClick={() => setSelectedDetailUser(null)}\n                  className=\"border-neutral-800 hover:bg-neutral-900 text-xs rounded-xl h-10 px-4\"\n                >\n                  в•ӘВҝв•Әв”Ӯв•ӘВ¬в”ҳГҘ в•ӘВ»в–ҲГ®в•ӘВәв”ҳГӨв”ҳГӘв”ҢВ»\n                </Button>\n                <Button\n                  onClick={() => {\n                    setSelectedDetailUser(null)\n                    router.push(`/chat?dm=${selectedDetailUser.id}`)\n                  }}\n                  className=\"bg-red-600 hover:bg-red-700 text-xs font-bold rounded-xl h-10 px-6 text-white active:scale-95 transition-all\"\n                >\n                  в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ  в•ӘВ»в•Әв–’ в”ҢГҘв•ӘВ¬\n                </Button>\n              </div>\n\n            </div>\n          </DialogContent>\n        </Dialog>\n      )}\n\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\feedback\\page.tsx","messages":[{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from 'react-hooks/set-state-in-effect').","line":74,"column":3,"severity":1,"nodeType":null,"fix":{"range":[1968,2020],"text":" "}},{"ruleId":"react-hooks/exhaustive-deps"