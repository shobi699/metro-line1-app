"'addPoints' is defined but never used.","line":4,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"addPoints"},"fix":{"range":[152,218],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { NextResponse } from 'next/server'\nimport { prisma } from '@/server/db'\nimport { getSessionUser, authErrorResponse } from '@/server/rbac/guard'\nimport { addPoints } from '@/server/modules/gamification/service'\n\ninterface QuizQuestion {\n  q: string\n  options: string[]\n  answerIndex: number\n}\n\nfunction extractQuiz(body: string): QuizQuestion[] | null {\n  const match = body.match(/\\[quiz\\]([\\s\\S]*?)\\[\\/quiz\\]/)\n  if (!match) return null\n  try {\n    return JSON.parse(match[1].trim())\n  } catch {\n    return null\n  }\n}\n\nexport async function POST(\n  request: Request,\n  { params }: { params: Promise<{ id: string }> },\n) {\n  const user = await getSessionUser(request)\n  if ('error' in user) return authErrorResponse(user)\n\n  const { id } = await params\n\n  try {\n    const bodyData = await request.json()\n    const { answers } = bodyData\n\n    if (!Array.isArray(answers)) {\n      return NextResponse.json(\n        { error: 'в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ«О“ГҮГ®в”ҳГ§в•ӘВә в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВ»в•Әв–’ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в•ӘГів•Әв–’в•ӘВәв–ҲГ®в”ҳГ§ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•Әв”Өв”ҳГӘв”ҳГҘв•ӘВ»' },\n        { status: 400 },\n      )\n    }\n\n    const post = await prisma.post.findUnique({\n      where: { id },\n    })\n\n    if (!post) {\n      return NextResponse.json({ error: 'в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВә в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»' }, { status: 404 })\n    }\n\n    const quiz = extractQuiz(post.body)\n\n    if (!quiz || quiz.length === 0) {\n      return NextResponse.json(\n        { error: 'в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВәв–ҲГ® в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬' },\n        { status: 400 },\n      )\n    }\n\n    if (answers.length !== quiz.length) {\n      return NextResponse.json(\n        { error: 'в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ«О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨв–ҲГ® в•ӘВҝв•ӘВә в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в”ҳГ в•Әв•–в•ӘВәв•ӘВҝв”ҳГ©в•ӘВ¬ в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ»' },\n        { status: 400 },\n      )\n    }\n\n    // Verify answers\n    const wrongAnswers: number[] = []\n    quiz.forEach((q, idx) => {\n      if (answers[idx] !== q.answerIndex) {\n        wrongAnswers.push(idx + 1) // 1-indexed for user visibility\n      }\n    })\n\n    if (wrongAnswers.length > 0) {\n      return NextResponse.json({\n        success: false,\n        message: `в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•Әв”Өв”ҳГ в•ӘВә в•ӘВҝв”ҳГ§ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ (${wrongAnswers.join('в•ӘГ® ')}) в”ҳГҘв•ӘВәв•ӘВ»в•Әв–’в•Әв”Ӯв•ӘВ¬ в•ӘВҝв”ҳГӘв•ӘВ». в”ҳГӨв•Әв•–в”ҳГјв•ӘВә в•ӘВ»в”ҳГӘв•ӘВҝв•ӘВәв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГӨв•ӘВәв•Әв”Ө в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».`,\n      })\n    }\n\n    // Award 50 points if all answers are correct\n    const period = new Date().toISOString().substring(0, 7) // e.g., \"2026-06\"\n    const reason = `quiz_completed_post_${post.id}`\n\n    // Check if points were already awarded\n    const existingScore = await prisma.gamificationScore.findUnique({\n      where: {\n        userId_period_reason: {\n          userId: user.id,\n          period,\n          reason,\n        },\n      },\n    })\n\n    if (existingScore) {\n      return NextResponse.json({\n        success: true,\n        alreadyAwarded: true,\n        message: 'в•Әв”Өв”ҳГ в•ӘВә в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в•Әв–’в•ӘВә в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в”ҳв•ӣв•ӘВәв•Әв”Ӯ в”ҢвҢҗв•Әв–’в•ӘВ»в–ҲГ®в•ӘВ»! (в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в”ҳГ©в•ӘВҝв”ҳГӨв•ӘВәв”ҳГҜ в•ӘВҝв”ҳГ§ в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ в•Әв”Өв”ҳГ в•ӘВә в”ҳГ в”ҳГҘв•Әв••в”ҳГӘв•Әв–’ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.)',\n      })\n    }\n\n    await prisma.$transaction(async (tx) => {\n      // Use service in tx if needed, but since service is simple we can call it or manually upsert inside tx\n      await tx.gamificationScore.upsert({\n        where: {\n          userId_period_reason: {\n            userId: user.id,\n            period,\n            reason,\n          },\n        },\n        update: { points: { increment: 50 } },\n        create: {\n          userId: user.id,\n          points: 50,\n          reason,\n          period,\n        },\n      })\n\n      // Write AuditLog\n      await tx.auditLog.create({\n        data: {\n          actorId: user.id,\n          entity: 'Post',\n          entityId: post.id,\n          action: 'update',\n          after: {\n            reason: 'Completed training quiz and earned 50 points',\n          },\n        },\n      })\n    })\n\n    return NextResponse.json({\n      success: true,\n      pointsAwarded: 50,\n      message: 'в•ӘВ¬в•ӘВҝв•Әв–’в–ҲГ®в”ҢвҢҗ! в•Әв”Өв”ҳГ в•ӘВә в•ӘВҝв”ҳГ§ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•Әв•Ўв•ӘВЎв–ҲГ®в•ӘВЎ в•ӘВ»в•ӘВәв•ӘВ»в–ҲГ®в•ӘВ» в”ҳГӘ в–Ҳв•Ўв–Ҳв–‘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҢвҢҗв•Әв–’в•ӘВ»в–ҲГ®в•ӘВ».',\n    })\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’'\n    return NextResponse.json(\n      { error: message },\n      { status: 500 },\n    )\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\api\\posts\\[id]\\read\\route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fi