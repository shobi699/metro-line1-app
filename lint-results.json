ifier","messageId":"unusedVar","endLine":31,"endColumn":8,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Radio"},"fix":{"range":[501,510],"text":""},"desc":"Remove unused variable \"Radio\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'FileSpreadsheet' is defined but never used.","line":32,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":32,"endColumn":18,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"FileSpreadsheet"},"fix":{"range":[510,529],"text":""},"desc":"Remove unused variable \"FileSpreadsheet\"."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":113,"column":11,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":113,"endColumn":14,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1818,1821],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1818,1821],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":114,"column":10,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":114,"endColumn":13,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1831,1834],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1831,1834],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":145,"column":56,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":145,"endColumn":59,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2457,2460],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2457,2460],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'hasNew' is assigned a value but never used.","line":266,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":266,"endColumn":19},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadLiveData'. Either include it or remove the dependency array.","line":322,"column":6,"nodeType":"ArrayExpression","endLine":322,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadLiveData]","fix":{"range":[9137,9150],"text":"[accessToken, loadLiveData]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadLiveData'. Either include it or remove the dependency array.","line":331,"column":6,"nodeType":"ArrayExpression","endLine":331,"endColumn":34,"suggestions":[{"desc":"Update the dependencies array to be: [pollingActive, accessToken, loadLiveData]","fix":{"range":[9382,9410],"text":"[pollingActive, accessToken, loadLiveData]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'triggerToast'. Either include it or remove the dependency array.","line":404,"column":6,"nodeType":"ArrayExpression","endLine":404,"endColumn":23,"suggestions":[{"desc":"Update the dependencies array to be: [simulatorActive, triggerToast]","fix":{"range":[12574,12591],"text":"[simulatorActive, triggerToast]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":15,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState, useRef } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { toFa, jalali, faTime } from '@/lib/fa'\nimport { cn } from '@/lib/utils'\nimport { TopAppBar } from '@/components/shared/top-app-bar'\nimport {\n  Bell,\n  Volume2,\n  VolumeX,\n  Play,\n  Pause,\n  Activity,\n  UserCheck,\n  CheckCircle2,\n  XCircle,\n  Clock,\n  User,\n  Shield,\n  ArrowLeftRight,\n  Trophy,\n  History,\n  Sparkles,\n  Zap,\n  Check,\n  AlertTriangle,\n  RefreshCw,\n  Search,\n  Eye,\n  Radio,\n  FileSpreadsheet,\n} from 'lucide-react'\n\n// О“Г¶ГҮО“Г¶ГҮ Types О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\ninterface PendingUser {\n  id: string\n  nationalId: string\n  name: string\n  phone: string | null\n  email: string | null\n  createdAt: string\n  role: {\n    id: string\n    key: string\n    name: string\n  }\n}\n\ninterface PendingSwap {\n  id: string\n  requesterId: string\n  targetId: string\n  sourceShiftId: string\n  targetShiftId: string\n  status: string\n  note: string | null\n  createdAt: string\n  requester: {\n    id: string\n    name: string\n    nationalId: string\n  }\n  target: {\n    id: string\n    name: string\n    nationalId: string\n  }\n  sourceShift: {\n    id: string\n    date: string\n    code: string\n  }\n  targetShift: {\n    id: string\n    date: string\n    code: string\n  }\n}\n\ninterface PendingAppeal {\n  id: string\n  logId: string\n  employeeId: string\n  reason: string\n  status: string\n  reviewedById: string | null\n  note: string | null\n  createdAt: string\n  employee: {\n    id: string\n    name: string\n    nationalId: string\n  }\n  log: {\n    id: string\n    scoreValue: number\n    note: string | null\n    actionType: {\n      id: string\n      title: string\n    }\n  }\n}\n\ninterface AuditLogEntry {\n  id: string\n  actorId: string\n  entity: string\n  entityId: string\n  action: string\n  before: any\n  after: any\n  createdAt: string\n  actor: {\n    id: string\n    name: string\n    role: {\n      name: string\n      key: string\n    }\n  }\n}\n\ninterface RoleOption {\n  id: string\n  key: string\n  name: string\n}\n\ninterface DBStatusData {\n  pendingUsers: PendingUser[]\n  pendingSwapRequests: PendingSwap[]\n  pendingAppeals: PendingAppeal[]\n  recentAuditLogs: AuditLogEntry[]\n  roles: RoleOption[]\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Web Audio Synth Alert Sound О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\nfunction playAlertSound(type: 'info' | 'warning' | 'success') {\n  if (typeof window === 'undefined') return\n  try {\n    const ctx = new (window.AudioContext || (window as any).webkitAudioContext)()\n    const osc = ctx.createOscillator()\n    const gain = ctx.createGain()\n\n    osc.connect(gain)\n    gain.connect(ctx.destination)\n\n    if (type === 'warning') {\n      osc.type = 'sine'\n      osc.frequency.setValueAtTime(587.33, ctx.currentTime) // D5\n      osc.frequency.setValueAtTime(880, ctx.currentTime + 0.1) // A5\n      gain.gain.setValueAtTime(0.2, ctx.currentTime)\n      gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.35)\n      osc.start(ctx.currentTime)\n      osc.stop(ctx.currentTime + 0.35)\n    } else if (type === 'success') {\n      osc.type = 'triangle'\n      osc.frequency.setValueAtTime(523.25, ctx.currentTime) // C5\n      osc.frequency.setValueAtTime(659.25, ctx.currentTime + 0.08) // E5\n      osc.frequency.setValueAtTime(783.99, ctx.currentTime + 0.16) // G5\n      gain.gain.setValueAtTime(0.15, ctx.currentTime)\n      gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3)\n      osc.start(ctx.currentTime)\n      osc.stop(ctx.currentTime + 0.3)\n    } else {\n      osc.type = 'sine'\n      osc.frequency.setValueAtTime(440, ctx.currentTime) // A4\n      gain.gain.setValueAtTime(0.1, ctx.currentTime)\n      gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.25)\n      osc.start(ctx.currentTime)\n      osc.stop(ctx.currentTime + 0.25)\n    }\n  } catch (e) {\n    console.warn('Audio Context blocked or unsupported:', e)\n  }\n}\n\n// О“Г¶ГҮО“Г¶ГҮ Main Page Component О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\nexport default function LiveActionsPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  \n  // Real DB States\n  const [users, setUsers] = useState<PendingUser[]>([])\n  const [swaps, setSwaps] = useState<PendingSwap[]>([])\n  const [appeals, setAppeals] = useState<PendingAppeal[]>([])\n  const [auditLogs, setAuditLogs] = useState<AuditLogEntry[]>([])\n  const [roles, setRoles] = useState<RoleOption[]>([])\n  const [loading, setLoading] = useState(true)\n\n  // Interactive Live Features\n  const [pollingActive, setPollingActive] = useState(true)\n  const [simulatorActive, setSimulatorActive] = useState(false)\n  const [audioEnabled, setAudioEnabled] = useState(true)\n  const [notificationPermission, setNotificationPermission] = useState<'default' | 'granted' | 'denied'>('default')\n  const [lastUpdated, setLastUpdated] = useState<Date>(new Date())\n  const [activeTab, setActiveTab] = useState<'all' | 'users' | 'swaps' | 'appeals' | 'logs'>('all')\n\n  const isTab = (tab: string) => activeTab === 'all' || activeTab === tab\n\n  // Notification and Action States\n  const [actionLoading, setActionLoading] = useState<string | null>(null)\n  const [notification, setNotification] = useState<{ type: 'success' | 'error', text: string } | null>(null)\n  const [selectedRoles, setSelectedRoles] = useState<Record<string, string>>({})\n  const [appealNotes, setAppealNotes] = useState<Record<string, string>>({})\n  const [toastMessages, setToastMessages] = useState<{ id: string; title: string; body: string; type: 'info' | 'warning' }[]>([])\n\n  // Tracking seen items to trigger alerts only on actual additions\n  const knownIdsRef = useRef<Set<string>>(new Set())\n  const initializedRef = useRef(false)\n\n  // Initialize permission status\n  useEffect(() => {\n    if (typeof window !== 'undefined' && 'Notification' in window) {\n      setNotificationPermission(Notification.permission)\n    }\n  }, [])\n\n  const requestNotificationPermission = async () => {\n    if (typeof window !== 'undefined' && 'Notification' in window) {\n      const res = await Notification.requestPermission()\n      setNotificationPermission(res)\n    }\n  }\n\n  const triggerToast = (title: string, body: string, type: 'info' | 'warning' = 'info') => {\n    const id = Math.random().toString(36).substring(2, 9)\n    setToastMessages((prev) => [{ id, title, body, type }, ...prev])\n    setTimeout(() => {\n      setToastMessages((prev) => prev.filter((m) => m.id !== id))\n    }, 5000)\n\n    if (audioEnabled) {\n      playAlertSound(type === 'warning' ? 'warning' : 'info')\n    }\n\n    if (typeof window !== 'undefined' && 'Notification' in window && Notification.permission === 'granted') {\n      new Notification(title, { body, dir: 'rtl', lang: 'fa-IR' })\n    }\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮ Fetch Function О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  async function loadLiveData(silent = false) {\n    if (!accessToken) return\n    if (!silent) setLoading(true)\n    try {\n      const res = await fetch('/api/admin/live-actions', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const json = await res.json()\n        const data = json.data as DBStatusData\n\n        setUsers(data.pendingUsers)\n        setSwaps(data.pendingSwapRequests)\n        setAppeals(data.pendingAppeals)\n        setAuditLogs(data.recentAuditLogs)\n        setRoles(data.roles)\n\n        // Check for new items to sound notification\n        let hasNew = false\n        const currentIds = new Set<string>()\n\n        data.pendingUsers.forEach((u) => {\n          currentIds.add(u.id)\n          if (!knownIdsRef.current.has(u.id)) {\n            if (initializedRef.current) {\n              triggerToast('в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ  в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ', `в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в”¬ВҪ${u.name}в”¬в•— в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВ»в”ҳГ в”ҳГӨв–ҲГ® ${toFa(u.nationalId)} в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ  в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§ в”ҳГӘ в”ҳГ в”ҳГҘв•ӘВ¬в•Әв••в•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВәв•Әв”Ӯв•ӘВ¬.`, 'warning')\n              hasNew = true\n            }\n            knownIdsRef.current.add(u.id)\n          }\n        })\n\n        data.pendingSwapRequests.forEach((s) => {\n          currentIds.add(s.id)\n          if (!knownIdsRef.current.has(s.id)) {\n            if (initializedRef.current) {\n              triggerToast('в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬', `в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•ӘВәв•Әв–“ в•Әв•–в•Әв–’в”ҳГј в”¬ВҪ${s.requester.name}в”¬в•— в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ».`, 'info')\n              hasNew = true\n            }\n            knownIdsRef.current.add(s.id)\n          }\n        })\n\n        data.pendingAppeals.forEach((a) => {\n          currentIds.add(a.id)\n          if (!knownIdsRef.current.has(a.id)) {\n            if (initializedRef.current) {\n              triggerToast('в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»', `в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”¬ВҪ${a.employee.name}в”¬в•— в•ӘВҝв”ҳГ§ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в•Әв•–в•ӘВә в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.`, 'info')\n              hasNew = true\n            }\n            knownIdsRef.current.add(a.id)\n          }\n        })\n\n        // Clean up stale IDs from known sets\n        knownIdsRef.current.forEach((id) => {\n          if (!currentIds.has(id) && !id.startsWith('mock-')) {\n            knownIdsRef.current.delete(id)\n          }\n        })\n\n        initializedRef.current = true\n        setLastUpdated(new Date())\n      }\n    } catch {\n      // live control data fetch failed silently\n    } finally {\n      if (!silent) setLoading(false)\n    }\n  }\n\n  // Initial Load\n  useEffect(() => {\n    void loadLiveData()\n  }, [accessToken])\n\n  // Polling Effect (every 8 seconds)\n  useEffect(() => {\n    if (!pollingActive || !accessToken) return\n    const timer = setInterval(() => {\n      void loadLiveData(true)\n    }, 8000)\n    return () => clearInterval(timer)\n  }, [pollingActive, accessToken])\n\n  // О“Г¶ГҮО“Г¶ГҮ Simulator Effect О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  useEffect(() => {\n    if (!simulatorActive) return\n    const timer = setInterval(() => {\n      // Pick random simulated event\n      const events = ['user', 'swap', 'appeal']\n      const type = events[Math.floor(Math.random() * events.length)]\n      const id = 'mock-' + Math.random().toString(36).substring(2, 9)\n\n      if (type === 'user') {\n        const mockNames = ['в”ҳГ в•Әв–’в•ӘВ¬в•Әв•ўв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв••в”ҳГ в–ҲГ®', 'в”ҳГӘв•ӘВЎв–ҲГ®в•ӘВ» в•Әв•Ўв•ӘВәв•ӘВ»в”ҳГ©в–ҲГ®', 'в”ҳГ в”ҳГ§в•ӘВ»в–ҲГ® в•ӘВәв•ӘВҝв•Әв–’в•ӘВәв”ҳГ§в–ҲГ®в”ҳГ в–ҲГ®']\n        const name = mockNames[Math.floor(Math.random() * mockNames.length)]\n        const nationalId = '008' + Math.floor(1000000 + Math.random() * 9000000)\n        const newUser: PendingUser = {\n          id,\n          name,\n          nationalId,\n          phone: '0912' + Math.floor(1000000 + Math.random() * 9000000),\n          email: 'simulated@metro.ir',\n          createdAt: new Date().toISOString(),\n          role: { id: 'temp', key: 'operator', name: 'в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’' },\n        }\n        setUsers((prev) => [newUser, ...prev])\n        triggerToast('в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ  в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®)', `в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в”¬ВҪ${name}в”¬в•— в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ  в”ҢвҢҗв•Әв–’в•ӘВ». (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“)`, 'warning')\n      } else if (type === 'swap') {\n        const mockNames = ['в•Әв”Ӯв•Әв•Јв–ҲГ®в•ӘВ» в•Әв–’в•Әв•ўв•ӘВәв–ҲГ®в–ҲГ®', 'в•ӘВәв•ӘВЎв•Әв”Ӯв•ӘВәв”ҳГҘ в”ҳГ©в•ӘВәв•Әв”Ӯв”ҳГ в–ҲГ®', 'в•ӘВәв”ҳГ в–ҲГ®в•Әв–’ в”ҳГ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®']\n        const name1 = mockNames[Math.floor(Math.random() * mockNames.length)]\n        const name2 = 'в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в”ҳГ§в•ӘВ»в”ҳГј'\n        const newSwap: PendingSwap = {\n          id,\n          requesterId: 'req-sim',\n          targetId: 'target-sim',\n          sourceShiftId: 's-sim',\n          targetShiftId: 't-sim',\n          status: 'pending',\n          note: 'в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ в•ӘВҝв”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГӨв•ӘВ¬ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГјв•Әв”Өв•Әв–’в•ӘВ»в”ҳГ§ в”ҳГ©в•ӘВҝв”ҳГӨв–ҲГ®',\n          createdAt: new Date().toISOString(),\n          requester: { id: 'req-sim', name: name1, nationalId: '123' },\n          target: { id: 'target-sim', name: name2, nationalId: '456' },\n          sourceShift: { id: 's-sim', date: new Date().toISOString(), code: 'morning' },\n          targetShift: { id: 't-sim', date: new Date().toISOString(), code: 'night' },\n        }\n        setSwaps((prev) => [newSwap, ...prev])\n        triggerToast('в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®)', `в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•ӘВәв•Әв–“ в•Әв•–в•Әв–’в”ҳГј в”¬ВҪ${name1}в”¬в•— в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ». (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“)`, 'info')\n      } else {\n        const mockNames = ['в•Әв•Јв”ҳГӨв–ҲГ®в•Әв–’в•Әв•ўв•ӘВә в•ӘВјв”ҳГӨв•ӘВәв”ҳГӨв–ҲГ®', 'в•Әв”Ӯв”ҳГ§в•Әв–’в•ӘВәв•ӘВҝ в•ӘВәв•ӘВЎв”ҳГ в•ӘВ»в–ҲГ®', 'в•ӘВЎв•ӘВәв”ҳГ в•ӘВ» в•Әв•–в•ӘВәв”ҳГ§в•Әв–’в–ҲГ®']\n        const name = mockNames[Math.floor(Math.random() * mockNames.length)]\n        const newAppeal: PendingAppeal = {\n          id,\n          logId: 'log-sim',\n          employeeId: 'emp-sim',\n          reason: 'в•ӘВ¬в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в•ӘВҝв”ҳГ§ в•ӘВ»в”ҳГӨв–ҲГ®в”ҳГӨ в•ӘВ¬в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в•ӘВ»в•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВәв•Әв•Јв•Әв–“в•ӘВәв”ҳГ  в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ в•Әв–’в•ӘВ« в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГӘ в”ҳГ в•ӘВ»в•ӘВәв•Әв–’в”ҢвҢҗ в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬ в•ӘВәв•Әв”Ӯв•ӘВ¬',\n          status: 'pending',\n          reviewedById: null,\n          note: null,\n          createdAt: new Date().toISOString(),\n          employee: { id: 'emp-sim', name, nationalId: '987' },\n          log: {\n            id: 'log-sim',\n            scoreValue: -5,\n            note: 'в•ӘВ¬в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬',\n            actionType: { id: 'act-sim', title: 'в•ӘВ¬в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬' },\n          },\n        }\n        setAppeals((prev) => [newAppeal, ...prev])\n        triggerToast('в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®)', `в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”¬ВҪ${name}в”¬в•— в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҢвҢҗв•Әв–’в•ӘВ». (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“)`, 'info')\n      }\n    }, 18000)\n\n    return () => clearInterval(timer)\n  }, [simulatorActive])\n\n  // О“Г¶ГҮО“Г¶ГҮ Operations Trigger О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n\n  async function handleApproveUser(userId: string) {\n    if (!accessToken) return\n    const roleKey = selectedRoles[userId] || 'operator'\n    setActionLoading(userId)\n    try {\n      // If it's a mocked user, resolve locally\n      if (userId.startsWith('mock-')) {\n        setUsers((prev) => prev.filter((u) => u.id !== userId))\n        setNotification({ type: 'success', text: 'в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв”Өв•ӘВ».' })\n        if (audioEnabled) playAlertSound('success')\n        return\n      }\n\n      const res = await fetch(`/api/admin/users/${userId}/approve`, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ roleKey }),\n      })\n      const json = await res.json()\n      if (res.ok) {\n        setNotification({ type: 'success', text: 'в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ».' })\n        setUsers((prev) => prev.filter((u) => u.id !== userId))\n        if (audioEnabled) playAlertSound('success')\n      } else {\n        setNotification({ type: 'error', text: json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’' })\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setActionLoading(null)\n    }\n  }\n\n  async function handleSwapDecision(swapId: string, decision: 'approved' | 'rejected') {\n    if (!accessToken) return\n    setActionLoading(swapId)\n    try {\n      if (swapId.startsWith('mock-')) {\n        setSwaps((prev) => prev.filter((s) => s.id !== swapId))\n        setNotification({ type: 'success', text: `в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ ${decision === 'approved' ? 'в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»' : 'в•Әв–’в•ӘВ»'} в•Әв”Өв•ӘВ».` })\n        if (audioEnabled) playAlertSound('success')\n        return\n      }\n\n      const res = await fetch('/api/swap-requests/approve', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ swapRequestId: swapId, decision }),\n      })\n      const json = await res.json()\n      if (res.ok) {\n        setNotification({ type: 'success', text: decision === 'approved' ? 'в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВ»в•Әв–’ в•ӘВ¬в”ҳГ©в”ҳГӘв–ҲГ®в”ҳГ  в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ».' : 'в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ».' })\n        setSwaps((prev) => prev.filter((s) => s.id !== swapId))\n        if (audioEnabled) playAlertSound('success')\n      } else {\n        setNotification({ type: 'error', text: json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВ¬в•Әв•Ўв”ҳГ в–ҲГ®в”ҳГ  в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®' })\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setActionLoading(null)\n    }\n  }\n\n  async function handleAppealDecision(appealId: string, status: 'approved' | 'rejected') {\n    if (!accessToken) return\n    const note = appealNotes[appealId] || ''\n    setActionLoading(appealId)\n    try {\n      if (appealId.startsWith('mock-')) {\n        setAppeals((prev) => prev.filter((a) => a.id !== appealId))\n        setNotification({ type: 'success', text: `в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ ${status === 'approved' ? 'в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»' : 'в•Әв–’в•ӘВ»'} в•Әв”Өв•ӘВ».` })\n        if (audioEnabled) playAlertSound('success')\n        return\n      }\n\n      const res = await fetch(`/api/admin/performance/appeal/${appealId}`, {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ status, note }),\n      })\n      const json = await res.json()\n      if (res.ok) {\n        setNotification({ type: 'success', text: status === 'approved' ? 'в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в”ҳв•ӣв•Әв–‘в–ҲГ®в•Әв–’в”ҳГјв•ӘВ¬в”ҳГ§ в”ҳГӘ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в•ӘВ«в•Әв•–в•ӘВә в•ӘВәв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎ в•Әв”Өв•ӘВ».' : 'в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ».' })\n        setAppeals((prev) => prev.filter((a) => a.id !== appealId))\n        if (audioEnabled) playAlertSound('success')\n      } else {\n        setNotification({ type: 'error', text: json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в•Әв•Ўв”ҳГ в–ҲГ®в”ҳГ  в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў' })\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setActionLoading(null)\n    }\n  }\n\n  // Manual Trigger Force Load\n  const handleForceRefresh = () => {\n    void loadLiveData()\n    triggerToast('в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®', 'в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҢвҢҗв”ҳГӨ в•Әв•Ўв”ҳГјО“ГҮГ®в”ҳГ§в•ӘВә в•ӘВәв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГӘв•ӘВәв”ҢвҢҗв•Әв”Өв–ҲГ® в”ҳГ в•ӘВјв•ӘВ»в•ӘВ» в•Әв”Өв•ӘВ».')\n  }\n\n  return (\n    <div className=\"flex-1 space-y-6 p-4 lg:p-6\" dir=\"rtl\">\n      <TopAppBar title=\"в”ҳв•ӣв–ҲГ®в•Әв”Өв•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘ в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬ в”ҳГӘ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§\" subtitle=\"в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ®в•ӘГ® в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ\" showHealth={true} />\n\n      {/* Floating System Messages */}\n      {notification && (\n        <div\n          className={cn(\n            'fixed bottom-4 left-4 z-50 p-4 rounded-xl shadow-2xl flex items-center gap-3 animate-in fade-in slide-in-from-bottom-4 duration-300 backdrop-blur-md',\n            notification.type === 'success'\n              ? 'bg-success/20 border border-success/40 text-success-foreground'\n              : 'bg-critical/20 border border-critical/40 text-critical-foreground',\n          )}\n        >\n          {notification.type === 'success' ? <CheckCircle2 className=\"size-5 shrink-0\" /> : <XCircle className=\"size-5 shrink-0\" />}\n          <div className=\"text-xs font-semibold\">{notification.text}</div>\n          <button onClick={() => setNotification(null)} className=\"text-[10px] underline ms-2 hover:opacity-80\">в•ӘВҝв•Әв”Ӯв•ӘВ¬в”ҳГҘ</button>\n        </div>\n      )}\n\n      {/* Floating Interactive Toast Ticker */}\n      <div className=\"fixed bottom-4 right-4 z-50 flex flex-col gap-2 max-w-sm w-full\">\n        {toastMessages.map((msg) => (\n          <div\n            key={msg.id}\n            className={cn(\n              'p-4 rounded-xl border shadow-xl flex gap-3 animate-in fade-in slide-in-from-right-4 duration-300 backdrop-blur-md bg-surface-container-high/90',\n              msg.type === 'warning' ? 'border-accent/40 text-accent' : 'border-info/30 text-info',\n            )}\n          >\n            <Bell className=\"size-5 shrink-0 animate-bounce\" />\n            <div>\n              <div className=\"text-xs font-bold\">{msg.title}</div>\n              <div className=\"text-[11px] text-foreground/80 mt-1\">{msg.body}</div>\n            </div>\n          </div>\n        ))}\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Dashboard Operations & Controls Panel О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"grid grid-cols-1 gap-4 lg:grid-cols-4\">\n        <div className=\"lg:col-span-3 bg-surface-container-low/40 backdrop-blur border border-border-subtle/50 rounded-2xl p-5 shadow-sm space-y-4\">\n          <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-3\">\n            <div className=\"flex items-center gap-2\">\n              <span className=\"flex h-3 w-3 relative\">\n                {pollingActive && (\n                  <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75\"></span>\n                )}\n                <span className={cn('relative inline-flex rounded-full h-3 w-3', pollingActive ? 'bg-accent' : 'bg-foreground-muted/50')}></span>\n              </span>\n              <h2 className=\"text-sm font-bold text-foreground\">в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в•Әв”Ө в”ҳГӘ в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§</h2>\n              <span className=\"text-[10px] bg-accent/15 border border-accent/30 text-accent px-2 py-0.5 rounded-full font-bold\">в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§</span>\n            </div>\n\n            <div className=\"flex flex-wrap items-center gap-2.5\">\n              {/* Force refresh */}\n              <button\n                onClick={handleForceRefresh}\n                className=\"h-9 px-3 rounded-lg border border-border/50 hover:bg-surface-container-high text-foreground-muted hover:text-foreground text-xs flex items-center gap-1.5 cursor-pointer transition-all duration-200\"\n                title=\"в•ӘВ¬в•ӘВәв•Әв–“в”ҳГ§ в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§\"\n              >\n                <RefreshCw className=\"size-3.5\" />\n                <span>в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә</span>\n              </button>\n\n              {/* Polling controller */}\n              <button\n                onClick={() => setPollingActive(!pollingActive)}\n                className={cn(\n                  'h-9 px-3 rounded-lg text-xs font-semibold flex items-center gap-1.5 cursor-pointer transition-all duration-200 border',\n                  pollingActive\n                    ? 'border-accent/30 bg-accent/5 text-accent hover:bg-accent/10'\n                    : 'border-border/50 bg-transparent text-foreground-muted hover:bg-surface-container-high',\n                )}\n              >\n                {pollingActive ? <Pause className=\"size-3.5\" /> : <Play className=\"size-3.5\" />}\n                <span>{pollingActive ? 'в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГј в”ҳв•ӣв•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’' : 'в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҳв•ӣв•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’'}</span>\n              </button>\n\n              {/* Audio controller */}\n              <button\n                onClick={() => setAudioEnabled(!audioEnabled)}\n                className=\"h-9 w-9 rounded-lg border border-border/50 hover:bg-surface-container-high text-foreground-muted hover:text-foreground flex items-center justify-center cursor-pointer transition-all duration-200\"\n                title={audioEnabled ? 'в”ҳГ©в•Әв•–в•Әв•Ј в•Әв•Ўв•ӘВ»в•ӘВәв–ҲГ® в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГҘ' : 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв•Ўв•ӘВ»в•ӘВәв–ҲГ® в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГҘ'}\n              >\n                {audioEnabled ? <Volume2 className=\"size-4 text-accent\" /> : <VolumeX className=\"size-4\" />}\n              </button>\n\n              {/* Notification Permission Request */}\n              {notificationPermission !== 'granted' && (\n                <button\n                  onClick={requestNotificationPermission}\n                  className=\"h-9 px-3 rounded-lg bg-info/10 hover:bg-info/20 text-info border border-info/20 text-xs font-semibold flex items-center gap-1.5 cursor-pointer transition-all\"\n                >\n                  <Bell className=\"size-3.5 animate-pulse\" />\n                  <span>в•ӘВәв•ӘВјв•ӘВәв•Әв–“в”ҳГ§ в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГҘ в•ӘВ»в•Әв”Ӯв”ҢвҢҗв•ӘВ¬в•ӘВәв”ҳв•ӣ</span>\n                </button>\n              )}\n            </div>\n          </div>\n\n          <div className=\"text-[11px] text-foreground-muted flex items-center gap-1.5\">\n            <Clock className=\"size-3.5\" />\n            <span>в•ӘГів•ӘВ«в•Әв–’в–ҲГ®в”ҳГҘ в”ҳГ§в”ҳГ в”ҢВ»в•ӘВәв”ҳГ О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ:</span>\n            <span className=\"font-mono text-foreground font-bold\">{faTime(lastUpdated)}</span>\n            <span className=\"text-foreground/45\">О“ГҮГі в”ҳГ§в•Әв–’ в–Ҳв•• в•ӘВҪв•ӘВәв”ҳГҘв–ҲГ®в”ҳГ§ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».</span>\n          </div>\n        </div>\n\n        {/* Simulator Widget */}\n        <div className=\"bg-gradient-to-br from-surface-container-high/40 to-surface-container-low/40 backdrop-blur border border-border-subtle/50 rounded-2xl p-5 shadow-sm space-y-3 flex flex-col justify-between\">\n          <div>\n            <div className=\"flex items-center gap-2 text-xs font-bold text-accent\">\n              <Zap className=\"size-4 animate-pulse text-accent\" />\n              <span>в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§</span>\n            </div>\n            <p className=\"text-[10px] text-foreground-muted mt-1 leading-relaxed\">\n              в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘГів•Әв–“в”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГӘ в•ӘВ»в”ҳГ в”ҳГӘв•ӘГ® в•ӘВҝв•ӘВә в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв•Әв–’в•Әв•ўв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в•ӘГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в–ҲГ®в•ӘВә в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в•Әв•Ўв”ҳГј в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘГів”ҳГӨв•ӘВәв•Әв–’в”ҳГ  в”ҳГ в–ҲГ®О“ГҮГ®в•Әв–“в”ҳГҘв”ҳГҘв•ӘВ».\n            </p>\n          </div>\n\n          <div className=\"flex items-center gap-2\">\n            <button\n              onClick={() => setSimulatorActive(!simulatorActive)}\n              className={cn(\n                'flex-1 h-9 rounded-lg text-xs font-bold flex items-center justify-center gap-1.5 cursor-pointer transition-all border',\n                simulatorActive\n                  ? 'bg-accent text-accent-foreground border-accent shadow-lg shadow-accent/20'\n                  : 'bg-transparent text-foreground hover:bg-surface-container-high border-border',\n              )}\n            >\n              {simulatorActive ? <Pause className=\"size-3.5\" /> : <Play className=\"size-3.5 text-accent\" />}\n              <span>{simulatorActive ? 'в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГј в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“' : 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“'}</span>\n            </button>\n          </div>\n        </div>\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Statistics Counters О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n        <div className=\"bg-surface-container-low/40 border border-border-subtle/40 rounded-2xl p-4 flex items-center gap-3\">\n          <div className=\"size-10 rounded-xl bg-warning/10 text-warning flex items-center justify-center\">\n            <User className=\"size-5\" />\n          </div>\n          <div>\n            <div className=\"text-[10px] text-foreground-muted\">в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©</div>\n            <div className=\"text-lg font-bold font-mono text-foreground mt-0.5\">{toFa(users.length)}</div>\n          </div>\n        </div>\n\n        <div className=\"bg-surface-container-low/40 border border-border-subtle/40 rounded-2xl p-4 flex items-center gap-3\">\n          <div className=\"size-10 rounded-xl bg-info/10 text-info flex items-center justify-center\">\n            <ArrowLeftRight className=\"size-5\" />\n          </div>\n          <div>\n            <div className=\"text-[10px] text-foreground-muted\">в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®</div>\n            <div className=\"text-lg font-bold font-mono text-foreground mt-0.5\">{toFa(swaps.length)}</div>\n          </div>\n        </div>\n\n        <div className=\"bg-surface-container-low/40 border border-border-subtle/40 rounded-2xl p-4 flex items-center gap-3\">\n          <div className=\"size-10 rounded-xl bg-accent/15 text-accent flex items-center justify-center\">\n            <Trophy className=\"size-5 text-accent\" />\n          </div>\n          <div>\n            <div className=\"text-[10px] text-foreground-muted\">в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»</div>\n            <div className=\"text-lg font-bold font-mono text-foreground mt-0.5\">{toFa(appeals.length)}</div>\n          </div>\n        </div>\n\n        <div className=\"bg-surface-container-low/40 border border-border-subtle/40 rounded-2xl p-4 flex items-center gap-3\">\n          <div className=\"size-10 rounded-xl bg-success/10 text-success flex items-center justify-center\">\n            <History className=\"size-5\" />\n          </div>\n          <div>\n            <div className=\"text-[10px] text-foreground-muted\">в”ҳГӨв•ӘВәв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в–ҲГ® в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’</div>\n            <div className=\"text-lg font-bold font-mono text-foreground mt-0.5\">{toFa(auditLogs.length)}</div>\n          </div>\n        </div>\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Main Layout: Lists on Right, Logs on Left О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-3\">\n        \n        {/* Operations Columns (span-2) */}\n        <div className=\"lg:col-span-2 space-y-4\">\n          \n          {/* Tab Toggles */}\n          <div className=\"flex border-b border-border/50 gap-2\">\n            {(\n              [\n                { key: 'all', label: 'в”ҳГ§в”ҳГ в”ҳГ§ в”ҳГ в”ҳГӘв•ӘВәв•Әв–’в•ӘВ»', count: users.length + swaps.length + appeals.length },\n                { key: 'users', label: 'в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ О“ГҮГ®в”ҳГ§в•ӘВә', count: users.length },\n                { key: 'swaps', label: 'в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВә', count: swaps.length },\n                { key: 'appeals', label: 'в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§', count: appeals.length },\n              ] as const\n            ).map((tab) => (\n              <button\n                key={tab.key}\n                onClick={() => setActiveTab(tab.key)}\n                className={cn(\n                  'pb-3 text-xs font-semibold px-4 cursor-pointer relative transition-all duration-200 flex items-center gap-1.5',\n                  activeTab === tab.key\n                    ? 'text-accent border-b-2 border-accent font-bold'\n                    : 'text-foreground-muted hover:text-foreground',\n                )}\n              >\n                <span>{tab.label}</span>\n                {tab.count > 0 && (\n                  <span className={cn(\n                    'text-[9px] px-1.5 py-0.5 rounded-full font-bold',\n                    activeTab === tab.key ? 'bg-accent text-accent-foreground' : 'bg-surface-container-highest text-foreground-muted'\n                  )}>\n                    {toFa(tab.count)}\n                  </span>\n                )}\n              </button>\n            ))}\n          </div>\n\n          {/* Conditional Empty State */}\n          {loading ? (\n            <div className=\"flex flex-col items-center justify-center py-20 bg-surface-container-low/20 border border-border-subtle/30 rounded-2xl\">\n              <RefreshCw className=\"size-8 text-foreground-muted animate-spin\" />\n              <div className=\"text-xs text-foreground-muted mt-3\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв•Ўв”ҳГјО“ГҮГ®в”ҳГ§в•ӘВә...</div>\n            </div>\n          ) : isTab('users') && users.length === 0 &&\n              isTab('swaps') && swaps.length === 0 &&\n              isTab('appeals') && appeals.length === 0 ? (\n            <div className=\"flex flex-col items-center justify-center py-20 bg-surface-container-low/20 border border-border-subtle/30 rounded-2xl text-center space-y-3\">\n              <CheckCircle2 className=\"size-10 text-success\" />\n              <div className=\"text-sm font-bold text-foreground\">в”ҳГ§в”ҳГ в”ҳГ§ в•Әв•Ўв”ҳГјО“ГҮГ®в”ҳГ§в•ӘВә в•ӘВ«в•ӘВәв”ҳГӨв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬</div>\n              <p className=\"text-[11px] text-foreground-muted max-w-sm px-4 leading-relaxed\">\n                в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®в•ӘГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в–ҲГ®в•ӘВә в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ». в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в•ӘВ» в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в•Әв–’в•ӘВә в•ӘВәв•Әв–“ в”ҳв•ӣв”ҳГҘв”ҳГӨ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВә в•Әв–’в”ҳГӘв•Әв”Өв”ҳГҘ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n              </p>\n            </div>\n          ) : null}\n\n          {/* 1. Users Approval List */}\n          {isTab('users') && users.length > 0 && (\n            <div className=\"space-y-3\">\n              <div className=\"text-xs font-bold text-foreground flex items-center gap-1.5 px-1.5\">\n                <User className=\"size-4 text-warning\" />\n                <span>в•Әв•Јв•Әв•ўв”ҳГӘв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» ({toFa(users.length)})</span>\n              </div>\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                {users.map((user) => (\n                  <div\n                    key={user.id}\n                    className=\"bg-surface-container-low/40 hover:bg-surface-container-low/75 border border-border-subtle/50 rounded-2xl p-4 shadow-sm transition-all duration-300 flex flex-col justify-between gap-3 animate-in zoom-in-95 duration-200\"\n                  >\n                    <div>\n                      <div className=\"flex items-center justify-between\">\n                        <div className=\"text-xs font-bold text-foreground\">{user.name}</div>\n                        <span className=\"text-[10px] bg-warning/10 border border-warning/30 text-warning px-2 py-0.5 rounded-full font-bold\">в•Әв•Јв•Әв•ўв”ҳГӘв–ҲГ®в•ӘВ¬ в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©</span>\n                      </div>\n                      <div className=\"grid grid-cols-2 gap-x-2 gap-y-1.5 mt-3 text-[10px] text-foreground-muted\">\n                        <div>в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ®: <span className=\"font-mono text-foreground\">{toFa(user.nationalId)}</span></div>\n                        <div>в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ: <span className=\"font-mono text-foreground\">{user.phone ? toFa(user.phone) : 'О“ГҮГ¶'}</span></div>\n                        <div className=\"col-span-2\">в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•ӘВәв”ҳГ : <span className=\"text-foreground\">{jalali(user.createdAt)}</span></div>\n                      </div>\n                    </div>\n\n                    <div className=\"border-t border-border-subtle/50 pt-3 mt-1 flex flex-col gap-2\">\n                      <div className=\"flex items-center gap-2\">\n                        <label className=\"text-[10px] text-foreground-muted shrink-0\">в•ӘВ¬в•Әв•Јв–ҲГ®в–ҲГ®в”ҳГҘ в”ҳГҘв”ҳГ©в•Әв”Ө в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®:</label>\n                        <select\n                          value={selectedRoles[user.id] || 'operator'}\n                          onChange={(e) => setSelectedRoles({ ...selectedRoles, [user.id]: e.target.value })}\n                          className=\"flex-1 h-8 rounded-lg border border-border bg-background px-2 text-[10px] text-foreground outline-none cursor-pointer focus:border-accent\"\n                        >\n                          {roles.map((role) => (\n                            <option key={role.id} value={role.key}>\n                              {role.name}\n                            </option>\n                          ))}\n                        </select>\n                      </div>\n\n                      <button\n                        onClick={() => handleApproveUser(user.id)}\n                        disabled={actionLoading === user.id}\n                        className=\"w-full h-8 bg-success hover:bg-success/90 disabled:bg-success/50 text-success-foreground text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 cursor-pointer shadow-sm shadow-success/10 transition-all scale-[0.98] active:scale-95\"\n                      >\n                        <UserCheck className=\"size-3.5\" />\n                        <span>в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв•Јв•Әв•ўв”ҳГӘв–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®</span>\n                      </button>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* 2. Shift Swaps List */}\n          {isTab('swaps') && swaps.length > 0 && (\n            <div className=\"space-y-3 pt-2\">\n              <div className=\"text-xs font-bold text-foreground flex items-center gap-1.5 px-1.5\">\n                <ArrowLeftRight className=\"size-4 text-info\" />\n                <span>в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® ({toFa(swaps.length)})</span>\n              </div>\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                {swaps.map((req) => (\n                  <div\n                    key={req.id}\n                    className=\"bg-surface-container-low/40 hover:bg-surface-container-low/75 border border-border-subtle/50 rounded-2xl p-4 shadow-sm transition-all duration-300 flex flex-col justify-between gap-3 animate-in zoom-in-95 duration-200\"\n                  >\n                    <div>\n                      <div className=\"flex items-center justify-between\">\n                        <div className=\"text-xs font-bold text-foreground\">в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®</div>\n                        <span className=\"text-[10px] bg-info/10 border border-info/30 text-info px-2 py-0.5 rounded-full font-bold\">в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬</span>\n                      </div>\n                      \n                      <div className=\"space-y-2 mt-3 bg-surface-container-high/30 rounded-xl p-2.5 text-[10px] border border-border/20\">\n                        <div className=\"flex items-center justify-between\">\n                          <span className=\"text-foreground-muted\">в”ҳГ в•ӘВ¬в”ҳГ©в•ӘВәв•Әв•ўв–ҲГ®:</span>\n                          <span className=\"text-foreground font-semibold\">{req.requester.name}</span>\n                        </div>\n                        <div className=\"flex items-center justify-between\">\n                          <span className=\"text-foreground-muted\">в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВјв•ӘВәв–ҲГ®в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘ:</span>\n                          <span className=\"text-foreground font-semibold\">{req.target.name}</span>\n                        </div>\n                        <div className=\"h-px bg-border/20 my-1\"></div>\n                        <div className=\"flex items-center justify-between\">\n                          <span className=\"text-foreground-muted\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в•ӘВҝв•ӘВ»в•ӘВә:</span>\n                          <span className=\"text-foreground font-mono\">\n                            {jalali(req.sourceShift.date)} ({req.sourceShift.code === 'morning' ? 'в•Әв•Ўв•ӘВҝв•ӘВЎ' : req.sourceShift.code === 'evening' ? 'в•Әв•Јв•Әв•Ўв•Әв–’' : 'в•Әв”Өв•ӘВҝ'})\n                          </span>\n                        </div>\n                        <div className=\"flex items-center justify-between\">\n                          <span className=\"text-foreground-muted\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в”ҳГ©в•Әв•Ўв•ӘВ»:</span>\n                          <span className=\"text-foreground font-mono\">\n                            {jalali(req.targetShift.date)} ({req.targetShift.code === 'morning' ? 'в•Әв•Ўв•ӘВҝв•ӘВЎ' : req.targetShift.code === 'evening' ? 'в•Әв•Јв•Әв•Ўв•Әв–’' : 'в•Әв”Өв•ӘВҝ'})\n                          </span>\n                        </div>\n                      </div>\n\n                      {req.note && (\n                        <div className=\"mt-2 text-[10px] text-foreground-muted leading-relaxed bg-surface/20 border border-border/20 rounded-lg p-2\">\n                          <span className=\"font-bold text-foreground\">в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎ:</span> {req.note}\n                        </div>\n                      )}\n                    </div>\n\n                    <div className=\"border-t border-border-subtle/50 pt-3 mt-1 grid grid-cols-2 gap-2\">\n                      <button\n                        onClick={() => handleSwapDecision(req.id, 'approved')}\n                        disabled={actionLoading === req.id}\n                        className=\"h-8 bg-success hover:bg-success/90 disabled:bg-success/50 text-success-foreground text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 cursor-pointer shadow-sm transition-all scale-[0.98] active:scale-95\"\n                      >\n                        <Check className=\"size-3.5\" />\n                        <span>в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬</span>\n                      </button>\n                      <button\n                        onClick={() => handleSwapDecision(req.id, 'rejected')}\n                        disabled={actionLoading === req.id}\n                        className=\"h-8 bg-critical hover:bg-critical/90 disabled:bg-critical/50 text-critical-foreground text-[10px] font-bold rounded-lg flex items-center justify-center gap-1.5 cursor-pointer shadow-sm transition-all scale-[0.98] active:scale-95\"\n                      >\n                        <XCircle className=\"size-3.5\" />\n                        <span>в•Әв–’в•ӘВ» в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬</span>\n                      </button>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* 3. Performance Appeals List */}\n          {isTab('appeals') && appeals.length > 0 && (\n            <div className=\"space-y-3 pt-2\">\n              <div className=\"text-xs font-bold text-foreground flex items-center gap-1.5 px-1.5\">\n                <Trophy className=\"size-4 text-accent\" />\n                <span>в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» ({toFa(appeals.length)})</span>\n              </div>\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                {appeals.map((appeal) => (\n                  <div\n                    key={appeal.id}\n                    className=\"bg-surface-container-low/40 hover:bg-surface-container-low/75 border border-border-subtle/50 rounded-2xl p-4 shadow-sm transition-all duration-300 flex flex-col justify-between gap-3 animate-in zoom-in-95 duration-200\"\n                  >\n                    <div>\n                      <div className=\"flex items-center justify-between\">\n                        <div className=\"text-xs font-bold text-foreground\">{appeal.employee.name}</div>\n                        <span className=\"text-[10px] bg-accent/15 border border-accent/30 text-accent px-2 py-0.5 rounded-full font-bold\">в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•ӘВҝв”ҳГ§ в•ӘВ«в•Әв•–в•ӘВә</span>\n                      </div>\n         