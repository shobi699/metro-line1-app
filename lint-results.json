      name: op.name,\n          phone: op.phone,\n          passwordHash,\n          status: 'active',\n          roleId: matchedRoleId,\n          customFields: op.customFields as unknown as Prisma.InputJsonValue\n        },\n      })\n      operators.push(user)\n    }\n\n    const allOperators = [superAdmin, admin, ...operators]\n    logSeed(`Users seeded: ${allOperators.length}`)\n\n    // О“Г¶ГҮО“Г¶ГҮ Shifts (today +/- 7 days) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    const shiftCodes = ['morning', 'evening', 'night', 'off'] as const\n    const today = new Date()\n    today.setHours(0, 0, 0, 0)\n\n    for (let offset = -7; offset <= 7; offset++) {\n      const date = new Date(today)\n      date.setDate(date.getDate() + offset)\n      date.setHours(0, 0, 0, 0)\n\n      for (let i = 0; i < allOperators.length; i++) {\n        const user = allOperators[i]\n        const code = shiftCodes[(i + offset + 10) % shiftCodes.length]\n        await prisma.shift.upsert({\n          where: { userId_date: { userId: user.id, date } },\n          update: {},\n          create: { userId: user.id, date, code: code as ShiftCode },\n        })\n      }\n    }\n    logSeed('Shifts seeded.')\n\n    // О“Г¶ГҮО“Г¶ГҮ Safety bulletins О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    const bulletins = await Promise.all([\n      prisma.safetyBulletin.create({\n        data: {\n          title: 'в•Әв–’в•Әв•Јв•ӘВәв–ҲГ®в•ӘВ¬ в•ӘВәв•Әв•Ўв”ҳГӘв”ҳГӨ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВ¬в•Әв•Јв”ҳГ в–ҲГ®в•Әв–’в”ҢВ»в•ӘВәв”ҳГ§',\n          body: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГјв•ӘВәв•ӘВ»в”ҳГ§ в•ӘВәв•Әв–“ в”ҢвҢҗв”ҳГӨв•ӘВәв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГӘ в”ҢвҢҗв”ҳГјв•Әв”Ө в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВҝв•ӘВ«в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в•Әв•Јв”ҳГ в–ҲГ®в•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬. в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв–“ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв•Әв–’в•ӘГ® в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“в•ӘВәв•ӘВ¬ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».',\n          active: true,\n        },\n      }),\n      prisma.safetyBulletin.create({\n        data: {\n          title: 'в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®',\n          body: 'в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГ в”ҳГҘв•ӘВ¬в•Әв”Өв•Әв–’ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•Әв–’в•ӘВә в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§ в”ҳГӘ в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ».',\n          active: true,\n        },\n      }),\n      prisma.safetyBulletin.create({\n        data: {\n          title: 'в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҳГ в•ӘВәв”ҳГ§в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®',\n          body: 'в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в”ҳГ в•ӘВәв”ҳГ§в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ в•ӘВ¬в”ҳГ§в–ҲГ®в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГӘ в”ҳГҘв•ӘВ¬в•ӘВәв–ҲГ®в•ӘВј в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘО“ГҮГ®в•ӘВ»в”ҳГ§в”ҳГҘв•ӘВ»в”ҳГ§ в”ҢвҢҗв•ӘВәв”ҳГ§в•Әв”Ө в–Ҳв–’в–Ҳв•Ўв”ҳВ¬ в•ӘВЎв”ҳГӘв•ӘВәв•ӘВ»в•ӘВҪ в”ҳГҘв•Әв”Ӯв•ӘВҝв•ӘВ¬ в•ӘВҝв”ҳГ§ в”ҳГ в•ӘВәв”ҳГ§ в”ҳГ©в•ӘВҝв”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬.',\n          active: false,\n        },\n      }),\n    ])\n    logSeed('Safety bulletins seeded.')\n\n    // О“Г¶ГҮО“Г¶ГҮ Read receipts О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    for (const op of operators.slice(0, 4)) {\n      await prisma.readReceipt.create({\n        data: {\n          userId: op.id,\n          safetyBulletinId: bulletins[0].id,\n        },\n      })\n    }\n    logSeed('Read receipts seeded.')\n\n    // О“Г¶ГҮО“Г¶ГҮ Tickets О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    const tickets = await Promise.all([\n      prisma.ticket.create({\n        data: {\n          title: 'в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® в•ӘВ»в•Әв–’в•ӘВҝ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–‘в–Ҳв–“',\n          description: 'в•ӘВ»в•Әв–’в•ӘВҝ в•Әв”Ӯв”ҳГ в•ӘВ¬ в•Әв–’в•ӘВәв•Әв”Ӯв•ӘВ¬ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–‘в–Ҳв–“ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө в•ӘВҝв•ӘВәв•Әв–“ в”ҳГҘв”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».',\n          priority: 'high',\n          status: 'open',\n          wagonCode: '102',\n          creatorId: operators[0].id,\n        },\n      }),\n      prisma.ticket.create({\n        data: {\n          title: 'в”ҢГҘв•Әв–’в•ӘВәв•Әв•‘ в•ӘВ«в•ӘВәв”ҳГ в”ҳГӘв•Әв”Ө в•Әв”Ӯв”ҢвҢҗв”ҳГӘв–ҲГ® в•Әв”Өв”ҳГ в•ӘВәв”ҳГӨв–ҲГ®',\n          description: 'в•Әв”Ӯв”ҳГ§ в”ҢГҘв•Әв–’в•ӘВәв•Әв•‘ в•Әв”Ӯв”ҢвҢҗв”ҳГӘв–ҲГ® в•Әв”Өв”ҳГ в•ӘВәв”ҳГӨв–ҲГ® в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө в•ӘВ«в•ӘВәв”ҳГ в”ҳГӘв•Әв”Ө в•Әв”Өв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв”ҳГҘв•ӘВ».',\n          priority: 'medium',\n          status: 'in_progress',\n          wagonCode: null,\n          creatorId: operators[1].id,\n        },\n      }),\n      prisma.ticket.create({\n        data: {\n          title: 'в•Әв”Ӯв•Әв–’ в”ҳГӘ в•Әв•Ўв•ӘВ»в•ӘВәв–ҲГ® в•Әв•‘в–ҲГ®в•Әв–’в•Әв•Јв•ӘВәв•ӘВ»в–ҲГ® в”ҳГ в”ҳГӘв•ӘВ¬в”ҳГӘв•Әв–’',\n          description: 'motor в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в–Ҳв–“в–Ҳв–‘в–Ҳв•Ў в•Әв•Ўв•ӘВ»в•ӘВәв–ҲГ® в•Әв•‘в–ҲГ®в•Әв–’в•Әв•Јв•ӘВәв•ӘВ»в–ҲГ® в•ӘВ¬в”ҳГӘв”ҳГӨв–ҲГ®в•ӘВ» в”ҳГ в–ҲГ®О“ГҮГ®в”ҢвҢҗв”ҳГҘв•ӘВ». в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ в•ӘВҝв”ҳГ§ в•ӘВҝв•ӘВәв•Әв–“в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГјв”ҳГҘв–ҲГ®.',\n          priority: 'critical',\n          status: 'open',\n          wagonCode: '205',\n          creatorId: operators[2].id,\n        },\n      }),\n    ])\n\n    for (const ticket of tickets) {\n      await prisma.ticketLog.create({\n        data: {\n          ticketId: ticket.id,\n          actorId: ticket.creatorId,\n          action: 'created',\n          note: 'в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬ в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в•Әв”Өв•ӘВ»',\n        },\n      })\n    }\n    logSeed('Tickets seeded.')\n\n    // О“Г¶ГҮО“Г¶ГҮ Custom field definitions О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    await ensurePersonnelCustomFields()\n    logSeed('Custom field definitions seeded.')\n\n    // О“Г¶ГҮО“Г¶ГҮ Competencies & Action Types О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    const competencies = [\n      { id: 'discipline', name: 'в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•–', weight: 1.0, direction: 'both' },\n      { id: 'productivity', name: 'в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в”ҳГӘв•Әв–’в–ҲГ®', weight: 1.2, direction: 'both' },\n      { id: 'quality', name: 'в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬', weight: 1.2, direction: 'both' },\n      { id: 'innovation', name: 'в”ҳГҘв”ҳГӘв•ӘГів”ҳГӘв•Әв–’в–ҲГ®', weight: 1.5, direction: 'positive' },\n      { id: 'teamwork', name: 'в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ¬в–ҲГ®в”ҳГ в–ҲГ®', weight: 1.0, direction: 'both' },\n      { id: 'compliance', name: 'в•ӘВәв”ҳГҘв•Әв•–в•ӘВҝв•ӘВәв”ҳГ© в”ҳГӘ в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬', weight: 2.0, direction: 'negative' },\n    ]\n\n    for (const c of competencies) {\n      await prisma.competency.upsert({\n        where: { id: c.id },\n        update: { name: c.name, weight: c.weight, direction: c.direction },\n        create: c,\n      })\n    }\n    logSeed('Competencies seeded.')\n\n    const actionTypes = [\n      // в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•– (discipline)\n      { id: 'a1', competencyId: 'discipline', title: 'в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’ в•ӘВҝв”ҳГ§О“ГҮГ®в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Ј в•ӘВ»в•Әв–’ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬', defaultScore: 5, maxSeverity: 'L1' },\n      { id: 'a6', competencyId: 'discipline', title: 'в•Әв–’в•Әв•Јв•ӘВәв–ҲГ®в•ӘВ¬ в•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ© в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в”ҳв•ӣв”ҳГӘв•Әв”Өв•Әв”Ө в”ҳГӘ в”ҳГ в•ӘВЎв–ҲГ®в•Әв•– в”ҢвҢҗв•ӘВәв•Әв–’', defaultScore: 5, maxSeverity: 'L1' },\n      { id: 'a7', competencyId: 'discipline', title: 'в•ӘГів•Әв–’в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в•Әв••в•ӘВәв”ҳГ§в•Әв–’ в”ҳГӘ в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“ в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§', defaultScore: 5, maxSeverity: 'L1' },\n      \n      // в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в”ҳГӘв•Әв–’в–ҲГ® (productivity)\n      { id: 'a2', competencyId: 'productivity', title: 'в•ӘВ¬в•ӘВЎв”ҳГӘв–ҲГ®в”ҳГӨ в•Әв–“в”ҳГӘв•ӘВ»в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ в•ӘВ»в•ӘВ»в”ҳГӨв•ӘВәв–ҲГ®в”ҳГҘ', defaultScore: 10, maxSeverity: 'L1' },\n      { id: 'a8', competencyId: 'productivity', title: 'в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВҪв”ҳГҘв•ӘВәв–ҲГ®в–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГӨв”ҳГӘв•Әв•‘в–ҲГ® в•ӘВ«в•Әв•–', defaultScore: 15, maxSeverity: 'L1' },\n      { id: 'a9', competencyId: 'productivity', title: 'в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в”ҳГӘв•Әв••в•ӘВәв–ҲГ®в”ҳГј в•ӘВ«в•ӘВәв•Әв–’в•ӘВј в•ӘВәв•Әв–“ в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ»в”ҳГ§ в”ҳГ в”ҳГӘв•Әв••в”ҳГј', defaultScore: 10, maxSeverity: 'L1' },\n      \n      // в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬ (quality)\n      { id: 'a3', competencyId: 'quality', title: 'в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ® в•ӘВҝв–ҲГ®О“ГҮГ®в”ҳГҘв”ҳГ©в•Әв•Ў / в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВә', defaultScore: 10, maxSeverity: 'L1' },\n      { id: 'a10', competencyId: 'quality', title: 'в•ӘВ»в”ҳГ©в•ӘВ¬ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВә в”ҳГӘ в•ӘВҝв•ӘВәв•Әв–“в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳв•ӣв–ҲГ®в•Әв”Өв”ҢВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’', defaultScore: 10, maxSeverity: 'L1' },\n      { id: 'a11', competencyId: 'quality', title: 'в”ҳГҘв”ҢВ»в”ҳГ§в•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘ в”ҳГ в•Әв–’в•ӘВәв”ҳГ©в•ӘВҝв•ӘВ¬ в•Әв•Јв•ӘВәв”ҳГӨв–ҲГ® в•ӘВәв•Әв–“ в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“в•ӘВәв•ӘВ¬ в”ҢвҢҗв•ӘВәв•ӘВҝв–ҲГ®в”ҳГҘ', defaultScore: 10, maxSeverity: 'L1' },\n      \n      // в”ҳГҘв”ҳГӘв•ӘГів”ҳГӘв•Әв–’в–ҲГ® (innovation)\n      { id: 'a4', competencyId: 'innovation', title: 'в”ҳв•ӣв–ҲГ®в•Әв”Өв”ҳГҘв”ҳГ§в•ӘВәв•ӘВ» в”ҢвҢҗв•ӘВәв”ҳГ§в•Әв”Ө в”ҳГ§в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§/в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ', defaultScore: 20, maxSeverity: 'L1' },\n      { id: 'a12', competencyId: 'innovation', title: 'в”ҳв•ӣв–ҲГ®в•Әв”Өв”ҳГҘв”ҳГ§в•ӘВәв•ӘВ» в•ӘВҝв”ҳГ§в•ӘВҝв”ҳГӘв•ӘВ» в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в–ҲГ®в•ӘВә в•ӘВәв”ҳГјв•Әв–“в•ӘВәв–ҲГ®в•Әв”Ө в•Әв”Ӯв•Әв–’в•Әв•Јв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв–’', defaultScore: 20, maxSeverity: 'L1' },\n      \n      // в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ¬в–ҲГ®в”ҳГ в–ҲГ® (teamwork)\n      { id: 'a5', competencyId: 'teamwork', title: 'в”ҢвҢҗв”ҳГ в”ҢвҢҗ в•ӘВҝв”ҳГ§ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ / в•ӘВЎв”ҳГӨв•ӘВәв”ҳГӨ в”ҳГ в•Әв”Өв”ҢвҢҗв”ҳГӨв•ӘВәв•ӘВ¬', defaultScore: 10, maxSeverity: 'L1' },\n      { id: 'a13', competencyId: 'teamwork', title: 'в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•Әв•Ўв”ҳГ в–ҲГ®в”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГӘ в•Әв–’в”ҳГӘв•ӘВЎв–ҲГ®в”ҳГ§ в•ӘВ¬в–ҲГ®в”ҳГ в–ҲГ® в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§', defaultScore: 10, maxSeverity: 'L1' },\n      \n      // в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  - в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•–\n      { id: 'n1', competencyId: 'discipline', title: 'в•ӘВ¬в•ӘГәв•ӘВ«в–ҲГ®в•Әв–’ / в•Әв•‘в–ҲГ®в•ӘВҝв•ӘВ¬ в•Әв•‘в–ҲГ®в•Әв–’в”ҳГ в”ҳГӘв•ӘВјв”ҳГ§', defaultScore: -5, maxSeverity: 'L3' },\n      { id: 'n5', competencyId: 'discipline', title: 'в”ҳГҘв”ҳГ©в•Әв•ў в•ӘГів–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв”ҳГӘв•Әв”Өв•Әв”Ө в–ҲГ®в•ӘВә в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•– в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§', defaultScore: -5, maxSeverity: 'L2' },\n      \n      // в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  - в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬\n      { id: 'n2', competencyId: 'quality', title: 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•ӘВ¬в”ҢвҢҗв•Әв–’в•ӘВәв•Әв–’в–ҲГ® / в•Әв”Ӯв”ҳГ§в”ҳГӨО“ГҮГ®в•ӘВәв”ҳГҘв”ҢВ»в•ӘВәв•Әв–’в–ҲГ®', defaultScore: -10, maxSeverity: 'L3' },\n      \n      // в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  - в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ¬в–ҲГ®в”ҳГ в–ҲГ®\n      { id: 'n3', competencyId: 'teamwork', title: 'в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в•ӘВ¬в”ҳГҘв•Әв”Ө в•ӘВ»в•Әв–’ в”ҳГ в•ӘВЎв–ҲГ®в•Әв•– в”ҢвҢҗв•ӘВәв•Әв–’', defaultScore: -10, maxSeverity: 'L2' },\n      { id: 'n6', competencyId: 'teamwork', title: 'в•Әв–’в”ҳГјв•ӘВ¬в•ӘВәв•Әв–’ в•Әв•‘в–ҲГ®в•Әв–’в•ӘВЎв•Әв–’в”ҳГјв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в–ҲГ®в•ӘВә в•Әв•Јв•ӘВ»в”ҳГ  в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв•ӘВә в•ӘВ¬в–ҲГ®в”ҳГ ', defaultScore: -10, maxSeverity: 'L2' },\n      \n      // в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  - в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в”ҳГӘв•Әв–’в–ҲГ®\n      { id: 'n7', competencyId: 'productivity', title: 'в•Әв”Ӯв”ҳГ§в”ҳГӨО“ГҮГ®в•ӘВәв”ҳГҘв”ҢВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в”ҳГӘв•Әв••в•ӘВәв–ҲГ®в”ҳГј в–ҲГ®в•ӘВә в•ӘВ¬в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в•ӘВ¬в•ӘВЎв”ҳГӘв–ҲГ®в”ҳГӨ', defaultScore: -10, maxSeverity: 'L3' },\n      \n      // в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  - в•ӘВәв”ҳГҘв•Әв•–в•ӘВҝв•ӘВәв”ҳГ© в”ҳГӘ в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬\n      { id: 'n4', competencyId: 'compliance', title: 'в”ҳГҘв”ҳГ©в•Әв•ў в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬в–ҲГ®/в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®', defaultScore: -20, maxSeverity: 'L3' },\n      { id: 'n8', competencyId: 'compliance', title: 'в•Әв•Јв•ӘВ»в”ҳГ  в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® в–ҲГ®в•ӘВә в•Әв”Ӯв”ҳГ§в”ҳГӨО“ГҮГ®в•ӘВәв”ҳГҘв”ҢВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®', defaultScore: -15, maxSeverity: 'L3' },\n      { id: 'n9', competencyId: 'compliance', title: 'в”ҳГҘв”ҳГ©в•Әв•ў в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв”Ӯв•Әв–’в•Әв•Јв•ӘВ¬ в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ (в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®)', defaultScore: -30, maxSeverity: 'L3' },\n    ]\n\n    for (const a of actionTypes) {\n      await prisma.performanceActionType.upsert({\n        where: { id: a.id },\n        update: { title: a.title, defaultScore: a.defaultScore, maxSeverity: a.maxSeverity },\n        create: a,\n      })\n    }\n    logSeed('Performance action types seeded.')\n\n    // О“Г¶ГҮО“Г¶ГҮ Performance Logs (initial) О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    const currentPeriodId = dayjs().locale('jalali').format('YYYY-MM')\n    const logCount = await prisma.performanceLog.count()\n    if (logCount === 0 && operators.length >= 3) {\n      await prisma.performanceLog.createMany({\n        data: [\n          {\n            employeeId: operators[0].id, // Ali Rezaei\n            recordedById: superAdmin.id,\n            actionTypeId: 'a1',\n            severity: 'L1',\n            scoreValue: 5,\n            note: 'в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’ в”ҳГ в”ҳГҘв•Әв••в”ҳГ  в”ҳГӘ в•Әв”Ӯв•Әв–’ в”ҳГӘв”ҳГ©в•ӘВ¬ в•ӘВ»в•Әв–’ в”ҢвҢҗв”ҳГӨ в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§',\n            periodId: currentPeriodId,\n            status: 'active',\n          },\n          {\n            employeeId: operators[0].id, // Ali Rezaei\n            recordedById: superAdmin.id,\n            actionTypeId: 'a3',\n            severity: 'L1',\n            scoreValue: 10,\n            note: 'в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в•ӘВәв”ҳГӘв•Әв–’в”ҳГ§в•ӘВәв”ҳГӨ в”ҳГӘ в•Әв”Ӯв•Әв–’в”ҳГӘв–ҲГ®в•Әв”Ӯ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВҝв–ҲГ® в”ҳГҘв”ҳГ©в•Әв•Ў в•Әв–’в”ҳГӘв–ҲГ® в”ҳГӨв”ҳГӘв”ҢвҢҗв”ҳГӘв”ҳГ в”ҳГӘв•ӘВ¬в–ҲГ®в”ҳГӘ в•ӘВ«в•Әв•– в–Ҳв–’',\n            periodId: currentPeriodId,\n            status: 'active',\n          },\n          {\n            employeeId: operators[1].id, // Mohammad Hosseini\n            recordedById: superAdmin.id,\n            actionTypeId: 'a2',\n            severity: 'L1',\n            scoreValue: 10,\n            note: 'в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ»в–ҲГ® в”ҳГӘ в•ӘГів”ҳГ в•ӘВәв•ӘВ»в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•Әв–“в”ҳГӘв•ӘВ»в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ в”ҳГ в”ҳГӘв•Әв•Јв•ӘВ» в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв–’в”ҳГӘв•Әв–“в•ӘВәв”ҳГҘв”ҳГ§',\n            periodId: currentPeriodId,\n            status: 'active',\n          },\n          {\n            employeeId: operators[1].id, // Mohammad Hosseini\n            recordedById: superAdmin.id,\n            actionTypeId: 'n1',\n            severity: 'L1',\n            scoreValue: -5,\n            note: 'в•ӘВ¬в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в–Ҳв–“в–Ҳв–‘ в•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ©в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв•Ўв•ӘВҝв•ӘВЎ',\n            periodId: currentPeriodId,\n            status: 'active',\n          },\n          {\n            employeeId: operators[2].id, // Zahra Karimi\n            recordedById: superAdmin.id,\n            actionTypeId: 'a4',\n            severity: 'L1',\n            scoreValue: 20,\n            note: 'в•ӘВәв•Әв–’в•ӘВәв•ӘВӘв”ҳГ§ в•Әв•–в•Әв–’в•ӘВЎ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ»в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВ¬в”ҳГ©в•Әв”Ӯв–ҲГ®в”ҳГ  в”ҳГҘв–ҲГ®в•Әв–’в”ҳГӘв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГӘ в”ҢвҢҗв•ӘВәв”ҳГ§в•Әв”Ө в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в•ӘВҝв–ҲГ®в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ',\n            periodId: currentPeriodId,\n            status: 'active',\n          },\n        ]\n      })\n      logSeed('Initial performance logs seeded.')\n    }\n\n    // О“Г¶ГҮО“Г¶ГҮ Settings О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n    await seedDefaultSettings(