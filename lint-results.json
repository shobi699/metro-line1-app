return `${jy}-${String(jm).padStart(2, '0')}`\n  }, [])\n\n  const [selectedPeriod, setSelectedPeriod] = useState<string>(currentJalaliMonth)\n  \n  // Available periods list for dropdown\n  const periodsList = useMemo(() => {\n    const year = parseInt(currentJalaliMonth.split('-')[0])\n    const month = parseInt(currentJalaliMonth.split('-')[1])\n    const list = []\n    for (let i = 0; i < 6; i++) {\n      let m = month - i\n      let y = year\n      if (m <= 0) {\n        m += 12\n        y -= 1\n      }\n      list.push(`${y}-${String(m).padStart(2, '0')}`)\n    }\n    return list\n  }, [currentJalaliMonth])\n\n  // Auth & role checks\n  const isManagerOrAdmin = useMemo(() => {\n    const roleKey = user?.roleKey || ''\n    return ['admin', 'super_admin', 'manager', 'chief', 'supervisor'].includes(roleKey)\n  }, [user])\n\n  // Scorecard state\n  const [scorecard, setScorecard] = useState<ScorecardData | null>(null)\n  const [loadingScorecard, setLoadingScorecard] = useState<boolean>(true)\n  const [scorecardError, setScorecardError] = useState<string>('')\n\n  // Leaderboard state\n  const [leaderboard, setLeaderboard] = useState<LeaderboardData | null>(null)\n  const [loadingLeaderboard, setLoadingLeaderboard] = useState<boolean>(false)\n  const [leaderboardError, setLeaderboardError] = useState<string>('')\n\n  // Manager state\n  const [managerData, setManagerData] = useState<ManagerData | null>(null)\n  const [loadingManager, setLoadingManager] = useState<boolean>(false)\n  const [managerError, setManagerError] = useState<string>('')\n  \n  // Appeals state (in manager view)\n  const [pendingAppeals, setPendingAppeals] = useState<AppealRequest[]>([])\n  const [loadingAppeals, setLoadingAppeals] = useState<boolean>(false)\n\n  // Nomination state (in manager view)\n  const [activeNomination, setActiveNomination] = useState<any>(null)\n  const [loadingNomination, setLoadingNomination] = useState<boolean>(false)\n\n  // New Action Type Form States\n  const [customAction, setCustomAction] = useState({\n    competencyId: '',\n    title: '',\n    defaultScore: 10,\n    maxSeverity: 'L1' as 'L1' | 'L2' | 'L3'\n  })\n  const [submittingCustomAction, setSubmittingCustomAction] = useState(false)\n  const [customActionSuccess, setCustomActionSuccess] = useState('')\n  const [customActionError, setCustomActionError] = useState('')\n\n  // Interactive Form States\n  const [quickLog, setQuickLog] = useState({\n    employeeId: '',\n    competencyId: '',\n    actionTypeId: '',\n    severity: 'L1' as 'L1' | 'L2' | 'L3',\n    note: '',\n    evidenceUrl: ''\n  })\n  const [submittingLog, setSubmittingLog] = useState(false)\n  const [logSuccessMessage, setLogSuccessMessage] = useState('')\n  const [logErrorMessage, setLogErrorMessage] = useState('')\n\n  // Appeal Modal States\n  const [appealModalOpen, setAppealModalOpen] = useState(false)\n  const [appealLogId, setAppealLogId] = useState<string | null>(null)\n  const [appealReason, setAppealReason] = useState('')\n  const [submittingAppeal, setSubmittingAppeal] = useState(false)\n  \n  // Appeal review action state\n  const [reviewNote, setReviewNote] = useState<Record<string, string>>({})\n  const [submittingReview, setSubmittingReview] = useState<string | null>(null) // contains appealId\n\n  // Fetch Scorecard Data\n  const fetchScorecard = async (period: string, empId?: string) => {\n    setLoadingScorecard(true)\n    setScorecardError('')\n    try {\n      const url = `/api/performance/scorecard?periodId=${period}${empId ? `&employeeId=${empId}` : ''}`\n      const res = await fetch(url, {\n        headers: { Authorization: `Bearer ${accessToken}` }\n      })\n      if (!res.ok) {\n        const errJson = await res.json()\n        throw new Error(errJson.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»')\n      }\n      const json = await res.json()\n      setScorecard(json.data)\n    } catch (err: any) {\n      setScorecardError(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setLoadingScorecard(false)\n    }\n  }\n\n  // Fetch Leaderboard Data\n  const fetchLeaderboard = async (period: string) => {\n    setLoadingLeaderboard(true)\n    setLeaderboardError('')\n    try {\n      const res = await fetch(`/api/performance/leaderboard?periodId=${period}`, {\n        headers: { Authorization: `Bearer ${accessToken}` }\n      })\n      if (!res.ok) throw new Error('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в•Әв–’в•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ®')\n      const json = await res.json()\n      setLeaderboard(json.data)\n    } catch (err: any) {\n      setLeaderboardError(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setLoadingLeaderboard(false)\n    }\n  }\n\n  // Fetch Manager Data (employees, action types, competencies)\n  const fetchManagerData = async (period: string) => {\n    setLoadingManager(true)\n    setManagerError('')\n    try {\n      const res = await fetch(`/api/admin/performance/logs?periodId=${period}`, {\n        headers: { Authorization: `Bearer ${accessToken}` }\n      })\n      if (!res.ok) throw new Error('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬')\n      const json = await res.json()\n      setManagerData(json.data)\n    } catch (err: any) {\n      setManagerError(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setLoadingManager(false)\n    }\n  }\n\n  // Fetch Appeals list (manager view)\n  const fetchAppeals = async () => {\n    setLoadingAppeals(true)\n    try {\n      const res = await fetch('/api/admin/performance/appeal', {\n        headers: { Authorization: `Bearer ${accessToken}` }\n      })\n      if (res.ok) {\n        const json = await res.json()\n        setPendingAppeals(json.data || [])\n      }\n    } catch {\n      // silent fail\n    } finally {\n      setLoadingAppeals(false)\n    }\n  }\n\n  // Fetch active period nomination\n  const fetchNomination = async (period: string) => {\n    setLoadingNomination(true)\n    try {\n      const res = await fetch(`/api/admin/performance/nominate?periodId=${period}`, {\n        headers: { Authorization: `Bearer ${accessToken}` }\n      })\n      if (res.ok) {\n        const json = await res.json()\n        setActiveNomination(json.data || null)\n      }\n    } catch {\n      // silent\n    } finally {\n      setLoadingNomination(false)\n    }\n  }\n\n  // Effect to load data based on active tab and period\n  useEffect(() => {\n    if (accessToken) {\n      if (activeTab === 'scorecard') {\n        fetchScorecard(selectedPeriod)\n      } else if (activeTab === 'leaderboard') {\n        fetchLeaderboard(selectedPeriod)\n      } else if (activeTab === 'manager' && isManagerOrAdmin) {\n        fetchManagerData(selectedPeriod)\n        fetchAppeals()\n        fetchNomination(selectedPeriod)\n      }\n    }\n  }, [activeTab, selectedPeriod, accessToken, isManagerOrAdmin])\n\n  // Handle Quick Log Form submission\n  const handleQuickLogSubmit = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!quickLog.employeeId || !quickLog.actionTypeId) {\n      setLogErrorMessage('в”ҳГӨв•Әв•–в”ҳГјв•ӘВә в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГӘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•Әв–’в•ӘВә в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»')\n      return\n    }\n    setSubmittingLog(true)\n    setLogSuccessMessage('')\n    setLogErrorMessage('')\n    try {\n      const res = await fetch('/api/admin/performance/logs', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`\n        },\n        body: JSON.stringify({\n          employeeId: quickLog.employeeId,\n          actionTypeId: quickLog.actionTypeId,\n          severity: quickLog.severity,\n          note: quickLog.note,\n          evidenceUrl: quickLog.evidenceUrl\n        })\n      })\n\n      const json = await res.json()\n      if (!res.ok) throw new Error(json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»')\n\n      setLogSuccessMessage(json.message || 'в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ» в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»')\n      setQuickLog({\n        employeeId: '',\n        competencyId: '',\n        actionTypeId: '',\n        severity: 'L1',\n        note: '',\n        evidenceUrl: ''\n      })\n      // Refresh manager data logs\n      fetchManagerData(selectedPeriod)\n    } catch (err: any) {\n      setLogErrorMessage(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setSubmittingLog(false)\n    }\n  }\n\n  // Handle new action type submission (Custom catalog)\n  const handleCustomActionSubmit = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!customAction.competencyId || !customAction.title.trim()) {\n      setCustomActionError('в”ҳГӨв•Әв•–в”ҳГјв•ӘВә в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГӘ в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в•Әв–’в•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»')\n      return\n    }\n    setSubmittingCustomAction(true)\n    setCustomActionSuccess('')\n    setCustomActionError('')\n    try {\n      const res = await fetch('/api/admin/performance/action-types', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`\n        },\n        body: JSON.stringify({\n          competencyId: customAction.competencyId,\n          title: customAction.title,\n          defaultScore: Number(customAction.defaultScore),\n          maxSeverity: customAction.maxSeverity\n        })\n      })\n\n      const json = await res.json()\n      if (!res.ok) throw new Error(json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»')\n\n      setCustomActionSuccess(json.message || 'в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв•Әв•ўв•ӘВәв”ҳГјв”ҳГ§ в•Әв”Өв•ӘВ»')\n      setCustomAction({\n        competencyId: '',\n        title: '',\n        defaultScore: 10,\n        maxSeverity: 'L1'\n      })\n      // Refresh manager data to populate dropdowns with the new item!\n      fetchManagerData(selectedPeriod)\n    } catch (err: any) {\n      setCustomActionError(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n    } finally {\n      setSubmittingCustomAction(false)\n    }\n  }\n\n  // Handle Appeal Submission\n  const handleAppealSubmit = async (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!appealLogId || !appealReason.trim()) return\n    setSubmittingAppeal(true)\n    try {\n      const res = await fetch('/api/performance/appeal', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`\n        },\n        body: JSON.stringify({\n          logId: appealLogId,\n          reason: appealReason\n        })\n      })\n\n      const json = await res.json()\n      if (!res.ok) throw new Error(json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў')\n\n      setAppealModalOpen(false)\n      setAppealReason('')\n      setAppealLogId(null)\n      // Refresh scorecard\n      fetchScorecard(selectedPeriod)\n    } catch (err: any) {\n      alert(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў')\n    } finally {\n      setSubmittingAppeal(false)\n    }\n  }\n\n  // Handle Appeal Review (HR/Admin)\n  const handleAppealReview = async (appealId: string, status: 'approved' | 'rejected') => {\n    setSubmittingReview(appealId)\n    try {\n      const res = await fetch(`/api/admin/performance/appeal/${appealId}`, {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`\n        },\n        body: JSON.stringify({\n          status,\n          note: reviewNote[appealId] || ''\n        })\n      })\n\n      const json = await res.json()\n      if (!res.ok) throw new Error(json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў')\n\n      // Refresh appeals queue and manager log list\n      await fetchAppeals()\n      await fetchManagerData(selectedPeriod)\n      // Clear review note for this appeal\n      setReviewNote((prev) => {\n        const next = { ...prev }\n        delete next[appealId]\n        return next\n      })\n    } catch (err: any) {\n      alert(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў')\n    } finally {\n      setSubmittingReview(null)\n    }\n  }\n\n  // Handle auto-nomination calculation\n  const handleTriggerNomination = async () => {\n    setLoadingNomination(true)\n    try {\n      const res = await fetch('/api/admin/performance/nominate', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`\n        },\n        body: JSON.stringify({ periodId: selectedPeriod })\n      })\n\n      const json = await res.json()\n      if (!res.ok) throw new Error(json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ в•Әв–“в•ӘВ»в–ҲГ®')\n\n      alert(json.message || 'в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в”ҳГӘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГҘв”ҳГ в”ҳГӘв”ҳГҘв”ҳГ§ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ»')\n      // Refresh nomination and manager logs\n      await fetchNomination(selectedPeriod)\n      await fetchManagerData(selectedPeriod)\n    } catch (err: any) {\n      alert(err.message || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в”ҳГјв•Әв–’в•ӘГів–ҲГ®в”ҳГҘв•ӘВ» в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§')\n    } finally {\n      setLoadingNomination(false)\n    }\n  }\n\n  // 1. Math calculation helper for custom SVG Radar Chart points\n  // 6 vertices representing the 6 core competencies in our schema\n  const radarAxes = [\n    { key: 'discipline', label: 'в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•– в”ҳГјв•Әв–’в•ӘВ»в–ҲГ®' },\n    { key: 'productivity', label: 'в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в”ҳГӘв•Әв–’в–ҲГ®' },\n    { key: 'quality', label: 'в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ®' },\n    { key: 'innovation', label: 'в”ҳГҘв”ҳГӘв•ӘГів”ҳГӘв•Әв–’в–ҲГ® в”ҳГӘ в•ӘВ«в”ҳГӨв•ӘВәв”ҳГ©в–ҲГ®в•ӘВ¬' },\n    { key: 'teamwork', label: 'в•Әв–’в”ҳГӘв•ӘВЎв–ҲГ®в”ҳГ§ в•ӘВ¬в–ҲГ®в”ҳГ в–ҲГ®' },\n    { key: 'compliance', label: 'в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬ в”ҳГӘ в•ӘВәв”ҳГҘв•Әв•–в•ӘВҝв•ӘВәв”ҳГ©' }\n  ]\n\n  const radarCoordinates = useMemo(() => {\n    if (!scorecard) return []\n    const center = 160\n    const maxRadius = 100\n    const radar = scorecard.competencyRadar\n\n    return radarAxes.map((axis, i) => {\n      const score = (radar as any)[axis.key] || 80 // Default to 80 if missing\n      const angle = -Math.PI / 2 + i * (2 * Math.PI / 6) // Hexagon vertices\n      const radius = (score / 100) * maxRadius\n      return {\n        key: axis.key,\n        label: axis.label,\n        score,\n        // Calculate standard trigonometry projection\n        x: center + radius * Math.cos(angle),\n        y: center + radius * Math.sin(angle),\n        // Grid points at 20%, 40%, 60%, 80%, 100% of max radius for drawing background grids\n        grids: [20, 40, 60, 80, 100].map((g) => {\n          const r = (g / 100) * maxRadius\n          return {\n            x: center + r * Math.cos(angle),\n            y: center + r * Math.sin(angle)\n          }\n        })\n      }\n    })\n  }, [scorecard])\n\n  // Grid polygon paths for background hexagon grids\n  const backgroundGridPaths = useMemo(() => {\n    if (radarCoordinates.length === 0) return []\n    const paths = []\n    for (let gIndex = 0; gIndex < 5; gIndex++) {\n      const points = radarCoordinates.map((c) => c.grids[gIndex])\n      const pathStr = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ') + ' Z'\n      paths.push(pathStr)\n    }\n    return paths\n  }, [radarCoordinates])\n\n  // Main data polygon path for the radar chart\n  const radarDataPath = useMemo(() => {\n    if (radarCoordinates.length === 0) return ''\n    return radarCoordinates.map((c, i) => `${i === 0 ? 'M' : 'L'} ${c.x} ${c.y}`).join(' ') + ' Z'\n  }, [radarCoordinates])\n\n  // Selected competency action types (filtered for manager log select dropdown)\n  const availableActionTypes = useMemo(() => {\n    if (!managerData || !quickLog.competencyId) return []\n    const selectedComp = managerData.competencies.find((c) => c.id === quickLog.competencyId)\n    return selectedComp ? selectedComp.actionTypes : []\n  }, [managerData, quickLog.competencyId])\n\n  // department statistics calculated dynamically from manager logs\n  const departmentStats = useMemo(() => {\n    if (!managerData || managerData.logs.length === 0) return []\n    const depts: Record<string, { total: number; count: number }> = {}\n    \n    // Group logs by department/post\n    managerData.logs.forEach((log) => {\n      const dept = (log.employee?.customFields as any)?.post || 'в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬'\n      const val = log.scoreValue\n      if (!depts[dept]) {\n        depts[dept] = { total: 100 + val, count: 1 } // start from base 100\n      } else {\n        depts[dept].total += val\n        depts[dept].count += 1\n      }\n    })\n\n    return Object.entries(depts).map(([name, data]) => ({\n      name,\n      avgScore: Math.max(0, Math.round(data.total / data.count))\n    }))\n  }, [managerData])\n\n  // Persian translations for severity labels\n  const severityLabels: Record<string, string> = {\n    L1: 'L1 - в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®',\n    L2: 'L2 - в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–',\n    L3: 'L3 - в•Әв”Өв•ӘВ»в–ҲГ®в•ӘВ» (в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®)'\n  }\n\n  // Competency IDs to Persian labels map\n  const competencyLabels: Record<string, string> = {\n    discipline: 'в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•– в”ҳГјв•Әв–’в•ӘВ»в–ҲГ®',\n    productivity: 'в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в”ҳГӘв•Әв–’в–ҲГ®',\n    quality: 'в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ®',\n    innovation: 'в•ӘВ«в”ҳГӨв•ӘВәв”ҳГ©в–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҳГҘв”ҳГӘв•ӘГів”ҳГӘв•Әв–’в–ҲГ®',\n    teamwork: 'в•Әв–’в”ҳГӘв•ӘВЎв–ҲГ®в”ҳГ§ в•ӘВ¬в–ҲГ®в”ҳГ в–ҲГ®',\n    compliance: 'в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬ в”ҳГӘ в•ӘВәв”ҳГҘв•Әв•–в•ӘВҝв•ӘВәв”ҳГ©'\n  }\n\n  return (\n    <div className=\"flex min-h-screen flex-col bg-surface\" dir=\"rtl\">\n      <TopAppBar\n        title=\"в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГӘ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•ЎО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® (KPI)\"\n        subtitle=\"в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»в–ҲГ®в•ӘГ® в”ҳГӨв–ҲГ®в•ӘВ»в•Әв–’в•ӘВҝв”ҳГӘв•Әв–’в•ӘВ» в”ҳГ в•ӘВЎв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГӘ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Ӯв•Әв–’в–ҲГ®в•Әв•Ј в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’\"\n        showHealth\n      />\n\n      <main className=\"flex-1 overflow-y-auto p-4 pt-20 md:p-6 space-y-6\">\n        \n        {/* Header Section: Period Selector and Tabs */}\n        <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border-b border-border/60 pb-4\">\n          \n          {/* Tab buttons */}\n          <div className=\"flex gap-1.5 p-1 bg-surface-container rounded-lg border border-border/50 max-w-fit\">\n            <Button\n              variant={activeTab === 'scorecard' ? 'default' : 'ghost'}\n              size=\"sm\"\n              onClick={() => setActiveTab('scorecard')}\n              className=\"text-xs font-semibold\"\n            >\n              <FileText className=\"size-3.5 me-1.5\" />\n              в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГ в”ҳГҘ\n            </Button>\n            <Button\n              variant={activeTab === 'leaderboard' ? 'default' : 'ghost'}\n              size=\"sm\"\n              onClick={() => setActiveTab('leaderboard')}\n              className=\"text-xs font-semibold\"\n            >\n              <Trophy className=\"size-3.5 me-1.5\" />\n              в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в•ӘВҝв•Әв–’в•ӘВ¬в•Әв–’в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә (в•Әв–’в•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ®)\n            </Button>\n            {isManagerOrAdmin && (\n              <Button\n                variant={activeTab === 'manager' ? 'default' : 'ghost'}\n                size=\"sm\"\n                onClick={() => setActiveTab('manager')}\n                className=\"text-xs font-semibold text-accent-foreground\"\n              >\n                <Briefcase className=\"size-3.5 me-1.5\" />\n                в”ҳв•ӣв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»\n              </Button>\n            )}\n          </div>\n\n          {/* Period Dropdown */}\n          <div className=\"flex items-center gap-2\">\n            <span className=\"text-xs text-foreground-muted font-bold\">в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ®:</span>\n            <div className=\"relative\">\n              <select\n                value={selectedPeriod}\n                onChange={(e) => setSelectedPeriod(e.target.value)}\n                className=\"appearance-none w-40 bg-surface-container border border-border rounded-lg px-3 py-1.5 text-xs font-bold text-foreground focus:outline-none focus:border-accent ps-8 cursor-pointer\"\n              >\n                {periodsList.map((p) => (\n                  <option key={p} value={p}>\n                    {toFa(p.replace('-', ' / '))}\n                  </option>\n                ))}\n              </select>\n              <ChevronDown className=\"absolute start-2.5 top-2.5 size-3.5 text-foreground-muted pointer-events-none\" />\n            </div>\n          </div>\n\n        </div>\n\n        {/* ========================================================================= */}\n        {/* TAB 1: MY SCORECARD */}\n        {/* ========================================================================= */}\n        {activeTab === 'scorecard' && (\n          <div className=\"space-y-6 animate-in fade-in duration-300\">\n            {loadingScorecard ? (\n              <div className=\"flex flex-col items-center justify-center p-24 gap-3\">\n                <Activity className=\"size-10 animate-spin text-accent\" />\n                <span className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в”ҳГӘ в•ӘВ¬в•ӘВјв”ҳГ в–ҲГ®в•Әв•Ј в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»...</span>\n              </div>\n            ) : scorecardError ? (\n              <div className=\"bg-critical/10 border border-critical/30 rounded-lg p-4 text-critical text-sm text-center flex items-center justify-center gap-2\">\n                <AlertTriangle className=\"size-5\" />\n                <span>{scorecardError}</span>\n              </div>\n            ) : scorecard ? (\n              <>\n                {/* Scorecard Profile Header & Alert Banner */}\n                <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                  \n                  {/* Score Radial Gauge Card */}\n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm flex flex-col items-center justify-center p-6 text-center\">\n                    <CardHeader className=\"p-0 pb-3 text-center\">\n                      <CardTitle className=\"text-sm font-bold\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§</CardTitle>\n                      <CardDescription className=\"text-[10px]\">\n                        в•ӘВ¬в•Әв–’в”ҢвҢҗв–ҲГ®в•ӘВҝ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§в•ӘГ® в•ӘВҝв•ӘВәв•Әв–“в•ӘВ»в”ҳГ§ в”ҳГҘв•Әв–“в”ҳГӘв”ҳГӨв–ҲГ® в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВҝв”ҳГӘв”ҳГҘв”ҳГӘв•Әв”ӮО“ГҮГ®в”ҳГ§в•ӘВә\n                      </CardDescription>\n                    </CardHeader>\n                    <CardContent className=\"p-0 flex flex-col items-center justify-center\">\n                      {/* SVG Radial Gauge */}\n                      <div className=\"relative w-40 h-40 flex items-center justify-center\">\n                        <svg className=\"w-full h-full transform -rotate-90\" viewBox=\"0 0 200 200\">\n                          {/* Outer Track */}\n                          <circle\n                            cx=\"100\"\n                            cy=\"100\"\n                            r=\"76\"\n                            stroke=\"var(--color-border)\"\n                            strokeWidth=\"10\"\n                            fill=\"transparent\"\n                            className=\"opacity-20\"\n                          />\n                          {/* Progress Circle (Scaled out of 120 max index) */}\n                          <circle\n                            cx=\"100\"\n                            cy=\"100\"\n                            r=\"76\"\n                            stroke={scorecard.summary.isWarning ? '#ef4444' : 'var(--color-accent)'}\n                            strokeWidth=\"12\"\n                            fill=\"transparent\"\n                            strokeDasharray={477.5}\n                            strokeDashoffset={477.5 - Math.min(1, scorecard.summary.finalScore / 120) * 477.5}\n                            strokeLinecap=\"round\"\n                            className=\"transition-all duration-1000 ease-out\"\n                          />\n                        </svg>\n                        \n                        {/* Text Inside Gauge */}\n                        <div className=\"absolute inset-0 flex flex-col items-center justify-center text-center\">\n                          <span className={`text-4xl font-black font-mono ${scorecard.summary.isWarning ? 'text-critical' : 'text-foreground'}`}>\n                            {toFa(scorecard.summary.finalScore)}\n                          </span>\n                          <span className=\"text-[10px] text-foreground-muted font-bold mt-0.5\">\n                            в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в–Ҳв–’в–Ҳв–“в–Ҳв–‘+\n                          </span>\n                        </div>\n                      </div>\n\n                      {/* Performance Alarm Banner */}\n                      {scorecard.summary.isWarning ? (\n                        <div className=\"mt-4 bg-critical/15 border border-critical/30 text-critical text-[11px] px-3 py-1.5 rounded-full font-bold animate-pulse flex items-center gap-1.5\">\n                          <AlertCircle className=\"size-3.5\" />\n                          <span>в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»: в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҢвҢҗв”ҳГӨ в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘ в•Әв–“в–ҲГ®в•Әв–’ в–Ҳв•–в–Ҳв–‘</span>\n                        </div>\n                      ) : (\n                        <div className=\"mt-4 bg-success/10 text-success text-[11px] px-3 py-1.5 rounded-full font-bold flex items-center gap-1.5\">\n                          <CheckCircle2 className=\"size-3.5\" />\n                          <span>в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГ в•Әв•–в”ҳГӨв”ҳГӘв•ӘВҝ в”ҳГӘ в•ӘВ»в•Әв–’ в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ»в”ҳГ§ в•ӘВ¬в•Әв•Јв”ҳГ§в•ӘВ» в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®</span>\n                        </div>\n                      )}\n                    </CardContent>\n                  </Card>\n\n                  {/* Competency Radar Chart Card */}\n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm md:col-span-2 flex flex-col\">\n                    <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest flex flex-row items-center justify-between\">\n                      <div>\n                        <CardTitle className=\"text-sm font-bold\">в”ҳГҘв”ҳГ©в•Әв”Өв”ҳГ§ в•ӘВ¬в•ӘВәв•Әв–’ в•Әв•Јв”ҳГҘв”ҢвҢҗв•ӘВҝв”ҳГӘв•ӘВ¬в–ҲГ® в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВә (Radar)</CardTitle>\n                        <CardDescription className=\"text-[10px]\">\n                          в”ҳГҘв”ҳГ в”ҳГӘв•ӘВ»в•ӘВәв•Әв–’ в”ҢГҘв”ҳГҘв•ӘВ»в•ӘВҝв”ҳГ…в•Әв•Јв•ӘВ»в–ҲГ® в”ҳГҘв”ҳГ©в•ӘВәв•Әв•– в”ҳГ©в”ҳГӘв•ӘВ¬ в”ҳГӘ в•Әв•ўв•Әв•Јв”ҳГј в•Әв–’в”ҳГјв•ӘВ¬в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘ в”ҳГјв”ҳГҘв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                        </CardDescription>\n                      </div>\n                      <Badge variant=\"outline\" className=\"text-[10px] bg-accent/5 text-accent font-bold\">\n                        в–Ҳв•ў в•ӘВҝв”ҳГ…в•Әв•Јв•ӘВ» в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’в–ҲГ®\n                      </Badge>\n                    </CardHeader>\n                    <CardContent className=\"p-4 flex-1 flex flex-col md:flex-row items-center justify-center gap-6\">\n                      \n                      {/* SVG Radar Chart */}\n                      <div className=\"w-64 h-64 shrink-0 relative\">\n                        <svg className=\"w-full h-full\" viewBox=\"0 0 320 320\">\n                          {/* Concentric grid lines (Concentric Hexagons) */}\n                          {backgroundGridPaths.map((pathStr, idx) => (\n                            <polygon\n                              key={idx}\n                              points={pathStr.replace(/[MLZ]/g, '').trim()}\n                              fill=\"none\"\n                              stroke=\"var(--color-border)\"\n                              strokeWidth=\"1\"\n                              className=\"opacity-30\"\n                            />\n                          ))}\n\n                          {/* Grid Labels for 20%, 40%, 60%, 80%, 100% on the vertical axis */}\n                          {[20, 40, 60, 80, 100].map((gridVal, idx) => {\n                            const y = 160 - (gridVal / 100) * 100\n                            return (\n                              <text\n                                key={idx}\n                                x=\"164\"\n                                y={y + 3}\n                                fill=\"var(--color-foreground-muted)\"\n                                className=\"text-[8px] font-bold font-mono opacity-50\"\n                              >\n                                {toFa(gridVal)}\n                              </text>\n                            )\n                          })}\n\n                          {/* Hexagon spokes/axes from center */}\n                          {radarCoordinates.map((coord, idx) => (\n                            <line\n                              key={idx}\n                              x1=\"160\"\n                              y1=\"160\"\n                              x2={coord.grids[4].x}\n                              y2={coord.grids[4].y}\n                              stroke=\"var(--color-border)\"\n                              strokeWidth=\"1\"\n                              className=\"opacity-40\"\n                            />\n                          ))}\n\n                          {/* Data Polygon Path */}\n                          {radarDataPath && (\n                            <polygon\n                              points={radarDataPath.replace(/[MLZ]/g, '').trim()}\n                              fill=\"var(--color-accent)\"\n                              fillOpacity=\"0.25\"\n                              stroke=\"var(--color-accent)\"\n                              strokeWidth=\"2.5\"\n                              className=\"transition-all duration-500\"\n                            />\n                          )}\n\n                          {/* Vertex Dots with Hover Tooltips */}\n                          {radarCoordinates.map((coord, idx) => (\n                            <g key={idx} className=\"group/dot\">\n                              <circle\n                                cx={coord.x}\n                                cy={coord.y}\n                                r=\"4.5\"\n                                fill=\"var(--color-surface)\"\n                                stroke=\"var(--color-accent)\"\n                                strokeWidth=\"2.5\"\n                                className=\"cursor-pointer transition-all duration-150 hover:r-6\"\n                              />\n                              {/* Axis Label Text */}\n                              {(() => {\n                                // Dynamic offset to keep labels outside the chart bounds\n                                const angle = -Math.PI / 2 + idx * (2 * Math.PI / 6)\n                                const textDist = 122\n                                const tx = 160 + textDist * Math.cos(angle)\n                                const ty = 160 + textDist * Math.sin(angle)\n                                return (\n                                  <text\n                                    x={tx}\n                                    y={ty + 3}\n                                    fill=\"var(--color-foreground)\"\n                                    className=\"text-[9px] font-bold\"\n                                    textAnchor=\"middle\"\n                                  >\n                                    {coord.label}\n                                  </text>\n                                )\n                              })()}\n                            </g>\n                          ))}\n                        </svg>\n                      </div>\n\n                      {/* Radar legends & values list */}\n                      <div className=\"grid grid-cols-2 gap-x-4 gap-y-2 w-full max-w-xs\">\n                        {radarCoordinates.map((coord, idx) => (\n                          <div key={idx} className=\"flex items-center justify-between text-xs p-1.5 rounded bg-surface border border-border/40\">\n                            <span className=\"text-foreground-muted font-bold truncate\">{coord.label}</span>\n                            <span className=\"font-mono font-black text-foreground\">\n                              {toFa(coord.score)}\n                            </span>\n                          </div>\n                        ))}\n                      </div>\n\n                    </CardContent>\n                  </Card>\n\n                </div>\n\n                {/* Score breakdown metrics and bonus cards */}\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n                  \n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm p-4\">\n                    <div className=\"flex items-center justify-between\">\n                      <div className=\"space-y-1\">\n                        <span className=\"text-xs font-semibold text-foreground-muted\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў</span>\n                        <h4 className=\"text-2xl font-bold font-mono text-foreground\">{toFa(scorecard.baseScore)}</h4>\n                        <p className=\"text-[9px] text-foreground-muted\">в”ҳГҘв”ҳГ©в•Әв•–в”ҳГ§ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВ»в•Әв–’ в•ӘВәв”ҳГӘв”ҳГӨ в”ҳГ в•ӘВәв”ҳГ§ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ®</p>\n                      </div>\n                      <div className=\"p-2.5 rounded-lg bg-surface border border-border text-foreground-muted\">\n                        <Activity className=\"size-5\" />\n                      </div>\n                    </div>\n                  </Card>\n\n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm p-4\">\n                    <div className=\"flex items-center justify-between\">\n                      <div className=\"space-y-1\">\n                        <span className=\"text-xs font-semibold text-foreground-muted\">в”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј в•ӘВ¬в•Әв”Өв”ҳГӘв–ҲГ®в”ҳГ©О“ГҮГ®в”ҳГ§в•ӘВә (в•ӘВ¬в•Әв•Јв•ӘВ»в–ҲГ®в”ҳГӨО“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§)</span>\n                        <h4 className=\"text-2xl font-bold font-mono text-success\">\n                          {toFa(scorecard.summary.positiveRaw)} ({toFa(scorecard.summary.positiveDiminished)}+)\n                        </h4>\n                        <p className=\"text-[9px] text-success font-semibold\">в•Әв•ўв•Әв–’в–ҲГ®в•ӘВҝ в”ҢвҢҗв•ӘВәв”ҳГ§в•Әв”Өв–ҲГ® в•ӘВҝв•ӘВә в”ҳГјв•Әв–’в”ҳГ в”ҳГӘв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–“в•ӘВ»в”ҳГ§ в”ҳГҘв•Әв–“в”ҳГӘв”ҳГӨв–ҲГ®</p>\n                      </div>\n                      <div className=\"p-2.5 rounded-lg bg-success/15 text-success\">\n                        <Check className=\"size-5\" />\n                      </div>\n                    </div>\n                  </Card>\n\n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm p-4\">\n                    <div className=\"flex items-center justify-between\">\n                      <div className=\"space-y-1\">\n                        <span className=\"text-xs font-semibold text-foreground-muted\">в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  в”ҳГӘ в”ҢвҢҗв•Әв”Ӯв•Әв–’ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“</span>\n                        <h4 className=\"text-2xl font-bold font-mono text-critical\">\n                          {toFa(scorecard.summary.negativeTotal)}-\n                        </h4>\n                        <p className=\"text-[9px] text-foreground-muted\">в•Әв•ўв•Әв–’в•ӘВҝ в•ӘВ»в•Әв–’ в•Әв•ўв•Әв–’в–ҲГ®в•ӘВҝ в•Әв”Өв•ӘВ»в•ӘВ¬ в•Әв”Ӯв•Әв•–в•ӘВЎ L1 в•ӘВ¬в•ӘВә L3</p>\n                      </div>\n                      <div className=\"p-2.5 rounded-lg bg-critical/15 text-critical\">\n                        <X className=\"size-5\" />\n                      </div>\n                    </div>\n                  </Card>\n\n                  {/* Bonus Card */}\n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm p-4\">\n                    <div className=\"flex items-center justify-between\">\n                      <div className=\"space-y-1\">\n                        <span className=\"text-xs font-semibold text-foreground-muted\">в•ӘВҝв”ҳГӘв”ҳГҘв”ҳГӘв•Әв”ӮО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГ в•Әв–’в•ӘВәв•Әв–’</span>\n                        <h4 className=\"text-2xl font-bold font-mono text-accent\">\n                          {toFa(scorecard.summary.consistencyBonus + scorecard.summary.streakBonus)}+\n                        </h4>\n                        <div className=\"flex gap-1.5 mt-1\">\n                          {scorecard.summary.consistencyBonus > 0 && (\n                            <Badge variant=\"outline\" className=\"text-[8px] bg-accent/5 text-accent border-accent/20\">\n                              в•ӘВҪв•ӘВҝв•ӘВәв•ӘВ¬ в–Ҳв–“F\n                            </Badge>\n                          )}\n                          {scorecard.summary.streakBonus > 0 && (\n                            <Badge variant=\"outline\" className=\"text-[8px] bg-yellow-500/5 text-yellow-500 border-yellow-500/20\">\n                              в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГ в•Әв–’в•ӘВәв•Әв–’ в–Ҳв”ӮM\n                            </Badge>\n                          )}\n                        </div>\n                      </div>\n                      <div className=\"p-2.5 rounded-lg bg-accent/15 text-accent\">\n                        <Award className=\"size-5\" />\n                      </div>\n                    </div>\n                  </Card>\n\n                </div>\n\n                {/* Timeline of Performance Logs */}\n                <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm\">\n                  <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest flex flex-row items-center justify-between\">\n                    <div>\n                      <CardTitle className=\"text-sm font-bold\">в•Әв–’в–ҲГ®в•Әв–“ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВә в”ҳГӘ в•Әв”Ӯв”ҳГӘв•ӘВәв•ӘВҝв”ҳГ© в•ӘВҪв•ӘВҝв•ӘВ¬в–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§</CardTitle>\n                      <CardDescription className=\"text-[10px]\">\n                        в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝв•Әв–’в•Әв”Ӯв–ҲГ®О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“в•ӘВәв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в•Әв–’в”ҳГӘв•Әв–“в•Әв”Өв”ҳГ в•ӘВәв•Әв–’\n                      </CardDescription>\n                    </div>\n                    <Badge variant=\"outline\" className=\"text-xs font-mono\">\n                      {toFa(scorecard.logs.length)} в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ» в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ\n                    </Badge>\n                  </CardHeader>\n                  <CardContent className=\"p-4\">\n                    {scorecard.logs.length === 0 ? (\n                      <div className=\"flex flex-col items-center justify-center p-10 text-center\">\n                        <CheckCircle2 className=\"size-12 text-success/60 mb-2\" />\n                        <span className=\"text-xs text-foreground-muted font-bold\">\n                          в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳГ в•ӘВҪв•ӘВҝв•ӘВ¬ в–ҲГ®в•ӘВә в”ҳГ в”ҳГҘв”ҳГјв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨв•ӘВәв”ҳГҜ в”ҳГҘв•Әв–’в”ҳГ в•ӘВәв”ҳГӨ в”ҳГӘ в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҢВ»в•Әв–“в•ӘВәв•Әв–’в•Әв”Ө.\n                        </span>\n                      </div>\n                    ) : (\n                      <div className=\"relative border-s border-border/70 mr-3 pr-4 space-y-6\">\n                        {scorecard.logs.map((log) => {\n                          const isPositive = log.scoreValue > 0\n                          const isAppealed = log.status === 'appealed'\n                          const isOverturned = log.status === 'overturned'\n\n                          return (\n                            <div key={log.id} className=\"relative\">\n                              \n                              {/* Icon Pin on timeline */}\n                              <span className={`absolute -right-[27px] top-1.5 flex size-5 items-center justify-center rounded-full border-2 ${\n                                isOverturned\n                                  ? 'bg-surface border-foreground-muted text-foreground-muted'\n                                  : isPositive\n                                    ? 'bg-success/20 border-success text-success'\n                                    : 'bg-critical/20 border-critical text-critical'\n                              }`}>\n                                {isOverturned ? (\n                                  <Check className=\"size-2.5\" />\n                                ) : isPositive ? (\n                                  <ThumbsUp className=\"size-2.5\" />\n                                ) : (\n                                  <AlertTriangle className=\"size-2.5\" />\n                                )}\n                              </span>\n\n                              {/* Log Card body */}\n                              <div className=\"bg-surface rounded-lg border border-border/50 p-4 transition-all hover:border-border\">\n                                <div className=\"flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between\">\n                                  \n                                  {/* Title & badge */}\n                                  <div className=\"flex items-center gap-2 flex-wrap\">\n                                    <span className=\"text-xs font-black text-foreground\">\n                                      {competencyLabels[log.actionType.competencyId] || log.actionType.competency.name} : {log.actionType.title}\n                                    </span>\n                                    <Badge\n                                      variant=\"outline\"\n                                      className={`text-[9px] font-mono font-semibold ${\n                                        isOverturned\n                                          ? 'bg-surface border-border text-foreground-muted'\n                                          : isPositive\n                                            ? 'bg-success/5 border-success/20 text-success'\n                                            : 'bg-critical/5 border-critical/20 text-critical'\n                                      }`}\n                                    >\n                                      {isOverturned ? 'в•ӘВҝв•ӘВәв•Әв•–в”ҳГӨО“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§' : isPositive ? `${toFa(log.scoreValue)}+ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“` : `${toFa(Math.abs(log.scoreValue))}- в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“`}\n                                    </Badge>\n\n                                    {log.severity && log.scoreValue < 0 && (\n                                      <Badge variant=\"outline\" className=\"text-[8px] bg-outline-variant/30 font-bold\">\n                                        в•Әв”Өв•ӘВ»в•ӘВ¬ {toFa(log.severity)}\n                                      </Badge>\n                                    )}\n\n                                    {/* Appeal Status Badges */}\n                                    {isAppealed && (\n                                      <Badge className=\"text-[8px] bg-warning/25 text-warning hover:bg-warning/25 border-warning/20\">\n                                        в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў\n                                      </Badge>\n                                    )}\n                                    {isOverturned && (\n                                      <Badge className=\"text-[8px] bg-success/25 text-success hover:bg-success/25 border-success/20\">\n                                        в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГӘ в”ҢвҢҗв•Әв”Ӯв•Әв–’ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳГӨв•Әв•‘в”ҳГӘ в•Әв”Өв•ӘВ»\n                                      </Badge>\n                                    )}\n                                  </div>\n\n                                  {/* Timestamp */}\n                                  <div className=\"text-[10px] text-foreground-muted font-bold font-mono\">\n                                    {jalali(log.createdAt)} в•ӘВ»в•Әв–’ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ {faTime(log.createdAt)}\n                                  </div>\n\n                                </div>\n\n                                {/* Log Note */}\n                                {log.note && (\n                                  <p className=\"mt-2 text-xs text-foreground-muted leading-relaxed bg-surface-container-lowest p-2 rounded border border-border/30\">\n                                    {log.note}\n                                  </p>\n                                )}\n\n                                {/* recordedBy and evidence */}\n                                <div className=\"mt-3 pt-2 border-t border-border/40 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between text-[10px] text-foreground-muted font-bold\">\n                                  <span>в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–: {log.recordedBy?.name || 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ '}</span>\n                                  \n                                  <div className=\"flex items-center gap-3\">\n                                    {log.evidenceUrl && (\n                                      <a\n                                        href={log.evidenceUrl}\n                                        target=\"_blank\"\n                                        rel=\"noreferrer\"\n                                        className=\"text-accent hover:underline flex items-center gap-1\"\n                                      >\n                                        <FileText className=\"size-3\" />\n                                        в”ҳГ в•Әв”Өв•ӘВәв”ҳГ§в•ӘВ»в”ҳГ§ в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬\n                                      </a>\n                                    )}\n\n                                    {/* Appeal Button */}\n                                    {!isPositive && !isAppealed && !isOverturned && (\n                                      <Button\n                                        variant=\"outline\"\n                                        size=\"icon-sm\"\n                                        className=\"h-6 px-2 text-[9px] font-bold text-critical border-critical/30 hover:bg-critical/5 hover:border-critical transition-colors\"\n                                        onClick={() => {\n                                          setAppealLogId(log.id)\n                                          setAppealModalOpen(true)\n                                        }}\n                                      >\n                                        в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•Әв–’в”ҳГӘв–ҲГ® в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»\n                                      </Button>\n                                    )}\n                                  </div>\n                                </div>\n\n                              </div>\n\n                            </div>\n                          )\n                        })}\n                      </div>\n                    )}\n                  </CardContent>\n                </Card>\n\n              </>\n            ) : (\n              <div className=\"text-center text-xs text-foreground-muted p-10 bg-surface-container border border-border rounded-lg\">\n                в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».\n              </div>\n            )}\n          </div>\n        )}\n\n        {/* ========================================================================= */}\n        {/* TAB 2: LEADERBOARD */}\n        {/* ========================================================================= */}\n        {activeTab === 'leaderboard' && (\n          <div className=\"space-y-6 animate-in fade-in duration-300\">\n            {loadingLeaderboard ? (\n              <div className=\"flex flex-col items-center justify-center p-24 gap-3\">\n                <Activity className=\"size-10 animate-spin text-accent\" />\n                <span className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в•Әв–’в•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҢвҢҗв”ҳГӨ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘ...</span>\n              </div>\n            ) : leaderboardError ? (\n              <div className=\"bg-critical/10 border border-critical/30 rounded-lg p-4 text-critical text-sm text-center flex items-center justify-center gap-2\">\n                <AlertTriangle className=\"size-5\" />\n                <span>{leaderboardError}</span>\n              </div>\n            ) : leaderboard ? (\n              <>\n                \n                {/* 3D-Like Podium Display for Top 3 */}\n                <div className=\"flex flex-col md:flex-row items-end justify-center gap-6 py-10 px-4 bg-surface-container-lowest border border-border rounded-lg shadow-sm\">\n                  \n                  {/* Rank 2: Silver */}\n                  {leaderboard.topFive[1] && (\n                    <div className=\"flex flex-col items-center order-2 md:order-1 w-full max-w-[200px]\">\n                      {/* User Info */}\n                      <div className=\"flex flex-col items-center text-center mb-3\">\n                        <div className=\"relative size-14 rounded-full border-2 border-slate-400 bg-surface flex items-center justify-center font-bold text-slate-400 text-lg shadow\">\n                          {leaderboard.topFive[1].avatar}\n                        </div>\n                        <span className=\"text-xs font-black mt-2 text-foreground truncate max-w-[120px]\">{leaderboard.topFive[1].name}</span>\n                        <span className=\"text-[9px] text-foreground-muted font-bold\">{leaderboard.topFive[1].dept}</span>\n                      </div>\n                      {/* Silver Pillar */}\n                      <div className=\"w-full bg-slate-400/25 border-t border-slate-400/50 rounded-t-lg h-28 flex flex-col items-center justify-center p-4\">\n                        <Trophy className=\"size-6 text-slate-400 mb-1.5\" />\n                        <span className=\"text-[10px] font-black text-slate-400\">в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГ </span>\n                        <span className=\"text-sm font-black font-mono mt-1 text-foreground\">{toFa(leaderboard.topFive[1].score)}</span>\n                      </div>\n                    </div>\n                  )}\n\n                  {/* Rank 1: Gold (Tallest and centered) */}\n                  {leaderboard.topFive[0] && (\n                    <div className=\"flex flex-col items-center order-1 md:order-2 w-full max-w-[220px] -mt-6\">\n                      {/* User Info */}\n                      <div className=\"flex flex-col items-center text-center mb-3\">\n                        <div className=\"relative size-18 rounded-full border-4 border-yellow-500 bg-surface flex items-center justify-center font-bold text-yellow-500 text-xl shadow-lg ring-4 ring-yellow-500/15\">\n                          {leaderboard.topFive[0].avatar}\n                          <span className=\"absolute -top-2.5 -right-2.5 bg-yellow-500 text-black text-[10px] font-black size-5 rounded-full flex items-center justify-center ring-2 ring-surface\">в–Ҳв–’</span>\n                        </div>\n                        <span className=\"text-sm font-black mt-2 text-foreground truncate max-w-[140px]\">{leaderboard.topFive[0].name}</span>\n                        <span className=\"text-[10px] text-foreground-muted font-bold\">{leaderboard.topFive[0].dept}</span>\n                      </div>\n                      {/* Gold Pillar */}\n                      <div className=\"w-full bg-yellow-500/20 border-t-2 border-yellow-500/40 rounded-t-lg h-36 flex flex-col items-center justify-center p-4 shadow-md\">\n                        <Trophy className=\"size-8 text-yellow-500 mb-1.5 animate-bounce\" />\n                        <span className=\"text-[11px] font-black text-yellow-500\">в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҝв•Әв–’в•ӘВ¬в•Әв–’ в”ҳГ в•ӘВәв”ҳГ§</span>\n                        <span className=\"text-base font-black font-mono mt-1 text-yellow-500\">{toFa(leaderboard.topFive[0].score)}</span>\n                      </div>\n                    </div>\n                  )}\n\n                  {/* Rank 3: Bronze */}\n                  {leaderboard.topFive[2] && (\n                    <div className=\"flex flex-col items-center order-3 md:order-3 w-full max-w-[200px]\">\n                      {/* User Info */}\n                      <div className=\"flex flex-col items-center text-center mb-3\">\n                        <div className=\"relative size-14 rounded-full border-2 border-amber-600 bg-surface flex items-center justify-center font-bold text-amber-600 text-lg shadow\">\n                          {leaderboard.topFive[2].avatar}\n                        </div>\n                        <span className=\"text-xs font-black mt-2 text-foreground truncate max-w-[120px]\">{leaderboard.topFive[2].name}</span>\n                        <span className=\"text-[9px] text-foreground-muted font-bold\">{leaderboard.topFive[2].dept}</span>\n                      </div>\n                      {/* Bronze Pillar */}\n                      <div className=\"w-full bg-amber-600/25 border-t border-amber-600/50 rounded-t-lg h-24 flex flex-col items-center justify-center p-4\">\n                        <Trophy className=\"size-5 text-amber-600 mb-1.5\" />\n                        <span className=\"text-[10px] font-black text-amber-700\">в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•Әв”Ӯв”ҳГӘв”ҳГ </span>\n                        <span className=\"text-sm font-black font-mono mt-1 text-foreground\">{toFa(leaderboard.topFive[2].score)}</span>\n                      </div>\n                    </div>\n                  )}\n\n                </div>\n\n                {/* Rank 4 and 5 List */}\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  {leaderboard.topFive.slice(3, 5).map((rec) => (\n                    <Card key={rec.employeeId} className=\"border border-border bg-surface-container-lowest/50 shadow-sm p-4\">\n                      <div className=\"flex items-center justify-between\">\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"text-sm font-black text-foreground-muted font-mono w-6\">\n                            #{toFa(rec.rank)}\n                          </span>\n                          <div className=\"size-9 rounded-full bg-surface-container border border-border flex items-center justify-center font-bold text-xs\">\n                            {rec.avatar}\n                          </div>\n                          <div>\n                            <div className=\"text-xs font-bold text-foreground\">{rec.name}</div>\n                            <div className=\"text-[9px] text-foreground-muted font-semibold\">{rec.dept}</div>\n                          </div>\n                        </div>\n                        <span className=\"text-xs font-black font-mono text-foreground\">\n                          {toFa(rec.score)} в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“\n                        </span>\n                      </div>\n                    </Card>\n                  ))}\n                </div>\n\n                {/* Private Rank Status Card (Ensures low rankings are hidden from public to save morale) */}\n                <Card className=\"border border-border bg-accent/5 shadow-md border-accent/25 p-5\">\n                  <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between\">\n                    <div className=\"space-y-1\">\n                      <h4 className=\"text-sm font-black text-accent flex items-center gap-2\">\n                        <ShieldCheck className=\"size-4\" />\n                        в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳГӘ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘВәв•ӘВ«в•ӘВ¬в•Әв•Ўв•ӘВәв•Әв•Ўв–ҲГ® в•Әв”Өв”ҳГ в•ӘВә (в”ҳГ в•ӘВЎв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв”ҳГ§)\n                      </h4>\n                      <p className=\"text-xs text-foreground-muted leading-relaxed\">\n                        в•ӘВәв–ҲГ®в”ҳГҘ в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•Әв•Ўв•Әв–’в”ҳГјв•ӘВәв”ҳГҜ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в•ӘВәв”ҳГҘв”ҢВ»в–ҲГ®в•Әв–“в”ҳГ§ в”ҳГӘ в•Әв–’в•Әв•Ўв•ӘВ» в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨв–ҲГ® в”ҳГјв•Әв–’в•ӘВ»в–ҲГ® в•ӘВҝв”ҳГ§ в•Әв”Өв”ҳГ в•ӘВә в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ». в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ«в•ӘВәв•Әв–’в•ӘВј в•ӘВәв•Әв–“ в–Ҳв•Ў в”ҳГҘв”ҳГјв•Әв–’ в•ӘВҝв•Әв–’в•ӘВ¬в•Әв–’ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ»в–ҲГ®в”ҢВ»в•Әв–’в–ҲГ® в”ҳГ©в•ӘВәв•ӘВҝв”ҳГӨ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ¬ в”ҳГҘв–ҲГ®в•Әв”Ӯв•ӘВ¬.\n                      </p>\n                    </div>\n\n                    <div className=\"grid grid-cols-3 gap-4 border-t border-border/50 pt-3 sm:border-t-0 sm:pt-0 shrink-0 text-center\">\n                      <div className=\"bg-surface border border-border/60 p-2.5 rounded-lg\">\n                        <div className=\"text-[10px] text-foreground-muted font-bold\">в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•Әв”Өв”ҳГ в•ӘВә</div>\n                        <div className=\"text-lg font-black font-mono text-foreground mt-1\">\n                          {leaderboard.myPrivateRank.rank ? `${toFa(leaderboard.myPrivateRank.rank)}` : 'О“ГҮГ¶'}\n                          <span className=\"text-[10px] text-foreground-muted font-normal ms-0.5\">\n                            в•ӘВәв•Әв–“ {toFa(leaderboard.myPrivateRank.totalCount)}\n                          </span>\n                        </div>\n                      </div>\n                      <div className=\"bg-surface border border-border/60 p-2.5 rounded-lg\">\n                        <div className=\"text-[10px] text-foreground-muted font-bold\">в•Әв•Ўв•ӘВ»в”ҢвҢҗ в•Әв–’в•ӘВ»в”ҳГ§</div>\n                        <div className=\"text-lg font-black font-mono text-accent mt-1\">\n                          {toFa(leaderboard.myPrivateRank.percentile)}в”ҳВ¬\n                        </div>\n                      </div>\n                      <div className=\"bg-surface border border-border/60 p-2.5 rounded-lg\">\n                        <div className=\"text-[10px] text-foreground-muted font-bold\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳГҘв•Әв–’в”ҳГ в•ӘВәв”ҳГӨ</div>\n                        <div className=\"text-lg font-black font-mono text-foreground mt-1\">\n                          {toFa(leaderboard.myPrivateRank.score)}\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                  <div className=\"mt-4 pt-3 border-t border-border/30 text-[11px] text-foreground-muted flex items-start gap-2\">\n                    <HelpCircle className=\"size-4 text-accent shrink-0 mt-0.5\" />\n                    <span>\n                      в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ў в•Әв•Ўв•ӘВ»в”ҢвҢҗ {toFa(leaderboard.myPrivateRank.percentile)}в”ҳВ¬ в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ»в”ҳГ§в•ӘВ» в”ҢвҢҗв”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•Әв”Өв”ҳГ в•ӘВә в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГјв•Әв–’в”ҳГ в”ҳГӘв”ҳГӨ Z-Score в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»в•ӘГ® в•ӘВҝв”ҳГ§в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ {toFa(leaderboard.myPrivateRank.percentile)} в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•ӘВәв•Әв–“ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ§в”ҳГ О“ГҮГ®в•Әв”Ӯв”ҳГ в•ӘВ¬ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в•ӘВәв”ҳГ§ в•ӘВҝв”ҳГӘв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘВҝв•ӘВә в•ӘВәв•Әв–’в•ӘВ¬в”ҳГ©в•ӘВәв–ҲГ® в•ӘВәв”ҳГҘв•Әв•ўв•ӘВҝв•ӘВәв•Әв•– в”ҳГјв•Әв–’в•ӘВ»в–ҲГ® в”ҳГӘ в•ӘВәв”ҳГјв•Әв–“в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ«в”ҳГӨв•ӘВәв”ҳГ©в–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в•ӘВ» в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•Әв–’в•Әв”Өв•ӘВ» в•ӘВ»в”ҳГ§в–ҲГ®в•ӘВ».\n                    </span>\n                  </div>\n                </Card>\n\n              </>\n            ) : (\n              <div className=\"text-center text-xs text-foreground-muted p-10\">в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в•Әв–’в•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».</div>\n            )}\n          </div>\n        )}\n\n        {/* ========================================================================= */}\n        {/* TAB 3: MANAGER PANEL */}\n        {/* ========================================================================= */}\n        {activeTab === 'manager' && isManagerOrAdmin && (\n          <div className=\"space-y-6 animate-in fade-in duration-300\">\n            {loadingManager ? (\n              <div className=\"flex flex-col items-center justify-center p-24 gap-3\">\n                <Activity className=\"size-10 animate-spin text-accent\" />\n                <span className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳв•ӣв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬в–ҲГ®...</span>\n              </div>\n            ) : managerError ? (\n              <div className=\"bg-critical/10 border border-critical/30 rounded-lg p-4 text-critical text-sm text-center flex items-center justify-center gap-2\">\n                <AlertTriangle className=\"size-5\" />\n                <span>{managerError}</span>\n              </div>\n            ) : managerData ? (\n              <div className=\"space-y-6\">\n\n                \n                {/* 1. Quick Log Form Card & Monthly calculation trigger */}\n                <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n                  \n                  {/* Quick Log Form */}\n                  <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm lg:col-span-2\">\n                    <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest\">\n                      <CardTitle className=\"text-sm font-bold flex items-center gap-2\">\n                        <Plus className=\"size-4 text-accent\" />\n                        в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Ӯв•Әв–’в–ҲГ®в•Әв•Ј в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ» в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ (в•ӘВ»в•Әв–’ в”ҳГӨв•ӘВЎв•Әв••в”ҳГ§)\n                      </CardTitle>\n                      <CardDescription className=\"text-[10px]\">\n                        в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в”ҳГ в•ӘВЎв•ӘВ¬в•Әв–’в”ҳГ в•ӘГ® в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“в•ӘВ»в”ҳГ§в–ҲГ® в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГӘв•ӘВәв”ҳГ©в•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГӘ в•ӘВҝв•ӘВә в•ӘВ»в•Әв–’в•ӘВј в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ». в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ»в•Әв–’ в•Әв”Ӯв•ӘВјв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».\n                      </CardDescription>\n                    </CardHeader>\n                    <CardContent className=\"p-4\">\n                      <form onSubmit={handleQuickLogSubmit} className=\"space-y-4\">\n                        \n                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                          \n                          {/* Employee Select */}\n                          <div className=\"space-y-1.5\">\n                            <label className=\"text-xs font-bold text-foreground\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГ в”ҳГҘв•ӘВ» / в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’:</label>\n                            <select\n                              value={quickLog.employeeId}\n                              onChange={(e) => setQuickLog({ ...quickLog, employeeId: e.target.value })}\n                              className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-xs text-foreground focus:outline-none focus:border-accent cursor-pointer\"\n                              required\n                            >\n                              <option value=\"\">-- в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’ --</option>\n                              {managerData.employees.map((emp) => (\n                                <option key={emp.id} value={emp.id}>\n                                  {emp.name} ({((emp.customFields as any)?.post) || 'в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ'})\n                                </option>\n                              ))}\n                            </select>\n                          </div>\n\n                          {/* Competency Group Select */}\n                          <div className=\"space-y-1.5\">\n                            <label className=\"text-xs font-bold text-foreground\">в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®:</label>\n                            <select\n                              value={quickLog.competencyId}\n                              onChange={(e) => setQuickLog({ ...quickLog, competencyId: e.target.value, actionTypeId: '' })}\n                              className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-xs text-foreground focus:outline-none focus:border-accent cursor-pointer\"\n                              required\n                            >\n                              <option value=\"\">-- в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® --</option>\n                              {managerData.competencies.map((comp) => (\n                                <option key={comp.id} value={comp.id}>\n                                  {comp.name} ({comp.direction === 'positive' ? 'в•ӘВ¬в•Әв”Өв”ҳГӘв–ҲГ®в”ҳГ©в–ҲГ®' : comp.direction === 'negative' ? 'в•ӘВ¬в”ҳГҘв•ӘВҝв–ҲГ®в”ҳГ§в–ҲГ®' : 'в•ӘВ»в”ҳГӘв•Әв•–в•Әв–’в”ҳГјв”ҳГ§'})\n                                </option>\n                              ))}\n                            </select>\n                          </div>\n\n                          {/* Action Type Select (Dependent on Competency) */}\n                          <div className=\"space-y-1.5 md:col-span-2\">\n                            <label className=\"text-xs font-bold text-foreground\">в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВәв•ӘВ«в•ӘВ¬в•Әв•Ўв•ӘВәв•Әв•Ўв–ҲГ®:</label>\n                            <select\n                              value={quickLog.actionTypeId}\n                              onChange={(e) => setQuickLog({ ...quickLog, actionTypeId: e.target.value })}\n                              className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-xs text-foreground focus:outline-none focus:border-accent cursor-pointer\"\n                              disabled={!quickLog.competencyId}\n                              required\n                            >\n                              <option value=\"\">-- в•ӘВәв•ӘВҝв•ӘВ¬в•ӘВ»в•ӘВә в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в•Әв–’в•ӘВә в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ» --</option>\n                              {availableActionTypes.map((act) => (\n                                <option key={act.id} value={act.id}>\n                                  {act.title} (в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў: {toFa(act.defaultScore)} | в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв”Өв•ӘВ»в•ӘВ¬: {toFa(act.maxSeverity)})\n                                </option>\n                              ))}\n                            </select>\n                          </div>\n\n                          {/* Severity Selector (only enabled for negative actions or general) */}\n                          <div className=\"space-y-1.5\">\n                            <label className=\"text-xs font-bold text-foreground\">в•Әв”Ӯв•Әв•–в•ӘВЎ в•Әв”Өв•ӘВ»в•ӘВ¬ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ» (Severity):</label>\n                            <select\n                              value={quickLog.severity}\n                              onChange={(e) => setQuickLog({ ...quickLog, severity: e.target.value as any })}\n                              className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-xs text-foreground focus:outline-none focus:border-accent cursor-pointer\"\n                            >\n                              <option value=\"L1\">{severityLabels.L1}</option>\n                              <option value=\"L2\">{severityLabels.L2}</option>\n                              <option value=\"L3\">{severityLabels.L3}</option>\n                            </select>\n                          </div>\n\n                          {/* Evidence Link */}\n                          <div className=\"space-y-1.5\">\n                            <label className=\"text-xs font-bold text-foreground\">в”ҳГӨв–ҲГ®в”ҳГҘв”ҢвҢҗ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ» в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬ (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®):</label>\n                            <input\n                              type=\"url\"\n                              value={quickLog.evidenceUrl}\n                              onChange={(e) => setQuickLog({ ...quickLog, evidenceUrl: e.target.value })}\n                              placeholder=\"https://example.com/evidence\"\n                              className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-xs text-foreground focus:outline-none focus:border-accent text-start\"\n                            />\n                          </div>\n\n                          {/* Note / Reason */}\n                          <div className=\"space-y-1.5 md:col-span-2\">\n                            <label className=\"text-xs font-bold text-foreground\">в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв•ӘВәв•ӘВ¬ в”ҳГӘ в•Әв•Јв”ҳГӨв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ (в–ҲГ®в•ӘВәв•ӘВ»в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§):</label>\n                            <textarea\n                              value={quickLog.note}\n                              onChange={(e) => setQuickLog({ ...quickLog, note: e.target.value })}\n                              placeholder=\"в•ӘВҝв•ӘВәв•ӘВҝв•ӘВ¬ в”ҢГҘв”ҳГ§ в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Јв–ҲГ®в•ӘГ® в•ӘВ»в•Әв–’ в”ҢГҘв”ҳГ§ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в–ҲГ® в”ҳГӘ в”ҢГҘв”ҳГ§ в•Әв”Өв•Әв–’в•ӘВЎв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ»в•ӘЖ’...\"\n                              className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-xs text-foreground focus:outline-none focus:border-accent min-h-[80px]\"\n                              required\n                            />\n                          </div>\n\n                        </div>\n\n                        {/* Error and Success alerts */}\n                        {logErrorMessage && (\n                          <div className=\"bg-critical/10 border border-critical/30 rounded px-3 py-2 text-critical text-xs flex items-center gap-1.5\">\n                            <AlertCircle className=\"size-3.5\" />\n                            <span>{logErrorMessage}</span>\n                          </div>\n                        )}\n                        {logSuccessMessage && (\n                          <div className=\"bg-success/10 border border-success/30 rounded px-3 py-2 text-success text-xs flex items-center gap-1.5\">\n                            <CheckCircle2 className=\"size-3.5\" />\n                            <span>{logSuccessMessage}</span>\n                          </div>\n                        )}\n\n                        {/* Submit Button */}\n                        <div className=\"flex justify-end\">\n                          <Button\n                            type=\"submit\"\n                            disabled={submittingLog}\n                            className=\"text-xs font-bold bg-accent hover:bg-accent-hover text-accent-foreground px-5 py-2 rounded-lg transition-colors\"\n                          >\n                            {submittingLog ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§...' : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ©в•Әв•–в•Әв•Јв–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв•ӘВјв”ҳГӨ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»'}\n                          </Button>\n                        </div>\n\n                      </form>\n                    </CardContent>\n                  </Card>\n\n                  {/* Trigger monthly calculations and normalizations */}\n                  <div className=\"space-y-6\">\n                    \n                    <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm\">\n                      <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest\">\n                        <CardTitle className=\"text-sm font-bold\">в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в”ҳГӘ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§</CardTitle>\n                      </CardHeader>\n                      <CardContent className=\"p-4 space-y-4\">\n                        <p className=\"text-xs text-foreground-muted leading-relaxed\">\n                          в•ӘВ»в•Әв–’ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в”ҳГ§в•Әв–’ в”ҳГ в•ӘВәв”ҳГ§ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ®в•ӘГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ Z-Score в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»в”ҳГ§в•ӘВәв•ӘГ® в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в•Әв•Ўв•ӘВ»в”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в”ҳГ в”ҳГӘв•ӘВ¬в”ҳГӘв•Әв–’ в•ӘВ¬в•Әв”Ӯв•ӘВәв”ҳГӘв–ҲГ®О“ГҮГ®в•Әв”Өв”ҢвҢҗв”ҳГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГҘв”ҳГ в”ҳГӘв”ҳГҘв”ҳГ§в•ӘГ® в•ӘВ»в”ҢвҢҗв”ҳГ в”ҳГ§ в•Әв–“в–ҲГ®в•Әв–’ в•Әв–’в•ӘВә в”ҢвҢҗв”ҳГӨв–ҲГ®в”ҢвҢҗ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                        </p>\n                        \n                        <Button\n                          type=\"button\"\n                          onClick={handleTriggerNomination}\n                          disabled={loadingNomination}\n                          className=\"w-full text-xs font-bold bg-accent hover:bg-accent-hover text-accent-foreground py-2.5 rounded-lg flex items-center justify-center gap-2\"\n                        >\n                          <Activity className=\"size-4 animate-pulse\" />\n                          {loadingNomination ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в”ҳГӘ в”ҳГҘв•Әв–’в”ҳГ в•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®...' : 'в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГӘ в”ҳГҘв•Әв–’в”ҳГ в•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® Z-Score'}\n                        </Button>\n                        \n                        <p className=\"text-[9px] text-foreground-muted text-center\">\n                          в•ӘВәв•ӘВјв•Әв–’в•ӘВәв–ҲГ® в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬ в•Әв”Ӯв”ҳГӘв•ӘВәв•ӘВҝв”ҳГ© в”ҳГ©в•ӘВҝв”ҳГӨв–ҲГ® в•Әв–’в•ӘВә в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ® в”ҳГӘ в”ҳГҘв•ӘВ¬в•ӘВәв–ҲГ®в•ӘВј в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ Snapshots в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢвҢҗв”ҳГҘв•ӘВ».\n                        </p>\n                      </CardContent>\n                    </Card>\n\n                    {/* Active Nomination Congratulation Digital Card */}\n                    {activeNomination ? (\n                      <Card className=\"border-2 border-yellow-500 bg-gradient-to-br from-yellow-950/20 to-surface-container shadow-lg relative overflow-hidden p-6 text-center\">\n                        <div className=\"absolute -right-6 -top-6 opacity-10\">\n                          <Trophy className=\"size-32 text-yellow-500\" />\n                        </div>\n                        <div className=\"flex flex-col items-center justify-center\">\n                          <Award className=\"size-12 text-yellow-500 mb-2 animate-pulse\" />\n                          <Badge className=\"bg-yellow-500 text-black text-[9px] font-black uppercase tracking-wider mb-2\">\n                            в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГҘв”ҳГ в”ҳГӘв”ҳГҘв”ҳГ§ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ {toFa(selectedPeriod.replace('-', ' / '))}\n                          </Badge>\n                          <h4 className=\"text-xl font-black text-foreground mt-1\">\n                            {activeNomination.periodEmployee?.name}\n                          </h4>\n                          <span className=\"text-xs text-foreground-muted font-semibold\">\n                            в•Әв”Ӯв”ҳГ в•ӘВ¬: {((activeNomination.periodEmployee?.customFields as any)?.post) || 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’'}\n                          </span>\n\n                          <p className=\"mt-4 text-[11px] text-foreground-muted leading-relaxed bg-yellow-500/5 p-3 rounded-lg border border-yellow-500/25\">\n                            <span className=\"font-bold text-yellow-500\">в•Әв•Јв”ҳГӨв•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ (в•ӘВ¬в•Әв”Ӯв•ӘВәв”ҳГӘв–ҲГ®О“ГҮГ®в•Әв”Өв”ҢвҢҗв”ҳГҘ):</span><br />\n                            {activeNomination.tiebreakerReason}\n                          </p>\n\n                          <div className=\"mt-4 bg-yellow-500/10 text-yellow-500 text-[10px] px-3 py-1.5 rounded-full font-bold inline-block border border-yellow-500/20\">\n                            в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВ¬ в•ӘВ¬в•ӘВҝв•Әв–’в–ҲГ®в”ҢвҢҗ в•ӘВ»в–ҲГ®в•ӘВјв–ҲГ®в•ӘВ¬в•ӘВәв”ҳГӨ в•Әв•Ўв•ӘВәв•ӘВ»в•Әв–’ в”ҳГӘ в”ҳв•ӣв•ӘВәв•ӘВ»в•ӘВәв•Әв”Ө HR в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ»\n                          </div>\n                        </div>\n                      </Card>\n                    ) : (\n                      <Card className=\"border border-border bg-surface-container-lowest/40 p-6 text-center text-xs text-foreground-muted\">\n                        <HelpCircle className=\"size-8 mx-auto mb-2 text-foreground-muted/50\" />\n                        <span>в”ҳГ§в”ҳГҘв”ҳГӘв•Әв–“ в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГҘв”ҳГ в”ҳГӘв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв”ҳГ§ в”ҳГӘ в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘВ»в”ҢвҢҗв”ҳГ в”ҳГ§ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬ в•Әв–’в•ӘВә в”ҢвҢҗв”ҳГӨв–ҲГ®в”ҢвҢҗ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».</span>\n                      </Card>\n                    )}\n\n                </div>\n\n                </div>\n\n                {/* Catalog & Manage Action Types (Custom actions list & creation) */}\n                <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm\">\n                  <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest flex flex-row items-center justify-between\">\n                    <div>\n                      <CardTitle className=\"text-sm font-bold flex items-center gap-2\">\n                        <Award className=\"size-4 text-accent\" />\n                        в”ҢвҢҗв•ӘВәв•ӘВ¬в•ӘВәв”ҳГӨв”ҳГӘв”ҢВ» в”ҳГӘ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў (в•ӘВ¬в•ӘВ«в•Әв•Ўв–ҲГ®в•Әв•Ў в”ҳГҘв”ҳГ в•Әв–’в•ӘВәв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘ)\n                      </CardTitle>\n                      <CardDescription className=\"text-[10px]\">\n                        в•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в•ӘВ» в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»в–ҲГ® в•ӘВҝв”ҳГ§ в”ҳГ в”ҳГҘв”ҳГӘв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§в•ӘВә в•ӘВәв•Әв•ўв•ӘВәв”ҳГјв”ҳГ§ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в”ҳГӘ в•Әв”Өв•ӘВ»в•ӘВ¬ в•ӘГів”ҳГҘ в•Әв–’в•ӘВә в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв”ҳГҜ в•ӘВ¬в•Әв•Јв–ҲГ®в–ҲГ®в”ҳГҘ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                      </CardDescription>\n                    </div>\n                  </CardHeader>\n                  <CardContent className=\"p-4 grid grid-cols-1 lg:grid-cols-3 gap-6\">\n                    \n                    {/* Add Custom Action Form */}\n                    <div className=\"lg:col-span-1 border-b lg:border-b-0 lg:border-l border-border/50 pb-6 lg:pb-0 lg:pl-6 space-y-4\">\n                      <h4 className=\"text-xs font-black text-foreground flex items-center gap-1\">\n                        <Plus className=\"size-3.5 text-accent\" />\n                        в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в”ҳГ в”ҳГҘв”ҳГӘ\n                      </h4>\n                      <form onSubmit={handleCustomActionSubmit} className=\"space-y-3\">\n                        <div className=\"space-y-1\">\n                          <label className=\"text-[11px] font-bold text-foreground\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»:</label>\n                          <input\n                            type=\"text\"\n                            placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҳГ в”ҳГ§в•ӘВәв•Әв–’ в•ӘВЎв•Әв–’в–ҲГ®в”ҳГ© в–ҲГ®в•ӘВә в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в•ӘВәв”ҳГӘв•Әв•–в”ҳГӨв•ӘВҝв•ӘВәв”ҳГҘв”ҳГ§...\"\n                            value={customAction.title}\n                            onChange={(e) => setCustomAction({ ...customAction, title: e.target.value })}\n                            className=\"w-full bg-surface border border-border rounded px-3 py-1.5 text-xs text-foreground focus:outline-none focus:border-accent\"\n                            required\n                          />\n                        </div>\n\n                        <div className=\"space-y-1\">\n                          <label className=\"text-[11px] font-bold text-foreground\">в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в”ҳГ в•Әв–’в•ӘВҝв”ҳГӘв•Әв•–в”ҳГ§:</label>\n                          <select\n                            value={customAction.competencyId}\n                            onChange={(e) => setCustomAction({ ...customAction, competencyId: e.target.value })}\n                            className=\"w-full bg-surface border border-border rounded px-3 py-1.5 text-xs text-foreground focus:outline-none focus:border-accent cursor-pointer\"\n                            required\n                          >\n                            <option value=\"\">-- в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® --</option>\n                            {managerData.competencies.map((comp) => (\n                              <option key={comp.id} value={comp.id}>\n                                {comp.name}\n                              </option>\n                            ))}\n                          </select>\n                        </div>\n\n                        <div className=\"grid grid-cols-2 gap-3\">\n                          <div className=\"space-y-1\">\n                            <label className=\"text-[11px] font-bold text-foreground\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў:</label>\n                            <input\n                              type=\"number\"\n                              placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: 10 в–ҲГ®в•ӘВә -15\"\n                              value={customAction.defaultScore}\n                              onChange={(e) => setCustomAction({ ...customAction, defaultScore: Number(e.target.value) })}\n                              className=\"w-full bg-surface border border-border rounded px-3 py-1.5 text-xs text-foreground focus:outline-none focus:border-accent\"\n                              required\n                            />\n                          </div>\n\n                          <div className=\"space-y-1\">\n                            <label className=\"text-[11px] font-bold text-foreground\">в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в•Әв”Өв•ӘВ»в•ӘВ¬ в”ҳГ в•ӘВјв•ӘВәв•Әв–“:</label>\n                            <select\n                              value={customAction.maxSeverity}\n                              onChange={(e) => setCustomAction({ ...customAction, maxSeverity: e.target.value as any })}\n                              className=\"w-full bg-surface border border-border rounded px-3 py-1.5 text-xs text-foreground focus:outline-none focus:border-accent cursor-pointer\"\n                            >\n                              <option value=\"L1\">L1 - в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®</option>\n                              <option value=\"L2\">L2 - в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–</option>\n                              <option value=\"L3\">L3 - в•Әв”Өв•ӘВ»в–ҲГ®в•ӘВ»</option>\n                            </select>\n                          </div>\n                        </div>\n\n                        {customActionError && (\n                          <div className=\"bg-critical/10 border border-critical/30 rounded px-2.5 py-1.5 text-critical text-[10px] flex items-center gap-1\">\n                            <AlertCircle className=\"size-3\" />\n                            <span>{customActionError}</span>\n                          </div>\n                        )}\n                        {customActionSuccess && (\n                          <div className=\"bg-success/10 border border-success/30 rounded px-2.5 py-1.5 text-success text-[10px] flex items-center gap-1\">\n                            <CheckCircle2 className=\"size-3\" />\n                            <span>{customActionSuccess}</span>\n                          </div>\n                        )}\n\n                        <Button\n                          type=\"submit\"\n                          disabled={submittingCustomAction}\n                          className=\"w-full text-xs font-bold bg-accent hover:bg-accent-hover text-accent-foreground py-2 rounded transition-colors\"\n                        >\n                          {submittingCustomAction ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ...' : 'в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВ»в•Әв–’ в”ҳГ в”ҳГҘв”ҳГӘ'}\n                        </Button>\n                      </form>\n                    </div>\n\n                    {/* View existing actions catalog grouped by competency */}\n                    <div className=\"lg:col-span-2 space-y-4 max-h-[340px] overflow-y-auto pr-2\">\n                      <h4 className=\"text-xs font-black text-foreground flex items-center gap-1\">\n                        <FileSpreadsheet className=\"size-3.5 text-accent\" />\n                        в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в”ҳГӘ в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬в•ӘВәв•Әв–’ в”ҳГҘв”ҳГ в•Әв–’в•ӘВәв•ӘВ¬ в”ҢвҢҗв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’\n                      </h4>\n                      <div className=\"space-y-4\">\n                        {managerData.competencies.map((comp) => (\n                          <div key={comp.id} className=\"border border-border/50 rounded-lg p-3 bg-surface/30\">\n                            <h5 className=\"text-xs font-black text-foreground border-b border-border/40 pb-1.5 mb-2 flex items-center justify-between\">\n                              <span>{comp.name}</span>\n                              <Badge variant=\"outline\" className=\"text-[9px] font-semibold bg-accent/5 text-accent\">\n                                {comp.direction === 'positive' ? 'в”ҳГ в•ӘВҪв•ӘВҝв•ӘВ¬' : comp.direction === 'negative' ? 'в”ҳГ в”ҳГҘв”ҳГјв–ҲГ®' : 'в•ӘВ»в”ҳГӘв•Әв•–в•Әв–’в”ҳГјв”ҳГ§'}\n                              </Badge>\n                            </h5>\n                            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-2\">\n                              {comp.actionTypes.map((act) => (\n                                <div key={act.id} className=\"flex items-center justify-between p-2 rounded bg-surface border border-border/30 text-xs\">\n                                  <span className=\"font-semibold text-foreground-muted truncate max-w-[170px]\" title={act.title}>\n                                    {act.title}\n                                  </span>\n                                  <div className=\"flex items-center gap-1.5\">\n                                    <Badge variant=\"outline\" className={`text-[9px] font-mono font-bold ${\n                                      act.defaultScore > 0 ? 'bg-success/5 border-success/20 text-success' : 'bg-critical/5 border-critical/20 text-critical'\n                                    }`}>\n                                      {act.defaultScore > 0 ? `+${toFa(act.defaultScore)}` : `${toFa(act.defaultScore)}`}\n                                    </Badge>\n                                    <Badge variant=\"outline\" className=\"text-[8px] opacity-75 font-mono\">\n                                      {toFa(act.maxSeverity)}\n                                    </Badge>\n                                  </div>\n                                </div>\n                              ))}\n                            </div>\n                          </div>\n                        ))}\n                      </div>\n                    </div>\n\n                  </CardContent>\n                </Card>\n\n                {/* 2. Appeals Queue Section (HR/Admin Panel) */}\n                <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm\">\n                  <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest flex flex-row items-center justify-between\">\n                    <div>\n                      <CardTitle className=\"text-sm font-bold flex items-center gap-2\">\n                        <AlertCircle className=\"size-4 text-warning\" />\n                        в•Әв•Ўв”ҳГј в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҝв”ҳГ§ в•ӘВјв•Әв–’в•ӘВәв–ҲГ®в”ҳГ  в”ҳГӘ в”ҢвҢҗв•Әв”Ӯв”ҳГӘв•Әв–’в•ӘВәв•ӘВ¬\n                      </CardTitle>\n                      <CardDescription className=\"text-[10px]\">\n                        в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв”ҳГҘв•ӘВ» в•Әв••в•Әв–’в”ҳГј в–Ҳв•– в•Әв–’в”ҳГӘв•Әв–“ в•ӘВәв•Әв–“ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§в•ӘГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв”ҳГҘв•ӘВ». в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘ в•Әв–’в•ӘВ»/в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘГів”ҳГҘ в•ӘВҝв•ӘВә HR/в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                      </CardDescription>\n                    </div>\n                    <Badge variant=\"outline\" className=\"text-xs bg-warning/5 text-warning font-bold\">\n                      {toFa(pendingAppeals.length)} в”ҳГ в”ҳГӘв•Әв–’в•ӘВ» в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’\n                    </Badge>\n                  </CardHeader>\n                  <CardContent className=\"p-4\">\n                    {loadingAppeals ? (\n                      <div className=\"text-center py-4 text-xs text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•Әв•Ўв”ҳГј в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬...</div>\n                    ) : pendingAppeals.length === 0 ? (\n                      <div className=\"text-center py-6 text-xs text-foreground-muted font-bold flex flex-col items-center justify-center gap-2\">\n                        <CheckCircle2 className=\"size-10 text-success/50\" />\n                        <span>в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©в–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в”ҳГ§в”ҳГ в”ҳГ§О“ГҮГ®в”ҢГҘв–ҲГ®в•Әв–“ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в”ҢвҢҗв•ӘВәв”ҳГӨв–ҲГ®в•ӘВҝв•Әв–’в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</span>\n                      </div>\n                    ) : (\n                      <div className=\"space-y-4\">\n                        {pendingAppeals.map((app) => (\n                          <div key={app.id} className=\"p-4 rounded-lg border border-border bg-surface flex flex-col md:flex-row md:items-start justify-between gap-4\">\n                            \n                            <div className=\"space-y-2\">\n                              {/* Header: Employee & log details */}\n                              <div className=\"flex items-center gap-2 flex-wrap\">\n                                <span className=\"text-xs font-black text-foreground\">{app.log.employee?.name}</span>\n                                <Badge variant=\"outline\" className=\"text-[9px] bg-critical/5 text-critical border-critical/20 font-bold\">\n                                  в”ҢвҢҗв•Әв”Ӯв•Әв–’ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВҝв•ӘВәв•ӘВҝв•ӘВ¬: {app.log.actionType?.title} ({toFa(app.log.scoreValue)} в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“)\n                                </Badge>\n                                <span className=\"text-[10px] text-foreground-muted font-mono\">\n                                  в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»: {jalali(app.log.createdAt)}\n                                </span>\n                              </div>\n                              \n                              {/* Log note */}\n                              {app.log.note && (\n                                <p className=\"text-[10px] text-foreground-muted bg-surface-container-lowest p-2 rounded\">\n                                  <strong className=\"text-foreground\">в–ҲГ®в•ӘВәв•ӘВ»в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬ в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’:</strong> {app.log.note}\n                                </p>\n                              )}\n\n                              {/* Appeal Reason */}\n                              <div className=\"text-[11px] text-foreground-muted bg-warning/5 border border-warning/15 p-3 rounded-lg leading-relaxed\">\n                                <strong className=\"text-warning\">в•ӘВ»в”ҳГӨв–ҲГ®в”ҳГӨ в”ҳГӘ в•ӘВ»в”ҳГјв•ӘВәв•Әв•Јв–ҲГ®в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ:</strong> {app.reason}\n                              </div>\n\n                              {/* Review Note text input */}\n                              <div className=\"pt-2 flex items-center gap-2\">\n                                <span className=\"text-[10px] text-foreground-muted font-bold shrink-0\">в–ҲГ®в•ӘВәв•ӘВ»в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’:</span>\n                                <input\n                                  type=\"text\"\n                                  placeholder=\"в•Әв•Јв”ҳГӨв•ӘВ¬ в”ҳв•ӣв•Әв–‘в–ҲГ®в•Әв–’в•Әв”Ө в–ҲГ®в•ӘВә в•Әв–’в•ӘВ» в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)...\"\n                                  value={reviewNote[app.id] || ''}\n                                  onChange={(e) => setReviewNote({ ...reviewNote, [app.id]: e.target.value })}\n                                  className=\"w-full max-w-md bg-surface-container border border-border rounded px-2 py-1 text-[10px] text-foreground focus:outline-none focus:border-accent\"\n                                />\n                              </div>\n\n                            </div>\n\n                            {/* Actions */}\n                            <div className=\"flex gap-2 shrink-0 self-end md:self-start\">\n                              <Button\n                                size=\"sm\"\n                                variant=\"outline\"\n                                className=\"text-[10px] font-bold text-success border-success/30 hover:bg-success/5 hover:border-success h-8\"\n                                onClick={() => handleAppealReview(app.id, 'approved')}\n                                disabled={submittingReview === app.id}\n                              >\n                                {submittingReview === app.id ? 'в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ®...' : 'в”ҳв•ӣв•Әв–‘в–ҲГ®в•Әв–’в•Әв”Ө в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў (в•ӘВәв•ӘВҝв•Әв•–в•ӘВәв”ҳГӨ в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§)'}\n                              </Button>\n                              <Button\n                                size=\"sm\"\n                                variant=\"outline\"\n                                className=\"text-[10px] font-bold text-critical border-critical/30 hover:bg-critical/5 hover:border-critical h-8\"\n                                onClick={() => handleAppealReview(app.id, 'rejected')}\n                                disabled={submittingReview === app.id}\n                              >\n                                {submittingReview === app.id ? 'в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ®...' : 'в•Әв–’в•ӘВ» в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў (в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§ в•ӘВҝв•ӘВәв”ҳГ©в–ҲГ® в•ӘВҝв”ҳГ в•ӘВәв”ҳГҘв•ӘВ»)'}\n                              </Button>\n                            </div>\n\n                          </div>\n                        ))}\n                      </div>\n                    )}\n                  </CardContent>\n                </Card>\n\n                {/* 3. Comparative department statistics (Calibration dashboard) */}\n                <Card className=\"border border-border bg-surface-container-lowest/70 shadow-sm\">\n                  <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest\">\n                    <CardTitle className=\"text-sm font-bold flex items-center gap-2\">\n                      <TrendingUp className=\"size-4 text-accent\" />\n                      в•ӘВ»в•ӘВәв•Әв”Өв•ӘВҝв”ҳГӘв•Әв–’в•ӘВ» в”ҢвҢҗв•ӘВәв”ҳГӨв–ҲГ®в•ӘВҝв•Әв–’в•ӘВәв•Әв”Ӯв–ҲГ®в”ҳГӘв”ҳГҘ: в”ҳГ в–ҲГ®в•ӘВәв”ҳГҘв”ҢВ»в–ҲГ®в”ҳГҘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВ¬в”ҳГјв”ҢвҢҗв–ҲГ®в”ҢвҢҗ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ» / в•Әв”Ӯв”ҳГ в•ӘВ¬\n                    </CardTitle>\n                    <CardDescription className=\"text-[10px]\">\n                      в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГӘв”ҢВ»в–ҲГ®в•Әв–’в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в•ӘВәв•ӘВ¬в–ҲГ®в”ҢвҢҗ в•ӘВәв•Әв–’в•Әв–“в•Әв”Өв–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ (в•Әв”Ӯв•ӘВ«в•ӘВ¬О“ГҮГ®в”ҢВ»в–ҲГ®в•Әв–’в–ҲГ®/в•ӘВ»в•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГӘв•ӘВ»в”ҳГӨв•ӘВҝв•ӘВәв•Әв–“в–ҲГ®в•Әв”Ө в•ӘВҝв–ҲГ®в•Әв”Ө в•ӘВәв•Әв–“ в•ӘВЎв•ӘВ» в•ӘВҝв–ҲГ®в”ҳГҘ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»в”ҳГ§в•ӘВә)\n                    </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"p-4 h-64 flex items-center justify-center\">\n                    {departmentStats.length === 0 ? (\n                      <div className=\"text-xs text-foreground-muted\">в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ®в”ҳГ  в”ҳГҘв”ҳГ в”ҳГӘв•ӘВ»в•ӘВәв•Әв–’ в”ҳГӘв•ӘВәв•ӘВЎв•ӘВ»в”ҳГ§в•ӘВә в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ»</div>\n                    ) : (\n                      <svg className=\"w-full h-full max-w-2xl\" viewBox=\"0 0 500 180\">\n                        {/* Grid lines */}\n                        {[0, 0.5, 1].map((ratio, i) => {\n                          const y = 20 + 130 * ratio\n                          const val = Math.round(150 * (1 - ratio))\n                          return (\n                            <g key={i} className=\"opacity-30\">\n                              <line x1=\"60\" y1={y} x2=\"480\" y2={y} stroke=\"var(--color-border)\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n                              <text x=\"50\" y={y + 4} fill=\"var(--color-foreground-muted)\" className=\"text-[9px]\" textAnchor=\"end\">\n                                {toFa(val)}\n                              </text>\n                            </g>\n                          )\n                        })}\n\n                        {/* Bar charts for each department */}\n                        {departmentStats.map((item, idx) => {\n                          const maxBarWidth = 46\n                          const chartWidth = 420\n                          const gap = (chartWidth - maxBarWidth * departmentStats.length) / (departmentStats.length + 1)\n                          const x = 60 + gap + (maxBarWidth + gap) * idx\n                          const barH = (item.avgScore / 150) * 130\n                          const y = 20 + 130 - barH\n\n                          return (\n                            <g key={idx} className=\"group/bar\">\n                              <rect\n                                x={x}\n                                y={y}\n                                width={maxBarWidth}\n                                height={barH}\n                                rx=\"4\"\n                                fill=\"var(--color-accent)\"\n                                fillOpacity=\"0.75\"\n                                className=\"transition-all duration-300 hover:fill-opacity-100 cursor-pointer\"\n                              />\n                              {/* Score text */}\n                              <text x={x + maxBarWidth / 2} y={y - 6} fill=\"var(--color-foreground)\" className=\"text-[9px] font-black\" textAnchor=\"middle\">\n                                {toFa(item.avgScore)}\n                              </text>\n                              {/* Department label */}\n                              <text x={x + maxBarWidth / 2} y=\"170\" fill=\"var(--color-foreground-muted)\" className=\"text-[9px] font-bold\" textAnchor=\"middle\">\n                                {item.name}\n                              </text>\n                            </g>\n                          )\n                        })}\n                      </svg>\n                    )}\n                  </CardContent>\n                </Card>\n\n              </div>\n            ) : (\n              <div className=\"text-center text-xs text-foreground-muted p-10\">в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬в–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».</div>\n            )}\n          </div>\n        )}\n\n      </main>\n\n      {/* ========================================================================= */}\n      {/* APPEAL REQUEST OVERLAY MODAL */}\n      {/* ========================================================================= */}\n      {appealModalOpen && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 animate-in fade-in duration-200\" dir=\"rtl\">\n          <Card className=\"w-full max-w-md border border-border bg-surface shadow-2xl animate-in zoom-in-95 duration-200\">\n            <CardHeader className=\"py-4 border-b border-border/40 bg-surface-container-lowest\">\n              <CardTitle className=\"text-sm font-bold flex items-center gap-2 text-critical\">\n                <AlertCircle className=\"size-4\" />\n                в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ® в•Әв–’в”ҳГӘв–ҲГ® в•Әв–’в”ҢвҢҗв”ҳГӘв•Әв–’в•ӘВ» в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»\n              </CardTitle>\n              <CardDescription className=\"text-[10px]\">\n                в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в•Әв”Өв”ҳГ в•ӘВә в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ в•ӘВә в•ӘВ»в•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВ¬в•ӘВәв•ӘВҝв”ҳГӨ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҳГ в”ҳГҘв•ӘВәв•ӘВҝв•Әв•Ј в•ӘВәв”ҳГҘв•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ©в•Әв–’в•ӘВәв•Әв–’ в”ҢВ»в•Әв–’в”ҳГјв•ӘВ¬в”ҳГ§ в”ҳГӘ в”ҳГ в”ҳГӘв•Әв–’в•ӘВ» в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝв•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГ©в•Әв–’в•ӘВәв•Әв–’ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢВ»в–ҲГ®в•Әв–’в•ӘВ».\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"p-4\">\n              <form onSubmit={handleAppealSubmit} className=\"space-y-4\">\n                \n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-bold text-foreground\">в•ӘВ»в”ҳГӨв•ӘВәв–ҲГ®в”ҳГӨв•ӘГ® в•Әв”Өв”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в”ҳГӘ в•ӘВ»в”ҳГјв•ӘВәв•Әв•Јв–ҲГ®в•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВә:</label>\n                  <textarea\n                    required\n                    value={appealReason}\n                    onChange={(e) => setAppealReason(e.target.value)}\n                    placeholder=\"в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬в•ӘГ® в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в–ҲГ®в•ӘВә в•Әв•Јв•ӘВ»в”ҳГ  в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ«в•Әв•–в•ӘВә в•ӘВҝв”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВҝв