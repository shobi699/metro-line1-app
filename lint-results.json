03', name: 'в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в”ҳГ©в”ҳГӨв”ҳГ§в”ҢвҢҗ', voltage: 748, current: 950, status: 'active', temperature: 39 },\n  { id: 'RECT-07', name: 'в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•ӘВЎв”ҳГ©в•ӘВәв”ҳГҘв–ҲГ®', voltage: 755, current: 1100, status: 'active', temperature: 45 },\n  { id: 'RECT-11', name: 'в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•ӘВ»в•Әв–’в”ҳГӘв•ӘВәв•Әв–“в”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГӨв•ӘВ¬', voltage: 742, current: 1400, status: 'active', temperature: 48 },\n  { id: 'RECT-15', name: 'в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ®', voltage: 749, current: 1550, status: 'active', temperature: 51 },\n  { id: 'RECT-21', name: 'в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•Әв”Өв”ҳГ§в•Әв–’ в•Әв–’в–ҲГ®', voltage: 758, current: 800, status: 'active', temperature: 38 },\n  { id: 'RECT-25', name: 'в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ', voltage: 760, current: 650, status: 'active', temperature: 35 },\n]\n\nconst INITIAL_TRACKS: SignalingTrack[] = [\n  { id: 'BLK-101', blockName: 'в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө - в”ҳГ©в–ҲГ®в•Әв•–в•Әв–’в–ҲГ®в”ҳГ§', status: 'occupied', switchState: 'straight', signalColor: 'red' },\n  { id: 'BLK-102', blockName: 'в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ©в–ҲГ®в•Әв•–в•Әв–’в–ҲГ®в”ҳГ§ - в•Әв•Ўв•ӘВ»в•Әв–’', status: 'clear', switchState: 'straight', signalColor: 'green' },\n  { id: 'BLK-203', blockName: 'в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ§в”ҳГ в•ӘВ¬ - в•ӘВЎв”ҳГ©в•ӘВәв”ҳГҘв–ҲГ®', status: 'warning', switchState: 'diverging', signalColor: 'yellow' },\n  { id: 'BLK-308', blockName: 'в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ§в”ҳГјв•ӘВ¬ в•ӘВ¬в–ҲГ®в•Әв–’ - в•Әв•–в•ӘВәв”ҳГӨв”ҳГ©в•ӘВәв”ҳГҘв–ҲГ®', status: 'clear', switchState: 'straight', signalColor: 'green' },\n  { id: 'BLK-412', blockName: 'в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ® - в”ҳв•ӣв•ӘВәв”ҳГҘв•Әв–“в•ӘВ»в”ҳГ§ в•ӘВ«в•Әв–’в•ӘВ»в•ӘВәв•ӘВ»', status: 'occupied', switchState: 'straight', signalColor: 'red' },\n  { id: 'BLK-502', blockName: 'в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•Әв•Јв”ҳГӨв–ҲГ® в•ӘГів•ӘВҝв•ӘВәв•ӘВ» - в•ӘВјв”ҳГӘв•ӘВәв”ҳГҘв”ҳГ в•Әв–’в•ӘВ» в”ҳГ©в•Әв•Ўв•ӘВәв•ӘВҝ', status: 'clear', switchState: 'straight', signalColor: 'green' },\n]\n\nconst INITIAL_LOGS: EventLog[] = [\n  { id: 'LOG-001', time: '01:45:12', source: 'в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө', message: 'в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в”ҳГӨв•ӘВЎв•Әв••в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•ӘВ»в•Әв–’в”ҳГӘв•ӘВәв•Әв–“в”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГӨв•ӘВ¬ (в–Ҳв•–в–Ҳв–’в–Ҳв–‘ в”ҳГӘв”ҳГӨв•ӘВ¬)', type: 'warning', operator: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’' },\n  { id: 'LOG-002', time: '01:40:05', source: 'в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ»', message: 'в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘ в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ§в”ҳГ в•ӘВ¬ - в•ӘВЎв”ҳГ©в•ӘВәв”ҳГҘв–ҲГ® в•ӘВҝв”ҳГ§ в•ӘВәв”ҳГҘв•ӘВЎв•Әв–’в•ӘВәв”ҳГјв–ҲГ®', type: 'info', operator: 'в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’ OCC' },\n  { id: 'LOG-003', time: '01:32:40', source: 'в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ®', message: 'в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ® в”ҳГ в”ҳГӘв”ҳГ©в•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳГјв•Әв–’в”ҢвҢҗв•ӘВәв”ҳГҘв•Әв”Ӯ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в–Ҳв”Өв–Ҳв”Өв–Ҳв–‘.в–Ҳв–’в–Ҳв–“в–Ҳв•Ў в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•Әв–’в–ҲГ®', type: 'warning', operator: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҳГҘв•Әв••в•ӘВәв•Әв–’в•ӘВ¬' },\n  { id: 'LOG-004', time: '01:15:00', source: 'в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө', message: 'в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв•Әв–’в”ҢвҢҗв•Әв–’в•ӘВ» в•ӘГів•Әв–“в”ҳГ в•ӘВәв–ҲГ®в•Әв”Өв–ҲГ® в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ в”ҳв•ӣв•Әв”Ӯ в•ӘВәв•Әв–“ в•ӘВәв”ҳГӘв•Әв–’в”ҳГ§в•ӘВәв”ҳГӨ', type: 'info', operator: 'в”ҳГ в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘ' },\n]\n\nexport default function InfrastructurePage() {\n  const [stations, setStations] = useState<RectifierStation[]>(INITIAL_STATIONS)\n  const [tracks, setTracks] = useState<SignalingTrack[]>(INITIAL_TRACKS)\n  const [logs, setLogs] = useState<EventLog[]>(INITIAL_LOGS)\n  const [activeTab, setActiveTab] = useState<'power' | 'signaling' | 'radio' | 'settings'>('power')\n\n  // в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВЎв•ӘВ» в•ӘГів•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв”ҳГ§ (в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘ в–Ҳв•–)\n  const [minVoltage, setMinVoltage] = useState(720)\n  const [maxVoltage, setMaxVoltage] = useState(780)\n  const [maxTemp, setMaxTemp] = useState(55)\n\n  // в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв•Әв–’в”ҳГ© в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  (Trip)\n  const [showTripDialog, setShowTripDialog] = useState(false)\n  const [selectedStationForTrip, setSelectedStationForTrip] = useState<RectifierStation | null>(null)\n  const [verificationCode, setVerificationCode] = useState('')\n  const [tripError, setTripError] = useState('')\n\n  // в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘ\n  const [radioChannels, setRadioChannels] = useState([\n    { name: 'в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ (CH 1)', frequency: '440.125 MHz', status: 'stable', load: '65%' },\n    { name: 'в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§в–ҲГ® (CH 2)', frequency: '442.250 MHz', status: 'stable', load: '32%' },\n    { name: 'в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в•ӘВ»в”ҳв•ӣв”ҳГӘ в”ҳГӘ в”ҳГ в•ӘВәв”ҳГҘв”ҳГӘв•Әв–’ (CH 3)', frequency: '445.500 MHz', status: 'stable', load: '18%' },\n    { name: 'в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в”ҳв•ӣв•Әв”Өв•ӘВ¬в–ҲГ®в•ӘВҝв•ӘВәв”ҳГҘ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® (CH 4)', frequency: '449.875 MHz', status: 'backup', load: '0%' },\n  ])\n\n  const handleToggleSwitch = (trackId: string) => {\n    setTracks((prev) =>\n      prev.map((t) => {\n        if (t.id === trackId) {\n          const nextState = t.switchState === 'straight' ? 'diverging' : 'straight'\n          const timeString = new Date().toLocaleTimeString('en-US', { hour12: false })\n          setLogs((prevLogs) => [\n            {\n              id: `LOG-${Date.now()}`,\n              time: timeString,\n              source: 'в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ»',\n              message: `в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘ ${t.blockName} в•ӘВҝв”ҳГ§ ${nextState === 'straight' ? 'в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ ' : 'в•ӘВәв”ҳГҘв•ӘВЎв•Әв–’в•ӘВәв”ҳГјв–ҲГ®'}`,\n              type: 'info',\n              operator: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n            },\n            ...prevLogs,\n          ])\n          return { ...t, switchState: nextState }\n        }\n        return t\n      }),\n    )\n  }\n\n  const handleToggleSignalColor = (trackId: string) => {\n    setTracks((prev) =>\n      prev.map((t) => {\n        if (t.id === trackId) {\n          const nextColor = t.signalColor === 'green' ? 'yellow' : t.signalColor === 'yellow' ? 'red' : 'green'\n          const nextStatus = nextColor === 'green' ? 'clear' : nextColor === 'yellow' ? 'warning' : 'occupied'\n          const timeString = new Date().toLocaleTimeString('en-US', { hour12: false })\n          setLogs((prevLogs) => [\n            {\n              id: `LOG-${Date.now()}`,\n              time: timeString,\n              source: 'в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ»',\n              message: `в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҢГҘв•Әв–’в•ӘВәв•Әв•‘ в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨ ${t.blockName} в•ӘВҝв”ҳГ§ в•Әв–’в”ҳГҘв”ҢВ» ${nextColor === 'green' ? 'в•Әв”Ӯв•ӘВҝв•Әв–“' : nextColor === 'yellow' ? 'в•Әв–“в•Әв–’в•ӘВ»' : 'в”ҳГ©в•Әв–’в”ҳГ в•Әв–“'}`,\n              type: 'warning',\n              operator: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n            },\n            ...prevLogs,\n          ])\n\n          return { ...t, signalColor: nextColor, status: nextStatus }\n        }\n        return t\n      }),\n    )\n  }\n\n  const handleInitiateTrip = (station: RectifierStation) => {\n    setSelectedStationForTrip(station)\n    setShowTripDialog(true)\n    setVerificationCode('')\n    setTripError('')\n  }\n\n  const handleConfirmTrip = () => {\n    if (verificationCode !== '750') {\n      setTripError('в”ҢвҢҗв•ӘВ» в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬в–ҲГ® в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГ§в”ҳГӘв–ҲГ®в•ӘВ¬ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв”Өв•ӘВ¬в•ӘВҝв•ӘВәв”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. (в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВә: в•Әв•Јв•ӘВ»в•ӘВ» в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  в–ҲГ®в•Әв•Јв”ҳГҘв–ҲГ® в–Ҳв•–в–Ҳв•Ўв–Ҳв–‘ в•Әв–’в•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»)')\n      return\n    }\n\n    if (selectedStationForTrip) {\n      setStations((prev) =>\n        prev.map((s) => (s.id === selectedStationForTrip.id ? { ...s, status: 'inactive', voltage: 0, current: 0 } : s)),\n      )\n\n      const timeString = new Date().toLocaleTimeString('en-US', { hour12: false })\n      setLogs((prevLogs) => [\n        {\n          id: `LOG-${Date.now()}`,\n          time: timeString,\n          source: 'в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө',\n          message: `!!! в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв•Әв–’в”ҳГ© (TRIP) в•ӘВ»в•Әв–’ ${selectedStationForTrip.name} в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ» !!!`,\n          type: 'critical',\n          operator: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n        },\n        ...prevLogs,\n      ],\n      )\n\n      setShowTripDialog(false)\n      setSelectedStationForTrip(null)\n    }\n  }\n\n  const handleRestorePower = (stationId: string) => {\n    setStations((prev) =>\n      prev.map((s) => (s.id === stationId ? { ...s, status: 'active', voltage: 750, current: 600 } : s)),\n    )\n\n    const timeString = new Date().toLocaleTimeString('en-US', { hour12: false })\n    setLogs((prevLogs) => [\n      {\n        id: `LOG-${Date.now()}`,\n        time: timeString,\n        source: 'в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө',\n        message: `в•ӘВҝв•Әв–’в”ҳГ©О“ГҮГ®в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в”ҳГ в•ӘВјв•ӘВ»в•ӘВ» в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  в•ӘВ»в•Әв–’ ${stations.find((s) => s.id === stationId)?.name}`,\n        type: 'info',\n        operator: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n      },\n      ...prevLogs,\n    ])\n  }\n\n  const handleSaveSettings = () => {\n    const timeString = new Date().toLocaleTimeString('en-US', { hour12: false })\n    setLogs((prevLogs) => [\n      {\n        id: `LOG-${Date.now()}`,\n        time: timeString,\n        source: 'в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө',\n        message: `в•ӘГів•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬: в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в”ҳГ в•ӘВјв•ӘВәв•Әв–“ (${minVoltage}V - ${maxVoltage}V)в•ӘГ® в•ӘВ»в”ҳГ в•ӘВәв–ҲГ® в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ (${maxTemp}в”¬в–‘C)`,\n        type: 'info',\n        operator: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n      },\n      ...prevLogs,\n    ])\n  }\n\n  return (\n    <div className=\"flex min-h-screen flex-col\" dir=\"rtl\">\n      <TopAppBar\n        title=\"в•Әв”Ӯв”ҳГҘв•Әв”Ӯв”ҳГӘв•Әв–’в”ҳГ§в•ӘВәв•ӘГ® в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө в•Әв–’в–ҲГ®в”ҳГӨв–ҲГ® в”ҳГӘ в•Әв•Јв”ҳГӨв•ӘВәв•ӘВӘв”ҳГ  в•ӘВ«в•Әв•– в–Ҳв–’\"\n        subtitle=\"в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®в•ӘВ¬в”ҳГӘв•Әв–’в–ҲГ®в”ҳГҘв”ҢВ» в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ»в•ӘГ® в•ӘВәв–ҲГ®в”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨв•ӘВәв”ҢвҢҗв–ҲГ®в”ҳГҘв”ҢВ»в•ӘГ® в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ \"\n      />\n\n      <main className=\"flex-1 p-4 pt-16 md:p-6 space-y-6\">\n        {/* Alerts / Live Status Badges */}\n        <div className=\"grid grid-cols-1 gap-4 md:grid-cols-4\">\n          {/* Traction Power */}\n          <Card className=\"relative overflow-hidden bg-surface-container-low/30 backdrop-blur-md border-border-subtle hover:border-amber-500/30 transition-colors duration-200\">\n            <div className=\"absolute top-0 right-0 h-[2px] w-12 bg-amber-500\" />\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в•ӘВҝв•Әв–’в”ҳГ© в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  (Traction)</p>\n                <h3 className=\"text-sm font-semibold mt-1 text-foreground\">\n                  {toFa(stations.filter((s) => s.status === 'active').length)} в•ӘВәв•Әв–“ {toFa(stations.length)} в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ\n                </h3>\n              </div>\n              <div className=\"bg-amber-500/10 p-2.5 rounded-md text-amber-500 border border-amber-500/20\">\n                <Zap className=\"size-4 animate-pulse\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Interlocking */}\n          <Card className=\"relative overflow-hidden bg-surface-container-low/30 backdrop-blur-md border-border-subtle hover:border-success/30 transition-colors duration-200\">\n            <div className=\"absolute top-0 right-0 h-[2px] w-12 bg-success\" />\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВәв–ҲГ®в”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨв•ӘВәв”ҢвҢҗв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГ в•Әв”Ӯв–ҲГ®в•Әв–’</p>\n                <h3 className=\"text-sm font-semibold mt-1 text-success\">в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘ в”ҳГӘ в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•ӘВ«в•Әв•–в•ӘВә</h3>\n              </div>\n              <div className=\"bg-success/10 p-2.5 rounded-md text-success border border-success/20\">\n                <GitBranch className=\"size-4\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Radio Frequency */}\n          <Card className=\"relative overflow-hidden bg-surface-container-low/30 backdrop-blur-md border-border-subtle hover:border-info/30 transition-colors duration-200\">\n            <div className=\"absolute top-0 right-0 h-[2px] w-12 bg-info\" />\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в”ҳГјв•Әв–’в”ҢвҢҗв•ӘВәв”ҳГҘв•Әв”Ӯ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ</p>\n                <h3 className=\"text-sm font-semibold mt-1 text-info font-mono\">{toFa('в–Ҳв”Өв–Ҳв”Өв–Ҳв–‘.в–Ҳв–’в–Ҳв–“в–Ҳв•Ў')} в”ҳГ в”ҢВ»в•ӘВәв”ҳГ§в•Әв–’в•ӘВ¬в•Әв–“</h3>\n              </div>\n              <div className=\"bg-info/10 p-2.5 rounded-md text-info border border-info/20\">\n                <Radio className=\"size-4\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          {/* Dispatching */}\n          <Card className=\"relative overflow-hidden bg-surface-container-low/30 backdrop-blur-md border-border-subtle hover:border-accent/30 transition-colors duration-200\">\n            <div className=\"absolute top-0 right-0 h-[2px] w-12 bg-accent\" />\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“в–ҲГ®</p>\n                <h3 className=\"text-sm font-semibold mt-1 text-success\">в”ҳГ в•ӘВ¬в•Әв•Ўв”ҳГӨ (в•ӘГів”ҳГҘв”ҳГӨв•ӘВәв–ҲГ®в”ҳГҘ)</h3>\n              </div>\n              <div className=\"bg-success/10 p-2.5 rounded-md text-success border border-success/20\">\n                <Database className=\"size-4\" />\n              </div>\n            </CardContent>\n          </Card>\n        </div>\n\n        {/* Tab Controls */}\n        <div className=\"flex border-b border-border-subtle gap-1 overflow-x-auto pb-1 bg-surface-container-low/20 p-1 rounded-lg\">\n          <Button\n            variant=\"ghost\"\n            className={`rounded-md h-9 shrink-0 gap-1.5 transition-colors duration-150 ${\n              activeTab === 'power'\n                ? 'bg-accent/10 text-accent border border-accent/20 font-medium'\n                : 'text-foreground-muted hover:text-foreground hover:bg-surface-hover'\n            }`}\n            onClick={() => setActiveTab('power')}\n          >\n            <Zap className=\"size-4\" />\n            <span>в”ҳв•ӣв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв•Әв–’в”ҳГ© в”ҳГӘ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  ({toFa(750)} в”ҳГӘв”ҳГӨв•ӘВ¬)</span>\n          </Button>\n\n          <Button\n            variant=\"ghost\"\n            className={`rounded-md h-9 shrink-0 gap-1.5 transition-colors duration-150 ${\n              activeTab === 'signaling'\n                ? 'bg-accent/10 text-accent border border-accent/20 font-medium'\n                : 'text-foreground-muted hover:text-foreground hover:bg-surface-hover'\n            }`}\n            onClick={() => setActiveTab('signaling')}\n          >\n            <GitBranch className=\"size-4\" />\n            <span>в•Әв•Јв”ҳГӨв•ӘВәв•ӘВӘв”ҳГ в•ӘГ® в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•Әв”Ӯв”ҳГҘв•Әв”Ӯв”ҳГӘв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ</span>\n          </Button>\n\n          <Button\n            variant=\"ghost\"\n            className={`rounded-md h-9 shrink-0 gap-1.5 transition-colors duration-150 ${\n              activeTab === 'radio'\n                ? 'bg-accent/10 text-accent border border-accent/20 font-medium'\n                : 'text-foreground-muted hover:text-foreground hover:bg-surface-hover'\n            }`}\n            onClick={() => setActiveTab('radio')}\n          >\n            <Radio className=\"size-4\" />\n            <span>в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®в”ҳГ  в”ҳГӘ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ®</span>\n          </Button>\n\n          <Button\n            variant=\"ghost\"\n            className={`rounded-md h-9 shrink-0 gap-1.5 transition-colors duration-150 ${\n              activeTab === 'settings'\n                ? 'bg-accent/10 text-accent border border-accent/20 font-medium'\n                : 'text-foreground-muted hover:text-foreground hover:bg-surface-hover'\n            }`}\n            onClick={() => setActiveTab('settings')}\n          >\n            <Settings className=\"size-4\" />\n            <span>в”ҳв•ӣв–ҲГ®в”ҢвҢҗв•Әв–’в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘГів•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’в”ҳГ§в•ӘВә</span>\n          </Button>\n        </div>\n\n        {/* Tab Contents */}\n        {activeTab === 'power' && (\n          <div className=\"space-y-6\">\n            {/* Rectifier Stations Table */}\n            <Card className=\"border-border-subtle bg-surface-container-low/30 backdrop-blur-md\">\n              <CardHeader className=\"flex flex-row items-center justify-between pb-3 border-b border-border-subtle\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Zap className=\"size-4 text-amber-500\" />\n                  в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®в•ӘВ¬в”ҳГӘв•Әв–’в–ҲГ®в”ҳГҘв”ҢВ» в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘ в•Әв–’в–ҲГ®в”ҳГӨв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ ({toFa(750)} в”ҳГӘв”ҳГӨв•ӘВ¬ в•ӘВ»в–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®)\n                </CardTitle>\n                <div className=\"flex items-center gap-2\">\n                  <Button variant=\"outline\" size=\"sm\" className=\"h-8 gap-1 rounded-md\" onClick={() => setStations(INITIAL_STATIONS)}>\n                    <RefreshCw className=\"size-3.5\" />\n                    <span>в•Әв–’в–ҲГ®в•Әв”Ӯв•ӘВ¬ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§</span>\n                  </Button>\n                </div>\n              </CardHeader>\n              <CardContent className=\"p-0\">\n                <div className=\"overflow-x-auto\">\n                  <table className=\"w-full text-right border-collapse\">\n                    <thead>\n                      <tr className=\"border-b border-border-subtle bg-surface-container/50 text-foreground-muted text-xs font-semibold\">\n                        <th className=\"p-3\">в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬</th>\n                        <th className=\"p-3\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’</th>\n                        <th className=\"p-3\">в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  (V DC)</th>\n                        <th className=\"p-3\">в•ӘВјв•Әв–’в–ҲГ®в•ӘВәв”ҳГҘ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ® (A)</th>\n                        <th className=\"p-3\">в•ӘВ»в”ҳГ в•ӘВәв–ҲГ® в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“в•ӘВәв•ӘВ¬</th>\n                        <th className=\"p-3\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ</th>\n                        <th className=\"p-3 text-left\">в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬ в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨв–ҲГ®</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-border-subtle text-sm\">\n                      {stations.map((s) => {\n                        const isVoltageOut = s.status === 'active' && (s.voltage < minVoltage || s.voltage > maxVoltage)\n                        const isTempOut = s.status === 'active' && s.temperature > maxTemp\n\n                        return (\n                          <tr key={s.id} className=\"hover:bg-surface-hover/50 transition-colors duration-150\">\n                            <td className=\"p-3 font-mono text-xs text-foreground-muted\">{s.id}</td>\n                            <td className=\"p-3 font-medium\">{s.name}</td>\n                            <td className={`p-3 font-mono ${isVoltageOut ? 'text-critical font-semibold animate-pulse' : ''}`}>\n                              <span className=\"flex items-center gap-1.5\">\n                                {toFa(s.voltage)} в”ҳГӘв”ҳГӨв•ӘВ¬\n                                {isVoltageOut && (\n                                  <Badge className=\"bg-critical/10 text-critical border border-critical/20 px-1 py-0 rounded-sm text-[10px]\">\n                                    <AlertTriangle className=\"size-2.5 me-0.5 inline\" />\n                                    в”ҳГҘв•ӘВәв”ҳГ в•Әв•Јв•ӘВ¬в•ӘВҝв•Әв–’\n                                  </Badge>\n                                )}\n                              </span>\n                            </td>\n                            <td className=\"p-3 font-mono\">{toFa(s.current)} в•ӘГів”ҳГ в”ҳв•ӣв•Әв–’</td>\n                            <td className={`p-3 font-mono ${isTempOut ? 'text-critical font-semibold animate-pulse' : ''}`}>\n                              <span className=\"flex items-center gap-1.5\">\n                                {toFa(s.temperature)}в”¬в–‘C\n                                {isTempOut && (\n                                  <Badge className=\"bg-critical/10 text-critical border border-critical/20 px-1 py-0 rounded-sm text-[10px]\">\n                                    в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®\n                                  </Badge>\n                                )}\n                              </span>\n                            </td>\n                            <td className=\"p-3\">\n                              <Badge\n                                variant=\"outline\"\n                                className={\n                                  s.status === 'active'\n                                    ? 'bg-success/10 text-success border-success/20 rounded-md font-medium'\n                                    : s.status === 'inactive'\n                                    ? 'bg-critical/10 text-critical border-critical/20 rounded-md font-medium animate-pulse'\n                                    : 'bg-warning/10 text-warning border-warning/20 rounded-md font-medium'\n                                }\n                              >\n                                {s.status === 'active' ? 'в•ӘВҝв•Әв–’в”ҳГ©О“ГҮГ®в•ӘВ»в•ӘВәв•Әв–’' : s.status === 'inactive' ? 'в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®' : 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГҘв•Әв”Ӯв”ҳГӘв•Әв–’'}\n                              </Badge>\n                            </td>\n                            <td className=\"p-3 text-left\">\n                              {s.status === 'active' ? (\n                                <Button\n                                  size=\"sm\"\n                                  variant=\"destructive\"\n                                  className=\"h-8 gap-1 rounded-md text-xs\"\n                                  onClick={() => handleInitiateTrip(s)}\n                                >\n                                  <Power className=\"size-3.5\" />\n                                  <span>в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв•Әв–’в”ҳГ©</span>\n                                </Button>\n                              ) : (\n                                <Button\n                                  size=\"sm\"\n                                  variant=\"outline\"\n                                  className=\"h-8 border-success/30 hover:bg-success/10 text-success hover:text-success gap-1 rounded-md text-xs\"\n                                  onClick={() => handleRestorePower(s.id)}\n                                >\n                                  <Play className=\"size-3.5\" />\n                                  <span>в”ҳГӘв•Әв•Ўв”ҳГӨ в”ҳГ в•ӘВјв•ӘВ»в•ӘВ» в•Әв–’в–ҲГ®в”ҳГӨ</span>\n                                </Button>\n                              )}\n                            </td>\n                          </tr>\n                        )\n                      })}\n                    </tbody>\n                  </table>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        )}\n\n        {activeTab === 'signaling' && (\n          <div className=\"space-y-6\">\n            <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-3\">\n              {/* Signaling Track Blocks List */}\n              <Card className=\"border-border-subtle bg-surface-container-low/30 backdrop-blur-md lg:col-span-2\">\n                <CardHeader className=\"border-b border-border-subtle pb-3\">\n                  <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                    <GitBranch className=\"size-4 text-accent\" />\n                    в•Әв”Ӯв”ҳГҘв•Әв”Ӯв”ҳГӘв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ» в•ӘВ«в•Әв•– в–Ҳв–’\n                  </CardTitle>\n                </CardHeader>\n                <CardContent className=\"p-0\">\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-right border-collapse\">\n                      <thead>\n                        <tr className=\"border-b border-border-subtle bg-surface-container/50 text-foreground-muted text-xs font-semibold\">\n                          <th className=\"p-3\">в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГ в•Әв”Ӯв–ҲГ®в•Әв–’</th>\n                          <th className=\"p-3\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ»</th>\n                          <th className=\"p-3\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘ</th>\n                          <th className=\"p-3\">в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨ в”ҢГҘв•Әв–’в•ӘВәв•Әв•‘</th>\n                          <th className=\"p-3 text-left\">в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘ</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-border-subtle text-sm\">\n                        {tracks.map((t) => (\n                          <tr key={t.id} className=\"hover:bg-surface-hover/50 transition-colors duration-150\">\n                            <td className=\"p-3 font-semibold\">{t.blockName}</td>\n                            <td className=\"p-3\">\n                              <Badge\n                                variant=\"outline\"\n                                className={\n                                  t.status === 'clear'\n                                    ? 'bg-success/10 text-success border-success/20 rounded-md font-medium'\n                                    : t.status === 'occupied'\n                                    ? 'bg-critical/10 text-critical border-critical/20 rounded-md font-medium animate-pulse'\n                                    : 'bg-warning/10 text-warning border-warning/20 rounded-md font-medium'\n                                }\n                              >\n                                {t.status === 'clear' ? 'в•ӘГів•Әв–“в•ӘВәв•ӘВ» (в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’)' : t.status === 'occupied' ? 'в•ӘВәв•Әв”Өв•Әв•‘в•ӘВәв”ҳГӨ (в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’)' : 'в•ӘВәв•ӘВЎв•ӘВ¬в–ҲГ®в•ӘВәв•Әв•–'}\n                              </Badge>\n                            </td>\n                            <td className=\"p-3\">\n                              <span className=\"font-mono text-xs text-foreground-muted\">\n                                {t.switchState === 'straight' ? 'в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ  (в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘ в”ҳГ©в”ҳГјв”ҳГӨ)' : 'в•ӘВәв”ҳГҘв•ӘВЎв•Әв–’в•ӘВәв”ҳГјв–ҲГ® (в•Әв–’в•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҢВ»в•Әв–’в•ӘВ»)'}\n                              </span>\n                            </td>\n                            <td className=\"p-3\">\n                              <div className=\"flex items-center gap-2\">\n                                <span\n                                  className={`size-2.5 rounded-full transition-all duration-300 ${\n                                    t.signalColor === 'green'\n                                      ? 'bg-success shadow-[0_0_10px_rgba(16,185,129,0.7)] animate-pulse'\n                                      : t.signalColor === 'yellow'\n                                      ? 'bg-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.7)]'\n                                      : 'bg-critical shadow-[0_0_12px_rgba(239,68,68,0.9)] animate-pulse'\n                                  }`}\n                                />\n                                <span className=\"text-xs font-medium\">\n                                  {t.signalColor === 'green' ? 'в•Әв”Ӯв•ӘВҝв•Әв–“ (в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬)' : t.signalColor === 'yellow' ? 'в•Әв–“в•Әв–’в•ӘВ» (в•ӘВәв•ӘВЎв•ӘВ¬в–ҲГ®в•ӘВәв•Әв•–)' : 'в”ҳГ©в•Әв–’в”ҳГ в•Әв–“ (в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГј)'}\n                                </span>\n                              </div>\n                            </td>\n                            <td className=\"p-3 text-left space-x-1 space-x-reverse\">\n                              <Button\n                                size=\"sm\"\n                                variant=\"outline\"\n                                className=\"h-8 text-xs rounded-md\"\n                                onClick={() => handleToggleSwitch(t.id)}\n                              >\n                                в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘ\n                              </Button>\n                              <Button\n                                size=\"sm\"\n                                variant=\"outline\"\n                                className=\"h-8 text-xs rounded-md\"\n                                onClick={() => handleToggleSignalColor(t.id)}\n                              >\n                                в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘ в”ҢГҘв•Әв–’в•ӘВәв•Әв•‘\n                              </Button>\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                </CardContent>\n              </Card>\n\n              {/* Graphic interlocking mock panel */}\n              <Card className=\"border-border-subtle bg-surface-container-low/30 backdrop-blur-md\">\n                <CardHeader className=\"border-b border-border-subtle pb-3\">\n                  <CardTitle className=\"text-sm font-semibold\">в”ҳГҘв”ҳГ в•ӘВәв–ҲГ® в”ҢВ»в•Әв–’в•ӘВәв”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ® в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВә (в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“)</CardTitle>\n                </CardHeader>\n                <CardContent className=\"pt-4 flex flex-col items-center justify-center space-y-6\">\n                  <div className=\"w-full p-4 border border-border-subtle rounded-lg bg-background-subtle/50 space-y-4 relative overflow-hidden\">\n                    <div className=\"absolute top-0 right-0 h-[2px] w-8 bg-accent\" />\n                    <div className=\"flex items-center justify-between text-xs text-foreground-muted\">\n                      <span>в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө</span>\n                      <span>в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘ {toFa(3)}</span>\n                      <span>в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•Әв•Ўв•ӘВ»в•Әв–’</span>\n                    </div>\n\n                    {/* Simple Track SVG representation */}\n                    <svg viewBox=\"0 0 300 80\" className=\"w-full h-auto text-foreground stroke-current\">\n                      {/* Main track line */}\n                      <path d=\"M 10 40 L 290 40\" strokeWidth=\"3\" className=\"stroke-neutral-700 dark:stroke-neutral-800\" />\n                      \n                      {/* Active green path segments */}\n                      <path d=\"M 10 40 L 120 40\" strokeWidth=\"3\" className=\"stroke-success/80 shadow-[0_0_8px_rgba(16,185,129,0.4)]\" />\n                      <path d=\"M 120 40 L 180 40\" strokeWidth=\"3\" className=\"stroke-critical/80 shadow-[0_0_8px_rgba(239,68,68,0.4)] animate-pulse\" />\n                      <path d=\"M 180 40 L 290 40\" strokeWidth=\"3\" className=\"stroke-success/80 shadow-[0_0_8px_rgba(16,185,129,0.4)]\" />\n\n                      {/* Switch line */}\n                      <path d=\"M 150 40 L 230 15\" strokeWidth=\"2.5\" className=\"stroke-dashed stroke-amber-500/70\" />\n\n                      {/* Station indicators */}\n                      <circle cx=\"30\" cy=\"40\" r=\"5\" className=\"fill-surface stroke-success\" strokeWidth=\"2\" />\n                      <circle cx=\"270\" cy=\"40\" r=\"5\" className=\"fill-surface stroke-critical\" strokeWidth=\"2\" />\n\n                      {/* Switch junction */}\n                      <polygon points=\"146,36 154,36 150,44\" className=\"fill-amber-500 animate-pulse\" />\n                    </svg>\n\n                    <div className=\"text-xs text-foreground-muted leading-relaxed\">\n                      вүЎЖ’ГҶГӯ в•Әв”Ӯв”ҳГӘв•Әв–“в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв•ӘВә в•Әв–’в”ҳГҘв”ҢВ» <span className=\"text-amber-500 font-semibold\">в”ҳГҘв•ӘВәв•Әв–’в”ҳГҘв•ӘВјв–ҲГ®</span> в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘО“ГҮГ®в•ӘВ»в”ҳГ§в”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГ в”ҳГӘв”ҳГ©в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГјв•Әв–’в•Әв•Јв–ҲГ® в”ҳГ§в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ». в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҝв•ӘВә в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ <span className=\"text-critical font-semibold\">в”ҳГ©в•Әв–’в”ҳГ в•Әв–“</span> в”ҳГ в•ӘВәв”ҳГҘв•Әв•Ј в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв”ҳГ§в•Әв–“ в•ӘВҝв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  ATC в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в”ҳГҘв•ӘВ» в•Әв”Өв•ӘВ».\n                    </div>\n                  </div>\n\n                  <div className=\"w-full p-4 border border-border-subtle rounded-lg bg-background-subtle/50 text-center\">\n                    <h5 className=\"text-xs font-semibold text-foreground-muted mb-2\">в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ ATC</h5>\n                    <div className=\"flex items-center justify-center gap-2\">\n                      <Badge className=\"bg-success/10 text-success border border-success/20 rounded-md font-medium\">в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҢвҢҗв•ӘВәв”ҳГ в”ҳв•ӣв–ҲГ®в”ҳГӘв•ӘВ¬в•Әв–’в–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ</Badge>\n                      <Badge className=\"bg-surface-container-highest text-foreground-muted border border-border rounded-md font-medium\">в•ӘВЎв•ӘВәв”ҳГӨв•ӘВ¬ в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ® в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ</Badge>\n                    </div>\n                  </div>\n                </CardContent>\n              </Card>\n            </div>\n          </div>\n        )}\n\n        {activeTab === 'radio' && (\n          <div className=\"space-y-6\">\n            <Card className=\"border-border-subtle bg-surface-container-low/30 backdrop-blur-md\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Radio className=\"size-4 text-info\" />\n                  в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГјв•Әв–’в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ® в•ӘВәв•ӘВ«в•ӘВ¬в•Әв•Ўв•ӘВәв•Әв•Ўв–ҲГ® в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ«в•Әв•– в–Ҳв–’\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"p-0\">\n                <div className=\"grid grid-cols-1 divide-y divide-border-subtle md:grid-cols-2 md:divide-y-0 md:gap-4 md:p-4\">\n                  {radioChannels.map((ch, idx) => (\n                    <div key={idx} className=\"flex items-center justify-between p-4 md:border md:rounded-lg border-border-subtle bg-background-subtle/40 backdrop-blur-sm hover:border-info/30 transition-all duration-200\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"rounded-md bg-info/10 p-2.5 text-info border border-info/20 relative\">\n                          <Radio className=\"size-4\" />\n                          <span className=\"absolute -top-1 -left-1 flex h-2 w-2\">\n                            <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-info opacity-75\"></span>\n                            <span className=\"relative inline-flex rounded-full h-2 w-2 bg-info\"></span>\n                          </span>\n                        </div>\n                        <div>\n                          <h4 className=\"text-sm font-semibold\">{ch.name}</h4>\n                          <p className=\"text-xs text-foreground-muted font-mono mt-0.5\">{toFa(ch.frequency)}</p>\n                        </div>\n                      </div>\n                      <div className=\"text-left flex flex-col items-end\">\n                        <Badge\n                          variant=\"outline\"\n                          className={\n                            ch.status === 'stable'\n                              ? 'bg-success/10 text-success border-success/20 rounded-md font-medium'\n                              : 'bg-info/10 text-info border-info/20 rounded-md font-medium'\n                          }\n                        >\n                          {ch.status === 'stable' ? 'в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨ в•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®' : 'в•Әв–’в•Әв–“в•Әв–’в”ҳГӘ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®'}\n                        </Badge>\n                        <p className=\"text-[10px] text-foreground-muted mt-1.5 font-mono\">\n                          в•ӘВҝв•ӘВәв•Әв–’ в•ӘВ¬в•Әв–’в•ӘВәв”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ®: {toFa(ch.load)}\n                        </p>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        )}\n\n        {activeTab === 'settings' && (\n          <div className=\"space-y-6\">\n            <Card className=\"border-border-subtle bg-surface-container-low/30 backdrop-blur-md max-w-2xl\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Settings className=\"size-4 text-accent\" />\n                  в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ» в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в”ҳГӘ в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•ӘВ¬в”ҳГӘв”ҳГ в•ӘВәв•ӘВ¬в–ҲГ®в”ҢвҢҗ\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-foreground-muted\">в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  (в”ҳГӘв”ҳГӨв•ӘВ¬ в•ӘВ»в–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®)</label>\n                  <input\n                    type=\"number\"\n                    value={minVoltage}\n                    onChange={(e) => setMinVoltage(Number(e.target.value))}\n                    className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-start text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                  />\n                  <p className=\"text-[10px] text-foreground-muted\">в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  в”ҳв•ӣв•ӘВәв–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВЎв•ӘВ» в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».</p>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-foreground-muted\">в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  (в”ҳГӘв”ҳГӨв•ӘВ¬ в•ӘВ»в–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®)</label>\n                  <input\n                    type=\"number\"\n                    value={maxVoltage}\n                    onChange={(e) => setMaxVoltage(Number(e.target.value))}\n                    className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-start text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-xs font-semibold text-foreground-muted\">в•ӘВ»в”ҳГ в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“в•ӘВәв•ӘВ¬ в•Әв–’в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГјв•ӘВәв–ҲГ®в•Әв–’ (в”¬в–‘C)</label>\n                  <input\n                    type=\"number\"\n                    value={maxTemp}\n                    onChange={(e) => setMaxTemp(Number(e.target.value))}\n                    className=\"h-9 w-full rounded-lg border border-border bg-surface px-3 text-sm text-start text-foreground placeholder:text-foreground-muted focus:outline-none focus:ring-1 focus:ring-ring transition-colors duration-150\"\n                  />\n                  <p className=\"text-[10px] text-foreground-muted\">в•ӘВ»в”ҳГ в•ӘВәв–ҲГ® в•ӘВҝв–ҲГ®в•Әв”Ө в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в•ӘВҝв•ӘВәв•Әв•Јв•ӘВҪ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘ в•ӘВ¬в”ҳГ§в”ҳГӘв–ҲГ®в”ҳГ§ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».</p>\n                </div>\n\n                <div className=\"flex justify-end pt-2\">\n                  <Button size=\"sm\" className=\"rounded-md h-9 text-xs\" onClick={handleSaveSettings}>\n                    в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳв•ӣв–ҲГ®в”ҢвҢҗв•Әв–’в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’в”ҳГ§в•ӘВә\n                  </Button>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        )}\n\n        {/* Live Logs Table */}\n        <Card className=\"border-border-subtle bg-surface-container-low/30 backdrop-blur-md\">\n          <CardHeader className=\"flex flex-row items-center justify-between pb-3 border-b border-border-subtle\">\n            <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n              <ShieldAlert className=\"size-4 text-critical\" />\n              в”ҳГӘв”ҳГ©в•ӘВәв–ҲГ®в•Әв•Ј в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГӘ в”ҳГӨв•ӘВәв”ҢВ» в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в•Әв•Јв”ҳГӨв•ӘВәв•ӘВӘв”ҳГ  в”ҳГӘ в•ӘВҝв•Әв–’в”ҳГ© в”ҢвҢҗв•Әв”Өв•Әв”Ө (RTL)\n            </CardTitle>\n            <Button\n              variant=\"outline\"\n              size=\"sm\"\n              className=\"h-8 rounded-md gap-1\"\n              onClick={() => {\n                const timeString = new Date().toLocaleTimeString('en-US', { hour12: false })\n                setLogs((prev) => [\n                  {\n                    id: `LOG-${Date.now()}`,\n                    time: timeString,\n                    source: 'в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ®',\n                    message: 'в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬в–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§ в•Әв–’в•ӘВәв•ӘВ»в–ҲГ®в”ҳГӘв–ҲГ®в–ҲГ® в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ» в•ӘВ«в•Әв•– в–Ҳв–’ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в•Әв”Өв•ӘВ».',\n                    type: 'info',\n                    operator: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’',\n                  },\n                  ...prev,\n                ])\n              }}\n            >\n              <RefreshCw className=\"size-3\" />\n              <span>в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ  в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§</span>\n            </Button>\n          </CardHeader>\n          <CardContent className=\"p-0\">\n            <div className=\"overflow-x-auto\">\n              <table className=\"w-full text-right border-collapse\">\n                <thead>\n                  <tr className=\"border-b border-border-subtle bg-surface-container/50 text-foreground-muted text-xs font-semibold\">\n                    <th className=\"p-3 w-28\">в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬</th>\n                    <th className=\"p-3 w-32\">в”ҳГ в”ҳГҘв•ӘВҝв•Әв•Ј в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»</th>\n                    <th className=\"p-3\">в•Әв”Өв•Әв–’в•ӘВЎ в”ҳГӘв•ӘВәв”ҳГ©в•Әв•Јв”ҳГ§ в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ»</th>\n                    <th className=\"p-3 w-28\">в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®</th>\n                    <th className=\"p-3 w-40\">в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨО“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-border-subtle text-sm\">\n                  {logs.map((log) => {\n                    const isCritical = log.type === 'critical'\n                    return (\n                      <tr\n                        key={log.id}\n                        className={`transition-colors duration-150 ${\n                          isCritical\n                            ? 'bg-critical/5 hover:bg-critical/10 text-critical border-y border-critical/20'\n                            : 'hover:bg-surface-hover/50'\n                        }`}\n                      >\n                        <td className=\"p-3 font-mono text-xs text-foreground-muted\">{toFa(log.time)}</td>\n                        <td className=\"p-3\">{log.source}</td>\n                        <td className={`p-3 font-medium ${isCritical ? 'text-critical' : ''}`}>\n                          {log.message.replace(/\\b\\d+\\b/g, (m) => toFa(m))}\n                        </td>\n                        <td className=\"p-3\">\n                          <Badge\n                            variant=\"outline\"\n                            className={\n                              log.type === 'info'\n                                ? 'bg-success/10 text-success border-success/20 rounded-md font-medium'\n                                : log.type === 'warning'\n                                ? 'bg-warning/10 text-warning border-warning/20 rounded-md font-medium'\n                                : 'bg-critical/10 text-critical border border-critical/30 rounded-md font-semibold animate-pulse'\n                            }\n                          >\n                            {log.type === 'info' ? 'в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•ЈО“ГҮГ®в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ®' : log.type === 'warning' ? 'в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’' : 'в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®'}\n                          </Badge>\n                        </td>\n                        <td className=\"p-3 text-foreground-muted text-xs\">{log.operator}</td>\n                      </tr>\n                    )\n                  })}\n                </tbody>\n              </table>\n            </div>\n          </CardContent>\n        </Card>\n      </main>\n\n      {/* Emergency Trip Dialog */}\n      {showTripDialog && selectedStationForTrip && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-md p-4 transition-all duration-300\">\n          <div className=\"w-full max-w-md rounded-lg border-2 border-critical bg-surface-container-high/90 p-6 shadow-[0_0_50px_rgba(239,68,68,0.3)] space-y-4 relative overflow-hidden animate-in fade-in zoom-in-95 duration-200\">\n            <div className=\"absolute top-0 right-0 h-[3px] w-full bg-gradient-to-l from-critical via-transparent to-critical\" />\n            \n            <div className=\"flex items-center gap-3 text-critical pt-2\">\n              <AlertTriangle className=\"size-6 animate-pulse\" />\n              <div>\n                <h4 className=\"text-sm font-semibold tracking-tight\">в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в”ҳГ©в•Әв•–в•Әв•Ј в”ҳГјв”ҳГӘв•Әв–’в–ҲГ® в•ӘВҝв•Әв–’в”ҳГ© в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  (TRIP)</h4>\n                <p className=\"text-xs text-foreground-muted mt-0.5\">в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝв–ҲГ®: {selectedStationForTrip.name}</p>\n              </div>\n            </div>\n\n            <p className=\"text-xs text-foreground-muted leading-relaxed bg-critical/5 p-3 border border-critical/10 rounded-lg\">\n              в•Әв”Өв”ҳГ в•ӘВә в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв•Әв–’в”ҳГ© в•Әв–’в”ҳГӘв–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§ в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ§в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВ». в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ  в•ӘВҝв”ҳГӨв•ӘВәв”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в”ҢвҢҗв”ҳГӨ в”ҳГҘв–ҲГ®в•Әв–’в”ҳГӘв–ҲГ® в”ҳГ в•ӘВЎв•Әв–’в”ҢвҢҗв”ҳГ§ в•Әв–’в–ҲГ®в”ҳГӨ в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в”ҳГ©в•Әв•–в•Әв•Ј в•Әв–’в•ӘВә в”ҳГ©в•Әв•–в•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГӘ в•ӘВҝв•ӘВәв•Әв•Јв•ӘВҪ в•ӘВ¬в”ҳГӘв”ҳГ©в”ҳГј в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в”ҳГ©в•Әв•–в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв”ҳГ§в•Әв–“ в•ӘВҝв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҳГ в•ӘВЎв•Әв–’в”ҢвҢҗв”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•Әв”Өв•ӘВ».\n            </p>\n\n            <div className=\"space-y-2\">\n              <label className=\"text-xs font-semibold text-critical block\">\n                в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»в•ӘГ® в”ҳГӘв”ҳГӨв•ӘВ¬в•ӘВәв”ҢГҝ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ» в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ  в•ӘВ«в•Әв•– в–Ҳв–’ ({toFa(750)}) в•Әв–’в•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»:\n    