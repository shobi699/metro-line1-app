"text":"[accessToken, load]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'openEdit'. Either include it or remove the dependency array.","line":270,"column":6,"nodeType":"ArrayExpression","endLine":270,"endColumn":21,"suggestions":[{"desc":"Update the dependencies array to be: [editId, openEdit, posts]","fix":{"range":[8063,8078],"text":"[editId, openEdit, posts]"}}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":534,"column":71,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":534,"endColumn":74,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[15874,15877],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[15874,15877],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"jsx-a11y/alt-text","severity":1,"message":"Image elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","line":1091,"column":23,"nodeType":"JSXOpeningElement","endLine":1091,"endColumn":66},{"ruleId":"jsx-a11y/alt-text","severity":1,"message":"Image elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","line":1212,"column":25,"nodeType":"JSXOpeningElement","endLine":1212,"endColumn":64}],"suppressedMessages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":1019,"column":35,"nodeType":"JSXOpeningElement","endLine":1019,"endColumn":136,"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":1205,"column":23,"nodeType":"JSXOpeningElement","endLine":1209,"endColumn":25,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useRef, useState, Suspense } from 'react'\nimport { useSearchParams } from 'next/navigation'\nimport { useAuthStore } from '@/features/auth'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { jalali } from '@/lib/fa'\nimport {\n  Plus,\n  Pencil,\n  Trash2,\n  Upload,\n  Loader2,\n  Newspaper,\n  ArrowRight,\n  Eye,\n  Settings,\n  Globe,\n  Sparkles,\n  Bold,\n  Heading,\n  List,\n  Image,\n  FileText,\n  CheckCircle,\n  AlertCircle,\n  Award,\n  Link2,\n  Trash,\n  Check,\n  Clock,\n  Settings2,\n  ChevronUp,\n  ChevronDown,\n  XCircle,\n  Video,\n  FileCode,\n  Undo2,\n  EyeOff,\n} from 'lucide-react'\nimport { toFa } from '@/lib/fa'\n\ninterface AdminPost {\n  id: string\n  type: string\n  title: string\n  slug: string\n  category: string | null\n  published: boolean\n  mandatory: boolean\n  createdAt: string\n  author: { name: string }\n  _count: { reads: number }\n}\n\ninterface FormState {\n  id: string | null\n  type: string\n  title: string\n  slug: string\n  category: string\n  excerpt: string\n  body: string\n  coverUrl: string\n  mediaUrl: string\n  mediaType: string\n  published: boolean\n  mandatory: boolean\n  targetRoles: string[]\n}\n\nexport interface QuizQuestionDef {\n  q: string\n  options: string[]\n  answerIndex: number\n}\n\nexport interface EditorBlock {\n  id: string\n  type: 'paragraph' | 'heading' | 'quote' | 'list' | 'video' | 'image'\n  content: string\n  level?: 2 | 3\n  caption?: string\n}\n\nconst TYPE_LABELS: Record<string, string> = {\n  news: 'в•ӘВәв•ӘВ«в•ӘВҝв•ӘВәв•Әв–’ в•ӘВ«в•Әв•– в–Ҳв–’',\n  blog: 'в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в”ҳГӘ в”ҳГӘв•ӘВҝв”ҳГӨв•ӘВәв”ҢВ»',\n  training: 'в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®',\n  circular: 'в•ӘВҝв•ӘВ«в•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®',\n  gallery: 'в”ҢВ»в•ӘВәв”ҳГӨв•Әв–’в–ҲГ® в”ҢГҘв”ҳГҘв•ӘВ»в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®',\n}\n\nconst EMPTY_FORM: FormState = {\n  id: null,\n  type: 'news',\n  title: '',\n  slug: '',\n  category: '',\n  excerpt: '',\n  body: '',\n  coverUrl: '',\n  mediaUrl: '',\n  mediaType: '',\n  published: true,\n  mandatory: false,\n  targetRoles: ['all'],\n}\n\nconst POPULAR_CATEGORIES = ['в”ҳГ в”ҳГ©в•Әв–’в•Әв–’в•ӘВәв•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬', 'в•Әв•Јв–ҲГ®в•ӘВҝО“ГҮГ®в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҳГјв”ҳГҘв–ҲГ® в”ҳГӘв•ӘВәв”ҢВ»в”ҳГҘ', 'в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§', 'в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв–ҲГ®в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®', 'в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ OCC']\n\nconst TARGET_ROLES_OPTIONS = [\n  { value: 'all', label: 'в”ҳГ§в”ҳГ в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’' },\n  { value: 'driver', label: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’' },\n  { value: 'dispatcher', label: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® OCC' },\n  { value: 'technician', label: 'в•ӘВ¬в”ҢвҢҗв”ҳГҘв•Әв”Ӯв–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘ' },\n  { value: 'station', label: 'в”ҳГ в•ӘВәв”ҳГ в”ҳГӘв•Әв–’в•ӘВәв”ҳГҘ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в”ҳГӘ в•Әв”Ӯв”ҢвҢҗв”ҳГӘ' },\n]\n\nfunction AdminContentPageContent() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const [posts, setPosts] = useState<AdminPost[]>([])\n  \n  // Query Parameter Direct Edit Listener\n  const searchParams = useSearchParams()\n  const editId = searchParams.get('edit')\n  const [loading, setLoading] = useState(true)\n  const [isWorkspaceOpen, setIsWorkspaceOpen] = useState(false)\n  const [form, setForm] = useState<FormState>(EMPTY_FORM)\n  const [saving, setSaving] = useState(false)\n  const [uploading, setUploading] = useState(false)\n  const coverRef = useRef<HTMLInputElement>(null)\n  const textareaRef = useRef<HTMLTextAreaElement>(null)\n\n  // Block Editor States\n  const [editorTab, setEditorTab] = useState<'visual' | 'code'>('visual')\n  const [blocks, setBlocks] = useState<EditorBlock[]>([\n    { id: 'initial-1', type: 'paragraph', content: '' },\n  ])\n  const [activeBlockId, setActiveBlockId] = useState<string | null>(null)\n\n  // Quiz Builder States\n  const [builtQuestions, setBuiltQuestions] = useState<QuizQuestionDef[]>([])\n  const [quizQ, setQuizQ] = useState('')\n  const [quizO1, setQuizO1] = useState('')\n  const [quizO2, setQuizO2] = useState('')\n  const [quizO3, setQuizO3] = useState('')\n  const [quizO4, setQuizO4] = useState('')\n  const [quizCorrect, setQuizCorrect] = useState(0)\n\n  // SEO Analyzer States\n  const [seoFocusKeyword, setSeoFocusKeyword] = useState('')\n\n  // Prerequisite State\n  const [prerequisiteId, setPrerequisiteId] = useState<string | null>(null)\n\n  // Autosave notification state\n  const [lastAutosaved, setLastAutosaved] = useState<string | null>(null)\n  const [hasRecoverableDraft, setHasRecoverableDraft] = useState(false)\n\n  // Markdown to Blocks Parser\n  const markdownToBlocks = (markdown: string): EditorBlock[] => {\n    if (!markdown.trim()) {\n      return [{ id: Math.random().toString(36).slice(2, 9), type: 'paragraph', content: '' }]\n    }\n\n    // Strip quiz tags\n    const textWithoutQuiz = markdown.replace(/\\[quiz\\]([\\s\\S]*?)\\[\\/quiz\\]/, '').trim()\n    const paragraphs = textWithoutQuiz.split(/\\n\\s*\\n/)\n    const parsedBlocks: EditorBlock[] = []\n\n    paragraphs.forEach((p) => {\n      const trimmed = p.trim()\n      if (!trimmed) return\n\n      const blockId = Math.random().toString(36).slice(2, 9)\n\n      if (trimmed.startsWith('## ')) {\n        parsedBlocks.push({ id: blockId, type: 'heading', level: 2, content: trimmed.replace(/^##\\s+/, '') })\n      } else if (trimmed.startsWith('### ')) {\n        parsedBlocks.push({ id: blockId, type: 'heading', level: 3, content: trimmed.replace(/^###\\s+/, '') })\n      } else if (trimmed.startsWith('> ')) {\n        const quoteText = trimmed.split('\\n').map((line) => line.replace(/^>\\s?/, '')).join('\\n')\n        parsedBlocks.push({ id: blockId, type: 'quote', content: quoteText })\n      } else if (trimmed.startsWith('- ') || trimmed.startsWith('* ')) {\n        const listItems = trimmed.split('\\n').map((line) => line.replace(/^[-\\*]\\s+/, '')).join('\\n')\n        parsedBlocks.push({ id: blockId, type: 'list', content: listItems })\n      } else if (trimmed.startsWith('[video]') && trimmed.endsWith('[/video]')) {\n        const videoUrl = trimmed.replace(/^\\[video\\]/, '').replace(/\\[\\/video\\]$/, '')\n        parsedBlocks.push({ id: blockId, type: 'video', content: videoUrl })\n      } else if (trimmed.startsWith('![') && trimmed.includes('](')) {\n        const match = trimmed.match(/^!\\[(.*?)\\]\\((.*?)\\)$/)\n        if (match) {\n          parsedBlocks.push({ id: blockId, type: 'image', content: match[2], caption: match[1] })\n        } else {\n          parsedBlocks.push({ id: blockId, type: 'paragraph', content: trimmed })\n        }\n      } else {\n        parsedBlocks.push({ id: blockId, type: 'paragraph', content: trimmed })\n      }\n    })\n\n    return parsedBlocks.length > 0 ? parsedBlocks : [{ id: 'empty-1', type: 'paragraph', content: '' }]\n  }\n\n  // Blocks to Markdown Serializer\n  const blocksToMarkdown = (editorBlocks: EditorBlock[]): string => {\n    return editorBlocks\n      .map((b) => {\n        const content = b.content.trim()\n        switch (b.type) {\n          case 'heading':\n            return b.level === 3 ? `### ${content}` : `## ${content}`\n          case 'quote':\n            return content.split('\\n').map((line) => `> ${line}`).join('\\n')\n          case 'list':\n            return content.split('\\n').map((line) => `- ${line}`).join('\\n')\n          case 'video':\n            return `[video]${content}[/video]`\n          case 'image':\n            return `![${b.caption || ''}](${content})`\n          case 'paragraph':\n          default:\n            return content\n        }\n      })\n      .filter(Boolean)\n      .join('\\n\\n')\n  }\n\n  // Load drafts and posts\n  async function load() {\n    if (!accessToken) return\n    try {\n      const res = await fetch('/api/posts?scope=admin', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setPosts(data.data as AdminPost[])\n      }\n    } catch {\n      // silent\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    load()\n    // Check for localStorage drafts on mount\n    const draft = localStorage.getItem('wordpress_draft_post')\n    if (draft) {\n      setHasRecoverableDraft(true)\n    }\n  }, [accessToken])\n\n  // Listen to editId from query parameters to automatically open the editor\n  useEffect(() => {\n    if (editId && posts.length > 0) {\n      const matched = posts.find((p) => p.id === editId)\n      if (matched) {\n        openEdit(matched)\n      }\n    }\n  }, [editId, posts])\n\n  // Periodic Autosave every 30 seconds\n  useEffect(() => {\n    if (!isWorkspaceOpen || form.id) return // Don't autosave when editing existing DB posts to avoid overwriting\n\n    const interval = setInterval(() => {\n      const finalBody = editorTab === 'visual' ? blocksToMarkdown(blocks) : form.body\n      if (form.title.trim() || finalBody.trim()) {\n        localStorage.setItem(\n          'wordpress_draft_post',\n          JSON.stringify({\n            form,\n            blocks,\n            builtQuestions,\n            seoFocusKeyword,\n            timestamp: new Date().toISOString(),\n          })\n        )\n        const now = new Date()\n        const timeStr = now.toLocaleTimeString('fa-IR', { hour: '2-digit', minute: '2-digit', second: '2-digit' })\n        setLastAutosaved(timeStr)\n        setHasRecoverableDraft(false)\n      }\n    }, 30000)\n\n    return () => clearInterval(interval)\n  }, [isWorkspaceOpen, form, blocks, builtQuestions, seoFocusKeyword, editorTab])\n\n  // Recover Draft Action\n  const recoverDraft = () => {\n    try {\n      const saved = localStorage.getItem('wordpress_draft_post')\n      if (saved) {\n        const parsed = JSON.parse(saved)\n        setForm(parsed.form)\n        setBlocks(parsed.blocks)\n        setBuiltQuestions(parsed.builtQuestions || [])\n        setSeoFocusKeyword(parsed.seoFocusKeyword || '')\n        setLastAutosaved(null)\n        setHasRecoverableDraft(false)\n        setIsWorkspaceOpen(true)\n      }\n    } catch {\n      // draft recovery failed silently\n    }\n  }\n\n  // Discard Draft Action\n  const discardDraft = () => {\n    localStorage.removeItem('wordpress_draft_post')\n    setHasRecoverableDraft(false)\n  }\n\n  function openCreate() {\n    setForm(EMPTY_FORM)\n    setBlocks([{ id: 'new-1', type: 'paragraph', content: '' }])\n    setBuiltQuestions([])\n    setSeoFocusKeyword('')\n    setPrerequisiteId(null)\n    setLastAutosaved(null)\n    setEditorTab('visual')\n    setIsWorkspaceOpen(true)\n  }\n\n  async function openEdit(post: AdminPost) {\n    if (!accessToken) return\n    setBuiltQuestions([])\n    setForm({\n      ...EMPTY_FORM,\n      id: post.id,\n      type: post.type,\n      title: post.title,\n      slug: post.slug,\n      category: post.category ?? '',\n      published: post.published,\n      mandatory: post.mandatory,\n    })\n    setLastAutosaved(null)\n    setEditorTab('visual')\n\n    try {\n      const res = await fetch(`/api/posts/${post.id}`, {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        const fullPost = data.data\n\n        let cleanBody = fullPost.body || ''\n\n        let prereqId: string | null = null\n        const prereqMatch = cleanBody.match(/\\[prerequisite\\]([\\s\\S]*?)\\[\\/prerequisite\\]/)\n        if (prereqMatch) {\n          prereqId = prereqMatch[1].trim()\n          cleanBody = cleanBody.replace(/\\[prerequisite\\]([\\s\\S]*?)\\[\\/prerequisite\\]/, '').trim()\n        }\n        setPrerequisiteId(prereqId)\n\n        const match = cleanBody.match(/\\[quiz\\]([\\s\\S]*?)\\[\\/quiz\\]/)\n        if (match) {\n          try {\n            const parsedQuestions = JSON.parse(match[1].trim())\n            setBuiltQuestions(parsedQuestions)\n            cleanBody = cleanBody.replace(/\\[quiz\\]([\\s\\S]*?)\\[\\/quiz\\]/, '').trim()\n          } catch {\n            // quiz JSON parse failed\n          }\n        }\n\n        setForm((f) => ({\n          ...f,\n          body: cleanBody,\n          slug: fullPost.slug || '',\n          excerpt: fullPost.excerpt || '',\n          coverUrl: fullPost.coverUrl || '',\n          mediaUrl: fullPost.mediaUrl || '',\n          mediaType: fullPost.mediaType || '',\n        }))\n\n        // Parse markdown text back to visual blocks\n        const parsedBlocks = markdownToBlocks(cleanBody)\n        setBlocks(parsedBlocks)\n      }\n    } catch {\n      // silent\n    }\n    setIsWorkspaceOpen(true)\n  }\n\n  async function handleCover(e: React.ChangeEvent<HTMLInputElement>) {\n    const file = e.target.files?.[0]\n    if (!file || !accessToken) return\n    setUploading(true)\n    try {\n      const fd = new FormData()\n      fd.append('file', file)\n      const res = await fetch('/api/uploads', {\n        method: 'POST',\n        headers: { Authorization: `Bearer ${accessToken}` },\n        body: fd,\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setForm((f) => ({\n          ...f,\n          coverUrl: data.data.url,\n          mediaUrl: data.data.url,\n          mediaType: data.data.type,\n        }))\n      }\n    } catch {\n      // silent\n    } finally {\n      setUploading(false)\n      if (coverRef.current) coverRef.current.value = ''\n    }\n  }\n\n  async function handleSave() {\n    if (!accessToken || !form.title.trim()) return\n    setSaving(true)\n\n    // Sync active blocks back to markdown body before submitting\n    let finalBody = form.body\n    if (editorTab === 'visual') {\n      finalBody = blocksToMarkdown(blocks)\n    }\n\n    if ((form.type === 'training' || form.type === 'gallery') && builtQuestions.length > 0) {\n      finalBody = `${finalBody}\\n\\n[quiz]\\n${JSON.stringify(builtQuestions, null, 2)}\\n[/quiz]`\n    }\n\n    if (prerequisiteId) {\n      finalBody = `${finalBody}\\n\\n[prerequisite]${prerequisiteId}[/prerequisite]`\n    }\n\n    try {\n      const payload = {\n        type: form.type,\n        title: form.title,\n        category: form.category,\n        excerpt: form.excerpt,\n        body: finalBody,\n        coverUrl: form.coverUrl,\n        mediaUrl: form.mediaUrl,\n        mediaType: form.mediaType,\n        published: form.published,\n        mandatory: form.mandatory,\n      }\n      const url = form.id ? `/api/posts/${form.id}` : '/api/posts'\n      const method = form.id ? 'PATCH' : 'POST'\n      const res = await fetch(url, {\n        method,\n        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${accessToken}` },\n        body: JSON.stringify(payload),\n      })\n      if (res.ok) {\n        localStorage.removeItem('wordpress_draft_post') // Clear autosaved draft on successful publish\n        setIsWorkspaceOpen(false)\n        load()\n      }\n    } catch {\n      // silent\n    } finally {\n      setSaving(false)\n    }\n  }\n\n  async function handleDelete(id: string) {\n    if (!accessToken) return\n    if (!confirm('в•ӘГів–ҲГ®в•ӘВә в•ӘВәв•Әв–“ в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВә в”ҳГӘ в•Әв”Ӯв”ҳГӘв•ӘВәв•ӘВҝв”ҳГ© в•ӘГів”ҳГҘ в”ҳГ в•Әв•–в”ҳГ в•ӘВӘв”ҳГҘ в”ҳГ§в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВ»в•ӘЖ’')) return\n    try {\n      const res = await fetch(`/api/posts/${id}`, {\n        method: 'DELETE',\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) load()\n    } catch {\n      // silent\n    }\n  }\n\n  // Title changes slug automatically for new posts\n  const handleTitleChange = (val: string) => {\n    const autoSlug = val\n      .trim()\n      .toLowerCase()\n      .replace(/[\\sО“ГҮГ®]+/g, '-')\n      .replace(/[^\\p{L}\\p{N}-]/gu, '')\n      .replace(/-+/g, '-')\n      .replace(/^-|-$/g, '')\n\n    setForm((f) => ({\n      ...f,\n      title: val,\n      slug: f.id ? f.slug : autoSlug,\n    }))\n  }\n\n  // Category selection handler\n  const handleSelectCategory = (catName: string) => {\n    setForm((f) => ({ ...f, category: catName }))\n  }\n\n  // Handle Tab Switch (Visual Blocks <-> Markdown)\n  const handleTabChange = (newTab: 'visual' | 'code') => {\n    if (newTab === 'code') {\n      // visual to code: serialize blocks to markdown string\n      const md = blocksToMarkdown(blocks)\n      setForm((f) => ({ ...f, body: md }))\n    } else {\n      // code to visual: parse markdown string back to blocks\n      const parsed = markdownToBlocks(form.body)\n      setBlocks(parsed)\n    }\n    setEditorTab(newTab)\n  }\n\n  // Block Controls Actions\n  const updateBlockContent = (id: string, newContent: string) => {\n    setBlocks((prev) => prev.map((b) => (b.id === id ? { ...b, content: newContent } : b)))\n  };\n\n  const updateBlockMeta = (id: string, key: 'level' | 'caption', val: any) => {\n    setBlocks((prev) => prev.map((b) => (b.id === id ? { ...b, [key]: val } : b)))\n  };\n\n  const addBlock = (type: EditorBlock['type'], afterId?: string) => {\n    const newBlock: EditorBlock = {\n      id: Math.random().toString(36).slice(2, 9),\n      type,\n      content: '',\n      ...(type === 'heading' ? { level: 2 } : {}),\n      ...(type === 'image' || type === 'video' ? { caption: '' } : {}),\n    }\n\n    if (!afterId) {\n      setBlocks((prev) => [...prev, newBlock])\n    } else {\n      const idx = blocks.findIndex((b) => b.id === afterId)\n      if (idx !== -1) {\n        const copy = [...blocks]\n        copy.splice(idx + 1, 0, newBlock)\n        setBlocks(copy)\n      }\n    }\n    setActiveBlockId(newBlock.id)\n  }\n\n  const removeBlock = (id: string) => {\n    if (blocks.length === 1) {\n      setBlocks([{ id: 'fallback-1', type: 'paragraph', content: '' }])\n      return\n    }\n    setBlocks((prev) => prev.filter((b) => b.id !== id))\n  }\n\n  const moveBlock = (id: string, direction: 'up' | 'down') => {\n    const idx = blocks.findIndex((b) => b.id === id)\n    if (idx === -1) return\n    if (direction === 'up' && idx === 0) return\n    if (direction === 'down' && idx === blocks.length - 1) return\n\n    const copy = [...blocks]\n    const targetIdx = direction === 'up' ? idx - 1 : idx + 1\n    const temp = copy[idx]\n    copy[idx] = copy[targetIdx]\n    copy[targetIdx] = temp\n    setBlocks(copy)\n  }\n\n  // Quiz helper functions\n  const addQuizQuestion = () => {\n    if (!quizQ.trim() || !quizO1.trim() || !quizO2.trim() || !quizO3.trim() || !quizO4.trim()) return\n    const newQ: QuizQuestionDef = {\n      q: quizQ.trim(),\n      options: [quizO1.trim(), quizO2.trim(), quizO3.trim(), quizO4.trim()],\n      answerIndex: quizCorrect,\n    }\n    setBuiltQuestions((prev) => [...prev, newQ])\n    setQuizQ('')\n    setQuizO1('')\n    setQuizO2('')\n    setQuizO3('')\n    setQuizO4('')\n    setQuizCorrect(0)\n  }\n\n  const removeQuizQuestion = (idx: number) => {\n    setBuiltQuestions((prev) => prev.filter((_, i) => i !== idx))\n  }\n\n  // Realtime Word Count & SEO checks\n  const getWordCount = () => {\n    const textStr = editorTab === 'visual' ? blocksToMarkdown(blocks) : form.body\n    return textStr ? textStr.trim().split(/\\s+/).filter(Boolean).length : 0\n  }\n\n  const getSeoAnalysis = () => {\n    const keyword = seoFocusKeyword.trim().toLowerCase()\n    const textStr = editorTab === 'visual' ? blocksToMarkdown(blocks) : form.body\n    const titleLower = form.title.toLowerCase()\n    const slugLower = form.slug.toLowerCase()\n\n    const results = [\n      {\n        id: 'kw-title',\n        label: 'в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•ӘВ»в•Әв–’ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§',\n        passed: keyword ? titleLower.includes(keyword) : null,\n        desc: 'в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВ»в•Әв–’ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ® в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•Әв”Өв”ҳГ в•ӘВә в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГјв•ӘВәв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ».',\n      },\n      {\n        id: 'kw-slug',\n        label: 'в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•ӘВ»в•Әв–’ в”ҳв•ӣв–ҲГ®в”ҳГӘв”ҳГҘв•ӘВ» в–ҲГ®в”ҢвҢҗв•ӘВ¬в•ӘВә (Slug)',\n        passed: keyword ? slugLower.includes(keyword) : null,\n        desc: 'в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в•ӘВәв–ҲГ®в”ҳГҘв•ӘВ¬в•Әв–’в”ҳГҘв•ӘВ¬в–ҲГ® в–ҲГ®в•ӘВә в•ӘВәв•Әв”Ӯв”ҳГӨв•ӘВәв”ҢВ» в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•Әв”Өв•ӘВәв”ҳГ в”ҳГӨ в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в”ҢвҢҗв•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ».',\n      },\n      {\n        id: 'kw-body',\n        label: 'в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•ӘВ»в•Әв–’ в”ҳГ в•ӘВ¬в”ҳГҘ в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®',\n        passed: keyword ? textStr.toLowerCase().includes(keyword) : null,\n        desc: 'в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҢвҢҗв•Әв”Ӯв•ӘВҝ в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•ӘВҝв”ҳГ§в•ӘВ¬в•Әв–’в•ӘГ® в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в–ҲГ®в”ҢвҢҗО“ГҮГ®в•ӘВҝв•ӘВәв•Әв–’ в•ӘВ»в•Әв–’ в”ҢвҢҗв”ҳГӨ в”ҳГ в•ӘВ¬в”ҳГҘ в•ӘВ¬в”ҢвҢҗв•Әв–’в•ӘВәв•Әв–’ в•Әв”Өв”ҳГӘв•ӘВ».',\n      },\n      {\n        id: 'len-title',\n        label: 'в•Әв•–в”ҳГӘв”ҳГӨ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§',\n        passed: form.title.trim().length >= 20 && form.title.trim().length <= 70,\n        desc: `в•Әв•–в”ҳГӘв”ҳГӨ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•ӘВҝв–ҲГ®в”ҳГҘ в–Ҳв–“в–Ҳв–‘ в•ӘВ¬в•ӘВә в–Ҳв•–в–Ҳв–‘ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’ в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ». (в•Әв•–в”ҳГӘв”ҳГӨ в”ҳГјв•Әв•Јв”ҳГӨв–ҲГ®: ${toFa(form.title.trim().length)} в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’)`,\n      },\n      {\n        id: 'len-excerpt',\n        label: 'в•Әв•–в”ҳГӘв”ҳГӨ в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§ в”ҳГӘ в”ҢГҘв”ҢвҢҗв–ҲГ®в•ӘВ»в”ҳГ§ в•Әв”Ӯв”ҳГҘв•ӘВ»',\n        passed: form.excerpt.trim().length >= 50 && form.excerpt.trim().length <= 180,\n        desc: `в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§ в•ӘВәв–ҲГ®в•ӘВ»в”ҳГ§ в•ӘГів”ҳГӨ в•ӘВҝв–ҲГ®в”ҳГҘ в–Ҳв•Ўв–Ҳв–‘ в•ӘВ¬в•ӘВә в–Ҳв–’в–Ҳв••в–Ҳв–‘ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•ӘВә в•ӘВ»в•Әв–’ в”ҳГ в”ҳГӘв•ӘВ¬в”ҳГӘв•Әв–’в”ҳГ§в•ӘВә в•Әв•Јв•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в–ҲГ®в•ӘВ»в”ҳГ§ в•Әв”Өв”ҳГӘв•ӘВ». (в•Әв•–в”ҳГӘв”ҳГӨ в”ҳГјв•Әв•Јв”ҳГӨв–ҲГ®: ${toFa(form.excerpt.trim().length)} в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’)`,\n      },\n      {\n        id: 'len-words',\n        label: 'в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в”ҢвҢҗв”ҳГӨ в”ҢвҢҗв”ҳГӨв”ҳГ в•ӘВәв•ӘВ¬ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§',\n        passed: getWordCount() >= 150,\n        desc: `в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в”ҢвҢҗв”ҳГӨв”ҳГ в•ӘВәв•ӘВ¬ в•ӘВ¬в”ҳГӘв•Әв•Ўв–ҲГ®в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•ӘВҝ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в–Ҳв–’в–Ҳв•Ўв–Ҳв–‘ в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. (в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в”ҢвҢҗв”ҳГӨв”ҳГ в•ӘВәв•ӘВ¬ в”ҳГјв•Әв•Јв”ҳГӨв–ҲГ®: ${toFa(getWordCount())} в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§)`,\n      },\n    ]\n\n    return results\n  }\n\n  // Insert markdown helpers in raw code tab\n  const insertMarkup = (before: string, after: string = '') => {\n    const textarea = textareaRef.current\n    if (!textarea) return\n\n    const start = textarea.selectionStart\n    const end = textarea.selectionEnd\n    const text = textarea.value\n    const selected = text.substring(start, end)\n    const replacement = before + selected + after\n\n    const newBody = text.substring(0, start) + replacement + text.substring(end)\n    setForm((f) => ({ ...f, body: newBody }))\n\n    setTimeout(() => {\n      textarea.focus()\n      textarea.setSelectionRange(start + before.length, start + before.length + selected.length)\n    }, 10)\n  }\n\n  const readingTime = Math.max(1, Math.round((editorTab === 'visual' ? blocksToMarkdown(blocks).length : form.body.length) / 400))\n\n  if (isWorkspaceOpen) {\n    return (\n      <div className=\"flex flex-col min-h-screen bg-background text-foreground\" dir=\"rtl\">\n        {/* WordPress Premium Sticky Header Bar */}\n        <header className=\"sticky top-0 z-40 flex items-center justify-between border-b border-border bg-surface/90 backdrop-blur-md px-4 py-3\">\n          <div className=\"flex items-center gap-3\">\n            <Button\n              variant=\"ghost\"\n              size=\"icon-sm\"\n              onClick={() => setIsWorkspaceOpen(false)}\n              className=\"text-foreground-muted hover:text-foreground cursor-pointer rounded-lg transition-all\"\n              title=\"в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв”Өв•ӘВ¬ в•ӘВҝв”ҳГ§ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬\"\n            >\n              <ArrowRight className=\"size-5\" />\n            </Button>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-accent animate-pulse\" />\n              <span className=\"text-sm font-bold tracking-tight\">\n                {form.id ? 'в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Өв”ҢВ»в•Әв–’ в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в”ҢВ»в”ҳГӘв•ӘВ¬в”ҳГҘв•ӘВҝв•Әв–’в”ҢВ» (в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§)' : 'в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”Өв•Әв–’в”ҳГјв•ӘВ¬в”ҳГ§ в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв”ҳГҘв•ӘВ»в”ҢВ»в–ҲГ® в”ҳГӘв•Әв–’в•ӘВ»в”ҳв•ӣв•Әв–’в•Әв”Ӯ (в•Әв•–в•Әв–’в•ӘВЎ в•ӘВ«в•Әв•– в–Ҳв–’)'}\n              </span>\n            </div>\n            {lastAutosaved && (\n              <Badge variant=\"outline\" className=\"text-[10px] bg-neutral-900 text-neutral-400 border-neutral-800 gap-1 select-none\">\n                <Clock className=\"size-3\" />\n                <span>в•ӘГів•ӘВ«в•Әв–’в–ҲГ®в”ҳГҘ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’: {lastAutosaved}</span>\n              </Badge>\n            )}\n          </div>\n\n          <div className=\"flex items-center gap-2.5\">\n            {/* View Mode Switching Tabs (Visual / Code) */}\n            <div className=\"flex items-center bg-surface-container-low border border-border rounded-lg p-0.5 select-none\">\n              <button\n                type=\"button\"\n                onClick={() => handleTabChange('visual')}\n                className={`flex items-center gap-1.5 px-3 py-1 text-xs font-semibold rounded-md transition-all cursor-pointer ${\n                  editorTab === 'visual' ? 'bg-accent text-white shadow-sm' : 'text-foreground-muted hover:text-foreground'\n                }`}\n              >\n                <Settings2 className=\"size-3.5\" />\n                <span>в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Өв”ҢВ»в•Әв–’ в•ӘВҝв•Әв•Ўв•Әв–’в–ҲГ® в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВә</span>\n              </button>\n              <button\n                type=\"button\"\n                onClick={() => handleTabChange('code')}\n                className={`flex items-center gap-1.5 px-3 py-1 text-xs font-semibold rounded-md transition-all cursor-pointer ${\n                  editorTab === 'code' ? 'bg-accent text-white shadow-sm' : 'text-foreground-muted hover:text-foreground'\n                }`}\n              >\n                <FileCode className=\"size-3.5\" />\n                <span>в”ҢвҢҗв•ӘВ» в”ҳГ в•ӘВәв•Әв–’в”ҢвҢҗО“ГҮГ®в•ӘВ»в•ӘВәв”ҳГӘв”ҳГҘ в•ӘВ«в•ӘВәв”ҳГ </span>\n              </button>\n            </div>\n\n            <Button\n              variant=\"ghost\"\n              size=\"sm\"\n              onClick={() => setForm((f) => ({ ...f, published: !f.published }))}\n              className=\"h-8 text-xs gap-1.5 cursor-pointer text-foreground-muted hover:bg-surface-hover hover:text-foreground border border-transparent hover:border-border rounded-lg\"\n            >\n              {form.published ? (\n                <>\n                  <Globe className=\"size-3.5 text-success\" />\n                  <span>в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§</span>\n                </>\n              ) : (\n                <>\n                  <EyeOff className=\"size-3.5 text-amber-500\" />\n                  <span>в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ»в•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ</span>\n                </>\n              )}\n            </Button>\n\n            <Button\n              size=\"sm\"\n              disabled={saving || !form.title.trim()}\n              onClick={handleSave}\n              className=\"bg-accent hover:bg-accent-hover text-white font-semibold h-8 text-xs px-4 gap-1.5 cursor-pointer shadow-lg shadow-accent/20 rounded-lg transition-all active:scale-95\"\n            >\n              {saving ? (\n                <Loader2 className=\"size-3.5 animate-spin\" />\n              ) : (\n                <Check className=\"size-4\" />\n              )}\n              <span>{form.id ? 'в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬' : 'в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в”ҳГҘв”ҳГ§в•ӘВәв–ҲГ®в–ҲГ®'}</span>\n            </Button>\n          </div>\n        </header>\n\n        {/* Workspace Layout */}\n        <main className=\"flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-4 gap-6\">\n          \n          {/* Main Writing Area (3 Columns) */}\n          <div className=\"lg:col-span-3 space-y-6\">\n            \n            {/* Post Title & Slug Editor */}\n            <div className=\"space-y-3 bg-surface-container-low/20 p-4 rounded-xl border border-border-subtle\">\n              <input\n                type=\"text\"\n                value={form.title}\n                onChange={(e) => handleTitleChange(e.target.value)}\n                placeholder=\"в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ в–ҲГ®в•ӘВә в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•Әв–’в•ӘВә в•ӘВәв–ҲГ®в”ҳГҘв•ӘВјв•ӘВә в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ»...\"\n                className=\"w-full bg-transparent border-none text-2xl md:text-3xl font-extrabold focus:outline-none focus:ring-0 placeholder:text-foreground-muted text-foreground text-right\"\n              />\n\n              <div className=\"flex items-center gap-1.5 text-xs text-foreground-muted bg-surface/50 px-3 py-1.5 rounded-lg border border-border/40 w-fit\">\n                <Link2 className=\"size-3.5 text-neutral-500\" />\n                <span className=\"font-semibold\">в”ҳв•ӣв–ҲГ®в”ҳГӘв”ҳГҘв•ӘВ» в–ҲГ®в”ҢвҢҗв•ӘВ¬в•ӘВә (Permalink):</span>\n                <span className=\"font-mono text-neutral-400 select-none\">\n                  http://localhost:3000/content/\n                </span>\n                <input\n                  type=\"text\"\n                  value={form.slug}\n                  onChange={(e) => setForm((f) => ({ ...f, slug: e.target.value }))}\n                  className=\"bg-transparent border-none p-0 text-xs font-mono text-accent focus:outline-none focus:ring-0 w-44\"\n                  placeholder=\"slug-url\"\n                />\n              </div>\n            </div>\n\n            {/* TAB CONTENT 1: VISUAL BLOCK EDITOR (Gutenberg) */}\n            {editorTab === 'visual' && (\n              <div className=\"space-y-4\">\n                <div className=\"text-xs text-foreground-muted select-none flex items-center justify-between border-b border-border pb-2 px-1\">\n                  <span>в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Јв•ӘГ® в•Әв–’в”ҳГӘв–ҲГ® в”ҳГ в•ӘВ¬в”ҳГҘ в”ҳГ§в•Әв–’ в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҢвҢҗв”ҳГӨв–ҲГ®в”ҢвҢҗ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ».</span>\n                  <span className=\"font-semibold\">в•ӘВ¬в•Әв–’в•ӘВ¬в–ҲГ®в•ӘВҝ в”ҳГ©в•Әв–’в•ӘВәв•Әв–’в”ҢВ»в–ҲГ®в•Әв–’в–ҲГ® в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗО“ГҮГ®в”ҳГ§в•ӘВә в•ӘВәв•Әв–“ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВә в•ӘВҝв”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в–ҲГ®в”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬.</span>\n                </div>\n\n                <div className=\"space-y-3 min-h-[300px]\">\n                  {blocks.map((block, index) => {\n                    const isActive = activeBlockId === block.id\n                    return (\n                      <div\n                        key={block.id}\n                        onFocus={() => setActiveBlockId(block.id)}\n                        className={`group relative p-3 rounded-lg border transition-all duration-150 ${\n                          isActive\n                            ? 'bg-surface border-accent shadow-sm'\n                            : 'bg-surface/45 hover:bg-surface border-border-subtle hover:border-border'\n                        }`}\n                      >\n                        {/* Block Action Controls (Hover & Focus overlay) */}\n                        <div className={`absolute left-2 top-2 flex items-center gap-1 bg-surface-container-low/95 border border-border rounded-md p-1 shadow-sm opacity-0 group-hover:opacity-100 transition-opacity z-10 ${isActive ? 'opacity-100' : ''}`}>\n                          <button\n                            type=\"button\"\n                            onClick={() => moveBlock(block.id, 'up')}\n                            disabled={index === 0}\n                            className=\"p-1 text-foreground-muted hover:text-foreground disabled:opacity-30 rounded cursor-pointer\"\n                            title=\"в•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ©в•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•ӘВҝв•ӘВәв”ҳГӨв•ӘВә\"\n                          >\n                            <ChevronUp className=\"size-3.5\" />\n                          </button>\n                          <button\n                            type=\"button\"\n                            onClick={() => moveBlock(block.id, 'down')}\n                            disabled={index === blocks.length - 1}\n                            className=\"p-1 text-foreground-muted hover:text-foreground disabled:opacity-30 rounded cursor-pointer\"\n                            title=\"в•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ©в•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в–ҲГ®в”ҳГҘ\"\n                          >\n                            <ChevronDown className=\"size-3.5\" />\n                          </button>\n                          <div className=\"w-[1px] h-3 bg-border mx-1\" />\n                          <span className=\"text-[9px] font-bold text-accent px-1\">\n                            {block.type === 'paragraph' && 'в”ҳв•ӣв•ӘВәв•Әв–’в•ӘВәв”ҢВ»в•Әв–’в•ӘВәв”ҳГј'}\n                            {block.type === 'heading' && `в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ» H${block.level}`}\n                            {block.type === 'quote' && 'в”ҳГҘв”ҳГ©в”ҳГӨ в”ҳГ©в”ҳГӘв”ҳГӨ'}\n                            {block.type === 'list' && 'в”ҳГјв”ҳГ§в•Әв–’в•Әв”Ӯв•ӘВ¬'}\n                            {block.type === 'video' && 'в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ'}\n                            {block.type === 'image' && 'в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’'}\n                          </span>\n                          <div className=\"w-[1px] h-3 bg-border mx-1\" />\n                          <button\n                            type=\"button\"\n                            onClick={() => addBlock('paragraph', block.id)}\n                            className=\"p-1 text-foreground-muted hover:text-success rounded cursor-pointer\"\n                            title=\"в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВҝв•Әв•Јв•ӘВ» в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГҘ\"\n                          >\n                            <Plus className=\"size-3.5\" />\n                          </button>\n                          <button\n                            type=\"button\"\n                            onClick={() => removeBlock(block.id)}\n                            className=\"p-1 text-critical hover:bg-critical/10 rounded cursor-pointer\"\n                            title=\"в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ\"\n                          >\n                            <Trash className=\"size-3.5\" />\n                          </button>\n                        </div>\n\n                        {/* Rendering Blocks dynamically based on type */}\n                        <div className=\"pl-32\">\n                          {block.type === 'paragraph' && (\n                            <textarea\n                              value={block.content}\n                              onChange={(e) => updateBlockContent(block.id, e.target.value)}\n                              placeholder=\"в”ҳГ в•ӘВ¬в”ҳГҘ в”ҳв•ӣв•ӘВәв•Әв–’в•ӘВәв”ҢВ»в•Әв–’в•ӘВәв”ҳГј в•Әв–’в•ӘВә в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ»...\"\n                              rows={Math.max(2, block.content.split('\\n').length)}\n                              className=\"w-full bg-transparent border-none p-0 text-sm text-foreground placeholder:text-foreground-muted focus:ring-0 focus:outline-none leading-7 text-right resize-none\"\n                            />\n                          )}\n\n                          {block.type === 'heading' && (\n                            <div className=\"space-y-2\">\n                              <div className=\"flex items-center gap-1\">\n                                <button\n                                  type=\"button\"\n                                  onClick={() => updateBlockMeta(block.id, 'level', 2)}\n                                  className={`px-2 py-0.5 rounded text-[10px] font-bold border cursor-pointer ${\n                                    block.level === 2 ? 'bg-accent/15 border-accent/30 text-accent' : 'border-border text-foreground-muted'\n                                  }`}\n                                >\n                                  в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ» H2\n                                </button>\n                                <button\n                                  type=\"button\"\n                                  onClick={() => updateBlockMeta(block.id, 'level', 3)}\n                                  className={`px-2 py-0.5 rounded text-[10px] font-bold border cursor-pointer ${\n                                    block.level === 3 ? 'bg-accent/15 border-accent/30 text-accent' : 'border-border text-foreground-muted'\n                                  }`}\n                                >\n                                  в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ» H3\n                                </button>\n                              </div>\n                              <input\n                                type=\"text\"\n                                value={block.content}\n                                onChange={(e) => updateBlockContent(block.id, e.target.value)}\n                                placeholder=\"в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ»...\"\n                                className={`w-full bg-transparent border-none p-0 font-extrabold focus:ring-0 focus:outline-none text-right ${\n                                  block.level === 3 ? 'text-base text-neutral-200' : 'text-lg text-foreground'\n                                }`}\n                              />\n                            </div>\n                          )}\n\n                          {block.type === 'quote' && (\n                            <div className=\"border-r-4 border-accent bg-accent/5 p-3 rounded-l-md space-y-1\">\n                              <textarea\n                                value={block.content}\n                                onChange={(e) => updateBlockContent(block.id, e.target.value)}\n                                placeholder=\"в”ҳГ в•ӘВ¬в”ҳГҘ в”ҳГҘв”ҳГ©в”ҳГӨ в”ҳГ©в”ҳГӘв”ҳГӨ в–ҲГ®в•ӘВә в•ӘВ¬в•Әв–‘в”ҢвҢҗв•Әв–’ в”ҳГ в”ҳГ§в”ҳГ  в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’...\"\n                                rows={Math.max(2, block.content.split('\\n').length)}\n                                className=\"w-full bg-transparent border-none p-0 text-sm italic text-neutral-300 placeholder:text-foreground-muted focus:ring-0 focus:outline-none leading-7 text-right resize-none font-medium\"\n                              />\n                            </div>\n                          )}\n\n                          {block.type === 'list' && (\n                            <div className=\"space-y-1\">\n                              <div className=\"text-[10px] text-foreground-muted select-none\">в”ҳГ§в•Әв–’ в•ӘВ«в•Әв•– в•Әв–’в•ӘВә в•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в–ҲГ®в”ҢвҢҗ в•ӘГів–ҲГ®в•ӘВ¬в”ҳГ  в”ҳГјв”ҳГ§в•Әв–’в•Әв”Ӯв•ӘВ¬ в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ» (в•ӘВҝв•ӘВә в•ӘВәв–ҲГ®в”ҳГҘв•ӘВ¬в•Әв–’ в•ӘВјв•ӘВ»в•ӘВә в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»)</div>\n                              <textarea\n                                value={block.content}\n                                onChange={(e) => updateBlockContent(block.id, e.target.value)}\n                                placeholder=\"- в•ӘГів–ҲГ®в•ӘВ¬в”ҳГ  в•ӘВәв”ҳГӘв”ҳГӨ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ&#10;- в•ӘГів–ҲГ®в•ӘВ¬в”ҳГ  в•ӘВ»в”ҳГӘв”ҳГ ...\"\n                                rows={Math.max(3, block.content.split('\\n').length)}\n                                className=\"w-full bg-transparent border-none p-0 text-sm text-foreground placeholder:text-foreground-muted focus:ring-0 focus:outline-none leading-7 text-right resize-none font-mono\"\n                              />\n                            </div>\n                          )}\n\n                          {block.type === 'video' && (\n                            <div className=\"space-y-3\">\n                              <div className=\"flex flex-col gap-1.5\">\n                                <Label className=\"text-[10px] text-foreground-muted\">в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ  в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® (в”ҳГјв•Әв–’в”ҳГ в•ӘВ¬ MP4):</Label>\n                                <div className=\"flex gap-2\">\n                                  <Input\n                                    value={block.content}\n                                    onChange={(e) => updateBlockContent(block.id, e.target.value)}\n                                    placeholder=\"https://example.com/videos/train-brake-tutorial.mp4\"\n                                    className=\"h-8 text-xs font-mono text-left dir-ltr flex-1\"\n                                  />\n                                  <input\n                                    type=\"file\"\n                                    accept=\"video/*\"\n                                    className=\"hidden\"\n                                    id={`video-upload-${block.id}`}\n                                    onChange={async (e) => {\n                                      const file = e.target.files?.[0]\n                                      if (!file || !accessToken) return\n                                      const fd = new FormData()\n                                      fd.append('file', file)\n                                      try {\n                                        const res = await fetch('/api/uploads', {\n                                          method: 'POST',\n                                          headers: { Authorization: `Bearer ${accessToken}` },\n                                          body: fd,\n                                        })\n                                        if (res.ok) {\n                                          const data = await res.json()\n                                          updateBlockContent(block.id, data.data.url)\n                                        } else {\n                                          const data = await res.json()\n                                          alert(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ')\n                                        }\n                                      } catch {\n                                        alert('в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’')\n                                      }\n                                    }}\n                                  />\n                                  <Button\n                                    type=\"button\"\n                                    variant=\"outline\"\n                                    size=\"sm\"\n                                    className=\"h-8 text-xs shrink-0 cursor-pointer\"\n                                    onClick={() => document.getElementById(`video-upload-${block.id}`)?.click()}\n                                  >\n                                    <Upload className=\"size-3.5 text-accent me-1\" />\n                                    <span>в•ӘГів”ҳв•ӣв”ҳГӨв”ҳГӘв•ӘВ» в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ</span>\n                                  </Button>\n                                </div>\n                              </div>\n                              {block.content.trim() && (\n                                <div className=\"rounded-lg overflow-hidden border border-border bg-black aspect-video max-w-md mx-auto\">\n                                  <video src={block.content} controls className=\"w-full h-full object-contain\" />\n                                </div>\n                              )}\n                              <Input\n                                value={block.caption || ''}\n                                onChange={(e) => updateBlockMeta(block.id, 'caption', e.target.value)}\n                                placeholder=\"в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎ в”ҢвҢҗв”ҳГӘв•ӘВ¬в•ӘВәв”ҳГ§ в•Әв–“в–ҲГ®в•Әв–’ в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ...\"\n                                className=\"h-8 text-xs text-right\"\n                              />\n                            </div>\n                          )}\n\n                          {block.type === 'image' && (\n                            <div className=\"space-y-3\">\n                              <div className=\"flex flex-col gap-1.5\">\n                                <Label className=\"text-[10px] text-foreground-muted\">в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ  в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ў:</Label>\n                                <Input\n                                  value={block.content}\n                                  onChange={(e) => updateBlockContent(block.id, e.target.value)}\n                                  placeholder=\"https://example.com/images/schematic.png\"\n                                  className=\"h-8 text-xs font-mono text-left dir-ltr\"\n                                />\n                              </div>\n                              {block.content.trim() && (\n                                <div className=\"rounded-lg overflow-hidden border border-border bg-neutral-950 max-h-56 max-w-sm mx-auto flex items-center justify-center\">\n                                  {/* eslint-disable-next-line @next/next/no-img-element */}\n                                  <img src={block.content} alt=\"в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’\" className=\"max-w-full max-h-full object-cover\" />\n                                </div>\n                              )}\n                              <Input\n                                value={block.caption || ''}\n                                onChange={(e) => updateBlockMeta(block.id, 'caption', e.target.value)}\n                                placeholder=\"в”ҢвҢҗв”ҳв•ӣв•Әв”Өв”ҳГҘ в”ҳГӘ в•Әв–“в–ҲГ®в•Әв–’в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’...\"\n                                className=\"h-8 text-xs text-right\"\n                              />\n                            </div>\n                          )}\n                        </div>\n                      </div>\n                    )\n                  })}\n                </div>\n\n                {/* Block Library Adder Panel */}\n                <div className=\"p-4 rounded-xl border border-dashed border-border bg-surface-container-low/10 flex flex-col items-center justify-center gap-3\">\n                  <span className=\"text-xs font-semibold text-foreground-muted\">в•ӘВәв•Әв•ўв•ӘВәв”ҳГјв”ҳГ§ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в–ҲГ®в•ӘВә в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в•Әв”Ӯв”ҳГҘв•ӘВ» в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§:</span>\n                  <div className=\"flex flex-wrap items-center justify-center gap-2\">\n                    <Button\n                      variant=\"outline\"\n                      size=\"sm\"\n                      onClick={() => addBlock('paragraph')}\n                      className=\"h-8 text-xs gap-1 cursor-pointer border-border hover:bg-surface-hover rounded-lg\"\n                    >\n                      <FileText className=\"size-3.5 text-neutral-400\" />\n                      <span>в”ҳв•ӣв•ӘВәв•Әв–’в”ҢВ»в•Әв–’в•ӘВәв”ҳГј в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</span>\n                    </Button>\n                    <Button\n                      variant=\"outline\"\n                      size=\"sm\"\n                      onClick={() => addBlock('heading')}\n                      className=\"h-8 text-xs gap-1 cursor-pointer border-border hover:bg-surface-hover rounded-lg\"\n                    >\n                      <Heading className=\"size-3.5 text-accent\" />\n                      <span>в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ» в”ҳГјв”ҳГҘв–ҲГ®</span>\n                    </Button>\n                    <Button\n                      variant=\"outline\"\n                      size=\"sm\"\n                      onClick={() => addBlock('quote')}\n                      className=\"h-8 text-xs gap-1 cursor-pointer border-border hover:bg-surface-hover rounded-lg\"\n                    >\n                      <Bold className=\"size-3.5 text-amber-500\" />\n                      <span>в”ҳГҘв”ҳГ©в”ҳГӨ в”ҳГ©в”ҳГӘв”ҳГӨ / в•ӘВ¬в•Әв–‘в”ҢвҢҗв•Әв–’</span>\n                    </Button>\n                    <Button\n                      variant=\"outline\"\n                      size=\"sm\"\n                      onClick={() => addBlock('list')}\n                      className=\"h-8 text-xs gap-1 cursor-pointer border-border hover:bg-surface-hover rounded-lg\"\n                    >\n                      <List className=\"size-3.5 text-success\" />\n                      <span>в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•Әв–’</span>\n                    </Button>\n                    <Button\n                      variant=\"outline\"\n                      size=\"sm\"\n                      onClick={() => addBlock('video')}\n                      className=\"h-8 text-xs gap-1 cursor-pointer border-border hover:bg-surface-hover rounded-lg\"\n                    >\n                      <Video className=\"size-3.5 text-red-500\" />\n                      <span>в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®</span>\n                    </Button>\n                    <Button\n                      variant=\"outline\"\n                      size=\"sm\"\n                      onClick={() => addBlock('image')}\n                      className=\"h-8 text-xs gap-1 cursor-pointer border-border hover:bg-surface-hover rounded-lg\"\n                    >\n                      <Image className=\"size-3.5 text-sky-500\" />\n                      <span>в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВәв”ҢВ»в•Әв–’в•ӘВәв”ҳГ  в”ҳГјв”ҳГҘв–ҲГ®</span>\n                    </Button>\n                  </div>\n                </div>\n              </div>\n            )}\n\n            {/* TAB CONTENT 2: RAW MARKDOWN EDITOR */}\n            {editorTab === 'code' && (\n              <div className=\"space-y-4\">\n                <div className=\"flex flex-wrap items-center gap-1.5 p-2 bg-surface border border-border rounded-t-lg border-b-0\">\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon\"\n                    type=\"button\"\n                    onClick={() => insertMarkup('**', '**')}\n                    className=\"size-8 text-foreground-muted hover:text-foreground rounded cursor-pointer\"\n                    title=\"в•ӘВҝв”ҳГӘв”ҳГӨв•ӘВ» (в•ӘВҝв•Әв–’в•ӘВјв•Әв”Ӯв•ӘВ¬в”ҳГ§)\"\n                  >\n                    <Bold className=\"size-4\" />\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon\"\n                    type=\"button\"\n                    onClick={() => insertMarkup('## ')}\n                    className=\"size-8 text-foreground-muted hover:text-foreground rounded cursor-pointer text-xs font-bold\"\n                    title=\"в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ» в–Ҳв–“\"\n                  >\n                    H2\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon\"\n                    type=\"button\"\n                    onClick={() => insertMarkup('### ')}\n                    className=\"size-8 text-foreground-muted hover:text-foreground rounded cursor-pointer text-[10px] font-bold\"\n                    title=\"в•Әв”Ӯв•Әв–’в•ӘВҝв•Әв–’в”ҢВ» в–Ҳв”Ӯ\"\n                  >\n                    H3\n                  </Button>\n                  <div className=\"h-4 w-[1px] bg-border mx-1\" />\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon\"\n                    type=\"button\"\n                    onClick={() => insertMarkup('- ')}\n                    className=\"size-8 text-foreground-muted hover:text-foreground rounded cursor-pointer\"\n                    title=\"в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•Әв–’\"\n                  >\n                    <List className=\"size-4\" />\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon\"\n                    type=\"button\"\n                    onClick={() => insertMarkup('> ')}\n                    className=\"size-8 text-foreground-muted hover:text-foreground rounded cursor-pointer\"\n                    title=\"в”ҳГҘв”ҳГ©в”ҳГӨ в”ҳГ©в”ҳГӘв”ҳГӨ\"\n                  >\n                    <FileText className=\"size-4\" />\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon\"\n                    type=\"button\"\n                    onClick={() => insertMarkup('[video]', '[/video]')}\n                    className=\"size-8 text-foreground-muted hover:text-foreground rounded cursor-pointer\"\n                    title=\"в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ\"\n                  >\n                    <Video className=\"size-4\" />\n                  </Button>\n                </div>\n                <textarea\n                  ref={textareaRef}\n                  value={form.body}\n                  onChange={(e) => setForm((f) => ({ ...f, body: e.target.value }))}\n                  placeholder=\"в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВәв–ҲГ® в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в–ҲГ®в•ӘВә в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ в•Әв–’в•ӘВә в•ӘВәв–ҲГ®в”ҳГҘв•ӘВјв•ӘВә в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҳГ в•ӘВәв•Әв–’в”ҢвҢҗО“ГҮГ®в•ӘВ»в•ӘВәв”ҳГӘв”ҳГҘ в•ӘВ«в•ӘВәв”ҳГ  в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ»...\"\n                  rows={14}\n                  className=\"w-full rounded-b-lg border border-border bg-surface-container-low/30 px-4 py-3 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none focus:border-border leading-7 text-right resize-y min-h-[350px] font-mono\"\n                />\n              </div>\n            )}\n\n            {/* Excerpt Section (WordPress Style Summary) */}\n            <Card className=\"border border-border-subtle bg-surface-container-low/30\">\n              <CardHeader className=\"py-3\">\n                <CardTitle className=\"text-xs font-bold text-foreground\">в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ (Excerpt)</CardTitle>\n                <CardDescription className=\"text-[10px]\">\n                  в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҢвҢҗв”ҳГӘв•ӘВ¬в•ӘВәв”ҳГ§ в”ҢвҢҗв”ҳГ§ в•ӘВ»в•Әв–’ в”ҳГӘв–ҲГ®в•ӘВ¬в•Әв–’в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•ӘВ«в•ӘВҝв•ӘВәв•Әв–’ в”ҳГӘ в”ҳГ в•ӘВәв”ҢГҝв”ҳГӘв”ҳГӨ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВ¬в•ӘВәв•ӘВҝв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».\n                </CardDescription>\n              </CardHeader>\n              <CardContent className=\"pb-4 pt-0\">\n                <textarea\n                  value={form.excerpt}\n                  onChange={(e) => setForm((f) => ({ ...f, excerpt: e.target.value }))}\n                  placeholder=\"в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв–ҲГ® в”ҢвҢҗв”ҳГӘв•ӘВ¬в•ӘВәв”ҳГ§в•ӘГ® в•Әв•Ўв•Әв–’в–ҲГ®в•ӘВЎ в”ҳГӘ в•ӘВ¬в•Әв–’в•Әв•‘в–ҲГ®в•ӘВҝО“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВјв”ҳГӨв•ӘВҝ в•ӘВ¬в”ҳГӘв•ӘВјв”ҳГ§ в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҳГҘ в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ»...\"\n                  rows={2}\n                  className=\"w-full rounded-lg border border-border bg-background px-3 py-2 text-xs focus:outline-none focus:border-accent leading-5 text-right resize-none\"\n                />\n              </CardContent>\n            </Card>\n\n            {/* Featured Image & Cover Uploader */}\n            <Card className=\"border border-border-subtle bg-surface-container-low/30\">\n              <CardHeader className=\"py-3\">\n                <CardTitle className=\"text-xs font-bold text-foreground\">в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ў в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§</CardTitle>\n              </CardHeader>\n              <CardContent className=\"pb-4 pt-0 space-y-4\">\n                <div className=\"flex flex-col md:flex-row items-center gap-4\">\n                  <div className=\"relative aspect-video w-full md:w-56 bg-neutral-950 rounded-lg border border-border overflow-hidden flex items-center justify-center\">\n                    {form.coverUrl ? (\n                      // eslint-disable-next-line @next/next/no-img-element\n                      <img\n                        src={form.coverUrl}\n                        alt=\"в”ҢвҢҗв•ӘВәв”ҳГӘв•Әв–’ в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ў\"\n                        className=\"w-full h-full object-cover\"\n                      />\n                    ) : (\n                      <div className=\"flex flex-col items-center gap-1 text-foreground-muted text-[10px] select-none\">\n                        <Image className=\"size-6 opacity-40\" />\n                        <span>в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ўв–ҲГ® в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬</span>\n                      </div>\n                    )}\n                  </div>\n\n                  <div className=\"flex-1 space-y-3 w-full\">\n                    <div className=\"flex items-center gap-2\">\n                      <input\n                        ref={coverRef}\n                        type=\"file\"\n                        className=\"hidden\"\n                        accept=\"image/*\"\n                        onChange={handleCover}\n                      />\n                      <Button\n                        variant=\"outline\"\n                        size=\"sm\"\n                        disabled={uploading}\n                        onClick={() => coverRef.current?.click()}\n                        className=\"h-9 text-xs gap-1.5 border-border-subtle hover:bg-surface-hover cursor-pointer rounded-lg\"\n                      >\n                        {uploading ? (\n                          <Loader2 className=\"size-4 animate-spin\" />\n                        ) : (\n                          <Upload className=\"size-4 text-accent\" />\n                        )}\n                        <span>в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҢГҘв”ҳГҘв•ӘВ»в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®</span>\n                      </Button>\n                      {form.coverUrl && (\n                        <Button\n                          variant=\"ghost\"\n                          size=\"sm\"\n                          onClick={() => setForm((f) => ({ ...f, coverUrl: '' }))}\n                          className=\"h-9 text-xs text-critical hover:bg-critical/5 gap-1.5 cursor-pointer rounded-lg\"\n                        >\n                          <Trash className=\"size-4\" />\n                          <span>в•ӘВЎв•Әв–‘в”ҳГј в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ў</span>\n                        </Button>\n                      )}\n                    </div>\n                    \n                    <div className=\"space-y-1.5\">\n                      <Label className=\"text-[10px] text-foreground-muted\">в–ҲГ®в•ӘВә в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в–ҲГ®в”ҳГ  в•ӘВ¬в•Әв•Ўв”ҳГӘв–ҲГ®в•Әв–’ в•Әв–’в•ӘВә в•ӘВәв–ҲГ®в”ҳГҘв•ӘВјв•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»:</Label>\n                      <Input\n                        value={form.coverUrl}\n                        onChange={(e) => setForm((f) => ({ ...f, coverUrl: e.target.value }))}\n                        placeholder=\"https://example.com/images/cover.jpg\"\n                        className=\"h-8 text-xs font-mono dir-ltr text-left\"\n                      />\n                    </div>\n                  </div>\n                </div>\n              </CardContent>\n            </Card>\n\n            {/* Educational Quiz Builder (Only visible when type is 'training' or 'gallery') */}\n            {(form.type === 'training' || form.type === 'gallery') && (\n              <Card className=\"border border-accent/25 bg-accent/5 rounded-xl overflow-hidden shadow-sm\">\n                <CardHeader className=\"py-3 border-b border-accent/15 bg-accent/10\">\n                  <CardTitle className=\"text-xs font-bold text-accent flex items-center gap-2\">\n                    <Award className=\"size-4 animate-bounce\" />\n                    в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в”ҢвҢҗв”ҳГӘв•ӘВӘв–ҲГ®в•Әв–“ в”ҳГӘ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®\n                  </CardTitle>\n                </CardHeader>\n                <CardContent className=\"pt-4 space-y-4\">\n                  {/* Question form */}\n                  <div className=\"space-y-3 bg-background/60 p-3.5 rounded-lg border border-border/40 text-xs\">\n                    <div className=\"flex flex-col gap-1.5\">\n                      <Label className=\"text-[11px] font-bold text-foreground\">в”ҳГ в•ӘВ¬в”ҳГҘ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ:</Label>\n                      <Input\n                        placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВ»в”ҢвҢҗв”ҳГ в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳв•ӣ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•Әв”Ӯв”ҢвҢҗв”ҳГӘ (ESD) в•ӘВ»в•Әв–’ в”ҢвҢҗв•ӘВ»в•ӘВәв”ҳГ  в•ӘВҝв•ӘВ«в•Әв”Ө в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГ©в•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘЖ’\"\n                        value={quizQ}\n                        onChange={(e) => setQuizQ(e.target.value)}\n                        className=\"h-9 text-xs text-right\"\n                      />\n                    </div>\n                    \n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                      <div className=\"flex flex-col gap-1\">\n                        <Label className=\"text-[10px] text-foreground-muted\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв–’ (в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•ӘВәв”ҳГӘв”ҳГӨ):</Label>\n                        <Input\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВ»в•Әв–’ в”ҳГ§в•Әв–’ в•ӘВ»в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҢвҢҗв”ҳГӘ\"\n                          value={quizO1}\n                          onChange={(e) => setQuizO1(e.target.value)}\n                          className=\"h-8 text-xs text-right\"\n                        />\n                      </div>\n                      <div className=\"flex flex-col gap-1\">\n                        <Label className=\"text-[10px] text-foreground-muted\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв–“ (в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•ӘВ»в”ҳГӘв”ҳГ ):</Label>\n                        <Input\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҳГјв”ҳГ©в•Әв•– в•ӘВ»в•Әв–’ в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в”ҳГ в•ӘВЎв”ҳГӨв–ҲГ® в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ»\"\n                          value={quizO2}\n                          onChange={(e) => setQuizO2(e.target.value)}\n                          className=\"h-8 text-xs text-right\"\n                        />\n                      </div>\n                      <div className=\"flex flex-col gap-1\">\n                        <Label className=\"text-[10px] text-foreground-muted\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв”Ӯ (в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•Әв”Ӯв”ҳГӘв”ҳГ ):</Label>\n                        <Input\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•Әв–“в–ҲГ®в•Әв–’ в•Әв•Ўв”ҳГҘв•ӘВ»в”ҳГӨв–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГӘв•Әв”Ӯв•Әв•– в•Әв”Ӯв”ҢвҢҗв”ҳГӘ\"\n                          value={quizO3}\n                          onChange={(e) => setQuizO3(e.target.value)}\n                          className=\"h-8 text-xs text-right\"\n                        />\n                      </div>\n                      <div className=\"flex flex-col gap-1\">\n                        <Label className=\"text-[10px] text-foreground-muted\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв”Ө (в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в”ҢГҘв”ҳГ§в•ӘВәв•Әв–’в”ҳГ ):</Label>\n                        <Input\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•Әв–’в”ҳГӘв–ҲГ® в•Әв”Өв–ҲГ®в•Әв”Өв”ҳГ§ в•ӘВјв”ҳГӨв”ҳГӘв–ҲГ® в”ҳГӨв”ҢвҢҗв”ҳГӘв”ҳГ в”ҳГӘв•ӘВ¬в–ҲГ®в”ҳГӘ\"\n                          value={quizO4}\n                          onChange={(e) => setQuizO4(e.target.value)}\n                          className=\"h-8 text-xs text-right\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-3 pt-3 border-t border-border/20\">\n                      <div className=\"flex items-center gap-2\">\n                        <Label className=\"text-[11px] font-bold text-foreground-muted shrink-0\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в•Әв•Ўв•ӘВЎв–ҲГ®в•ӘВЎ в”ҳГӘ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ» в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ:</Label>\n                        <select\n                          value={quizCorrect}\n                          onChange={(e) => setQuizCorrect(Number(e.target.value))}\n                          className=\"h-8 rounded-lg border border-border bg-surface text-xs px-3 cursor-pointer outline-none font-semibold text-accent focus:border-accent\"\n                        >\n                          <option value={0}>в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв–’</option>\n                          <option value={1}>в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв–“</option>\n                          <option value={2}>в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв”Ӯ</option>\n                          <option value={3}>в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ в–Ҳв”Ө</option>\n                        </select>\n                      </div>\n\n                      <Button\n                        type=\"button\"\n                        size=\"sm\"\n                        onClick={addQuizQuestion}\n                        className=\"h-8 text-[11px] font-bold gap-1.5 px-4 cursor-pointer bg-accent hover:bg-accent-hover text-white rounded-lg transition-all\"\n                      >\n                        <Plus className=\"size-3.5\" />\n                        <span>в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в•ӘВәв–ҲГ®в”ҳГҘ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГ§ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§</span>\n                      </Button>\n                    </div>\n                  </div>\n\n                  {/* List of currently built questions */}\n                  {builtQuestions.length > 0 ? (\n                    <div className=\"space-y-2.5\">\n                      <Label className=\"text-[11px] font-bold text-foreground block\">в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘв–ҲГ® ({toFa(builtQuestions.length)} в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ):</Label>\n                      <div className=\"space-y-2 max-h-52 overflow-y-auto pr-1\">\n                        {builtQuestions.map((q, idx) => (\n                          <div key={idx} className=\"flex items-center justify-between p-3 rounded-lg bg-surface border border-border text-xs shadow-sm hover:border-accent/30 transition-all\">\n                            <div className=\"flex flex-col gap-1.5 min-w-0 flex-1\">\n                              <span className=\"font-semibold text-foreground truncate\">{toFa(idx + 1)}. {q.q}</span>\n                              <span className=\"text-[10px] text-success font-semibold flex items-center gap-1\">\n                                <Check className=\"size-3\" />\n                                <span>в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•Әв•Ўв•ӘВЎв–ҲГ®в•ӘВЎ: в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§ {toFa(q.answerIndex + 1)} ({q.options[q.answerIndex]})</span>\n                              </span>\n                            </div>\n                            <Button\n                              type=\"button\"\n                              variant=\"ghost\"\n                              size=\"icon\"\n                              onClick={() => removeQuizQuestion(idx)}\n                              className=\"size-8 text-critical hover:bg-critical/10 rounded-lg shrink-0 cursor-pointer transition-colors\"\n                            >\n                              <Trash className=\"size-4\" />\n                            </Button>\n                          </div>\n                        ))}\n                      </div>\n                    </div>\n                  ) : (\n                    <div className=\"text-center py-8 text-xs text-foreground-muted border border-dashed border-border rounded-xl bg-background/15 select-none\">\n                      в”ҢвҢҗв”ҳГӘв•ӘВӘв–ҲГ®в•Әв–“ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв•Әв•Јв•Әв•–в•ӘВәв–ҲГ® в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв•ӘГ® в•ӘВЎв•ӘВ¬в”ҳГ в•ӘВә в”ҢГҘв”ҳГҘв•ӘВ» в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ в•Әв•–в•Әв–’в•ӘВәв•ӘВЎв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </div>\n                  )}\n                </CardContent>\n              </Card>\n            )}\n          </div>\n\n          {/* WordPress Settings & SEO Sidebar Panel (1 Column) */}\n          <div className=\"lg:col-span-1 space-y-6\">\n            \n            {/* Sidebar Module 1: Publish Settings */}\n            <Card className=\"border border-border bg-surface shadow-sm rounded-xl overflow-hidden\">\n              <CardHeader className=\"py-3 border-b border-border/50 bg-neutral-900/45 select-none\">\n                <CardTitle className=\"text-xs font-bold flex items-center gap-1.5 text-foreground\">\n                  <Settings className=\"size-4 text-accent\" />\n                  в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’ в•Әв”Ӯв”ҳГҘв•ӘВ»\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"p-4 space-y-4 text-xs\">\n                \n                {/* Publish status toggler */}\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-foreground-muted\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв”Ӯв”ҳГҘв•ӘВ»:</span>\n                  <Badge className={form.published ? 'bg-success/15 text-success border-transparent' : 'bg-neutral-800 text-neutral-400'}>\n                    {form.published ? 'в”ҳГ в”ҳГҘв•ӘВ¬в•Әв”Өв•Әв–’ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ®' : 'в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ'}\n                  </Badge>\n                </div>\n\n                {/* Estimate time */}\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-foreground-muted\">в”ҳГ в•ӘВ»в•ӘВ¬ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§:</span>\n                  <span className=\"font-bold font-mono text-accent\">{toFa(readingTime)} в•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ©в”ҳГ§</span>\n                </div>\n\n                <div className=\"h-[1px] bg-border\" />\n\n                {/* Document Type Selector */}\n                <div className=\"flex flex-col gap-1.5\">\n                  <Label className=\"text-foreground-muted font-semibold\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГӘ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§:</Label>\n                  <select\n                    value={form.type}\n                    onChange={(e) => setForm((f) => ({ ...f, type: e.target.value }))}\n                    className=\"h-9 rounded-lg border border-border bg-surface px-2.5 text-xs outline-none focus:border-accent cursor-pointer font-semibold\"\n                  >\n                    {Object.entries(TYPE_LABELS).map(([k, v]) => (\n                      <option key={k} value={k}>\n                        {v}\n                      </option>\n                    ))}\n                  </select>\n                </div>\n\n                {/* Prerequisite Course Selection */}\n                {(form.type === 'training' || form.type === 'gallery') && (\n                  <>\n                    <div className=\"h-[1px] bg-border my-2\" />\n                    <div className=\"flex flex-col gap-1.5\">\n                      <Label className=\"text-foreground-muted font-semibold\">в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ (в”ҳГ©в”ҳГјв”ҳГӨ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§):</Label>\n                      <select\n                        value={prerequisiteId || ''}\n                        onChange={(e) => setPrerequisiteId(e.target.value || null)}\n                        className=\"h-9 rounded-lg border border-border bg-surface px-2.5 text-xs outline-none focus:border-accent cursor-pointer font-semibold\"\n                      >\n                        <option value=\"\">-- в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ (в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ©в”ҳГјв”ҳГӨ) --</option>\n                        {posts\n                          .filter((p) => p.id !== form.id && (p.type === 'training' || p.type === 'gallery'))\n                          .map((p) => (\n                            <option key={p.id} value={p.id}>\n                              {TYPE_LABELS[p.type] || p.type}: {p.title}\n                            </option>\n                          ))}\n                      </select>\n                      <p className=\"text-[10px] text-foreground-muted leading-relaxed\">\n                        в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ в”ҳГӘв•Әв••в”ҳГјв”ҳГҘв•ӘВ» в•ӘВәв•ӘВҝв•ӘВ¬в•ӘВ»в•ӘВә в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ в•Әв–’в•ӘВә в•ӘВҝв”ҳГ§ в•ӘВәв•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВҝв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГҘв•ӘВ» (в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ в•Әв–’в•ӘВә в•ӘВ»в–ҲГ®в•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в•Әв–’в•ӘВә в”ҳв•ӣв•ӘВәв•Әв”Ӯ в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ») в•ӘВ¬в•ӘВә в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ®в•Әв”Өв•ӘВәв”ҳГҘ в•ӘВҝв•ӘВәв•Әв–“ в•Әв”Өв”ҳГӘв•ӘВ».\n                      </p>\n                    </div>\n                  </>\n                )}\n\n                <div className=\"h-[1px] bg-border\" />\n\n                {/* Mandatory Checkbox */}\n                <div className=\"space-y-3\">\n                  <label className=\"flex items-center gap-2 text-xs font-semibold text-foreground cursor-pointer pt-1 select-none\">\n                    <input\n                      type=\"checkbox\"\n                      checked={form.mandatory}\n                      onChange={(e) => setForm((f) => ({ ...f, mandatory: e.target.checked }))}\n                      className=\"size-4 rounded border-border text-accent focus:ring-accent accent-accent\"\n                    />\n                    <span>в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв•ӘВ»в”ҳГҘ в”ҳГӘ в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§ в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬</span>\n                  </label>\n                  \n                  {form.mandatory && (\n                    <div className=\"space-y-2 bg-background/50 p-2.5 rounded-lg border border-border-subtle\">\n                      <Label className=\"text-[10px] text-foreground-muted block\">в•ӘВјв•ӘВәв”ҳГ в•Әв•Јв”ҳГ§ в”ҳГ§в•ӘВ»в”ҳГј в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§ в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ®:</Label>\n                      <div className=\"space-y-1.5\">\n                        {TARGET_ROLES_OPTIONS.map((role) => (\n                          <label key={role.value} className=\"flex items-center gap-2 text-[10px] text-foreground-muted cursor-pointer select-none\">\n                            <input\n                              type=\"checkbox\"\n                              checked={form.targetRoles.includes(role.value)}\n                              onChange={(e) => {\n                                const checked = e.target.checked\n                                if (role.value === 'all') {\n                                  setForm((f) => ({ ...f, targetRoles: checked ? ['all'] : [] }))\n                                } else {\n                                  setForm((f) => {\n                                    const filtered = f.targetRoles.filter((r) => r !== 'all')\n                                    const next = checked ? [...filtered, role.value] : filtered.filter((r) => r !== role.value)\n                                    return { ...f, targetRoles: next.length === 0 ? ['all'] : next }\n                                  })\n                                }\n                              }}\n                              className=\"size-3.5 rounded border-border accent-accent\"\n                            />\n                            <span>{role.label}</span>\n                          </label>\n                        ))}\n                      </div>\n                    </div>\n                  )}\n                </div>\n\n              </CardContent>\n            </Card>\n\n            {/* Sidebar Module 2: Category Manager */}\n            <Card className=\"border border-border bg-surface shadow-sm rounded-xl overflow-hidden\">\n              <CardHeader className=\"py-3 border-b border-border/50 bg-neutral-900/45 select-none\">\n                <CardTitle className=\"text-xs font-bold text-foreground\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГӘ в•ӘВҝв•Әв–’в”ҢГҘв•Әв”Ӯв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВә</CardTitle>\n              </CardHeader>\n              <CardContent className=\"p-4 space-y-4 text-xs\">\n                <div className=\"flex flex-col gap-1.5\">\n                  <Label className=\"text-foreground-muted font-semibold\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ® в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§:</Label>\n                  <Input\n                    value={form.category}\n                    onChange={(e) => setForm((f) => ({ ...f, category: e.target.value }))}\n                    placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®в•ӘГ® в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГӘв•ӘВәв”ҢВ»в”ҳГҘ...\"\n                    className=\"h-8 text-xs text-right\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <span className=\"text-[10px] text-foreground-muted font-semibold block\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВЎв•ӘВҝв”ҳГӘв•ӘВҝ в•ӘВ«в•Әв•– в–Ҳв–’:</span>\n                  <div className=\"flex flex-wrap gap-1\">\n                    {POPULAR_CATEGORIES.map((cat) => (\n                      <button\n                        key={cat}\n                        type=\"button\"\n                        onClick={() => handleSelectCategory(cat)}\n                        className={`px-2 py-1 rounded text-[10px] border transition-all cursor-pointer ${\n                          form.category === cat ? 'bg-accent/15 border-accent text-accent' : 'bg-background hover:bg-surface-hover border-border text-foreground-muted'\n                        }`}\n                      >\n                        {cat}\n                      </button>\n                    ))}\n                  </div>\n                </div>\n              </CardContent>\n            </Card>\n\n            {/* Sidebar Module 3: Yoast SEO Assistant & Google Snippet Simulator */}\n            <Card className=\"border border-border bg-surface shadow-sm rounded-xl overflow-hidden\">\n              <CardHeader className=\"py-3 border-b border-border/50 bg-neutral-900/45 select-none\">\n                <CardTitle className=\"text-xs font-bold flex items-center gap-1.5 text-foreground\">\n                  <Sparkles className=\"size-4 text-amber-500\" />\n                  в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”Өв•Әв–’в”ҳГјв•ӘВ¬в”ҳГ§ в•Әв”Ӯв•ӘВӘв”ҳГӘ (OCC-SEO)\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"p-4 space-y-4 text-xs\">\n                \n                {/* Focus keyword input */}\n                <div className=\"flex flex-col gap-1.5\">\n                  <Label className=\"text-[10px] text-foreground-muted font-semibold\">в•Әв•Јв•ӘВҝв•ӘВәв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в”ҢвҢҗв•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ®:</Label>\n                  <Input\n                    value={seoFocusKeyword}\n                    onChange={(e) => setSeoFocusKeyword(e.target.value)}\n                    placeholder=\"в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ® в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ®...\"\n                    className=\"h-8 text-xs text-right\"\n                  />\n                </div>\n\n                <div className=\"h-[1px] bg-border\" />\n\n                {/* Google Snippet Simulator */}\n                <div className=\"space-y-2\">\n                  <Label className=\"text-[10px] text-foreground-muted font-semibold block\">в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•Әв–’ в”ҳГҘв•ӘВ¬в•ӘВәв–ҲГ®в•ӘВј в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘв–ҲГ® в”ҢВ»в”ҳГӘв”ҢВ»в”ҳГӨ:</Label>\n                  <div className=\"rounded-lg bg-black/50 border border-neutral-800 p-3 space-y-1 text-right leading-relaxed font-sans select-none\">\n                    <span className=\"text-[9px] text-neutral-400 block font-mono\">http://localhost:3000 О“ГҮв•‘ content О“ГҮв•‘ {form.slug || 'slug'}</span>\n                    <span className=\"text-xs text-sky-400 font-bold hover:underline block truncate leading-tight\">{form.title || 'в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГ в”ҳГӘв”ҳГҘв”ҳГ§ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•Әв”Өв”ҳГ в•ӘВә'}</span>\n                    <p className=\"text-[10px] text-neutral-400 line-clamp-2 leading-relaxed\">\n                      {form.excerpt || 'в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•Әв–’ в”ҳГҘв•ӘВ¬в•ӘВәв–ҲГ®в•ӘВј в”ҢВ»в”ҳГӘв”ҢВ»в”ҳГӨв•ӘГ® в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВ«в•Әв”Ө в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»...'}\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"h-[1px] bg-border\" />\n\n                {/* Live SEO checklist */}\n                <div className=\"space-y-2\">\n                  <Label className=\"text-[10px] text-foreground-muted font-semibold block\">в”ҢГҘв”ҢвҢҗО“ГҮГ®в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в•Әв”Ӯв•ӘВӘв”ҳГӘ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§:</Label>\n                  <div className=\"space-y-2\">\n                    {getSeoAnalysis().map((chk) => {\n                      let statusIcon = <div className=\"w-2.5 h-2.5 rounded-full bg-neutral-600 shrink-0\" />\n                      if (chk.passed === true) {\n                        statusIcon = <div className=\"w-2.5 h-2.5 rounded-full bg-success shrink-0\" />\n                      } else if (chk.passed === false) {\n                        statusIcon = <div className=\"w-2.5 h-2.5 rounded-full bg-critical shrink-0\" />\n                      }\n                      \n                      return (\n                        <div key={chk.id} className=\"flex gap-2 items-start text-[10px] text-foreground-muted leading-relaxed\">\n                          {statusIcon}\n                          <div className=\"space-y-0.5\">\n                            <span className=\"font-bold text-foreground block\">{chk.label}</span>\n                            <span>{chk.desc}</span>\n                          </div>\n                        </div>\n                      )\n                    })}\n                  </div>\n                </div>\n\n              </CardContent>\n            </Card>\n\n          </div>\n        </main>\n      </div>\n    )\n  }\n\n  // LIST VIEW: DASHBOARD TABLE OF PUBLICATIONS\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4\" dir=\"rtl\">\n      \n      {/* Recovery Banner if localstorage draft exists */}\n      {hasRecoverableDraft && (\n        <div className=\"rounded-xl border border-amber-500/25 bg-amber-500/5 p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 shadow-sm animate-pulse-subtle\">\n          <div className=\"flex items-center gap-3\">\n            <AlertCircle className=\"size-5 text-amber-500 shrink-0\" />\n            <div className=\"space-y-0.5\">\n              <h4 className=\"text-xs font-bold text-amber-500\">в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВ»</h4>\n              <p className=\"text-[11px] text-foreground-muted\">в–ҲГ®в”ҢвҢҗ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ в”ҳГ в”ҳГҘв•ӘВ¬в•Әв”Өв•Әв–’ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ»в•Әв–’ в”ҳГ в•Әв–’в”ҳГӘв”ҢВ»в•Әв–’ в•Әв”Өв”ҳГ в•ӘВә в•ӘВәв•Әв–“ в”ҳГ©в•ӘВҝв”ҳГӨ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘГів–ҲГ®в•ӘВә в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в•ӘВ» в•ӘГів”ҳГҘ в•Әв–’в•ӘВә в•ӘВҝв•ӘВәв•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»?</p>\n            </div>\n          </div>\n          <div className=\"flex items-center gap-2\">\n            <Button\n              onClick={recoverDraft}\n              size=\"sm\"\n              className=\"bg-amber-600 hover:bg-amber-700 text-white h-8 text-[11px] font-bold rounded-lg cursor-pointer transition-all\"\n            >\n              <Plus className=\"size-3.5\" />\n              <span>в•ӘВҝв•ӘВәв•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§</span>\n            </Button>\n            <Button\n              onClick={discardDraft}\n              variant=\"ghost\"\n              size=\"sm\"\n              className=\"h-8 text-[11px] text-foreground-muted hover:text-foreground cursor-pointer rounded-lg border border-border/65\"\n            >\n              <Trash className=\"size-3.5\" />\n              <span>в•ӘВЎв•Әв–‘в”ҳГј в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ</span>\n            </Button>\n          </div>\n        </div>\n      )}\n\n      {/* List View Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-border pb-4\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg-mobile md:text-headline-lg text-foreground flex items-center gap-2 select-none\">\n            <Newspaper className=\"size-6 text-accent\" />\n            в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВә в”ҳГӘ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ\n          </h1>\n          <p className=\"text-sm text-foreground-muted mt-1\">\n            в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ®в•ӘГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•ӘВҝв•ӘВә в”ҢвҢҗв”ҳГӘв•ӘВӘв–ҲГ®в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ»в•ӘГ® в•ӘВҝв•ӘВ«в•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГӘ в•ӘВәв•ӘВ«в•ӘВҝв•ӘВәв•Әв–’ в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в•ӘВҝв•Әв–’в•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВ«в•Әв•– в–ҲГ®в”ҢвҢҗ\n          </p>\n        </div>\n        <Button\n          onClick={openCreate}\n          className=\"w-full md:w-auto bg-accent hover:bg-accent-hover text-white h-10 text-xs gap-1.5 cursor-pointer rounded-lg shadow-lg shadow-accent/15 transition-all font-semibold active:scale-95\"\n        >\n          <Plus className=\"size-4\" />\n          <span>в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» (в•Әв•–в•Әв–’в•ӘВЎ в”ҳГӘв•Әв–’в•ӘВ»в”ҳв•ӣв•Әв–’в•Әв”Ӯ)</span>\n        </Button>\n      </div>\n\n      {loading ? (\n        <div role=\"status\" className=\"rounded-xl border border-border p-12 text-center flex flex-col items-center justify-center gap-2 bg-surface-container-low/20\">\n          <Loader2 className=\"size-7 animate-spin text-accent\" />\n          <p className=\"text-xs text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’в•ӘВәв•ӘВ¬ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§...</p>\n        </div>\n      ) : posts.length === 0 ? (\n        <div className=\"rounded-xl border border-border p-12 text-center bg-surface-container-low/10 border-dashed select-none\">\n          <Newspaper className=\"size-8 mx-auto opacity-30 text-foreground-muted mb-2\" />\n          <p className=\"text-xs text-foreground-muted\">в”ҳГ§в”ҳГҘв”ҳГӘв•Әв–“ в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВәв–ҲГ®в–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в”ҳГ§в”ҳГ в–ҲГ®в”ҳГҘ в•ӘВЎв•ӘВәв”ҳГӨв•ӘВә в•ӘВәв”ҳГӘв”ҳГӨв–ҲГ®в”ҳГҘ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в–ҲГ®в•ӘВә в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•Әв–’в•ӘВә в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ»!</p>\n        </div>\n      ) : (\n        /* Publication Management Table */\n        <div className=\"border border-border rounded-xl bg-surface-container-low/10 overflow-hidden shadow-sm\">\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full text-right border-collapse\">\n              <thead>\n                <tr className=\"border-b border-border bg-surface/75 text-foreground-muted text-xs font-semibold select-none\">\n                  <th className=\"p-4\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§</th>\n                  <th className=\"p-4\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВә</th>\n                  <th className=\"p-4\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®</th>\n                  <th className=\"p-4\">в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв”ҳГҘв•ӘВ»в”ҳГ§</th>\n                  <th className=\"p-4\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬</th>\n                  <th className=\"p-4\">в•ӘГів”ҳГ в•ӘВәв•Әв–’ в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§</th>\n                  <th className=\"p-4\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Өв•ӘВәв•Әв–’</th>\n                  <th className=\"p-4 text-left\">в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-border-subtle text-xs\">\n                {posts.map((post) => (\n                  <tr key={post.id} className=\"hover:bg-surface-hover/30 transition-colors duration-150\">\n                    <td className=\"p-4 font-semibold text-foreground max-w-xs truncate\">\n                      <div className=\"flex flex-col gap-1\">\n                        <span>{post.title}</span>\n                        <span className=\"text-[10px] text-foreground-muted font-mono tracking-tight dir-ltr text-end select-all\">/{post.slug}</span>\n                      </div>\n                    </td>\n                    <td className=\"p-4\">\n                      <Badge variant=\"outline\" className=\"text-[10px] bg-background border-border text-foreground-muted font-semibold select-none\">\n                        {TYPE_LABELS[post.type] || post.type}\n                      </Badge>\n                    </td>\n                    <td className=\"p-4 text-foreground-muted\">{post.category || 'в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§'}</td>\n                    <td className=\"p-4 text-foreground-muted\">{post.author?.name || 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ '}</td>\n                    <td className=\"p-4\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <Badge className={post.published ? 'bg-success/15 text-success border-transparent text-[10px] font-semibold' : 'bg-neutral-800 text-neutral-400 text-[10px] font-semibold'}>\n                          {post.published ? 'в”ҳГ в”ҳГҘв•ӘВ¬в•Әв”Өв•Әв–’ в•Әв”Өв•ӘВ»в”ҳГ§' : 'в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯ'}\n                        </Badge>\n                        {post.mandatory && (\n                          <Badge className=\"bg-critical/15 text-critical border-transparent text-[10px] font-bold animate-pulse\">\n                            в”ҳГ в•Әв•–в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ§ в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ®\n                          </Badge>\n                        )}\n                      </div>\n                    </td>\n                    <td className=\"p-4 font-mono font-semibold text-foreground-muted\">{toFa(post._count.reads)} в•ӘВҝв•ӘВәв•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§</td>\n                    <td className=\"p-4 font-mono text-foreground-muted\">{jalali(post.createdAt)}</td>\n                    <td className=\"p-4 text-left\">\n                      <div className=\"flex items-center justify-end gap-1.5\">\n                        <Button\n                          variant=\"ghost\"\n                          size=\"icon\"\n                          onClick={() => openEdit(post)}\n                          className=\"size-8 text-foreground-muted hover:text-accent hover:bg-accent/5 rounded-lg cursor-pointer transition-all\"\n                          title=\"в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВҝв”ҳГӨв•ӘВәв”ҢвҢҗ в”ҳГӘв•Әв–’в•ӘВ»в”ҳв•ӣв•Әв–’в•Әв”Ӯ\"\n                        >\n                          <Pencil className=\"size-4\" />\n                        </Button>\n                        <Button\n                          variant=\"ghost\"\n                          size=\"icon\"\n                          onClick={() => handleDelete(post.id)}\n                          className=\"size-8 text-critical hover:bg-critical/10 rounded-lg cursor-pointer transition-all\"\n                          title=\"в•ӘВЎв•Әв–‘в”ҳГј в•ӘВ»в•ӘВәв•ӘВӘв”ҳГ в–ҲГ® в”ҳГҘв”ҳГӘв•Әв”Өв•ӘВ¬в”ҳГ§\"\n                        >\n                          <Trash2 className=\"size-4\" />\n                        </Button>\n                      </div>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}\n\nexport default function AdminContentPage() {\n  return (\n    <Suspense fallback={\n      <div className=\"flex flex-1 flex-col items-center justify-center p-12 min-h-screen bg-background\" dir=\"rtl\">\n        <Loader2 className=\"size-7 animate-spin text-accent animate-bounce\" />\n        <p className=\"text-xs text-foreground-muted mt-2 font-semibold\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ¬в”ҳГӘв”ҳГӨв–ҲГ®в•ӘВ» в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВәв–ҲГ® в”ҳГӘв•Әв–’в•ӘВ»в”ҳв•ӣв•Әв–’в•Әв”Ӯ...</p>\n      </div>\n    }>\n      <AdminContentPageContent />\n    </Suspense>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\documents-queue\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Badge' is defined but never used.","line":5,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":15,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Badge"},"fix":{"range":[127,173],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'FileX' is defined but never used.","line":25,"column":21,"nodeType":"Identifier","messageId":"unusedVar","endLine":25,"endColumn":26,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"FileX"},"fix":{"range":[627,634],"text":""},"desc":"Remove unused variable \"FileX\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Calendar' is defined but never used.","line":25,"column":28,"nodeType":"Identifier","messageId":"unusedVar","endLine":25,"endColumn":36,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Calendar"},"fix":{"range":[634,644],"text":""},"desc":"Remove unused variable \"Calendar\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'User' is defined but never used.","line":25,"column":38,"nodeType":"Identifier","messageId":"unusedVar","endLine":25,"endColumn":42,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"User"},"fix":{"range":[644,650],"text":""},"desc":"Remove unused variable \"User\"."}]}],"suppressedMessages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":214,"column":17,"nodeType":"JSXOpeningElement","endLine":218,"endColumn":19,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useState } from 'react'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport {\n  Table,\n  TableBody,\n  TableCell,\n  TableHead,\n  TableHeader,\n  TableRow,\n} from '@/components/ui/table'\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogFooter,\n} from '@/components/ui/dialog'\nimport { Textarea } from '@/components/ui/textarea'\nimport { Label } from '@/components/ui/label'\nimport { TopAppBar } from '@/components/shared/top-app-bar'\nimport { FileCheck, FileX, Calendar, User, ShieldAlert, Eye, CheckCircle2 } from 'lucide-react'\n\ninterface DocumentRequest {\n  id: string\n  userName: string\n  personnelNo: string\n  docType: string\n  submissionDate: string\n  fileUrl: string\n  status: 'pending' | 'approved' | 'rejected'\n}\n\nconst INITIAL_REQUESTS: DocumentRequest[] = [\n  {\n    id: 'DOC-1021',\n    userName: 'в•Әв•Јв”ҳГӨв–ҲГ® в•ӘВәв•Әв•Ўв•Әв•‘в•Әв–’в–ҲГ®',\n    personnelNo: '100234',\n    docType: 'в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•Әв”Өв”ҳГ§в•Әв–’в–ҲГ®',\n    submissionDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ө/в–Ҳв–‘в–Ҳв–’',\n    fileUrl: 'https://images.unsplash.com/photo-1586075010923-2dd4570fb338?w=500&auto=format&fit=crop&q=80',\n    status: 'pending',\n  },\n  {\n    id: 'DOC-1022',\n    userName: 'в”ҳГ в•ӘВЎв”ҳГ в•ӘВ»в•Әв–’в•Әв•ўв•ӘВә в•Әв•Јв”ҳГӨв”ҳГӘв–ҲГ®',\n    personnelNo: '100452',\n    docType: 'в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв•ӘВәв•ӘВ¬ в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’ (в•Әв”Ӯв•ӘВәв”ҳГӨв•ӘВәв”ҳГҘв”ҳГ§)',\n    submissionDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–“в–Ҳв••',\n    fileUrl: 'https://images.unsplash.com/photo-1606857521015-7f9fcf423740?w=500&auto=format&fit=crop&q=80',\n    status: 'pending',\n  },\n  {\n    id: 'DOC-1023',\n    userName: 'в•Әв”Ӯв”ҳГ§в•Әв–’в•ӘВәв•ӘВҝ в•Әв”Ӯв”ҳв•ӣв”ҳГ§в•Әв–’в–ҲГ®',\n    personnelNo: '100109',\n    docType: 'в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВ¬ в•ӘВҝв”ҳГ§в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬ в•ӘВәв•ӘВ«в•ӘВ¬в•Әв•Ўв•ӘВәв•Әв•Ўв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬',\n    submissionDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–“в–Ҳв•Ў',\n    fileUrl: 'https://images.unsplash.com/photo-1554415707-6e8cfc93fe23?w=500&auto=format&fit=crop&q=80',\n    status: 'pending',\n  },\n  {\n    id: 'DOC-1024',\n    userName: 'в•Әв–’в•Әв•ўв•ӘВә в•ӘВЎв•ӘВ»в•ӘВәв•ӘВ»',\n    personnelNo: '100366',\n    docType: 'в•ӘВ¬в•Әв•Јв”ҳГ§в•ӘВ»в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ»в•Әв–’ в•ӘВЎв•Әв–’в–ҲГ®в”ҳГ  в•Әв–’в–ҲГ®в”ҳГӨ в•Әв”Ӯв”ҳГӘв”ҳГ ',\n    submissionDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–“в–Ҳв”Ө',\n    fileUrl: 'https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=500&auto=format&fit=crop&q=80',\n    status: 'pending',\n  },\n]\n\nexport default function DocumentsQueuePage() {\n  const [requests, setRequests] = useState<DocumentRequest[]>(INITIAL_REQUESTS)\n  const [activeRequest, setActiveRequest] = useState<DocumentRequest | null>(null)\n  const [previewOpen, setPreviewOpen] = useState(false)\n  const [rejectOpen, setRejectOpen] = useState(false)\n  const [rejectReason, setRejectReason] = useState('')\n  const [successMsg, setSuccessMsg] = useState('')\n\n  const handleApprove = (id: string) => {\n    setRequests((prev) => prev.filter((r) => r.id !== id))\n    setSuccessMsg('в•Әв”Ӯв”ҳГҘв•ӘВ» в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в”ҳГӨв•ӘВәв”ҢВ» в”ҳГ в”ҳГ в–ҲГ®в•Әв–“в–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ».')\n    setPreviewOpen(false)\n    setTimeout(() => setSuccessMsg(''), 3000)\n  }\n\n  const handleReject = () => {\n    if (!activeRequest || !rejectReason.trim()) return\n    setRequests((prev) => prev.filter((r) => r.id !== activeRequest.id))\n    setRejectOpen(false)\n    setRejectReason('')\n    setSuccessMsg('в•Әв”Ӯв”ҳГҘв•ӘВ» в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ» в”ҳГӘ в•ӘВ»в”ҳГӨв–ҲГ®в”ҳГӨ в•Әв–’в•ӘВ» в”ҳГ в•ӘВ»в•ӘВәв•Әв–’в”ҢвҢҗ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ».')\n    setTimeout(() => setSuccessMsg(''), 3000)\n  }\n\n  return (\n    <div className=\"flex min-h-screen flex-col\" dir=\"rtl\">\n      <TopAppBar\n        title=\"в•Әв•Ўв”ҳГј в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГ в•ӘВ»в•ӘВәв•Әв–’в”ҢвҢҗ в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ®\"\n        subtitle=\"в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГӘ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\"\n      />\n\n      <main className=\"flex-1 p-4 pt-16 md:p-6 space-y-6\">\n        {successMsg && (\n          <div className=\"flex items-center gap-2 rounded-lg border border-success/30 bg-success/10 p-3 text-sm text-success\">\n            <CheckCircle2 className=\"size-4 shrink-0\" />\n            <span>{successMsg}</span>\n          </div>\n        )}\n\n        <Card>\n          <CardHeader className=\"flex flex-row items-center justify-between border-b border-border-subtle pb-4\">\n            <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n              <FileCheck className=\"size-4 text-accent\" />\n              в”ҳГ в•ӘВ»в•ӘВәв•Әв–’в”ҢвҢҗ в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ© в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® ({requests.length})\n            </CardTitle>\n          </CardHeader>\n          <CardContent className=\"p-0\">\n            {requests.length === 0 ? (\n              <div className=\"flex flex-col items-center justify-center p-8 text-foreground-muted\">\n                <FileCheck className=\"size-10 mb-2 opacity-50\" />\n                <p className=\"text-sm\">в•Әв”Ӯв”ҳГҘв•ӘВ» в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©в–ҲГ® в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГј в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ».</p>\n              </div>\n            ) : (\n              <Table>\n                <TableHeader className=\"bg-background-subtle\">\n                  <TableRow>\n                    <TableHead className=\"text-right text-xs\">в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬</TableHead>\n                    <TableHead className=\"text-right text-xs\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</TableHead>\n                    <TableHead className=\"text-right text-xs\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®</TableHead>\n                    <TableHead className=\"text-right text-xs\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ</TableHead>\n                    <TableHead className=\"text-right text-xs\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ</TableHead>\n                    <TableHead className=\"text-center text-xs\">в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө</TableHead>\n                    <TableHead className=\"text-center text-xs\">в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬</TableHead>\n                  </TableRow>\n                </TableHeader>\n                <TableBody>\n                  {requests.map((r) => (\n                    <TableRow key={r.id} className=\"hover:bg-surface-hover\">\n                      <TableCell className=\"font-mono text-xs text-foreground-muted\">{r.id}</TableCell>\n                      <TableCell className=\"text-sm font-medium\">{r.userName}</TableCell>\n                      <TableCell className=\"font-mono text-sm\">{r.personnelNo}</TableCell>\n                      <TableCell className=\"text-sm text-foreground-muted\">{r.docType}</TableCell>\n                      <TableCell className=\"text-sm text-foreground-muted\">{r.submissionDate}</TableCell>\n                      <TableCell className=\"text-center\">\n                        <Button\n                          variant=\"ghost\"\n                          size=\"icon-sm\"\n                          onClick={() => {\n                            setActiveRequest(r)\n                            setPreviewOpen(true)\n                          }}\n                        >\n                          <Eye className=\"size-4\" />\n                        </Button>\n                      </TableCell>\n                      <TableCell className=\"text-center\">\n                        <div className=\"flex items-center justify-center gap-1.5\">\n                          <Button\n                            size=\"sm\"\n                            variant=\"outline\"\n                            className=\"h-8 border-success/30 hover:bg-success/15 text-success\"\n                            onClick={() => handleApprove(r.id)}\n                          >\n                            в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»\n                          </Button>\n                          <Button\n                            size=\"sm\"\n                            variant=\"ghost\"\n                            className=\"h-8 hover:bg-critical/10 text-critical\"\n                            onClick={() => {\n                              setActiveRequest(r)\n                              setRejectOpen(true)\n                            }}\n                          >\n                            в•Әв–’в•ӘВ» в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ\n                          </Button>\n                        </div>\n                      </TableCell>\n                    </TableRow>\n                  ))}\n                </TableBody>\n              </Table>\n            )}\n          </CardContent>\n        </Card>\n      </main>\n\n      {/* Preview Dialog */}\n      <Dialog open={previewOpen} onOpenChange={setPreviewOpen}>\n        <DialogContent className=\"max-w-xl\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-right\">в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§</DialogTitle>\n          </DialogHeader>\n          {activeRequest && (\n            <div className=\"space-y-4\">\n              <div className=\"grid grid-cols-2 gap-4 rounded-lg bg-background-subtle p-3 text-sm\">\n                <div>\n                  <span className=\"text-foreground-muted\">в”ҳГјв•Әв–’в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в”ҳГ§:</span> {activeRequest.userName}\n                </div>\n                <div>\n                  <span className=\"text-foreground-muted\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®:</span> {activeRequest.personnelNo}\n                </div>\n                <div className=\"col-span-2\">\n                  <span className=\"text-foreground-muted\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ:</span> {activeRequest.docType}\n                </div>\n              </div>\n              <div className=\"relative aspect-video rounded-lg overflow-hidden border border-border bg-surface-container-high flex items-center justify-center\">\n                {/* eslint-disable-next-line @next/next/no-img-element */}\n                <img\n                  src={activeRequest.fileUrl}\n                  alt=\"в•Әв”Ӯв”ҳГҘв•ӘВ» в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨв–ҲГ®\"\n                  className=\"max-h-full object-contain\"\n                />\n              </div>\n            </div>\n          )}\n          <DialogFooter className=\"flex gap-2 justify-end mt-2\">\n            <Button\n              variant=\"outline\"\n              size=\"sm\"\n              onClick={() => setPreviewOpen(false)}\n            >\n              в•ӘВҝв•Әв”Ӯв•ӘВ¬в”ҳГҘ\n            </Button>\n            <Button\n              size=\"sm\"\n              className=\"bg-success hover:bg-success/90 text-white\"\n              onClick={() => activeRequest && handleApprove(activeRequest.id)}\n            >\n              в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Ӯв”ҳГҘв•ӘВ»\n            </Button>\n          </DialogFooter>\n        </DialogContent>\n      </Dialog>\n\n      {/* Reject Dialog */}\n      <Dialog open={rejectOpen} onOpenChange={setRejectOpen}>\n        <DialogContent className=\"max-w-md\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-right flex items-center gap-2 text-critical\">\n              <ShieldAlert className=\"size-5\" />\n              в•Әв–’в•ӘВ» в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҳГҘв”ҳГ©в•Әв•Ў в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ\n            </DialogTitle>\n          </DialogHeader>\n          <div className=\"space-y-3 py-2\">\n            <Label htmlFor=\"reject-reason\" className=\"text-right block\">в•ӘВ»в”ҳГӨв–ҲГ®в”ҳГӨ в•Әв–’в•ӘВ» в–ҲГ®в•ӘВә в”ҳГҘв”ҳГ©в•Әв•Ў в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ (в•ӘВҝв”ҳГ§ в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Ј в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•Әв–’в•Әв”Ӯв–ҲГ®в•ӘВ»):</Label>\n            <Textarea\n              id=\"reject-reason\"\n              placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: в”ҢвҢҗв–ҲГ®в”ҳГјв–ҲГ®в•ӘВ¬ в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв•ӘВә в”ҳГҘв–ҲГ®в•Әв”Ӯв•ӘВ¬ в–ҲГ®в•ӘВә в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГ в”ҳГҘв”ҳГ©в•Әв•ўв–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\"\n              value={rejectReason}\n              onChange={(e) => setRejectReason(e.target.value)}\n              className=\"text-right\"\n            />\n          </div>\n          <DialogFooter className=\"flex gap-2 justify-end mt-2\">\n            <Button\n              variant=\"outline\"\n              size=\"sm\"\n              onClick={() => setRejectOpen(false)}\n            >\n              в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n            </Button>\n            <Button\n              size=\"sm\"\n              variant=\"default\"\n              className=\"bg-critical hover:bg-critical-600 text-critical-foreground\"\n              onClick={handleReject}\n              disabled={!rejectReason.trim()}\n            >\n              в•Әв–’в•ӘВ» в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ в”ҳГӘ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в•ӘВәв•Әв•Јв”ҳГӨв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГ©в•Әв•Ў\n            </Button>\n          </DialogFooter>\n        </DialogContent>\n      </Dialog>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\exams-editor\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErr