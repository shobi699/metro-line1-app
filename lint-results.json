line":1550,"column":66,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":1550,"endColumn":69,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[70902,70905],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[70902,70905],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":1810,"column":77,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":1810,"endColumn":80,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[87695,87698],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[87695,87698],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":2231,"column":72,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":2231,"endColumn":75,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[112588,112591],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[112588,112591],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":24,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useState, useEffect, useMemo } from 'react'\nimport dayjs from 'dayjs'\nimport 'dayjs-jalali'\nimport {\n  ChevronRight,\n  ChevronLeft,\n  Sparkles,\n  Plus,\n  AlertTriangle,\n  Check,\n  Users,\n  ArrowLeftRight,\n  Clock,\n  CheckCircle2,\n  Calendar as CalendarIcon,\n  Loader2,\n  Info,\n  Sliders,\n  Settings,\n  Trash,\n  Download,\n  FileText,\n  UserCheck,\n  Eye,\n  Shield,\n  CalendarDays\n} from 'lucide-react'\n\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Badge } from '@/components/ui/badge'\nimport { Switch } from '@/components/ui/switch'\nimport { Dialog, DialogContent, DialogDescription, DialogFooter, DialogHeader, DialogTitle } from '@/components/ui/dialog'\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select'\nimport { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Textarea } from '@/components/ui/textarea'\n\nimport { useAuthStore } from '@/features/auth'\nimport { useShiftsStore, CycleTemplate, ShiftAssignment, DEFAULT_TEMPLATES, DEFAULT_ASSIGNMENTS } from '@/features/shifts'\nimport { getShiftForUserAndDate, MOCK_USERS_LIST, MOCK_GROUPS_LIST } from '@/lib/cycle-math'\nimport { toFa } from '@/lib/fa'\nimport { cn } from '@/lib/utils'\n\ninterface Shift {\n  id: string\n  date: string\n  code: 'morning' | 'evening' | 'night' | 'off'\n  note: string | null\n  userId: string\n  user: { id: string; name: string; nationalId: string }\n}\n\ninterface User {\n  id: string\n  name: string\n  nationalId: string\n  role: { key: string; name: string }\n  customFields?: any\n}\n\ninterface SwapRequest {\n  id: string\n  status: string\n  note: string | null\n  createdAt: string\n  requester: { id: string; name: string; role?: { key: string; name: string } }\n  target: { id: string; name: string; role?: { key: string; name: string } }\n  sourceShift: { id: string; date: string; code: string }\n  targetShift: { id: string; date: string; code: string }\n}\n\ninterface Conflict {\n  userName: string\n  userId: string\n  date: string\n  reason: string\n}\n\nconst shiftLabels: Record<string, string> = {\n  morning: 'в•Әв•Ўв•ӘВҝв•ӘВЎ',\n  evening: 'в•Әв•Јв•Әв•Ўв•Әв–’',\n  night: 'в•Әв”Өв•ӘВҝ',\n  off: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬',\n  office: 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®'\n}\n\nconst shiftTimes: Record<string, string> = {\n  morning: 'в–Ҳв–‘в–Ҳв•ў:в–Ҳв–‘в–Ҳв–‘ - в–Ҳв–’в–Ҳв”Ө:в–Ҳв–‘в–Ҳв–‘',\n  evening: 'в–Ҳв–’в–Ҳв”Ө:в–Ҳв–‘в–Ҳв–‘ - в–Ҳв–“в–Ҳв–“:в–Ҳв–‘в–Ҳв–‘',\n  night: 'в–Ҳв–“в–Ҳв–“:в–Ҳв–‘в–Ҳв–‘ - в–Ҳв–‘в–Ҳв•ў:в–Ҳв–‘в–Ҳв–‘',\n  off: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬',\n  office: 'в–Ҳв–‘в–Ҳв•–:в–Ҳв”Ӯв–Ҳв–‘ - в–Ҳв–’в–Ҳв•ў:в–Ҳв–’в–Ҳв•Ў'\n}\n\nconst shiftColors: Record<string, string> = {\n  morning: 'bg-success/10 text-success border-success/20 hover:bg-success/15',\n  evening: 'bg-info/10 text-info border-info/20 hover:bg-info/15',\n  night: 'bg-purple-500/10 text-purple-400 border-purple-500/20 hover:bg-purple-500/15',\n  office: 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20 hover:bg-indigo-500/15',\n  off: 'bg-background/45 text-foreground-muted border-border border-dashed hover:bg-background/60',\n}\n\nexport default function AdminShiftsPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n\n  // Zustand Store\n  const {\n    templates,\n    assignments,\n    addTemplate,\n    deleteTemplate,\n    assignTemplate,\n    deleteAssignment\n  } = useShiftsStore()\n\n  // Tabs state\n  const [activeTab, setActiveTab] = useState<'roster' | 'builder' | 'assignments' | 'swaps' | 'settings'>('roster')\n\n  // Roster view configuration\n  const [weekOffset, setWeekOffset] = useState(0)\n  const [department, setDepartment] = useState('all')\n  const [lineFilter, setLineFilter] = useState('line1')\n  const [viewType, setViewType] = useState<'weekly' | 'monthly'>('weekly')\n\n  // Year and Month states for Monthly View (Jalali Month/Year)\n  const now = dayjs().locale('jalali')\n  const [selectedYear, setSelectedYear] = useState(() => now.year())\n  const [selectedMonth, setSelectedMonth] = useState(() => now.month() + 1)\n\n  // Loaded data\n  const [users, setUsers] = useState<User[]>([])\n  const [dbShifts, setDbShifts] = useState<Shift[]>([])\n  const [swapRequests, setSwapRequests] = useState<SwapRequest[]>([])\n\n  // Dynamic Shift settings from database\n  const [dbMinRestHours, setDbMinRestHours] = useState(12)\n  const [dbMaxConsecutiveNights, setDbMaxConsecutiveNights] = useState(2)\n  const [dbRoleParity, setDbRoleParity] = useState(true)\n\n  // Loadings\n  const [loading, setLoading] = useState(true)\n  const [settingsLoading, setSettingsLoading] = useState(false)\n  const [actionLoading, setActionLoading] = useState<Record<string, boolean>>({})\n  const [aiRunning, setAiRunning] = useState(false)\n  const [aiStage, setAiStage] = useState(0)\n\n  // Shift assignment modal states\n  const [shiftModalOpen, setShiftModalOpen] = useState(false)\n  const [selectedUserId, setSelectedUserId] = useState('')\n  const [selectedDate, setSelectedDate] = useState('')\n  const [selectedShiftCode, setSelectedShiftCode] = useState<'morning' | 'evening' | 'night' | 'off'>('morning')\n  const [selectedNote, setSelectedNote] = useState('')\n  const [isCellEdit, setIsCellEdit] = useState(false)\n  const [formSubmitLoading, setFormSubmitLoading] = useState(false)\n\n  // Template Builder form states\n  const [tplName, setTplName] = useState('')\n  const [tplType, setTplType] = useState<'rotational' | 'staff'>('rotational')\n  const [tplRegime, setTplRegime] = useState<'rotational_9h' | 'rotational_12h' | 'staff'>('rotational_9h')\n  const [tplLength, setTplLength] = useState<number>(6)\n  const [tplShifts, setTplShifts] = useState<Array<{\n    day: number\n    code: 'morning' | 'evening' | 'night' | 'off' | 'office'\n    label: string\n    hours: number\n    startTime: string\n    endTime: string\n  }>>([])\n\n  // Shift Assignment form states\n  const [assignTplId, setAssignTplId] = useState('')\n  const [assignTargetType, setAssignTargetType] = useState<'user' | 'group'>('group')\n  const [assignTargetId, setAssignTargetId] = useState('A')\n  const [assignAnchorDate, setAssignAnchorDate] = useState('2026-06-01')\n\n  // Notification Banner\n  const [notification, setNotification] = useState<{\n    type: 'success' | 'error'\n    text: string\n  } | null>(null)\n\n  useEffect(() => {\n    if (notification) {\n      const timer = setTimeout(() => setNotification(null), 4000)\n      return () => clearTimeout(timer)\n    }\n  }, [notification])\n\n  // Synchronize shifts detail inputs dynamically for Template Builder\n  useEffect(() => {\n    const length = tplRegime === 'staff' ? 7 : tplLength\n    const defaultShifts = Array.from({ length }).map((_, i) => {\n      const d = i + 1\n      if (tplRegime === 'staff') {\n        const isWeekend = d === 6 || d === 7\n        return {\n          day: d,\n          code: (isWeekend ? 'off' : 'office') as any,\n          label: isWeekend ? 'в•ӘВ¬в•Әв•Јв•Әв•–в–ҲГ®в”ҳГӨ' : 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®',\n          hours: isWeekend ? 0 : 8.75,\n          startTime: isWeekend ? '' : '07:30',\n          endTime: isWeekend ? '' : '16:15',\n        }\n      } else if (tplRegime === 'rotational_12h') {\n        const isDay = d % 4 === 1\n        const isNight = d % 4 === 2\n        return {\n          day: d,\n          code: (isDay ? 'morning' : isNight ? 'night' : 'off') as any,\n          label: isDay ? 'в•Әв–’в”ҳГӘв•Әв–“в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§' : isNight ? 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§' : 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)',\n          hours: isDay ? 12 : isNight ? 12 : 0,\n          startTime: isDay ? '07:00' : isNight ? '19:00' : '',\n          endTime: isDay ? '19:00' : isNight ? '07:00' : '',\n        }\n      } else {\n        const isMorning = d % 6 === 1 || d % 6 === 2\n        const isEvening = d % 6 === 3 || d % 6 === 4\n        return {\n          day: d,\n          code: (isMorning ? 'morning' : isEvening ? 'evening' : 'off') as any,\n          label: isMorning ? 'в•Әв•Ўв•ӘВҝв•ӘВЎО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§' : isEvening ? 'в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§' : 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)',\n          hours: isMorning ? 9 : isEvening ? 9 : 0,\n          startTime: isMorning ? '07:00' : isEvening ? '16:00' : '',\n          endTime: isMorning ? '16:00' : isEvening ? '01:00' : '',\n        }\n      }\n    })\n    setTplShifts(defaultShifts)\n  }, [tplLength, tplRegime])\n\n  // Calculate Saturday & Friday of the current week offset\n  const weekDays = useMemo(() => {\n    const today = new Date()\n    const jsDay = today.getDay()\n    const daysSinceSaturday = (jsDay + 1) % 7\n    const saturday = new Date(today)\n    saturday.setDate(today.getDate() - daysSinceSaturday + (weekOffset * 7))\n    saturday.setHours(0, 0, 0, 0)\n\n    const days = []\n    for (let i = 0; i < 7; i++) {\n      const d = new Date(saturday)\n      d.setDate(saturday.getDate() + i)\n      days.push(d)\n    }\n    return days\n  }, [weekOffset])\n\n  const saturdayDate = weekDays[0]\n  const fridayDate = weekDays[6]\n\n  // Calculate all days in the selected month for Monthly View\n  const monthlyDays = useMemo(() => {\n    const start = dayjs().locale('jalali').year(selectedYear).month(selectedMonth - 1).startOf('month')\n    const end = dayjs().locale('jalali').year(selectedYear).month(selectedMonth - 1).endOf('month')\n\n    const days = []\n    let curr = start\n    while (curr.isBefore(end) || curr.isSame(end, 'day')) {\n      days.push(curr.toDate())\n      curr = curr.add(1, 'day')\n    }\n    return days\n  }, [selectedYear, selectedMonth])\n\n  const activeDays = viewType === 'weekly' ? weekDays : monthlyDays\n\n  // Fetch all required data from server\n  async function loadData() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      // 1. Fetch Users\n      const usersRes = await fetch('/api/users?pageSize=100', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (usersRes.ok) {\n        const usersData = await usersRes.json()\n        setUsers(usersData.data.users || [])\n      }\n\n      // 2. Fetch Shift Overrides for active date range\n      const startStr = activeDays[0].toISOString()\n      const endStr = activeDays[activeDays.length - 1].toISOString()\n\n      const shiftsRes = await fetch(`/api/shifts?startDate=${startStr}&endDate=${endStr}`, {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (shiftsRes.ok) {\n        const shiftsData = await shiftsRes.json()\n        setDbShifts(shiftsData.data || [])\n      }\n\n      // 3. Fetch Pending Swap Requests\n      const swapsRes = await fetch('/api/swap-requests/inbox', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (swapsRes.ok) {\n        const swapsData = await swapsRes.json()\n        setSwapRequests(swapsData.data || [])\n      }\n    } catch {\n      // shifts data fetch failed silently\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  // Fetch settings from database on mount\n  async function fetchSettings() {\n    if (!accessToken) return\n    setSettingsLoading(true)\n    try {\n      const settingsRes = await fetch('/api/admin/settings', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (settingsRes.ok) {\n        const settingsData = await settingsRes.json()\n        const list = settingsData.data || []\n\n        const restSetting = list.find((s: any) => s.key === 'shifts.minRestHours')\n        const nightsSetting = list.find((s: any) => s.key === 'shifts.maxConsecutiveNights')\n        const paritySetting = list.find((s: any) => s.key === 'shifts.roleParity')\n\n        if (restSetting) setDbMinRestHours(JSON.parse(restSetting.value))\n        if (nightsSetting) setDbMaxConsecutiveNights(JSON.parse(nightsSetting.value))\n        if (paritySetting) setDbRoleParity(JSON.parse(paritySetting.value))\n      }\n    } catch {\n      // settings fetch failed silently\n    } finally {\n      setSettingsLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    void fetchSettings()\n  }, [accessToken])\n\n  useEffect(() => {\n    void loadData()\n  }, [weekOffset, selectedYear, selectedMonth, viewType, accessToken])\n\n  // Save Settings to database\n  async function handleSaveSettings() {\n    if (!accessToken) return\n    setSettingsLoading(true)\n    try {\n      const res = await fetch('/api/admin/settings', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          updates: [\n            { key: 'shifts.minRestHours', value: Number(dbMinRestHours) },\n            { key: 'shifts.maxConsecutiveNights', value: Number(dbMaxConsecutiveNights) },\n            { key: 'shifts.roleParity', value: Boolean(dbRoleParity) },\n          ]\n        })\n      })\n      if (res.ok) {\n        setNotification({ type: 'success', text: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГӘ в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ».' })\n        await fetchSettings()\n        await loadData()\n      } else {\n        const json = await res.json()\n        setNotification({ type: 'error', text: json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬' })\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setSettingsLoading(false)\n    }\n  }\n\n  // Save specific setting reset\n  async function handleResetSettings() {\n    if (!accessToken) return\n    setSettingsLoading(true)\n    try {\n      const res = await fetch('/api/admin/settings', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          updates: [\n            { key: 'shifts.minRestHours', value: 12 },\n            { key: 'shifts.maxConsecutiveNights', value: 2 },\n            { key: 'shifts.roleParity', value: true },\n          ]\n        })\n      })\n      if (res.ok) {\n        setNotification({ type: 'success', text: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГ§ в”ҳГ в”ҳГ©в•ӘВәв•ӘВ»в–ҲГ®в•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв–’в•ӘВ»в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГҘв•ӘВ».' })\n        await fetchSettings()\n        await loadData()\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setSettingsLoading(false)\n    }\n  }\n\n  // Reset templates and assignments to system defaults (stored in Zustand)\n  function handleResetTemplatesAndAssignments() {\n    if (confirm('вүЎЖ’ГңВҝ в•ӘГів–ҲГ®в•ӘВә в”ҳГ в•Әв•–в”ҳГ в•ӘВӘв”ҳГҘ в”ҳГ§в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВ» в”ҢвҢҗв”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в•ӘВ» в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•Әв–’в•ӘВә в•ӘВҝв”ҳГ§ в•ӘВЎв•ӘВәв”ҳГӨв•ӘВ¬ в•ӘВәв”ҳГӘв”ҳГӨв–ҲГ®в”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»в•ӘЖ’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ  в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВә в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ® в•Әв”Өв”ҳГ в•ӘВә в•Әв–’в•ӘВә в•ӘВЎв•Әв–‘в”ҳГј в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в”ҢвҢҗв•Әв–’в•ӘВ».')) {\n      useShiftsStore.setState({\n        templates: DEFAULT_TEMPLATES,\n        assignments: DEFAULT_ASSIGNMENTS\n      })\n      setNotification({ type: 'success', text: 'в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВә в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВҝв”ҳГ§ в”ҳГ в”ҳГ©в•ӘВәв•ӘВ»в–ҲГ®в•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•Әв”Өв•ӘВ»в”ҳГҘв•ӘВ».' })\n      void loadData()\n    }\n  }\n\n  // О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n  // SHARED CORE COMPUTATIONAL ENGINE\n  // О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n  // Combines: 1. Cycle math template shifts (Zustand) + 2. DB manual overrides\n  const resolvedRosterMap = useMemo(() => {\n    const roster: Record<string, Record<string, { code: string; label: string; note: string | null; isOverride: boolean; hours: number; startTime: string; endTime: string }>> = {}\n\n    // Map DB overrides first\n    const overrideMap: Record<string, Record<string, Shift>> = {}\n    dbShifts.forEach((shift) => {\n      const dateStr = dayjs(shift.date).format('YYYY-MM-DD')\n      if (!overrideMap[shift.userId]) overrideMap[shift.userId] = {}\n      overrideMap[shift.userId][dateStr] = shift\n    })\n\n    users.forEach((user) => {\n      roster[user.id] = {}\n      activeDays.forEach((day) => {\n        const dateObj = dayjs(day)\n        const dateStr = dateObj.format('YYYY-MM-DD')\n\n        // 1. Get default shift from template cycle\n        const userGroup = user.customFields?.group || 'A'\n        const cycleRes = getShiftForUserAndDate(user.id, dateObj, assignments, templates, undefined, userGroup)\n\n        // Default properties\n        let code = cycleRes?.shift?.code || 'off'\n        let label = cycleRes?.shift?.label || 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬'\n        let hours = cycleRes?.shift?.hours || 0\n        let startTime = cycleRes?.shift?.startTime || ''\n        let endTime = cycleRes?.shift?.endTime || ''\n        let isOverride = false\n        let note = null\n\n        // 2. Apply database manual override if exists\n        const override = overrideMap[user.id]?.[dateStr]\n        if (override) {\n          code = override.code\n          label = shiftLabels[override.code] || override.code\n          isOverride = true\n          note = override.note\n\n          // Set standard hours for overrides\n          if (code === 'morning') { hours = 9; startTime = '07:00'; endTime = '16:00' }\n          else if (code === 'evening') { hours = 9; startTime = '16:00'; endTime = '01:00' }\n          else if (code === 'night') { hours = 12; startTime = '19:00'; endTime = '07:00' }\n          else if (code === 'off') { hours = 0; startTime = ''; endTime = '' }\n        }\n\n        roster[user.id][dateStr] = {\n          code,\n          label,\n          note,\n          isOverride,\n          hours,\n          startTime,\n          endTime\n        }\n      })\n    })\n\n    return roster\n  }, [users, activeDays, dbShifts, assignments, templates])\n\n  // Identify Conflicts based on rest hours and consecutive nights settings\n  const conflicts = useMemo<Conflict[]>(() => {\n    const list: Conflict[] = []\n    const shiftStartHours: Record<string, number> = { morning: 6, evening: 14, night: 22, office: 7.5 }\n    const shiftEndHours: Record<string, number> = { morning: 14, evening: 22, night: 30, office: 16.25 } // 30 is 06:00 next day\n\n    users.forEach((user) => {\n      const userShifts = resolvedRosterMap[user.id] || {}\n\n      // 1. Check minimum rest hours between consecutive days\n      for (let i = 0; i < activeDays.length - 1; i++) {\n        const d1Str = dayjs(activeDays[i]).format('YYYY-MM-DD')\n        const d2Str = dayjs(activeDays[i + 1]).format('YYYY-MM-DD')\n\n        const s1 = userShifts[d1Str]\n        const s2 = userShifts[d2Str]\n\n        if (!s1 || !s2 || s1.code === 'off' || s2.code === 'off') continue\n\n        const endHourVal = shiftEndHours[s1.code] || 0\n        const startHourVal = shiftStartHours[s2.code] || 0\n\n        const endMs = new Date(activeDays[i]).getTime() + endHourVal * 60 * 60 * 1000\n        const startMs = new Date(activeDays[i + 1]).getTime() + startHourVal * 60 * 60 * 1000\n\n        const gapHours = (startMs - endMs) / (1000 * 60 * 60)\n\n        if (gapHours < dbMinRestHours) {\n          const jalaliDateStr = dayjs(activeDays[i + 1]).format('dddd D MMMM')\n          list.push({\n            userName: user.name,\n            userId: user.id,\n            date: d2Str,\n            reason: `в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в•Әв–’в”ҳГӘв•Әв–“ ${jalaliDateStr}: в”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВҝв–ҲГ®в”ҳГҘ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв–’в”ҳГӘв•Әв–“ в”ҳГ©в•ӘВҝв”ҳГӨ (${s1.label}) в”ҳГӘ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВәв”ҳГ в•Әв–’в”ҳГӘв•Әв–“ (${s2.label}) в•ӘВ¬в”ҳГҘв”ҳГ§в•ӘВә ${toFa(gapHours.toFixed(1))} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в•ӘВәв•Әв”Ӯв•ӘВ¬ в”ҢвҢҗв”ҳГ§ в”ҢвҢҗв”ҳГ в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ в•ӘВЎв•ӘВ» в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® (${toFa(dbMinRestHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬) в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ».`,\n          })\n        }\n      }\n\n      // 2. Check maximum consecutive nights limit\n      let consecutiveNightsCount = 0\n      for (let i = 0; i < activeDays.length; i++) {\n        const dStr = dayjs(activeDays[i]).format('YYYY-MM-DD')\n        const s = userShifts[dStr]\n\n        if (s && s.code === 'night') {\n          consecutiveNightsCount++\n          if (consecutiveNightsCount > dbMaxConsecutiveNights) {\n            const jalaliDateStr = dayjs(activeDays[i]).format('dddd D MMMM')\n            list.push({\n              userName: user.name,\n              userId: user.id,\n              date: dStr,\n              reason: `в”ҳГҘв”ҳГ©в•Әв•ў в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ в•ӘВ»в•Әв–’ в•Әв–’в”ҳГӘв•Әв–“ ${jalaliDateStr}: в•ӘВәв–ҲГ®в”ҳГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ»в•ӘВәв•Әв–’в•ӘВәв–ҲГ® ${toFa(consecutiveNightsCount)} в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬ в”ҢвҢҗв”ҳГ§ в”ҳГјв•Әв–’в•ӘВәв•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ в•Әв”Ӯв”ҳГ©в”ҳГј в”ҳГ в•Әв•Ўв”ҳГӘв•ӘВҝ (${toFa(dbMaxConsecutiveNights)} в•Әв”Өв•ӘВҝ) в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ».`,\n            })\n          }\n        } else {\n          consecutiveNightsCount = 0\n        }\n      }\n    })\n\n    return list\n  }, [users, resolvedRosterMap, activeDays, dbMinRestHours, dbMaxConsecutiveNights])\n\n  // Check if a shift cell is currently active/live\n  const isShiftLive = (dateStr: string, code: string) => {\n    const todayStr = dayjs().format('YYYY-MM-DD')\n    if (dateStr !== todayStr) return false\n\n    const currentHour = new Date().getHours()\n    if (code === 'morning' && currentHour >= 6 && currentHour < 14) return true\n    if (code === 'evening' && currentHour >= 14 && currentHour < 22) return true\n    if (code === 'night' && (currentHour >= 22 || currentHour < 6)) return true\n    return false\n  }\n\n  // Handle Swap approval or rejection (swap-skill)\n  async function handleSwapDecision(swapRequestId: string, decision: 'approved' | 'rejected') {\n    setActionLoading((prev) => ({ ...prev, [swapRequestId]: true }))\n    try {\n      const res = await fetch('/api/swap-requests/approve', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ swapRequestId, decision }),\n      })\n\n      if (res.ok) {\n        setNotification({ type: 'success', text: decision === 'approved' ? 'в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВ»в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ».' : 'в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ».' })\n        await loadData()\n      } else {\n        const data = await res.json()\n        setNotification({ type: 'error', text: data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВ¬в•Әв•Ўв”ҳГ в–ҲГ®в”ҳГ  в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®' })\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setActionLoading((prev) => ({ ...prev, [swapRequestId]: false }))\n    }\n  }\n\n  // Swap Request Rule Engine (swap-skill) using dynamic DB settings\n  const evaluateSwapRules = (req: SwapRequest) => {\n    const roleParity = req.requester.role?.key === req.target.role?.key\n\n    const date1 = dayjs(req.sourceShift.date)\n    const date2 = dayjs(req.targetShift.date)\n    const diffDays = Math.abs(date1.diff(date2, 'day'))\n\n    let restViolation = false\n    if (diffDays === 1) {\n      if (req.targetShift.code === 'night' && req.sourceShift.code === 'morning') {\n        restViolation = true\n      }\n    }\n\n    const nightViolation = req.sourceShift.code === 'night' && req.targetShift.code === 'night' && diffDays === 1\n\n    return [\n      {\n        name: 'в”ҳГ§в”ҳГ в•ӘВ¬в•Әв–’в•ӘВәв•Әв–“в–ҲГ® в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в”ҳГӘ в”ҳГҘв”ҳГ©в•Әв”Ө в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®',\n        status: !dbRoleParity ? 'success' : roleParity ? 'success' : 'warning',\n        desc: !dbRoleParity\n          ? 'в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘ в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҳГ§в”ҳГ в•ӘВ¬в•Әв–’в•ӘВәв•Әв–“в–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө в•ӘВ»в•Әв–’ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬.'\n          : roleParity ? 'в”ҳГ§в•Әв–’ в•ӘВ»в”ҳГӘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ»в•ӘВәв•Әв–’в•ӘВәв–ҲГ® в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГ§в”ҳГ в•ӘВ¬в•Әв–’в•ӘВәв•Әв–“ в”ҳГ§в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ».' : 'в•Әв•Јв•ӘВ»в”ҳГ  в”ҳГ§в”ҳГ в•ӘВ¬в•Әв–’в•ӘВәв•Әв–“в–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө! в–ҲГ®в”ҢвҢҗв–ҲГ® в•ӘВәв•Әв–“ в•Әв•–в•Әв–’в”ҳГјв–ҲГ®в”ҳГҘ в•ӘВ»в•ӘВәв•Әв–’в•ӘВәв–ҲГ® в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГ в•ӘВ¬в”ҳГјв•ӘВәв”ҳГӘв•ӘВ¬в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬.'\n      },\n      {\n        name: 'в•Әв–’в•Әв•Јв•ӘВәв–ҲГ®в•ӘВ¬ в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ®',\n        status: nightViolation ? 'error' : 'success',\n        desc: nightViolation\n          ? `в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’! в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в”ҳГ в”ҳГҘв•ӘВјв•Әв–’ в•ӘВҝв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® в”ҳГҘв•ӘВәв•ӘВәв–ҲГ®в”ҳГ в”ҳГҘ (в•ӘВҝв–ҲГ®в•Әв”Ө в•ӘВәв•Әв–“ ${toFa(dbMaxConsecutiveNights)} в•Әв”Өв•ӘВҝ) в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».`\n          : `в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® (${toFa(dbMaxConsecutiveNights)} в•Әв”Өв•ӘВҝ) в•ӘВҝв”ҳГ§ в•ӘВ»в•Әв–’в•Әв”Ӯв•ӘВ¬в–ҲГ® в•Әв–’в•Әв•Јв•ӘВәв–ҲГ®в•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.`\n      },\n      {\n        name: 'в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ®',\n        status: restViolation ? 'error' : 'success',\n        desc: restViolation\n          ? `в•ӘВ«в•Әв•–в•ӘВә! в”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳв•ӣв•Әв”Ӯ в•ӘВәв•Әв–“ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в”ҢвҢҗв”ҳГ в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ ${toFa(dbMinRestHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».`\n          : `в”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® (в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ ${toFa(dbMinRestHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬) в•ӘВЎв”ҳГјв•Әв•• в”ҳГ в–ҲГ®О“ГҮГ®в”ҢВ»в•Әв–’в•ӘВ»в•ӘВ».`\n      }\n    ]\n  }\n\n  // Visual AI Rescheduling auto-fix (autoresolve) that persists solutions to the DB\n  async function runAiAutofix() {\n    if (conflicts.length === 0) {\n      setNotification({ type: 'success', text: 'в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в–ҲГ®в•ӘВә в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® в•ӘВ»в•Әв–’ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в”ҳГјв•Әв•Јв”ҳГӨв–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».' })\n      return\n    }\n\n    setAiRunning(true)\n    setAiStage(0)\n    await new Promise((resolve) => setTimeout(resolve, 800))\n    setAiStage(1)\n    await new Promise((resolve) => setTimeout(resolve, 800))\n    setAiStage(2)\n    await new Promise((resolve) => setTimeout(resolve, 800))\n    setAiStage(3)\n    await new Promise((resolve) => setTimeout(resolve, 600))\n\n    try {\n      // Save \"off\" overrides in the database for all conflicting cells\n      for (const conflict of conflicts) {\n        await fetch('/api/shifts', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            Authorization: `Bearer ${accessToken}`,\n          },\n          body: JSON.stringify({\n            userId: conflict.userId,\n            date: conflict.date,\n            code: 'off',\n            note: 'в•Әв–’в”ҳГјв•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ¬в•Әв•Јв•ӘВәв•Әв–’в•Әв•ў в•Әв–“в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•– в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n          }),\n        })\n      }\n      setNotification({ type: 'success', text: `в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ ${toFa(conflicts.length)} в•ӘВ¬в•Әв•Јв•ӘВәв•Әв–’в•Әв•ў в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв–’в•ӘВә в•Әв–’в”ҳГјв•Әв•Ј в”ҳГӘ в•ӘВ»в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҢвҢҗв•Әв–’в•ӘВ».` })\n      await loadData()\n    } catch (error) {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв•ӘВәв•ӘВ¬ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setAiRunning(false)\n    }\n  }\n\n  // Open Cell Quick Edit Dialog\n  function handleCellClick(userId: string, dateStr: string, currentShift?: { code: string; note: string | null }) {\n    setSelectedUserId(userId)\n    setSelectedDate(dateStr)\n    setSelectedShiftCode((currentShift?.code as any) || 'morning')\n    setSelectedNote(currentShift?.note || '')\n    setIsCellEdit(true)\n    setShiftModalOpen(true)\n  }\n\n  // Open New Shift Dialog\n  function handleNewShiftClick() {\n    setSelectedUserId(users[0]?.id || '')\n    setSelectedDate(dayjs().format('YYYY-MM-DD'))\n    setSelectedShiftCode('morning')\n    setSelectedNote('')\n    setIsCellEdit(false)\n    setShiftModalOpen(true)\n  }\n\n  // Save Manual Shift Override (POST /api/shifts)\n  async function handleSaveShift(e: React.FormEvent) {\n    e.preventDefault()\n    if (!accessToken) return\n    setFormSubmitLoading(true)\n\n    try {\n      const res = await fetch('/api/shifts', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({\n          userId: selectedUserId,\n          date: selectedDate,\n          code: selectedShiftCode,\n          note: selectedNote || null,\n        }),\n      })\n\n      const json = await res.json()\n      if (res.ok) {\n        setNotification({ type: 'success', text: 'в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВ»в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•Әв”Өв•ӘВ».' })\n        setShiftModalOpen(false)\n        await loadData()\n      } else {\n        setNotification({ type: 'error', text: json.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬' })\n      }\n    } catch {\n      setNotification({ type: 'error', text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’' })\n    } finally {\n      setFormSubmitLoading(false)\n    }\n  }\n\n  // Helper function to detect template regime label\n  const getTemplateRegimeLabel = (tpl: CycleTemplate) => {\n    if (tpl.type === 'staff') return 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ®'\n    const has12hShift = tpl.shifts.some(s => s.hours === 12)\n    if (has12hShift) return 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ®'\n    return 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ®'\n  }\n\n  // Helper function to calculate average weekly hours for a template\n  const getTemplateAvgWeeklyHours = (tpl: CycleTemplate) => {\n    const total = tpl.shifts.reduce((acc, s) => acc + s.hours, 0)\n    const days = tpl.type === 'staff' ? 7 : tpl.length\n    return days > 0 ? ((total / days) * 7).toFixed(1) : '0'\n  }\n\n  // Template Builder Save\n  function handleSaveTemplate() {\n    if (!tplName.trim()) return\n    const finalType = tplRegime === 'staff' ? 'staff' : 'rotational'\n    const finalLength = tplRegime === 'staff' ? 7 : tplLength\n    addTemplate({\n      name: tplName,\n      type: finalType,\n      length: finalLength,\n      shifts: tplShifts\n    })\n    setTplName('')\n    setTplLength(6)\n    setNotification({ type: 'success', text: `в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ \"${tplName}\" в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳГ§в•Әв”Ӯв•ӘВ¬в”ҳГ§ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬в–ҲГ® в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•Әв”Өв•ӘВ».` })\n  }\n\n  // Preset Applier for Metro Line 1 Shift Patterns\n  const applyPreset = (presetType: '12_36' | 'rotational_12h_6d' | 'rotational_9h' | 'three_shift_9h' | 'staff_5d') => {\n    if (presetType === '12_36') {\n      setTplName('в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв–’в–Ҳв–“/в–Ҳв”Ӯв–Ҳв•ў в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ')\n      setTplRegime('rotational_12h')\n      setTplType('rotational')\n      setTplLength(4)\n      setTplShifts([\n        { day: 1, code: 'morning', label: 'в•Әв–’в”ҳГӘв•Әв–“в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 12, startTime: '07:30', endTime: '19:30' },\n        { day: 2, code: 'night', label: 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 12, startTime: '19:30', endTime: '07:30' },\n        { day: 3, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n        { day: 4, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n      ])\n    } else if (presetType === 'rotational_12h_6d') {\n      setTplName('в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв•ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ® в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§')\n      setTplRegime('rotational_12h')\n      setTplType('rotational')\n      setTplLength(6)\n      setTplShifts([\n        { day: 1, code: 'morning', label: 'в•Әв–’в”ҳГӘв•Әв–“в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 12, startTime: '07:00', endTime: '19:00' },\n        { day: 2, code: 'morning', label: 'в•Әв–’в”ҳГӘв•Әв–“в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 12, startTime: '07:00', endTime: '19:00' },\n        { day: 3, code: 'night', label: 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 12, startTime: '19:00', endTime: '07:00' },\n        { day: 4, code: 'night', label: 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 12, startTime: '19:00', endTime: '07:00' },\n        { day: 5, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n        { day: 6, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n      ])\n    } else if (presetType === 'rotational_9h') {\n      setTplName('в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв•ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ® в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§')\n      setTplRegime('rotational_9h')\n      setTplType('rotational')\n      setTplLength(6)\n      setTplShifts([\n        { day: 1, code: 'morning', label: 'в•Әв•Ўв•ӘВҝв•ӘВЎО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '07:00', endTime: '16:00' },\n        { day: 2, code: 'morning', label: 'в•Әв•Ўв•ӘВҝв•ӘВЎО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '07:00', endTime: '16:00' },\n        { day: 3, code: 'evening', label: 'в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '16:00', endTime: '01:00' },\n        { day: 4, code: 'evening', label: 'в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '16:00', endTime: '01:00' },\n        { day: 5, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n        { day: 6, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n      ])\n    } else if (presetType === 'three_shift_9h') {\n      setTplName('в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв•Ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ в–Ҳв”Ӯ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬в”ҳГ§ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§')\n      setTplRegime('rotational_9h')\n      setTplType('rotational')\n      setTplLength(5)\n      setTplShifts([\n        { day: 1, code: 'morning', label: 'в•Әв•Ўв•ӘВҝв•ӘВЎО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '07:00', endTime: '16:00' },\n        { day: 2, code: 'evening', label: 'в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '16:00', endTime: '01:00' },\n        { day: 3, code: 'night', label: 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', hours: 9, startTime: '22:00', endTime: '07:00' },\n        { day: 4, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n        { day: 5, code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)', hours: 0, startTime: '', endTime: '' },\n      ])\n    } else if (presetType === 'staff_5d') {\n      setTplName('в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в–Ҳв•Ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§')\n      setTplRegime('staff')\n      setTplType('staff')\n      setTplLength(7)\n      setTplShifts([\n        { day: 1, code: 'office', label: 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј', hours: 8.75, startTime: '07:30', endTime: '16:15' },\n        { day: 2, code: 'office', label: 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј', hours: 8.75, startTime: '07:30', endTime: '16:15' },\n        { day: 3, code: 'office', label: 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј', hours: 8.75, startTime: '07:30', endTime: '16:15' },\n        { day: 4, code: 'office', label: 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј', hours: 8.75, startTime: '07:30', endTime: '16:15' },\n        { day: 5, code: 'office', label: 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј', hours: 8.75, startTime: '07:30', endTime: '16:15' },\n        { day: 6, code: 'off', label: 'в•ӘВ¬в•Әв•Јв•Әв•–в–ҲГ®в”ҳГӨ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§', hours: 0, startTime: '', endTime: '' },\n        { day: 7, code: 'off', label: 'в•ӘВ¬в•Әв•Јв•Әв•–в–ҲГ®в”ҳГӨ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§', hours: 0, startTime: '', endTime: '' },\n      ])\n    }\n  }\n\n  // Shift Assignment Save\n  function handleSaveAssignment() {\n    if (!assignTplId) return\n    assignTemplate({\n      templateId: assignTplId,\n      targetType: assignTargetType,\n      targetId: assignTargetId,\n      anchorDate: assignAnchorDate\n    })\n    setNotification({ type: 'success', text: 'в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ» в”ҳГӘ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв”ҳГ§О“ГҮГ®в•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ».' })\n    void loadData()\n  }\n\n  // Filtered users for grid\n  const filteredUsers = useMemo(() => {\n    if (department === 'all') return users\n    if (department === 'drivers') {\n      return users.filter((u) => u.role?.key === 'operator')\n    }\n    return users.filter((u) => u.role?.key !== 'operator')\n  }, [users, department])\n\n  // Persian Months for selectors\n  const persianMonths = [\n    { value: 1, label: 'в”ҳГјв•Әв–’в”ҳГӘв•Әв–’в•ӘВ»в–ҲГ®в”ҳГҘ' },\n    { value: 2, label: 'в•ӘВәв•Әв–’в•ӘВ»в–ҲГ®в•ӘВҝв”ҳГ§в•Әв”Өв•ӘВ¬' },\n    { value: 3, label: 'в•ӘВ«в•Әв–’в•ӘВ»в•ӘВәв•ӘВ»' },\n    { value: 4, label: 'в•ӘВ¬в–ҲГ®в•Әв–’' },\n    { value: 5, label: 'в”ҳГ в•Әв–’в•ӘВ»в•ӘВәв•ӘВ»' },\n    { value: 6, label: 'в•Әв”Өв”ҳГ§в•Әв–’в–ҲГ®в”ҳГӘв•Әв–’' },\n    { value: 7, label: 'в”ҳГ в”ҳГ§в•Әв–’' },\n    { value: 8, label: 'в•ӘГів•ӘВҝв•ӘВәв”ҳГҘ' },\n    { value: 9, label: 'в•ӘГів•Әв–‘в•Әв–’' },\n    { value: 10, label: 'в•ӘВ»в–ҲГ®' },\n    { value: 11, label: 'в•ӘВҝв”ҳГ§в”ҳГ в”ҳГҘ' },\n    { value: 12, label: 'в•ӘВәв•Әв”Ӯв”ҳГјв”ҳГҘв•ӘВ»' },\n  ]\n\n  return (\n    <div className=\"flex-1 flex flex-col bg-background text-foreground min-h-screen\" dir=\"rtl\">\n\n      {/* Header Actions & Controls */}\n      <div className=\"px-6 py-4 bg-surface/50 border-b border-border flex flex-col md:flex-row justify-between items-start md:items-center gap-4 shrink-0\">\n        <div>\n          <h1 className=\"text-xl font-bold tracking-tight text-foreground md:text-2xl flex items-center gap-2\">\n            <CalendarIcon className=\"size-6 text-accent\" />\n            в”ҳв•ӣв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГӘ в•ӘВҝв”ҳГ§в–ҲГ®в”ҳГҘв”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§О“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә\n          </h1>\n          <div className=\"flex items-center gap-2 mt-1 text-foreground-muted text-xs font-semibold\">\n            <Shield className=\"size-3.5 text-accent animate-pulse\" />\n            <span>в•ӘВҝв•ӘВ«в•Әв”Ө в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҢвҢҗв”ҳГӨв•ӘВәв”ҳГҘ в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГӘ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ</span>\n          </div>\n        </div>\n\n        {/* Quick Date and AI Actions */}\n        <div className=\"flex flex-wrap items-center gap-3 w-full md:w-auto\">\n          {activeTab === 'roster' && (\n            <>\n              {viewType === 'weekly' ? (\n                <div className=\"flex bg-surface rounded-lg p-1 border border-border/85\">\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon-sm\"\n                    onClick={() => setWeekOffset((o) => o - 1)}\n                    className=\"hover:bg-surface-hover text-foreground-muted rounded-md h-8 w-8 cursor-pointer\"\n                    title=\"в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§ в”ҳГ©в•ӘВҝв”ҳГӨ\"\n                  >\n                    <ChevronRight className=\"size-4\" />\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    onClick={() => setWeekOffset(0)}\n                    className=\"px-3 py-1 text-xs font-bold hover:bg-surface-hover rounded-md text-foreground h-8 cursor-pointer\"\n                  >\n                    в•ӘВәв”ҳГ в•Әв–’в”ҳГӘв•Әв–“\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    size=\"icon-sm\"\n                    onClick={() => setWeekOffset((o) => o + 1)}\n                    className=\"hover:bg-surface-hover text-foreground-muted rounded-md h-8 w-8 cursor-pointer\"\n                    title=\"в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§ в•ӘВҝв•Әв•Јв•ӘВ»\"\n                  >\n                    <ChevronLeft className=\"size-4\" />\n                  </Button>\n                </div>\n              ) : (\n                <div className=\"flex items-center gap-2 bg-surface p-1 rounded-lg border border-border/80\">\n                  <select\n                    value={selectedMonth}\n                    onChange={(e) => setSelectedMonth(Number(e.target.value))}\n                    className=\"bg-transparent text-xs font-semibold text-foreground outline-none px-2 py-1 cursor-pointer border-none\"\n                  >\n                    {persianMonths.map((m) => (\n                      <option key={m.value} value={m.value} className=\"bg-surface\">\n                        {m.label}\n                      </option>\n                    ))}\n                  </select>\n                  <select\n                    value={selectedYear}\n                    onChange={(e) => setSelectedYear(Number(e.target.value))}\n                    className=\"bg-transparent text-xs font-semibold text-foreground outline-none px-2 py-1 cursor-pointer border-none\"\n                  >\n                    <option value={2026} className=\"bg-surface\">{toFa(2026)}</option>\n                    <option value={2027} className=\"bg-surface\">{toFa(2027)}</option>\n                  </select>\n                </div>\n              )}\n\n              <Button\n                onClick={runAiAutofix}\n                disabled={aiRunning || conflicts.length === 0}\n                className=\"px-4 h-9 border border-border bg-surface hover:bg-surface-hover text-foreground rounded-lg text-xs font-bold transition-all flex items-center gap-2 cursor-pointer disabled:opacity-40\"\n              >\n                <Sparkles className=\"size-3.5 text-warning shrink-0\" />\n                в•ӘВЎв”ҳГӨ в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВә в•ӘВҝв•ӘВә AI\n              </Button>\n\n              <Button\n                onClick={handleNewShiftClick}\n                className=\"px-4 h-9 bg-accent hover:bg-accent-hover text-accent-foreground rounded-lg text-xs font-bold transition-all flex items-center gap-1.5 shadow cursor-pointer\"\n              >\n                <Plus className=\"size-4 shrink-0\" />\n                в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ» в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n              </Button>\n            </>\n          )}\n        </div>\n      </div>\n\n      {/* Tabs Menu */}\n      <div className=\"flex border-b border-border bg-surface/25 px-6 shrink-0\">\n        <button\n          onClick={() => setActiveTab('roster')}\n          className={cn(\n            \"px-4 py-3.5 text-xs font-bold border-b-2 transition-all flex items-center gap-2 cursor-pointer\",\n            activeTab === 'roster'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <CalendarIcon className=\"size-4\" />\n          в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ (Roster Grid)\n        </button>\n        <button\n          onClick={() => setActiveTab('builder')}\n          className={cn(\n            \"px-4 py-3.5 text-xs font-bold border-b-2 transition-all flex items-center gap-2 cursor-pointer\",\n            activeTab === 'builder'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <Sliders className=\"size-4\" />\n          в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ (Template Builder)\n        </button>\n        <button\n          onClick={() => setActiveTab('assignments')}\n          className={cn(\n            \"px-4 py-3.5 text-xs font-bold border-b-2 transition-all flex items-center gap-2 cursor-pointer\",\n            activeTab === 'assignments'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <UserCheck className=\"size-4\" />\n          в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВә в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n        </button>\n        <button\n          onClick={() => setActiveTab('swaps')}\n          className={cn(\n            \"px-4 py-3.5 text-xs font-bold border-b-2 transition-all flex items-center gap-2 cursor-pointer relative\",\n            activeTab === 'swaps'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <ArrowLeftRight className=\"size-4\" />\n          в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n          {swapRequests.length > 0 && (\n            <span className=\"absolute top-1.5 left-1 size-4 bg-accent text-accent-foreground text-[8px] font-black rounded-full flex items-center justify-center\">\n              {swapRequests.length}\n            </span>\n          )}\n        </button>\n        <button\n          onClick={() => setActiveTab('settings')}\n          className={cn(\n            \"px-4 py-3.5 text-xs font-bold border-b-2 transition-all flex items-center gap-2 cursor-pointer\",\n            activeTab === 'settings'\n              ? \"border-accent text-accent\"\n              : \"border-transparent text-foreground-muted hover:text-foreground\"\n          )}\n        >\n          <Settings className=\"size-4\" />\n          в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬\n        </button>\n      </div>\n\n      {/* Notification Banner */}\n      {notification && (\n        <div\n          className={cn(\n            \"mx-6 mt-4 flex items-center gap-2 p-4 rounded-lg border text-xs font-bold animate-in fade-in slide-in-from-top-2 duration-300\",\n            notification.type === 'success'\n              ? 'bg-success/10 border-success/30 text-success'\n              : 'bg-critical/10 border-critical/30 text-critical'\n          )}\n        >\n          {notification.type === 'success' ? (\n            <CheckCircle2 className=\"size-4 shrink-0\" />\n          ) : (\n            <AlertTriangle className=\"size-4 shrink-0\" />\n          )}\n          <span>{notification.text}</span>\n        </div>\n      )}\n\n      {/* Tab Contents */}\n      <div className=\"flex-1 overflow-hidden\">\n\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {/* TAB 1: ROSTER GRID (THE MAIN TIMETABLE) */}\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {activeTab === 'roster' && (\n          <div className=\"h-full overflow-hidden p-4 md:p-6 flex flex-col lg:flex-row gap-6\">\n\n            {/* Left: Schedule Grid Container */}\n            <div className=\"w-full lg:w-8/12 flex flex-col gap-4 h-full overflow-hidden\">\n\n              {/* Grid Top Filters */}\n              <div className=\"bg-surface/40 border border-border rounded-xl p-3 flex justify-between items-center gap-3 shrink-0\">\n                <div className=\"flex gap-2\">\n                  <select\n                    value={department}\n                    onChange={(e) => setDepartment(e.target.value)}\n                    className=\"bg-background/50 border border-border rounded-lg px-3 py-1.5 text-xs text-foreground font-bold outline-none focus-visible:border-accent cursor-pointer\"\n                  >\n                    <option value=\"all\">в”ҳГ§в”ҳГ в”ҳГ§ в•ӘВ»в”ҳв•ӣв•ӘВәв•Әв–’в•ӘВ¬в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә</option>\n                    <option value=\"drivers\">в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’</option>\n                    <option value=\"staff\">в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§в–ҲГ® в”ҳГӘ в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®</option>\n                  </select>\n\n                  <select\n                    value={lineFilter}\n                    onChange={(e) => setLineFilter(e.target.value)}\n                    className=\"bg-background/50 border border-border rounded-lg px-3 py-1.5 text-xs text-foreground font-bold outline-none focus-visible:border-accent cursor-pointer\"\n                  >\n                    <option value=\"line1\">в•ӘВ«в•Әв•– в–Ҳв–’ - в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө в•ӘВҝв”ҳГ§ в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ</option>\n                  </select>\n                </div>\n\n                <div className=\"flex bg-background/50 rounded-lg p-0.5 border border-border\">\n                  <Button\n                    variant=\"ghost\"\n                    onClick={() => setViewType('weekly')}\n                    className={cn(\n                      \"px-3 h-7 text-xs font-bold rounded-md transition-all cursor-pointer\",\n                      viewType === 'weekly'\n                        ? 'bg-accent text-accent-foreground shadow'\n                        : 'text-foreground-muted hover:text-foreground'\n                    )}\n                  >\n                    в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ®\n                  </Button>\n                  <Button\n                    variant=\"ghost\"\n                    onClick={() => setViewType('monthly')}\n                    className={cn(\n                      \"px-3 h-7 text-xs font-bold rounded-md transition-all cursor-pointer\",\n                      viewType === 'monthly'\n                        ? 'bg-accent text-accent-foreground shadow'\n                        : 'text-foreground-muted hover:text-foreground'\n                    )}\n                  >\n                    в”ҳГ в•ӘВәв”ҳГ§в•ӘВәв”ҳГҘв”ҳГ§\n                  </Button>\n                </div>\n              </div>\n\n              {/* Grid Timetable */}\n              <div className=\"bg-surface/40 border border-border rounded-xl flex-1 overflow-hidden flex flex-col shadow-md backdrop-blur-sm\">\n                {loading ? (\n                  <div className=\"flex-1 flex flex-col items-center justify-center p-12 text-center\">\n                    <Loader2 className=\"size-8 animate-spin text-accent mb-3\" />\n                    <p className=\"text-sm text-foreground-muted font-medium\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Ӯв•Әв–’в•ӘВәв•Әв”Ӯв•Әв–’в–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’...</p>\n                  </div>\n                ) : filteredUsers.length > 0 ? (\n                  <div className=\"overflow-auto flex-1 scrollbar-thin relative\">\n                    <table className=\"w-full text-right border-collapse min-w-[900px]\">\n                      <thead className=\"bg-surface/95 text-foreground sticky top-0 z-30 border-b border-border/80 backdrop-blur-md\">\n                        <tr>\n                          <th className=\"py-3.5 px-4 text-xs font-black w-52 text-start sticky right-0 z-40 bg-surface border-l border-border/80 shadow-[2px_0_5px_rgba(0,0,0,0.3)]\">\n                            в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                          </th>\n                          {activeDays.map((day, idx) => {\n                            const isToday = dayjs(day).format('YYYY-MM-DD') === dayjs().format('YYYY-MM-DD')\n                            return (\n                              <th\n                                key={idx}\n                                className={cn(\n                                  \"py-2 px-2 text-center text-xs font-bold border-l border-border/60 min-w-[100px]\",\n                                  isToday ? 'bg-accent/10 text-accent font-black' : ''\n                                )}\n                              >\n                                <div className=\"text-[11px]\">{dayjs(day).format('dddd')}</div>\n                                <div className=\"text-[9px] text-foreground-muted/85 font-data-mono mt-0.5\">\n                                  {toFa(dayjs(day).format('MM/DD'))}\n                                </div>\n                              </th>\n                            )\n                          })}\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-border/50\">\n                        {filteredUsers.map((user) => (\n                          <tr key={user.id} className=\"hover:bg-surface-hover/10 transition-colors\">\n                            {/* Sticky User Info Cell */}\n                            <td className=\"py-3 px-4 sticky right-0 z-20 bg-surface/90 border-l border-border/50 backdrop-blur-sm shadow-[2px_0_5px_rgba(0,0,0,0.15)]\">\n                              <div className=\"flex items-center gap-2.5 text-start\">\n                                <div className=\"w-8 h-8 rounded-full bg-accent/10 text-accent flex items-center justify-center font-bold border border-accent/20 text-xs shrink-0\">\n                                  {user.name.slice(0, 2)}\n                                </div>\n                                <div className=\"overflow-hidden\">\n                                  <div className=\"text-xs font-bold text-foreground truncate\">{user.name}</div>\n                                  <div className=\"text-[9px] text-foreground-muted/90 truncate mt-0.5 flex items-center gap-1\">\n                                    <span>{user.role?.name || 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’'}</span>\n                                    <span className=\"text-[8px] bg-surface-container border border-border rounded px-1\">\n                                      в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ {toFa(user.customFields?.group || 'A')}\n                                    </span>\n                                  </div>\n                                </div>\n                              </div>\n                            </td>\n\n                            {/* Shift Cells */}\n                            {activeDays.map((day, idx) => {\n                              const dateStr = dayjs(day).format('YYYY-MM-DD')\n                              const shift = resolvedRosterMap[user.id]?.[dateStr]\n                              const hasConflict = conflicts.some((c) => c.userId === user.id && c.date === dateStr)\n\n                              return (\n                                <td\n                                  key={idx}\n                                  onClick={() => handleCellClick(user.id, dateStr, shift)}\n                                  className=\"p-1 border-l border-border/30 cursor-pointer min-w-[100px]\"\n                                >\n                                  {shift ? (\n                                    <div\n                                      className={cn(\n                                        \"rounded-lg p-2 text-center border relative transition-all group\",\n                                        hasConflict\n                                          ? 'bg-critical/10 border-critical/40 text-critical hover:bg-critical/15 ring-1 ring-critical/20'\n                                          : shift.isOverride\n                                            ? cn(shiftColors[shift.code], \"border-accent/40 ring-1 ring-accent/10\")\n                                            : shiftColors[shift.code] || 'bg-surface border-border'\n                                      )}\n                                      title={shift.note || ''}\n                                    >\n                                      {/* Override Indicator */}\n                                      {shift.isOverride && (\n                                        <div className=\"absolute top-1 right-1\" title=\"в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ» в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•– в•ӘВәв•ӘВ»в”ҳГ в–ҲГ®в”ҳГҘ\">\n                                          <div className=\"size-1 bg-accent rounded-full animate-pulse\" />\n                                        </div>\n                                      )}\n\n                                      {/* Conflict icon */}\n                                      {hasConflict && (\n                                        <div className=\"absolute top-1 left-1\" title=\"в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® в–ҲГ®в•ӘВә в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ\">\n                                          <AlertTriangle className=\"size-3 text-critical animate-pulse\" />\n                                        </div>\n                                      )}\n\n                                      {/* Pulsing indicator for active live shift */}\n                                      {!hasConflict && isShiftLive(dateStr, shift.code) && (\n                                        <span className=\"absolute top-1 left-1 flex h-1.5 w-1.5\">\n                                          <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75\"></span>\n                                          <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-success\"></span>\n                                        </span>\n                                      )}\n\n                                      <div className=\"font-data-mono text-xs font-bold leading-none\">{toFa(shiftTimes[shift.code] || '')}</div>\n                                      <div className=\"text-[8.5px] text-foreground-muted/90 mt-1 font-bold leading-none truncate\">\n                                        {isShiftLive(dateStr, shift.code) ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВәв•ӘВјв•Әв–’в•ӘВә' : shift.label}\n                                      </div>\n                                    </div>\n                                  ) : (\n                                    <div className=\"rounded-lg p-2 text-center border border-dashed border-border/65 text-foreground-muted/55 hover:border-border/90 transition-colors\">\n                                      <div className=\"font-data-mono text-xs\">-</div>\n                                      <div className=\"text-[9px] mt-1\">-</div>\n                                    </div>\n                                  )}\n                                </td>\n                              )\n                            })}\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                ) : (\n                  <div className=\"flex-1 flex flex-col items-center justify-center p-12 text-center\">\n                    <Users className=\"size-12 text-foreground-muted/40 mb-3\" />\n                    <p className=\"text-sm text-foreground-muted font-medium\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВ»в”ҳв•ӣв•ӘВәв•Әв–’в•ӘВ¬в”ҳГ в•ӘВәв”ҳГҘ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў в•Әв”Өв•ӘВ»в”ҳГ§ в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».</p>\n                  </div>\n                )}\n              </div>\n            </div>\n\n            {/* Right: Sidebar widgets */}\n            <div className=\"w-full lg:w-4/12 flex flex-col gap-6 h-full overflow-y-auto\">\n\n              {/* Roster Live Status Widget */}\n              <div className=\"bg-surface/40 border border-border rounded-xl p-5 shadow-md relative overflow-hidden backdrop-blur-sm\">\n                <div className=\"absolute top-0 right-0 w-full h-[3px] bg-accent\"></div>\n                <h2 className=\"text-xs font-black text-foreground mb-4 flex items-center gap-2\">\n                  <Users className=\"size-4 text-accent\" />\n                  в•ӘВ«в”ҳГӨв•ӘВәв•Әв•Ўв”ҳГ§ в•ӘГів”ҳГ в•ӘВәв•Әв–’в–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГ в•Әв–’в”ҳГӘв•Әв–“\n                </h2>\n\n                <div className=\"grid grid-cols-2 gap-3 mb-4\">\n                  <div className=\"bg-surface/30 border border-border rounded-lg p-3 text-center\">\n                    <div className=\"text-xl font-black text-success\">{toFa(12)}</div>\n                    <div className=\"text-[10px] text-foreground-muted font-bold mt-1\">в•ӘВЎв•ӘВәв•Әв•ўв•Әв–’ в•ӘВ»в•Әв–’ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬</div>\n                  </div>\n                  <div className=\"bg-surface/30 border border-border rounded-lg p-3 text-center\">\n                    <div className=\"text-xl font-black text-foreground\">{toFa(8)}</div>\n                    <div className=\"text-[10px] text-foreground-muted font-bold mt-1\">в•ӘГів”ҳГј / в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬</div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-3\">\n                  <div>\n                    <div className=\"flex justify-between items-center text-[11px] text-foreground-muted mb-1 font-bold\">\n                      <span>в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘГів”ҳГ в•ӘВәв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВҝв•ӘВәв•Әв”Ө (Standby)</span>\n                      <span className=\"font-bold text-foreground\">{toFa(3)} в”ҳГҘв”ҳГјв•Әв–’</span>\n                    </div>\n                    <div className=\"w-full bg-surface-container rounded-full h-1 border border-border\">\n                      <div className=\"bg-success h-1 rounded-full\" style={{ width: '75%' }}></div>\n                    </div>\n                  </div>\n                  <div>\n                    <div className=\"flex justify-between items-center text-[11px] text-foreground-muted mb-1 font-bold\">\n                      <span>в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв–“в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ©в•Әв–’в”ҳГ в•Әв–“</span>\n                      <span className=\"font-bold text-critical\">{toFa(conflicts.length)} в”ҳГ в”ҳГӘв•Әв–’в•ӘВ»</span>\n                    </div>\n                    <div className=\"w-full bg-surface-container rounded-full h-1 border border-border\">\n                      <div className={cn(\"h-1 rounded-full\", conflicts.length > 0 ? \"bg-critical\" : \"bg-success\")} style={{ width: conflicts.length > 0 ? '100%' : '0%' }}></div>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              {/* Safety Conflicts Widget */}\n              {conflicts.length > 0 && (\n                <div className=\"bg-critical/5 border border-critical/20 rounded-xl p-5 shadow-md space-y-3.5 relative overflow-hidden backdrop-blur-sm\">\n                  <div className=\"absolute right-0 top-0 w-1.5 h-full bg-accent animate-pulse\"></div>\n                  <h2 className=\"text-xs font-black text-critical flex items-center gap-1.5\">\n                    <AlertTriangle className=\"size-4 text-critical animate-bounce\" />\n                    в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГӘ в•Әв”Ӯв–ҲГ®в•Әв–’ ({toFa(conflicts.length)})\n                  </h2>\n\n                  <div className=\"space-y-2.5 max-h-[220px] overflow-y-auto pr-1\">\n                    {conflicts.map((con, idx) => (\n                      <div key={idx} className=\"bg-critical/10 border border-critical/20 rounded-lg p-2.5 space-y-1 hover:border-critical/30 transition-colors\">\n                        <div className=\"flex items-center justify-between border-b border-critical/15 pb-1\">\n                          <span className=\"text-xs font-bold text-critical\">{con.userName}</span>\n                        </div>\n                        <p className=\"text-[10px] text-foreground-muted leading-relaxed font-semibold\">\n                          {con.reason}\n                        </p>\n                      </div>\n                    ))}\n                  </div>\n\n                  <Button\n                    onClick={runAiAutofix}\n                    disabled={aiRunning}\n                    className=\"w-full bg-accent hover:bg-accent-hover text-accent-foreground text-xs font-bold py-2 h-9 rounded-lg transition-all shadow flex items-center justify-center gap-1.5 cursor-pointer\"\n                  >\n                    <Sparkles className=\"size-3.5\" />\n                    в•Әв–’в”ҳГјв•Әв•Ј в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВә в•ӘВҝв•ӘВә в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ®\n                  </Button>\n                </div>\n              )}\n\n              {/* Roster Guide Info Box */}\n              <div className=\"bg-surface/35 border border-border/80 rounded-xl p-4.5 space-y-3 backdrop-blur-sm text-xs text-foreground-muted leading-relaxed\">\n                <h3 className=\"font-bold text-foreground flex items-center gap-1.5 border-b border-border/40 pb-2\">\n                  <Info className=\"size-4 text-accent\" />\n                  в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВәв–ҲГ® в”ҢвҢҗв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§О“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®\n                </h3>\n                <p>в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Ӯв•Әв–’в•ӘВәв•Әв”Ӯв•Әв–’в–ҲГ® в•ӘВЎв•ӘВәв•Әв•Ўв”ҳГӨ в•ӘВәв•ӘВ»в•Әв•‘в•ӘВәв”ҳГ  в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в”ҳГӘ в”ҳГ в•ӘВ¬в•Әв•‘в–ҲГ®в•Әв–’ в•ӘВҝв•ӘВә в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ® (в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ»в”ҳГ§в•ӘВә) в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n                <ul className=\"space-y-1.5 pr-2 border-r border-border/50\">\n                  <li className=\"flex items-center gap-1.5\"><span className=\"size-2 rounded bg-success/25 border border-success\" /> в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв•Ўв•ӘВҝв•ӘВЎ: в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ (в–Ҳв–‘в–Ҳв•–:в–Ҳв–‘в–Ҳв–‘ в•ӘВәв”ҳГӨв–ҲГ® в–Ҳв–’в–Ҳв•ў:в–Ҳв–‘в–Ҳв–‘)</li>\n                  <li className=\"flex items-center gap-1.5\"><span className=\"size-2 rounded bg-info/25 border border-info\" /> в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв•Јв•Әв•Ўв•Әв–’: в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ (в–Ҳв–’в–Ҳв•ў:в–Ҳв–‘в–Ҳв–‘ в•ӘВәв”ҳГӨв–ҲГ® в–Ҳв–‘в–Ҳв–’:в–Ҳв–‘в–Ҳв–‘)</li>\n                  <li className=\"flex items-center gap-1.5\"><span className=\"size-2 rounded bg-purple-500/25 border border-purple-500\" /> в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ: в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ (в–Ҳв–’в–Ҳв•Ј:в–Ҳв–‘в–Ҳв–‘ в•ӘВәв”ҳГӨв–ҲГ® в–Ҳв–‘в–Ҳв•–:в–Ҳв–‘в–Ҳв–‘ в•Әв•Ўв•ӘВҝв•ӘВЎ)</li>\n                  <li className=\"flex items-center gap-1.5\"><span className=\"size-2 rounded bg-indigo-500/25 border border-indigo-500\" /> в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®: в–Ҳв••.в–Ҳв•–в–Ҳв•Ў в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј</li>\n                </ul>\n              </div>\n\n            </div>\n          </div>\n        )}\n\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {/* TAB 2: TEMPLATE BUILDER */}\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {activeTab === 'builder' && (() => {\n          const totalHours = tplShifts.reduce((acc, s) => acc + s.hours, 0)\n          const cycleDays = tplRegime === 'staff' ? 7 : tplLength\n          const avgWeeklyHours = cycleDays > 0 ? ((totalHours / cycleDays) * 7).toFixed(1) : '0'\n          const workDays = tplShifts.filter(s => s.code !== 'off').length\n          const offDays = tplShifts.filter(s => s.code === 'off').length\n\n          return (\n            <div className=\"h-full overflow-y-auto p-4 md:p-6 space-y-6\">\n              <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\n\n                {/* Left Form: Create Template */}\n                <div className=\"lg:col-span-5\">\n                  <Card className=\"border-border bg-surface-container-low/80 backdrop-blur\">\n                    <CardHeader>\n                      <CardTitle className=\"text-base font-bold flex items-center gap-1.5 justify-start\">\n                        <Sliders className=\"size-5 text-accent\" />\n                        в•Әв•–в•Әв–’в•ӘВәв•ӘВЎв–ҲГ® в”ҳГӘ в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n                      </CardTitle>\n                      <CardDescription className=\"text-xs text-start\">\n                        в–ҲГ®в”ҢвҢҗ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв•ӘВ«в•ӘВ¬в•Әв•Ўв•ӘВәв•Әв•Ўв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§в•ӘГ® в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в–ҲГ®в•ӘВә в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                      </CardDescription>\n                    </CardHeader>\n                    <CardContent className=\"space-y-5\">\n                      {/* Name */}\n                      <div className=\"space-y-1.5\">\n                        <Label htmlFor=\"tpl-name\" className=\"text-xs font-bold flex justify-start\">в”ҳГҘв•ӘВәв”ҳГ  в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ</Label>\n                        <Input\n                          id=\"tpl-name\"\n                          placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: в–Ҳв”Ө в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ в–Ҳв–’в–Ҳв–“/в–Ҳв”Ӯв–Ҳв•ў в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВ«в•Әв•– в–Ҳв–’\"\n                          value={tplName}\n                          onChange={(e) => setTplName(e.target.value)}\n                          className=\"h-10 text-sm border-border text-start\"\n                        />\n                      </div>\n\n                      {/* Work Regime Selection */}\n                      <div className=\"space-y-2\">\n                        <Label className=\"text-xs font-bold flex justify-start\">в•Әв–’в”ҢГҝв–ҲГ®в”ҳГ  в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в”ҳГӘ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬О“ГҮГ®в•ӘВ»в”ҳГ§в–ҲГ®</Label>\n                        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-2.5\">\n                          {/* Card 1: 9-hour rotational */}\n                          <button\n                            type=\"button\"\n                            onClick={() => {\n                              setTplRegime('rotational_9h')\n                              setTplType('rotational')\n                              setTplLength(6)\n                            }}\n                            className={cn(\n                              \"p-3 rounded-xl border text-start transition-all cursor-pointer flex flex-col justify-between h-24 w-full\",\n                              tplRegime === 'rotational_9h'\n                                ? \"border-accent bg-accent/5 ring-1 ring-accent/20\"\n                                : \"border-border bg-background/40 hover:bg-background/85\"\n                            )}\n                          >\n                            <div className=\"flex items-center justify-between w-full\">\n                              <span className={cn(\"text-xs font-bold\", tplRegime === 'rotational_9h' ? \"text-accent\" : \"text-foreground\")}>в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ®</span>\n                              <Clock className={cn(\"size-4\", tplRegime === 'rotational_9h' ? \"text-accent\" : \"text-foreground-muted\")} />\n                            </div>\n                            <div className=\"text-[9px] text-foreground-muted leading-relaxed\">\n                              в”ҳГӘв–ҲГ®в”ҢГҝв”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•Әв•Ўв•ӘВҝв•ӘВЎ в”ҳГӘ в•Әв•Јв•Әв•Ўв•Әв–’ в•ӘВ«в•Әв•– в–Ҳв–’. в•Әв”Ӯв–ҲГ®в”ҢвҢҗв”ҳГӨ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў: в–Ҳв•ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§.\n                            </div>\n                          </button>\n\n                          {/* Card 2: 12-hour rotational */}\n                          <button\n                            type=\"button\"\n                            onClick={() => {\n                              setTplRegime('rotational_12h')\n                              setTplType('rotational')\n                              setTplLength(4)\n                            }}\n                            className={cn(\n                              \"p-3 rounded-xl border text-start transition-all cursor-pointer flex flex-col justify-between h-24 w-full\",\n                              tplRegime === 'rotational_12h'\n                                ? \"border-accent bg-accent/5 ring-1 ring-accent/20\"\n                                : \"border-border bg-background/40 hover:bg-background/85\"\n                            )}\n                          >\n                            <div className=\"flex items-center justify-between w-full\">\n                              <span className={cn(\"text-xs font-bold\", tplRegime === 'rotational_12h' ? \"text-accent\" : \"text-foreground\")}>в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ®</span>\n                              <CalendarIcon className={cn(\"size-4\", tplRegime === 'rotational_12h' ? \"text-accent\" : \"text-foreground-muted\")} />\n                            </div>\n                            <div className=\"text-[9px] text-foreground-muted leading-relaxed\">\n                              в•Әв–’в”ҢГҝв–ҲГ®в”ҳГ  в•Әв”Ӯв”ҳГҘв”ҢВ»в–ҲГ®в”ҳГҘ в–Ҳв–’в–Ҳв–“/в–Ҳв”Ӯв–Ҳв•ў в”ҳГӘ в–Ҳв–’в–Ҳв–“/в–Ҳв”Өв–Ҳв•• (в•Әв–’в”ҳГӘв•Әв–“в•ӘГ® в•Әв”Өв•ӘВҝв•ӘГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬). в•Әв”Ӯв–ҲГ®в”ҢвҢҗв”ҳГӨ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў: в–Ҳв”Ө в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§.\n                            </div>\n                          </button>\n\n                          {/* Card 3: Staff */}\n                          <button\n                            type=\"button\"\n                            onClick={() => {\n                              setTplRegime('staff')\n                              setTplType('staff')\n                              setTplLength(7)\n                            }}\n                            className={cn(\n                              \"p-3 rounded-xl border text-start transition-all cursor-pointer flex flex-col justify-between h-24 w-full\",\n                              tplRegime === 'staff'\n                                ? \"border-accent bg-accent/5 ring-1 ring-accent/20\"\n                                : \"border-border bg-background/40 hover:bg-background/85\"\n                            )}\n                          >\n                            <div className=\"flex items-center justify-between w-full\">\n                              <span className={cn(\"text-xs font-bold\", tplRegime === 'staff' ? \"text-accent\" : \"text-foreground\")}>в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® в”ҳГӘ в”ҳв•ӣв•Әв”Өв•ӘВ¬в–ҲГ®в•ӘВҝв•ӘВәв”ҳГҘв–ҲГ®</span>\n                              <Users className={cn(\"size-4\", tplRegime === 'staff' ? \"text-accent\" : \"text-foreground-muted\")} />\n                            </div>\n                            <div className=\"text-[9px] text-foreground-muted leading-relaxed\">\n                              в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВҪв•ӘВәв•ӘВҝв•ӘВ¬ в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ® в”ҳГ§в”ҳГ в”ҢВ»в•ӘВәв”ҳГ  в•ӘВҝв•ӘВә в•ӘВ¬в”ҳГ©в”ҳГӘв–ҲГ®в”ҳГ  в•ӘВјв”ҳГӨв•ӘВәв”ҳГӨв–ҲГ® в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ® в”ҢвҢҗв•Әв”Өв”ҳГӘв•Әв–’.\n                            </div>\n                          </button>\n                        </div>\n                      </div>\n\n                      {/* Presets */}\n                      <div className=\"space-y-2 border-t border-border/30 pt-4\">\n                        <Label className=\"text-xs font-bold flex justify-start text-foreground/90\">в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в•ӘГів”ҳГ в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГӘ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•ӘВ«в•Әв•– в–Ҳв–’</Label>\n                        <div className=\"flex flex-wrap gap-1.5 justify-start\">\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            type=\"button\"\n                            onClick={() => applyPreset('12_36')}\n                            className=\"text-[10px] h-7 px-2 border-border/70 hover:border-accent hover:text-accent cursor-pointer\"\n                          >\n                            <Sparkles className=\"size-3 me-1 text-accent animate-pulse\" />\n                            в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв–’в–Ҳв–“/в–Ҳв”Ӯв–Ҳв•ў в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ® (в•Әв–’в”ҳГӘв•Әв–“в•ӘГ® в•Әв”Өв•ӘВҝв•ӘГ® в–Ҳв–“в•ӘГів”ҳГј)\n                          </Button>\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            type=\"button\"\n                            onClick={() => applyPreset('rotational_12h_6d')}\n                            className=\"text-[10px] h-7 px-2 border-border/70 hover:border-accent hover:text-accent cursor-pointer\"\n                          >\n                            <CalendarIcon className=\"size-3 me-1 text-amber-500 animate-pulse\" />\n                            в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в–Ҳв•ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ (в–Ҳв–“в•Әв–’в”ҳГӘв•Әв–“в•ӘГ® в–Ҳв–“в•Әв”Өв•ӘВҝв•ӘГ® в–Ҳв–“в•ӘГів”ҳГј)\n                          </Button>\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            type=\"button\"\n                            onClick={() => applyPreset('rotational_9h')}\n                            className=\"text-[10px] h-7 px-2 border-border/70 hover:border-accent hover:text-accent cursor-pointer\"\n                          >\n                            <Clock className=\"size-3 me-1 text-success\" />\n                            в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ® (в–Ҳв–“в•Әв•Ўв•ӘВҝв•ӘВЎв•ӘГ® в–Ҳв–“в•Әв•Јв•Әв•Ўв•Әв–’в•ӘГ® в–Ҳв–“в•ӘГів”ҳГј)\n                          </Button>\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            type=\"button\"\n                            onClick={() => applyPreset('three_shift_9h')}\n                            className=\"text-[10px] h-7 px-2 border-border/70 hover:border-accent hover:text-accent cursor-pointer\"\n                          >\n                            <ArrowLeftRight className=\"size-3 me-1 text-info\" />\n                            в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в–Ҳв”Ӯ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬в”ҳГ§ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§ (в•Әв•Ўв•ӘВҝв•ӘВЎв•ӘГ® в•Әв•Јв•Әв•Ўв•Әв–’в•ӘГ® в•Әв”Өв•ӘВҝв•ӘГ® в–Ҳв–“в•ӘГів”ҳГј)\n                          </Button>\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            type=\"button\"\n                            onClick={() => applyPreset('staff_5d')}\n                            className=\"text-[10px] h-7 px-2 border-border/70 hover:border-accent hover:text-accent cursor-pointer\"\n                          >\n                            <UserCheck className=\"size-3 me-1 text-purple-400\" />\n                            в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ® в–Ҳв•Ў в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®\n                          </Button>\n                        </div>\n                      </div>\n\n                      {/* Cycle Length Input */}\n                      {tplRegime !== 'staff' && (\n                        <div className=\"space-y-1.5 border-t border-border/30 pt-4 animate-in fade-in slide-in-from-top-1 duration-200\">\n                          <Label htmlFor=\"tpl-len\" className=\"text-xs font-bold flex justify-start\">в•Әв•–в”ҳГӘв”ҳГӨ в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§ в•ӘВ¬в”ҳГҘв•ӘВәв”ҳГӘв•ӘВҝ (в•Әв–’в”ҳГӘв•Әв–“)</Label>\n                          <div className=\"flex items-center gap-3\">\n                            <Input\n                              id=\"tpl-len\"\n                              type=\"number\"\n                              min={1}\n                              max={30}\n                              value={tplLength}\n                              onChange={(e) => setTplLength(Math.max(1, Number(e.target.value)))}\n                              className=\"h-9 text-sm border-border text-start w-24\"\n                            />\n                            <span className=\"text-[10px] text-foreground-muted text-start leading-relaxed\">\n                              в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§ в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в•Әв–“в–ҲГ®в•Әв–’ в•ӘВәв•Әв•ўв•ӘВәв”ҳГјв”ҳГ§ в”ҳГӘ в”ҳГ©в•ӘВәв•ӘВҝв”ҳГӨ в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв”ҳГҘв•ӘВ».\n                            </span>\n                          </div>\n                        </div>\n                      )}\n\n                      {/* Roster shifts detail inputs */}\n                      <div className=\"border-t border-border/30 pt-4 space-y-3\">\n                        <div className=\"flex items-center justify-between\">\n                          <h3 className=\"text-xs font-bold text-foreground/95 flex justify-start\">в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ  в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§:</h3>\n                          <Badge variant=\"secondary\" className=\"text-[9px] font-bold\">\n                            {toFa(tplShifts.length)} в•Әв–’в”ҳГӘв•Әв–“ в•ӘВ»в•Әв–’ в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§\n                          </Badge>\n                        </div>\n\n                        <div className=\"space-y-2 max-h-64 overflow-y-auto pr-1\">\n                          {tplShifts.map((dayShift, idx) => (\n                            <div key={dayShift.day} className=\"flex items-center gap-2 bg-background/40 border border-border/60 p-2.5 rounded-xl text-xs justify-between\">\n                              <span className=\"font-bold shrink-0 text-foreground-muted w-12 text-start\">в•Әв–’в”ҳГӘв•Әв–“ {toFa(dayShift.day)}:</span>\n\n                              <select\n                                value={dayShift.code}\n                                onChange={(e) => {\n                                  const newShifts = [...tplShifts]\n                                  const code = e.target.value as any\n                                  newShifts[idx].code = code\n\n                                  if (tplRegime === 'rotational_12h') {\n                                    if (code === 'morning') {\n                                      newShifts[idx].label = 'в•Әв–’в”ҳГӘв•Әв–“в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§'\n                                      newShifts[idx].hours = 12\n                                      newShifts[idx].startTime = '07:00'\n                                      newShifts[idx].endTime = '19:00'\n                                    } else if (code === 'night') {\n                                      newShifts[idx].label = 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§'\n                                      newShifts[idx].hours = 12\n                                      newShifts[idx].startTime = '19:00'\n                                      newShifts[idx].endTime = '07:00'\n                                    } else {\n                                      newShifts[idx].label = 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)'\n                                      newShifts[idx].hours = 0\n                                      newShifts[idx].startTime = ''\n                                      newShifts[idx].endTime = ''\n                                    }\n                                  } else if (tplRegime === 'rotational_9h') {\n                                    if (code === 'morning') {\n                                      newShifts[idx].label = 'в•Әв•Ўв•ӘВҝв•ӘВЎО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§'\n                                      newShifts[idx].hours = 9\n                                      newShifts[idx].startTime = '07:00'\n                                      newShifts[idx].endTime = '16:00'\n                                    } else if (code === 'evening') {\n                                      newShifts[idx].label = 'в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§'\n                                      newShifts[idx].hours = 9\n                                      newShifts[idx].startTime = '16:00'\n                                      newShifts[idx].endTime = '01:00'\n                                    } else if (code === 'night') {\n                                      newShifts[idx].label = 'в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§'\n                                      newShifts[idx].hours = 9\n                                      newShifts[idx].startTime = '22:00'\n                                      newShifts[idx].endTime = '07:00'\n                                    } else {\n                                      newShifts[idx].label = 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)'\n                                      newShifts[idx].hours = 0\n                                      newShifts[idx].startTime = ''\n                                      newShifts[idx].endTime = ''\n                                    }\n                                  } else {\n                                    if (code === 'office') {\n                                      newShifts[idx].label = 'в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј'\n                                      newShifts[idx].hours = 8.75\n                                      newShifts[idx].startTime = '07:30'\n                                      newShifts[idx].endTime = '16:15'\n                                    } else {\n                                      newShifts[idx].label = 'в•ӘВ¬в•Әв•Јв•Әв•–в–ҲГ®в”ҳГӨ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§'\n                                      newShifts[idx].hours = 0\n                                      newShifts[idx].startTime = ''\n                                      newShifts[idx].endTime = ''\n                                    }\n                                  }\n                                  setTplShifts(newShifts)\n                                }}\n                                className=\"bg-surface border border-border rounded-lg px-2 py-1 outline-none text-xs text-foreground cursor-pointer focus:ring-1 focus:ring-accent\"\n                              >\n                                {tplRegime === 'rotational_12h' && (\n                                  <>\n                                    <option value=\"morning\">в•Әв–’в”ҳГӘв•Әв–“в”ҢвҢҗв•ӘВәв•Әв–’ (в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§)</option>\n                                    <option value=\"night\">в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ (в–Ҳв–’в–Ҳв–“ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§)</option>\n                                    <option value=\"off\">в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)</option>\n                                  </>\n                                )}\n                                {tplRegime === 'rotational_9h' && (\n                                  <>\n                                    <option value=\"morning\">в•Әв•Ўв•ӘВҝв•ӘВЎО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ (в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§)</option>\n                                    <option value=\"evening\">в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ (в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§)</option>\n                                    <option value=\"night\">в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’ (в–Ҳв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§)</option>\n                                    <option value=\"off\">в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј)</option>\n                                  </>\n                                )}\n                                {tplRegime === 'staff' && (\n                                  <>\n                                    <option value=\"office\">в•ӘВәв•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј (в–Ҳв••:в–Ҳв”Өв–Ҳв•Ў в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§)</option>\n                                    <option value=\"off\">в•ӘВ¬в•Әв•Јв•Әв•–в–ҲГ®в”ҳГӨ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§</option>\n                                  </>\n                                )}\n                              </select>\n\n                              <span className=\"text-[10px] text-foreground-muted font-mono leading-none shrink-0 w-24 text-center bg-background/50 py-1 px-1.5 rounded border border-border/30\">\n                                {dayShift.startTime ? `${toFa(dayShift.startTime)} - ${toFa(dayShift.endTime)}` : 'в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬'}\n                              </span>\n                            </div>\n                          ))}\n                        </div>\n                      </div>\n\n                      {/* Cycle Statistics Summary */}\n                      <div className=\"border-t border-border/30 pt-4 space-y-3 bg-surface-container-highest/30 -mx-6 px-6 pb-2 rounded-b-lg\">\n                        <h3 className=\"text-xs font-bold text-foreground/95 flex items-center gap-1.5 justify-start\">\n                          <Info className=\"size-4 text-accent\" />\n                          в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГӘ в•ӘГів”ҳГ в•ӘВәв•Әв–’в–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§:\n                        </h3>\n\n                        <div className=\"grid grid-cols-2 gap-2 text-[10px]\">\n                          <div className=\"bg-background/45 border border-border/50 p-2 rounded-xl flex flex-col justify-between\">\n                            <span className=\"text-foreground-muted text-start\">в”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§:</span>\n                            <span className=\"font-bold text-foreground text-start mt-1 text-[11px]\">\n                              {toFa(totalHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬\n                            </span>\n                          </div>\n                          <div className=\"bg-background/45 border border-border/50 p-2 rounded-xl flex flex-col justify-between\">\n                            <span className=\"text-foreground-muted text-start\">в”ҳГ в–ҲГ®в•ӘВәв”ҳГҘв”ҢВ»в–ҲГ®в”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ:</span>\n                            <span className=\"font-bold text-accent text-start mt-1 text-[11px]\">\n                              {toFa(avgWeeklyHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§\n                            </span>\n                          </div>\n                          <div className=\"bg-background/45 border border-border/50 p-2 rounded-xl flex flex-col justify-between\">\n                            <span className=\"text-foreground-muted text-start\">в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГӘв•Әв••в”ҳГј в”ҢвҢҗв•ӘВәв•Әв–’:</span>\n                            <span className=\"font-bold text-success text-start mt-1 text-[11px]\">\n                              {toFa(workDays)} в•Әв–’в”ҳГӘв•Әв–“ в”ҢвҢҗв•ӘВәв•Әв–’\n                            </span>\n                          </div>\n                          <div className=\"bg-background/45 border border-border/50 p-2 rounded-xl flex flex-col justify-between\">\n                            <span className=\"text-foreground-muted text-start\">в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (в•ӘГів”ҳГј):</span>\n                            <span className=\"font-bold text-info text-start mt-1 text-[11px]\">\n                              {toFa(offDays)} в•Әв–’в”ҳГӘв•Әв–“ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬\n                            </span>\n                          </div>\n                        </div>\n\n                        {/* Fatigue risk rating / warning */}\n                        {Number(avgWeeklyHours) > 48 && (\n                          <div className=\"bg-critical/10 text-critical border border-critical/20 p-2.5 rounded-xl flex items-start gap-2 text-[9px] leading-relaxed text-start\">\n                            <AlertTriangle className=\"size-4 shrink-0 mt-0.5\" />\n                            <span>\n                              в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’! в”ҳГ в–ҲГ®в•ӘВәв”ҳГҘв”ҢВ»в–ҲГ®в”ҳГҘ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ® ({toFa(avgWeeklyHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬) в”ҳГјв•Әв–’в•ӘВәв•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ в•Әв”Ӯв”ҳГ©в”ҳГј в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® в–Ҳв”Өв–Ҳв•• в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ»в•Әв–’ в”ҳГ§в”ҳГјв•ӘВ¬в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ в”ҳГ в”ҳГ в”ҢвҢҗв”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬ в”ҳГ в”ҳГҘв•ӘВјв•Әв–’ в•ӘВҝв”ҳГ§ в•ӘВ«в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в•Әв”Өв•ӘВ»в–ҲГ®в•ӘВ» в”ҳГӘ в”ҢвҢҗв•ӘВәв”ҳГ§в•Әв”Ө в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•Әв”Өв”ҳГӘв•ӘВ».\n                            </span>\n                          </div>\n                        )}\n                        {Number(avgWeeklyHours) <= 48 && Number(avgWeeklyHours) >= 40 && (\n                          <div className=\"bg-success/10 text-success border border-success/20 p-2.5 rounded-xl flex items-start gap-2 text-[9px] leading-relaxed text-start\">\n                            <CheckCircle2 className=\"size-4 shrink-0 mt-0.5\" />\n                            <span>\n                              в•Әв”Өв•ӘВәв•ӘВ«в•Әв•Ў в•ӘВҝв•ӘВәв•Әв–’ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘ в”ҳГӘ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв•Әв–“в”ҳГҘ. в”ҳГ в–ҲГ®в•ӘВәв”ҳГҘв”ҢВ»в–ҲГ®в”ҳГҘ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ® ({toFa(avgWeeklyHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬) в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨв•ӘВәв”ҳГҜ в•ӘВ»в•Әв–’ в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ»в”ҳГ§ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® в”ҳГӘ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ» в•Әв–’в•ӘВәв”ҳГ§О“ГҮГ®в•ӘГів”ҳГ§в”ҳГҘ в•Әв”Өв”ҳГ§в•Әв–’в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                            </span>\n                          </div>\n                        )}\n                      </div>\n                    </CardContent>\n                    <CardFooter className=\"border-t border-border/30 pt-4 flex justify-end\">\n                      <Button onClick={handleSaveTemplate} disabled={!tplName.trim()} className=\"px-5 h-9 bg-accent hover:bg-accent-hover text-accent-foreground text-xs font-bold cursor-pointer rounded-lg\">\n                        <Check className=\"size-4 me-1.5\" />\n                        в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§\n                      </Button>\n                    </CardFooter>\n                  </Card>\n                </div>\n\n                {/* Right Cards: List of Templates */}\n                <div className=\"lg:col-span-7 space-y-4\">\n                  <div className=\"flex items-center justify-between\">\n                    <h2 className=\"text-sm font-black text-foreground\">в”ҳГ©в•ӘВәв”ҳГӨв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  ({toFa(templates.length)})</h2>\n                  </div>\n\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                    {templates.map((tpl) => (\n                      <Card key={tpl.id} className=\"border border-border bg-surface/35 hover:border-border/80 transition-all flex flex-col justify-between rounded-xl\">\n                        <CardHeader className=\"pb-2\">\n                          <div className=\"flex justify-between items-start\">\n                            <CardTitle className=\"text-xs font-bold text-foreground text-start leading-relaxed\">{tpl.name}</CardTitle>\n                            <Badge variant=\"outline\" className={cn(\n                              \"text-[9px] font-bold border\",\n                              tpl.type === 'staff' && \"bg-purple-500/5 text-purple-400 border-purple-500/20\",\n                              tpl.type === 'rotational' && tpl.shifts.some(s => s.hours === 12) && \"bg-amber-500/5 text-amber-400 border-amber-500/20\",\n                              tpl.type === 'rotational' && !tpl.shifts.some(s => s.hours === 12) && \"bg-success/5 text-success border-success/20\"\n                            )}>\n                              {getTemplateRegimeLabel(tpl)}\n                            </Badge>\n                          </div>\n                        </CardHeader>\n                        <CardContent className=\"pb-3 text-[11px] text-foreground-muted\">\n                          <div className=\"flex flex-wrap gap-1 mt-1.5 justify-start\">\n                            {tpl.shifts.map((s) => (\n                              <span\n                                key={s.day}\n                                className={cn(\n                                  \"px-1.5 py-0.5 rounded-md text-[9px] font-bold border\",\n                                  s.code === 'morning' && s.hours === 12 && \"bg-amber-500/10 text-amber-400 border-amber-500/20\",\n                                  s.code === 'morning' && s.hours !== 12 && \"bg-success/10 text-success border-success/20\",\n                                  s.code === 'evening' && \"bg-info/10 text-info border-info/20\",\n                                  s.code === 'night' && \"bg-purple-500/10 text-purple-400 border-purple-500/20\",\n                                  s.code === 'office' && \"bg-indigo-500/10 text-indigo-400 border-indigo-500/20\",\n                                  s.code === 'off' && \"bg-background text-foreground-muted border-border\"\n                                )}\n                                title={`${s.label} (${s.startTime ? `${s.startTime}-${s.endTime}` : 'в•ӘГів”ҳГј'})`}\n                              >\n                                {toFa(s.day)}: {s.label || shiftLabels[s.code] || s.code}\n                              </span>\n                            ))}\n                          </div>\n\n                          <div className=\"flex justify-between items-center mt-3.5 text-[10px] text-foreground-muted bg-background/30 p-2 rounded-lg border border-border/40\">\n                            <span>в•Әв•–в”ҳГӘв”ҳГӨ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§: {toFa(tpl.type === 'staff' ? 7 : tpl.length)} в•Әв–’в”ҳГӘв•Әв–“</span>\n                            <span>в”ҳГ в–ҲГ®в•ӘВәв”ҳГҘв”ҢВ»в–ҲГ®в”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ§в”ҳГјв•ӘВ¬в”ҢВ»в–ҲГ®: <strong className=\"text-accent\">{toFa(getTemplateAvgWeeklyHours(tpl))} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬</strong></span>\n                          </div>\n                        </CardContent>\n                        <CardFooter className=\"border-t border-border/10 pt-2.5 flex justify-end\">\n                          <Button\n                            variant=\"ghost\"\n                            onClick={() => deleteTemplate(tpl.id)}\n                            disabled={tpl.id.startsWith('tpl-rotational') || tpl.id.startsWith('tpl-staff')} // Prevent deleting system defaults\n                            className=\"text-critical hover:bg-critical/10 text-[10px] font-bold h-7 cursor-pointer disabled:opacity-30 rounded-md\"\n                          >\n                            <Trash className=\"size-3.5 me-1\" />\n                            в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ\n                          </Button>\n                        </CardFooter>\n                      </Card>\n                    ))}\n                  </div>\n                </div>\n\n              </div>\n            </div>\n          )\n        })()}\n\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {/* TAB 3: SHIFT ASSIGNMENTS */}\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {activeTab === 'assignments' && (\n          <div className=\"h-full overflow-y-auto p-4 md:p-6 space-y-6\">\n            <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\n\n              {/* Left Form: Assign Template */}\n              <div className=\"lg:col-span-5\">\n                <Card className=\"border-border bg-surface-container-low/80 backdrop-blur\">\n                  <CardHeader>\n                    <CardTitle className=\"text-base font-bold flex items-center gap-1.5\">\n                      <UserCheck className=\"size-5 text-accent\" />\n                      в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                    </CardTitle>\n                    <CardDescription className=\"text-xs\">\n                      в•Әв”Ӯв–ҲГ®в”ҢвҢҗв”ҳГӨ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВә в•Әв–’в•ӘВә в•ӘВҝв•Әв–’ в”ҳГ в•ӘВҝв”ҳГҘв•ӘВәв–ҲГ® в–ҲГ®в”ҢвҢҗ в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҳГӨв”ҳГҘв”ҢВ»в•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ (Anchor) в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в–ҲГ®в•ӘВә в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в”ҳГ в•ӘВ¬в•Әв•Ўв”ҳГӨ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                    </CardDescription>\n                  </CardHeader>\n                  <CardContent className=\"space-y-4\">\n                    <div className=\"space-y-1.5\">\n                      <Label className=\"text-xs font-bold flex justify-start\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬</Label>\n                      <Select value={assignTplId} onValueChange={(v) => setAssignTplId(v || '')}>\n                        <SelectTrigger className=\"h-10 text-xs\">\n                          <SelectValue placeholder=\"в–ҲГ®в”ҢвҢҗ в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»...\" />\n                        </SelectTrigger>\n                        <SelectContent>\n                          {templates.map((t) => (\n                            <SelectItem key={t.id} value={t.id} className=\"text-xs\">\n                              {t.name} ({t.type === 'staff' ? 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®' : `${toFa(t.length)} в•Әв–’в”ҳГӘв•Әв–“в”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ®`})\n                            </SelectItem>\n                          ))}\n                        </SelectContent>\n                      </Select>\n                    </div>\n\n                    <div className=\"grid grid-cols-2 gap-4\">\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-bold flex justify-start\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГ§в•ӘВ»в”ҳГј в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ</Label>\n                        <Select value={assignTargetType} onValueChange={(v: any) => setAssignTargetType(v)}>\n                          <SelectTrigger className=\"h-10 text-xs\">\n                            <SelectValue />\n                          </SelectTrigger>\n                          <SelectContent>\n                            <SelectItem value=\"group\" className=\"text-xs\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬в–ҲГ® (A, B, C)</SelectItem>\n                            <SelectItem value=\"user\" className=\"text-xs\">в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ / в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВ«в•ӘВәв•Әв•Ў</SelectItem>\n                          </SelectContent>\n                        </Select>\n                      </div>\n\n                      <div className=\"space-y-1.5\">\n                        <Label className=\"text-xs font-bold flex justify-start\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГ§в•ӘВ»в”ҳГј</Label>\n                        {assignTargetType === 'group' ? (\n                          <Select value={assignTargetId} onValueChange={(v) => setAssignTargetId(v || '')}>\n                            <SelectTrigger className=\"h-10 text-xs\">\n                              <SelectValue />\n                            </SelectTrigger>\n                            <SelectContent>\n                              {MOCK_GROUPS_LIST.map((g) => (\n                                <SelectItem key={g.key} value={g.key} className=\"text-xs\">{g.name}</SelectItem>\n                              ))}\n                            </SelectContent>\n                          </Select>\n                        ) : (\n                          <Select value={assignTargetId} onValueChange={(v) => setAssignTargetId(v || '')}>\n                            <SelectTrigger className=\"h-10 text-xs\">\n                              <SelectValue />\n                            </SelectTrigger>\n                            <SelectContent>\n                              {users.map((u) => (\n                                <SelectItem key={u.id} value={u.id} className=\"text-xs\">{u.name}</SelectItem>\n                              ))}\n                            </SelectContent>\n                          </Select>\n                        )}\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-1.5\">\n                      <Label htmlFor=\"anchor-date\" className=\"text-xs font-bold flex justify-start\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҳГӨв”ҳГҘв”ҢВ»в•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§ (в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ)</Label>\n                      <Input\n                        id=\"anchor-date\"\n                        type=\"date\"\n                        value={assignAnchorDate}\n                        onChange={(e) => setAssignAnchorDate(e.target.value)}\n                        className=\"h-10 text-sm border-border text-start font-data-mono\"\n                      />\n                      <p className=\"text-[10px] text-foreground-muted mt-1 text-right leading-relaxed pr-1\">\n                        в•ӘВ¬в•Әв–‘в”ҢвҢҗв•Әв–’: в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВәв–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в•Әв”Өв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬в–ҲГ®в•ӘГ® в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬ в•Әв–’в”ҳГӘв•Әв–“ в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§ в•ӘВәв•Әв–“ в•ӘВ¬в”ҳГјв•ӘВәв•Әв•ўв”ҳГӨ в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҳГ§в•ӘВ»в”ҳГј в•ӘВҝв•ӘВә в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҳГӨв”ҳГҘв”ҢВ»в•Әв–’в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВЎв•ӘВәв•Әв•Ўв”ҳГӨ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».\n                      </p>\n                    </div>\n                  </CardContent>\n                  <CardFooter className=\"border-t border-border/30 pt-4 flex justify-end\">\n                    <Button onClick={handleSaveAssignment} disabled={!assignTplId} className=\"px-5 h-9 bg-accent hover:bg-accent-hover text-accent-foreground text-xs font-bold cursor-pointer\">\n                      <Check className=\"size-4 me-1.5\" />\n                      в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ\n                    </Button>\n                  </CardFooter>\n                </Card>\n              </div>\n\n              {/* Right Cards: Active Assignments */}\n              <div className=\"lg:col-span-7 space-y-4\">\n                <h2 className=\"text-sm font-black text-foreground\">в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  ({toFa(assignments.length)})</h2>\n\n                <div className=\"space-y-3\">\n                  {assignments.map((assign) => {\n                    const tpl = templates.find((t) => t.id === assign.templateId)\n                    const targetLabel = assign.targetType === 'group'\n                      ? `в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ ${MOCK_GROUPS_LIST.find((g) => g.key === assign.targetId)?.name || assign.targetId}`\n                      : `в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ: ${users.find((u) => u.id === assign.targetId)?.name || assign.targetId}`\n\n                    return (\n                      <div key={assign.id} className=\"bg-surface/35 border border-border rounded-xl p-4 flex items-center justify-between hover:border-border/80 transition-all text-xs\">\n                        <div className=\"space-y-1.5 text-right\">\n                          <div className=\"font-bold text-foreground text-sm flex items-center gap-2\">\n                            <Shield className=\"size-4 text-accent\" />\n                            {targetLabel}\n                          </div>\n                          <div className=\"text-foreground-muted flex items-center gap-4\">\n                            <span>в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘ: <strong className=\"text-foreground\">{tpl?.name || 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}</strong></span>\n                            <span>в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВәв•Әв–“: <strong className=\"text-foreground font-data-mono\">{toFa(dayjs(assign.anchorDate).format('YYYY/MM/DD'))}</strong></span>\n                          </div>\n                        </div>\n\n                        <Button\n                          variant=\"ghost\"\n                          onClick={() => deleteAssignment(assign.id)}\n                          disabled={assign.id.startsWith('assign-group')} // Keep default seeds safe\n                          className=\"text-critical hover:bg-critical/10 text-[10px] font-bold h-8 cursor-pointer disabled:opacity-30\"\n                        >\n                          <Trash className=\"size-3.5 me-1\" />\n                          в•ӘВЎв•Әв–‘в”ҳГј в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝ\n                        </Button>\n                      </div>\n                    )\n                  })}\n                </div>\n              </div>\n\n            </div>\n          </div>\n        )}\n\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {/* TAB 4: SWAP REQUESTS */}\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {activeTab === 'swaps' && (\n          <div className=\"h-full overflow-y-auto p-4 md:p-6 space-y-6 max-w-4xl mx-auto\">\n            <div className=\"flex items-center justify-between border-b border-border/30 pb-3\">\n              <div>\n                <h2 className=\"text-base font-bold text-foreground flex items-center gap-2\">\n                  <ArrowLeftRight className=\"size-5 text-accent\" />\n                  в•Әв•Ўв”ҳГҘв•ӘВ»в”ҳГӘв”ҳГ© в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                </h2>\n                <p className=\"text-xs text-foreground-muted mt-0.5\">в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в•ӘВҝв•ӘВәв•ӘВ»в”ҳГӨ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в”ҢвҢҗв”ҳГ§ в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“в”ҳГ в”ҳГҘв•ӘВ» в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»/в•Әв–’в•ӘВ» в•ӘВәв•ӘВ»в”ҳГ в–ҲГ®в”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n              </div>\n              <Badge className=\"bg-accent/10 border-accent/30 text-accent text-xs font-bold px-2.5 py-0.5\">\n                {toFa(swapRequests.length)} в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©\n              </Badge>\n            </div>\n\n            <div className=\"space-y-4\">\n              {swapRequests.length > 0 ? (\n                swapRequests.map((req) => {\n                  const rules = evaluateSwapRules(req)\n                  const hasRuleError = rules.some(r => r.status === 'error')\n                  const hasRuleWarning = rules.some(r => r.status === 'warning')\n\n                  return (\n                    <div key={req.id} className=\"bg-surface/35 border border-border rounded-xl p-5 space-y-4 hover:border-border/80 transition-all shadow-sm\">\n                      <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center gap-2\">\n                          <div className=\"w-8 h-8 rounded-full bg-accent/10 text-accent border border-accent/25 flex items-center justify-center text-xs font-bold\">\n                            {req.requester.name.slice(0, 2)}\n                          </div>\n                          <div>\n                            <span className=\"text-xs font-bold text-foreground block\">{req.requester.name}</span>\n                            <span className=\"text-[9px] text-foreground-muted font-bold mt-0.5 block\">{req.requester.role?.name || 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’'}</span>\n                          </div>\n                        </div>\n                        <span className=\"text-[10px] text-foreground-muted font-data-mono\">\n                          в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВҪв•ӘВҝв•ӘВ¬: {toFa(new Date(req.createdAt).toLocaleDateString('fa-IR'))}\n                        </span>\n                      </div>\n\n                      {/* Swap details block */}\n                      <div className=\"grid grid-cols-1 md:grid-cols-12 items-center bg-background/55 border border-border/60 p-3.5 rounded-lg text-xs font-data-mono text-center gap-3\">\n                        <div className=\"md:col-span-5 bg-surface border border-border/40 p-2.5 rounded\">\n                          <div className=\"font-bold text-foreground\">{req.requester.name}</div>\n                          <div className=\"text-foreground-muted text-[10px] mt-1\">{toFa(dayjs(req.sourceShift.date).format('YYYY/MM/DD'))} ({dayjs(req.sourceShift.date).format('dddd')})</div>\n                          <Badge className=\"mt-2 text-[10px] bg-accent/10 text-accent border-accent/30\">{shiftLabels[req.sourceShift.code]}</Badge>\n                        </div>\n\n                        <div className=\"md:col-span-2 flex justify-center\">\n                          <ArrowLeftRight className=\"size-6 text-foreground-muted/65\" />\n                        </div>\n\n                        <div className=\"md:col-span-5 bg-surface border border-border/40 p-2.5 rounded\">\n                          <div className=\"font-bold text-foreground\">{req.target.name}</div>\n                          <div className=\"text-foreground-muted text-[10px] mt-1\">{toFa(dayjs(req.targetShift.date).format('YYYY/MM/DD'))} ({dayjs(req.targetShift.date).format('dddd')})</div>\n                          <Badge className=\"mt-2 text-[10px] bg-accent/10 text-accent border-accent/30\">{shiftLabels[req.targetShift.code]}</Badge>\n                        </div>\n                      </div>\n\n                      {/* Safety Rule Engine Panel (swap-skill) */}\n                      <div className=\"bg-surface/50 border border-border/45 p-4 rounded-xl space-y-3\">\n                        <h3 className=\"text-[11px] font-black text-foreground flex items-center gap-1.5\">\n                          <Shield className=\"size-4 text-accent\" />\n                          в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВәв”ҳГҘв•Әв•–в•ӘВҝв•ӘВәв”ҳГ© в•ӘВҝв•ӘВә в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв•– в–Ҳв–’:\n                        </h3>\n                        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n                          {rules.map((rule, idx) => (\n                            <div key={idx} className=\"bg-background/45 p-3 rounded-lg border border-border/40 flex flex-col gap-1 text-[10px]\">\n                              <div className=\"flex items-center gap-1.5 font-bold\">\n                                <span className={cn(\n                                  \"size-2 rounded-full\",\n                                  rule.status === 'success' ? 'bg-success' : rule.status === 'warning' ? 'bg-warning animate-pulse' : 'bg-critical animate-ping'\n                                )}></span>\n                                <span className={cn(\n                                  rule.status === 'success' ? 'text-success' : rule.status === 'warning' ? 'text-warning' : 'text-critical'\n                                )}>{rule.name}</span>\n                              </div>\n                              <p className=\"text-foreground-muted/80 leading-relaxed mt-1\">{rule.desc}</p>\n                            </div>\n                          ))}\n                        </div>\n                      </div>\n\n                      {req.note && (\n                        <p className=\"text-[11px] text-foreground-muted border-r-2 border-border pr-2.5 leading-relaxed font-medium\">\n                          в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ: {req.note}\n                        </p>\n                      )}\n\n                      <div className=\"flex gap-3 pt-2\">\n                        <Button\n                          onClick={() => handleSwapDecision(req.id, 'rejected')}\n                          disabled={actionLoading[req.id]}\n                          className=\"flex-1 border border-border bg-surface hover:bg-surface-hover text-foreground text-xs font-bold h-9.5 rounded-lg cursor-pointer transition-colors disabled:opacity-50\"\n                        >\n                          в•Әв–’в•ӘВ» в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®\n                        </Button>\n                        <Button\n                          onClick={() => handleSwapDecision(req.id, 'approved')}\n                          disabled={actionLoading[req.id]}\n                          className={cn(\n                            \"flex-1 text-white text-xs font-bold h-9.5 rounded-lg cursor-pointer transition-colors disabled:opacity-50 flex items-center justify-center gap-1.5\",\n                            hasRuleError ? 'bg-critical/85 hover:bg-critical' : hasRuleWarning ? 'bg-warning/85 hover:bg-warning' : 'bg-success/85 hover:bg-success'\n                          )}\n                        >\n                          <Check className=\"size-4\" />\n                          в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ® в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§\n                        </Button>\n                      </div>\n                    </div>\n                  )\n                })\n              ) : (\n                <div className=\"flex flex-col items-center justify-center py-16 text-center border border-dashed border-border rounded-2xl bg-surface/10\">\n                  <CheckCircle2 className=\"size-10 text-foreground-muted/40 mb-3\" />\n                  <p className=\"text-sm text-foreground-muted font-bold\">в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҳГӘ в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв”ҳГҘв•ӘВ». в•Әв•Ўв”ҳГҘв•ӘВ»в”ҳГӘв”ҳГ© в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»в–ҲГ® в•ӘВ«в•ӘВәв”ҳГӨв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n                </div>\n              )}\n            </div>\n          </div>\n        )}\n\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {/* TAB 5: SHIFT RULES SETTINGS PANEL */}\n        {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n        {activeTab === 'settings' && (\n          <div className=\"h-full overflow-y-auto p-4 md:p-6 max-w-2xl mx-auto\">\n            <Card className=\"border border-accent/20 bg-surface-container-low/80 backdrop-blur relative overflow-hidden\">\n              <div className=\"absolute top-0 right-0 w-full h-[4px] bg-accent\"></div>\n              <CardHeader className=\"border-b border-border/40 pb-4\">\n                <CardTitle className=\"text-base font-bold flex items-center gap-1.5\">\n                  <Settings className=\"size-5 text-accent\" />\n                  в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГӘ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                </CardTitle>\n                <CardDescription className=\"text-xs\">\n                  в”ҳв•ӣв•ӘВәв•Әв–’в•ӘВәв”ҳГ в•ӘВ¬в•Әв–’в”ҳГ§в•ӘВә в”ҳГӘ в•Әв”Ӯв”ҳГ©в”ҳГјО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв•– в–Ҳв–’ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n                </CardDescription>\n              </CardHeader>\n\n              <CardContent className=\"space-y-6 pt-6\">\n                {settingsLoading ? (\n                  <div className=\"flex flex-col items-center justify-center py-12\">\n                    <Loader2 className=\"size-8 animate-spin text-accent mb-2\" />\n                    <p className=\"text-xs text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳв•ӣв–ҲГ®в”ҢвҢҗв•Әв–’в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•ӘВәв•Әв–“ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ...</p>\n                  </div>\n                ) : (\n                  <>\n                    {/* 1. Min Rest Hours */}\n                    <div className=\"space-y-3 p-4 rounded-xl bg-background/30 border border-border/60\">\n                      <div className=\"flex justify-between items-center\">\n                        <Label className=\"text-xs font-black text-foreground\">в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</Label>\n                        <Badge variant=\"outline\" className=\"font-data-mono text-accent bg-accent/5\">\n                          {toFa(dbMinRestHours)} в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬\n                        </Badge>\n                      </div>\n                      <p className=\"text-[10.5px] text-foreground-muted leading-relaxed\">\n                        в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в”ҳГ в•ӘВ»в•ӘВ¬ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв–ҲГ®в”ҳГҘ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв”ҳГӘв”ҳГӨ в”ҳГӘ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВҝв•Әв•Јв•ӘВ»в–ҲГ®. в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҢвҢҗв”ҳГ в•ӘВ¬в•Әв–’ в•ӘВҝв”ҳГӘв•ӘВ»в”ҳГҘв•ӘГ® в•ӘВ¬в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ в•ӘВ¬в•Әв–’в•ӘВәв”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ® в”ҳГ©в•Әв–’в”ҳГ в•Әв–“ в•Әв–’в”ҳГҘв”ҢВ» в•ӘВ»в•Әв–’ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•Әв”Өв•ӘВ».\n                      </p>\n                      <div className=\"flex items-center gap-4 pt-1.5\">\n                        <input\n                          type=\"range\"\n                          min={8}\n                          max={24}\n                          value={dbMinRestHours}\n                          onChange={(e) => setDbMinRestHours(Number(e.target.value))}\n                          className=\"flex-1 accent-accent cursor-pointer h-1.5 bg-surface rounded-lg border-none\"\n                        />\n                        <span className=\"text-xs font-bold text-foreground-muted w-10 text-left font-data-mono\">{toFa(dbMinRestHours)}h</span>\n                      </div>\n                    </div>\n\n                    {/* 2. Max Consecutive Nights */}\n                    <div className=\"space-y-3 p-4 rounded-xl bg-background/30 border border-border/60\">\n                      <div className=\"flex justify-between items-center\">\n                        <Label className=\"text-xs font-black text-foreground\">в•Әв”Ӯв”ҳГ©в”ҳГј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“</Label>\n                        <Badge variant=\"outline\" className=\"font-data-mono text-accent bg-accent/5\">\n                          в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ {toFa(dbMaxConsecutiveNights)} в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГӨв–ҲГ®\n                        </Badge>\n                      </div>\n                      <p className=\"text-[10.5px] text-foreground-muted leading-relaxed\">\n                        в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝ в”ҳГ в•ӘВ¬в”ҳГҘв•ӘВәв”ҳГӘв•ӘВҝ в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘВјв”ҳГӨв”ҳГӘв”ҢВ»в–ҲГ®в•Әв–’в–ҲГ® в•ӘВәв•Әв–“ в•ӘВ«в”ҳГӘв•ӘВәв•ӘВҝО“ГҮГ®в•ӘГів”ҳГӨв”ҳГӘв•ӘВ»в”ҢВ»в–ҲГ® в”ҳГӘ в•ӘВ¬в•Әв•ўв”ҳГ в–ҲГ®в”ҳГҘ в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в•ӘВјв•Әв”Ӯв”ҳГ в–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в”ҳГӨв”ҳГӘв”ҢвҢҗв”ҳГӘв”ҳГ в”ҳГӘв•ӘВ¬в–ҲГ®в”ҳГӘв•Әв–’в•ӘВәв”ҳГҘв•ӘВәв”ҳГҘ в•ӘВ«в•Әв•– в–Ҳв–’.\n                      </p>\n                      <div className=\"flex items-center gap-4 pt-1.5\">\n                        <input\n                          type=\"range\"\n                          min={1}\n                          max={5}\n                          value={dbMaxConsecutiveNights}\n                          onChange={(e) => setDbMaxConsecutiveNights(Number(e.target.value))}\n                          className=\"flex-1 accent-accent cursor-pointer h-1.5 bg-surface rounded-lg border-none\"\n                        />\n                        <span className=\"text-xs font-bold text-foreground-muted w-10 text-left font-data-mono\">{toFa(dbMaxConsecutiveNights)} в•Әв”Өв•ӘВҝ</span>\n                      </div>\n                    </div>\n\n                    {/* 3. Role Parity Swap Toggle */}\n                    <div className=\"flex items-center justify-between p-4 rounded-xl bg-background/30 border border-border/60 gap-6\">\n                      <div className=\"space-y-1 text-right flex-1\">\n                        <Label className=\"text-xs font-black text-foreground\">в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ  в”ҳГ§в”ҳГ в•ӘВ¬в•Әв–’в•ӘВәв•Әв–“в–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө в”ҳГӘ в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВјв•ӘВәв•ӘВҝв•ӘВјв•ӘВәв–ҲГ®в–ҲГ®</Label>\n                        <p className=\"text-[10.5px] text-foreground-muted leading-relaxed\">\n                          в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•ӘВҝв”ҳГӘв•ӘВ»в”ҳГҘв•ӘГ® в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВ¬в•Әв•Јв”ҳГӘв–ҲГ®в•Әв•ў в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬в–ҲГ® в”ҢвҢҗв”ҳГ§ в”ҳГҘв”ҳГ©в•Әв”Ө в”ҳГјв”ҳГҘв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВҝв•ӘВ»в•ӘВә в”ҳГӘ в”ҳГ в”ҳГ©в•Әв•Ўв•ӘВ» в–ҲГ®в”ҢвҢҗв•Әв”Ӯв•ӘВәв”ҳГҘ в”ҳГҘв•ӘВҝв•ӘВәв•Әв”Өв•ӘВ» (в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•ӘВҝв•ӘВә в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•Әв•Јв•ӘВәв•ӘВ»в–ҲГ®) в•ӘВҝв•ӘВә в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•Әв•Јв•ӘВ»в”ҳГ  в”ҳГ§в”ҳГ в•ӘВ¬в•Әв–’в•ӘВәв•Әв–“в–ҲГ® в”ҳГ в”ҳГӘв•ӘВәв•ӘВјв”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ».\n                        </p>\n                      </div>\n                      <Switch\n                        checked={dbRoleParity}\n                        onCheckedChange={setDbRoleParity}\n                      />\n                    </div>\n                  </>\n                )}\n              </CardContent>\n\n              <CardFooter className=\"border-t border-border/30 pt-4 flex justify-between flex-wrap gap-2\">\n                <div className=\"flex gap-2\">\n                  <Button\n                    variant=\"outline\"\n                    onClick={handleResetSettings}\n                    disabled={settingsLoading}\n                    className=\"px-4 h-9.5 text-xs font-bold text-foreground hover:bg-surface border-border cursor-pointer disabled:opacity-50\"\n                  >\n                    в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ\n                  </Button>\n                  <Button\n                    variant=\"outline\"\n                    onClick={handleResetTemplatesAndAssignments}\n                    className=\"px-4 h-9.5 text-xs font-bold text-critical hover:bg-critical/10 border-critical/30 cursor-pointer\"\n                  >\n                    в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв”ҳГӨв”ҢВ»в”ҳГӘв”ҳГ§в•ӘВә в”ҳГӘ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв”Ӯв•ӘВәв•ӘВҝО“ГҮГ®в”ҳГ§в•ӘВә в•ӘВҝв”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў\n                  </Button>\n                </div>\n                <Button\n                  onClick={handleSaveSettings}\n                  disabled={settingsLoading}\n                  className=\"px-6 h-9.5 bg-accent hover:bg-accent-hover text-accent-foreground text-xs font-bold cursor-pointer shadow disabled:opacity-50 flex items-center justify-center gap-1.5\"\n                >\n                  {settingsLoading ? <Loader2 className=\"size-4 animate-spin\" /> : <Check className=\"size-4\" />}\n                  в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВ»в•Әв–’ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ\n                </Button>\n              </CardFooter>\n            </Card>\n          </div>\n        )}\n\n      </div>\n\n      {/* Roster Assignment and Inline Cell Edit Modal */}\n      <Dialog open={shiftModalOpen} onOpenChange={setShiftModalOpen}>\n        <DialogContent className=\"max-w-sm w-full\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-base font-bold text-foreground text-start\">\n              {isCellEdit ? 'в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ® в”ҳГӘ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ» в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®' : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ» в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»'}\n            </DialogTitle>\n            <DialogDescription className=\"text-xs text-foreground-muted text-start\">\n              в•ӘВҝв•ӘВә в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ»в•ӘГ® в•Әв”Ӯв–ҲГ®в”ҢвҢҗв”ҳГӨ в”ҳГ в•ӘВЎв•ӘВәв•Әв”Ӯв•ӘВҝв•ӘВәв•ӘВ¬в–ҲГ® в”ҢГҘв•Әв–’в•ӘВ«в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨ в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•Әв”Өв•ӘВ».\n            </DialogDescription>\n          </DialogHeader>\n          <form onSubmit={handleSaveShift} className=\"space-y-4 py-1.5\">\n            {isCellEdit ? (\n              <div className=\"bg-surface/30 p-3 rounded-xl border border-border/80 space-y-2 text-xs\">\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"font-bold text-foreground-muted\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ:</span>\n                  <strong className=\"text-foreground\">{users.find((u) => u.id === selectedUserId)?.name}</strong>\n                </div>\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"font-bold text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬:</span>\n                  <strong className=\"text-foreground font-data-mono\">{toFa(dayjs(selectedDate).format('YYYY/MM/DD'))} ({dayjs(selectedDate).format('dddd')})</strong>\n                </div>\n              </div>\n            ) : (\n              <>\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"assign-user\" className=\"text-xs font-bold text-foreground flex justify-start\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</Label>\n                  <select\n                    id=\"assign-user\"\n                    value={selectedUserId}\n                    onChange={(e) => setSelectedUserId(e.target.value)}\n                    className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                  >\n                    {users.map((u) => (\n                      <option key={u.id} value={u.id}>\n                        {u.name} ({u.role?.name || 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’'})\n                      </option>\n                    ))}\n                  </select>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"assign-date\" className=\"text-xs font-bold text-foreground flex justify-start\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬</Label>\n                  <Input\n                    id=\"assign-date\"\n                    type=\"date\"\n                    required\n                    value={selectedDate}\n                    onChange={(e) => setSelectedDate(e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border font-data-mono text-start\"\n                  />\n                </div>\n              </>\n            )}\n\n            <div className=\"space-y-1.5\">\n              <Label className=\"text-xs font-bold text-foreground flex justify-start\">в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ»</Label>\n              <div className=\"grid grid-cols-2 gap-2\">\n                {[\n                  { code: 'morning', label: 'в•Әв•Ўв•ӘВҝв•ӘВЎ (в•Әв•Ўв•ӘВҝв•ӘВЎв”ҢвҢҗв•ӘВәв•Әв–’)', color: 'border-success/30 hover:bg-success/5 text-success' },\n                  { code: 'evening', label: 'в•Әв•Јв•Әв•Ўв•Әв–’ (в•Әв•Јв•Әв•Ўв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’)', color: 'border-info/30 hover:bg-info/5 text-info' },\n                  { code: 'night', label: 'в•Әв”Өв•ӘВҝ (в•Әв”Өв•ӘВҝО“ГҮГ®в”ҢвҢҗв•ӘВәв•Әв–’)', color: 'border-purple-500/30 hover:bg-purple-500/5 text-purple-400' },\n                  { code: 'off', label: 'в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв–’в•ӘВәв•ӘВЎв•ӘВ¬ (Off)', color: 'border-border hover:bg-surface-hover text-foreground' },\n                ].map((item) => {\n                  const active = selectedShiftCode === item.code\n                  return (\n                    <button\n                      key={item.code}\n                      type=\"button\"\n                      onClick={() => setSelectedShiftCode(item.code as any)}\n                      className={cn(\n                        \"h-9 border rounded-lg text-xs font-bold transition-all cursor-pointer\",\n                        item.color,\n                        active ? 'ring-1 ring-accent bg-accent/5 font-black' : 'opacity-80'\n                      )}\n                    >\n                      {item.label}\n                    </button>\n                  )\n                })}\n              </div>\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"assign-note\" className=\"text-xs font-bold text-foreground flex justify-start\">в•Әв•Јв”ҳГӨв•ӘВ¬ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВәв”ҳГӘв•Әв–’в•ӘВәв–ҲГ®в•ӘВ»</Label>\n              <Input\n                id=\"assign-note\"\n                placeholder=\"в•ӘВ»в”ҳГӨв•ӘВәв–ҲГ®в”ҳГӨв–ҲГ® в”ҳГҘв•Әв••в–ҲГ®в•Әв–’ в”ҳГ в•Әв–’в•ӘВ«в•Әв•Ўв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•Әв•Јв”ҳГӨв•ӘВәв•ӘВјв–ҲГ®в•ӘГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•ӘВјв•ӘВәв–ҲГ®в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘ...\"\n                value={selectedNote}\n                onChange={(e) => setSelectedNote(e.target.value)}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border text-start\"\n              />\n            </div>\n\n            <DialogFooter className=\"pt-4 flex justify-end gap-2\">\n              <Button\n                type=\"button\"\n                variant=\"ghost\"\n                onClick={() => setShiftModalOpen(false)}\n                className=\"cursor-pointer text-xs\"\n              >\n                в”ҳГӨв•Әв•‘в”ҳГӘ\n              </Button>\n              <Button\n                type=\"submit\"\n    