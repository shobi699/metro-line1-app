в–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҢвҢҗв•Әв–’в•ӘВ».`}\n                      {log.action === 'delete' && `в–ҲГ®в”ҢвҢҗ ${log.entity} в•Әв–’в•ӘВә в•ӘВЎв•Әв–‘в”ҳГј в”ҢвҢҗв•Әв–’в•ӘВ».`}\n                      {log.action === 'import' && 'в–ҲГ®в”ҢвҢҗ в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ в•Әв–’в•ӘВә в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГӘ в”ҳв•ӣв•Әв–’в•ӘВ»в•ӘВәв•Әв–“в•Әв”Ө в”ҳГҘв”ҳГ в”ҳГӘв•ӘВ».'}\n                      {!['login', 'logout', 'create', 'update', 'delete', 'import'].includes(log.action) && `${log.action} в•Әв–’в”ҳГӘв–ҲГ® ${log.entity}`}\n                    </div>\n                    \n                    <div className=\"text-[9px] text-foreground-muted/70 mt-0.5 bg-surface/20 border border-border/10 rounded px-1.5 py-0.5 inline-block font-mono\">\n                      {log.actor?.role?.name || 'в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГҘв”ҳГ©в•Әв”Ө'}\n                    </div>\n                  </div>\n                ))\n              )}\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\operator-licenses\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'XCircle' is defined but never used.","line":15,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":15,"endColumn":10,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"XCircle"},"fix":{"range":[353,364],"text":""},"desc":"Remove unused variable \"XCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AlertTriangle' is defined but never used.","line":16,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":16,"endColumn":16,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AlertTriangle"},"fix":{"range":[364,381],"text":""},"desc":"Remove unused variable \"AlertTriangle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'RefreshCw' is defined but never used.","line":17,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":17,"endColumn":12,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"RefreshCw"},"fix":{"range":[381,394],"text":""},"desc":"Remove unused variable \"RefreshCw\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useState } from 'react'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { TopAppBar } from '@/components/shared/top-app-bar'\nimport {\n  Award,\n  HeartPulse,\n  Clock,\n  Search,\n  Plus,\n  CheckCircle,\n  XCircle,\n  AlertTriangle,\n  RefreshCw,\n  Settings,\n  ShieldAlert,\n  GraduationCap,\n} from 'lucide-react'\n\ninterface Operator {\n  id: string\n  name: string\n  employeeCode: string\n  licenseTier: 'base_3' | 'base_2' | 'base_1' | 'senior'\n  medicalStatus: 'approved' | 'pending_exam' | 'expired'\n  medicalExpiry: string\n  simulatorScore: number // out of 100\n  lastSimulatorTest: string\n  licenseExpiry: string\n  safetyScore: number // out of 100\n}\n\nconst INITIAL_OPERATORS: Operator[] = [\n  { id: '1', name: 'в•ӘВЎв”ҳГ в–ҲГ®в•ӘВ»в•Әв–’в•Әв•ўв•ӘВә в•Әв–’в•Әв•ўв•ӘВәв–ҲГ®в–ҲГ®', employeeCode: '10203', licenseTier: 'senior', medicalStatus: 'approved', medicalExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–‘в–Ҳв•Ў/в–Ҳв–’в–Ҳв–“', simulatorScore: 92, lastSimulatorTest: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв–“/в–Ҳв–’в–Ҳв–‘', licenseExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•–/в–Ҳв–‘в–Ҳв••/в–Ҳв–’в–Ҳв•Ј', safetyScore: 98 },\n  { id: '2', name: 'в•ӘВәв”ҳГ в–ҲГ®в•Әв–’ в”ҳГ©в•ӘВәв•Әв”Ӯв”ҳГ в–ҲГ®', employeeCode: '10355', licenseTier: 'base_1', medicalStatus: 'approved', medicalExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–‘в–Ҳв–“/в–Ҳв–“в–Ҳв–‘', simulatorScore: 88, lastSimulatorTest: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв–’/в–Ҳв–’в–Ҳв•Ў', licenseExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–‘в–Ҳв•Ў', safetyScore: 95 },\n  { id: '3', name: 'в”ҳГ в•Әв–’в•ӘВ¬в•Әв•ўв–ҲГ® в”ҢвҢҗв•Әв–’в–ҲГ®в”ҳГ в–ҲГ®', employeeCode: '10582', licenseTier: 'base_2', medicalStatus: 'expired', medicalExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–‘в–Ҳв–’', simulatorScore: 78, lastSimulatorTest: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв”Ө/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв–‘', licenseExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–‘в–Ҳв”Ө/в–Ҳв–’в–Ҳв•Ў', safetyScore: 82 },\n  { id: '4', name: 'в•ӘВјв”ҳГӘв•ӘВәв•ӘВ» в”ҳГ§в•ӘВәв•Әв”Өв”ҳГ в–ҲГ®', employeeCode: '10744', licenseTier: 'base_3', medicalStatus: 'approved', medicalExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–‘в–Ҳв•Ј/в–Ҳв–‘в–Ҳв–’', simulatorScore: 85, lastSimulatorTest: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–‘в–Ҳв•Ў', licenseExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•–/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–‘в–Ҳв–’', safetyScore: 90 },\n  { id: '5', name: 'в•Әв–’в•Әв•ўв•ӘВә в”ҳГ в”ҳГӨв”ҢвҢҗв–ҲГ®', employeeCode: '11090', licenseTier: 'base_1', medicalStatus: 'pending_exam', medicalExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ө/в–Ҳв”Ӯв–Ҳв–‘', simulatorScore: 81, lastSimulatorTest: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв”Ө/в–Ҳв–’в–Ҳв–’/в–Ҳв–’в–Ҳв•Ў', licenseExpiry: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–‘в–Ҳв–“/в–Ҳв–“в–Ҳв–‘', safetyScore: 87 },\n]\n\nconst TIER_LABELS: Record<Operator['licenseTier'], string> = {\n  base_3: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв”Ӯ (в”ҳГӨв”ҳГӘв”ҢвҢҗв”ҳГӘв”ҳГ в”ҳГӘв•ӘВ¬в–ҲГ®в”ҳГӘ в”ҳГ в•ӘВәв”ҳГҘв”ҳГӘв•Әв–’в–ҲГ®)',\n  base_2: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“ (в”ҳГ в•Әв”Ӯв•ӘВәв”ҳГјв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в•ӘВ«в•Әв•– в”ҳГјв•Әв–’в•Әв•Јв–ҲГ®)',\n  base_1: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’ (в”ҳГ в•Әв”Ӯв•ӘВәв”ҳГјв•Әв–’в•ӘВҝв•Әв–’в–ҲГ® в•ӘВ«в•Әв•– в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®)',\n  senior: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» (в”ҳГ в•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳГӘ в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВәв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’)',\n}\n\nexport default function OperatorLicensesPage() {\n  const [operators, setOperators] = useState<Operator[]>(INITIAL_OPERATORS)\n  const [searchTerm, setSearchTerm] = useState('')\n  const [filterTier, setFilterTier] = useState<string>('all')\n  const [filterMedical, setFilterMedical] = useState<string>('all')\n\n  // в”ҳГјв•Әв–’в”ҳГ  в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n  const [showAddForm, setShowAddForm] = useState(false)\n  const [opName, setOpName] = useState('')\n  const [opCode, setOpCode] = useState('')\n  const [opTier, setOpTier] = useState<Operator['licenseTier']>('base_3')\n  const [opMedStatus, setOpMedStatus] = useState<Operator['medicalStatus']>('approved')\n  const [opMedExpiry, setOpMedExpiry] = useState('в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв•Ј')\n  const [opSimScore, setOpSimScore] = useState(85)\n  const [opSimDate, setOpSimDate] = useState('в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–“в–Ҳв–‘')\n  const [opLicExpiry, setOpLicExpiry] = useState('в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•–/в–Ҳв–’в–Ҳв–“/в–Ҳв–“в–Ҳв•Ј')\n  const [opSafety, setOpSafety] = useState(90)\n\n  // в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВЎв•ӘВ» в•ӘГів•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв”ҳГ§ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘ (в”ҳГ©в•ӘВәв”ҳГҘв”ҳГӘв”ҳГҘ в–Ҳв•–)\n  const [minPassingSimScore, setMinPassingSimScore] = useState(80)\n  const [medicalValidityMonths, setMedicalValidityMonths] = useState(12)\n  const [safetyAlertThreshold, setSafetyAlertThreshold] = useState(85)\n  const [successMessage, setSuccessMessage] = useState('')\n\n  const handleAddOperator = (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!opName || !opCode) {\n      alert('в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в”ҳГҘв•ӘВәв”ҳГ  в”ҳГӘ в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•Әв–’в•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».')\n      return\n    }\n\n    const newOperator: Operator = {\n      id: `OP-${operators.length + 1}`,\n      name: opName,\n      employeeCode: opCode,\n      licenseTier: opTier,\n      medicalStatus: opMedStatus,\n      medicalExpiry: opMedExpiry,\n      simulatorScore: opSimScore,\n      lastSimulatorTest: opSimDate,\n      licenseExpiry: opLicExpiry,\n      safetyScore: opSafety,\n    }\n\n    setOperators((prev) => [newOperator, ...prev])\n    setShowAddForm(false)\n    resetForm()\n    setSuccessMessage('в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ».')\n    setTimeout(() => setSuccessMessage(''), 4000)\n  }\n\n  const resetForm = () => {\n    setOpName('')\n    setOpCode('')\n    setOpTier('base_3')\n    setOpMedStatus('approved')\n    setOpSimScore(85)\n    setOpSafety(90)\n  }\n\n  const handleUpdateSimulatorScore = (id: string, score: number) => {\n    setOperators((prev) =>\n      prev.map((op) => {\n        if (op.id === id) {\n          const nextScore = Math.min(100, Math.max(0, score))\n          return {\n            ...op,\n            simulatorScore: nextScore,\n            lastSimulatorTest: 'в”ҳГ§в”ҳГ О“ГҮГ®в•ӘВәв”ҢвҢҗв”ҳГҘв”ҳГӘв”ҳГҘ (в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®)',\n          }\n        }\n        return op\n      }),\n    )\n  }\n\n  const filteredOperators = operators.filter((op) => {\n    const matchesSearch = op.name.includes(searchTerm) || op.employeeCode.includes(searchTerm)\n    const matchesTier = filterTier === 'all' || op.licenseTier === filterTier\n    const matchesMedical = filterMedical === 'all' || op.medicalStatus === filterMedical\n    return matchesSearch && matchesTier && matchesMedical\n  })\n\n  // в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВә в–ҲГ®в•ӘВә в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“\n  const expiredMedicalsCount = operators.filter((o) => o.medicalStatus === 'expired').length\n  const lowSafetyCount = operators.filter((o) => o.safetyScore < safetyAlertThreshold).length\n  const lowSimulatorCount = operators.filter((o) => o.simulatorScore < minPassingSimScore).length\n\n  return (\n    <div className=\"flex min-h-screen flex-col\" dir=\"rtl\">\n      <TopAppBar\n        title=\"в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГӘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВ«в•Әв•– в–Ҳв–’\"\n        subtitle=\"в”ҳв•ӣв–ҲГ®в”ҢВ»в–ҲГ®в•Әв–’в–ҲГ® в”ҳГӘ в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в”ҳГ в•ӘВ»в•ӘВәв•Әв–’в”ҢвҢҗв•ӘГ® в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ® в”ҳГӘ в”ҳГҘв•ӘВ¬в•ӘВәв–ҲГ®в•ӘВј в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в”ҳГӨв”ҢвҢҗв”ҳГӘв”ҳГ в”ҳГӘв•ӘВ¬в–ҲГ®в”ҳГӘ в•Әв–’в•ӘВәв”ҳГҘв•ӘВәв”ҳГҘ\"\n      />\n\n      <main className=\"flex-1 p-4 pt-16 md:p-6 space-y-6\">\n        {successMessage && (\n          <div className=\"flex items-center gap-2 rounded-lg border border-success/30 bg-success/10 p-3 text-sm text-success\">\n            <CheckCircle className=\"size-4 shrink-0\" />\n            <span>{successMessage}</span>\n          </div>\n        )}\n\n        {/* Widgets / Alarm Indicators */}\n        <div className=\"grid grid-cols-1 gap-4 md:grid-cols-3\">\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв•ӘВәв•ӘВ¬ в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ в”ҳГҘв”ҳГ©в•Әв•ўв–ҲГ®О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§</p>\n                <h3 className={`text-lg font-bold mt-1 ${expiredMedicalsCount > 0 ? 'text-critical' : 'text-success'}`}>\n                  {expiredMedicalsCount} в”ҳГ в”ҳГӘв•Әв–’в•ӘВ» в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“в”ҳГ в”ҳГҘв•ӘВ» в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв”ҳГ§ в”ҳГјв”ҳГӘв•Әв–’в–ҲГ®\n                </h3>\n              </div>\n              <div className={`p-2.5 rounded-lg ${expiredMedicalsCount > 0 ? 'bg-critical/10 text-critical' : 'bg-success/15 text-success'}`}>\n                <HeartPulse className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в”ҳГ в•Әв–’в•ӘВ»в”ҳГӘв•ӘВ»в–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ (в•Әв–“в–ҲГ®в•Әв–’ {minPassingSimScore} в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“)</p>\n                <h3 className={`text-lg font-bold mt-1 ${lowSimulatorCount > 0 ? 'text-warning' : 'text-success'}`}>\n                  {lowSimulatorCount} в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“в”ҳГ в”ҳГҘв•ӘВ» в•ӘВ¬в”ҢвҢҗв•Әв–’в•ӘВәв•Әв–’ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ\n                </h3>\n              </div>\n              <div className={`p-2.5 rounded-lg ${lowSimulatorCount > 0 ? 'bg-warning/10 text-warning' : 'bg-success/15 text-success'}`}>\n                <GraduationCap className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ® (в”ҳв•ӣв•ӘВәв–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в•ӘВ¬в•Әв–’ в•ӘВәв•Әв–“ {safetyAlertThreshold})</p>\n                <h3 className={`text-lg font-bold mt-1 ${lowSafetyCount > 0 ? 'text-critical' : 'text-success'}`}>\n                  {lowSafetyCount} в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв–’в•ӘВәв”ҳГҘв”ҳГҘв•ӘВ»в”ҢВ»в–ҲГ®\n                </h3>\n              </div>\n              <div className={`p-2.5 rounded-lg ${lowSafetyCount > 0 ? 'bg-critical/10 text-critical' : 'bg-success/15 text-success'}`}>\n                <ShieldAlert className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n        </div>\n\n        <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-3\">\n          {/* Main Operators List */}\n          <div className=\"lg:col-span-2 space-y-6\">\n            <Card className=\"border-border-subtle bg-surface-container-low\">\n              <CardHeader className=\"flex flex-row items-center justify-between pb-3 border-b border-border-subtle\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Award className=\"size-4 text-accent\" />\n                  в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГӘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ\n                </CardTitle>\n                <Button size=\"sm\" className=\"h-8 gap-1\" onClick={() => setShowAddForm(!showAddForm)}>\n                  <Plus className=\"size-4\" />\n                  <span>в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в–ҲГ®в•ӘВә в”ҳГ в•ӘВ»в•Әв–’в”ҢвҢҗ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</span>\n                </Button>\n              </CardHeader>\n              <CardContent className=\"pt-4\">\n                {/* Search & Filters */}\n                <div className=\"flex flex-col gap-3 md:flex-row md:items-center mb-4\">\n                  <div className=\"relative flex-1\">\n                    <Search className=\"absolute right-3 top-2.5 size-4 text-foreground-muted\" />\n                    <input\n                      type=\"text\"\n                      placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГҘв•ӘВәв”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в–ҲГ®в•ӘВә в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®...\"\n                      value={searchTerm}\n                      onChange={(e) => setSearchTerm(e.target.value)}\n                      className=\"w-full rounded-md border border-border bg-surface pr-9 pl-3 py-2 text-sm text-foreground focus:outline-none focus:ring-1 focus:ring-accent\"\n                    />\n                  </div>\n\n                  <div className=\"flex gap-2\">\n                    <select\n                      value={filterTier}\n                      onChange={(e) => setFilterTier(e.target.value)}\n                      className=\"rounded-md border border-border bg-surface px-2.5 py-2 text-xs\"\n                    >\n                      <option value=\"all\">в”ҳГ§в”ҳГ в”ҳГ§ в•Әв–’в•ӘВ»в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</option>\n                      <option value=\"base_3\">в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв”Ӯ</option>\n                      <option value=\"base_2\">в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“</option>\n                      <option value=\"base_1\">в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’</option>\n                      <option value=\"senior\">в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ»</option>\n                    </select>\n\n                    <select\n                      value={filterMedical}\n                      onChange={(e) => setFilterMedical(e.target.value)}\n                      className=\"rounded-md border border-border bg-surface px-2.5 py-2 text-xs\"\n                    >\n                      <option value=\"all\">в”ҳГ§в”ҳГ в”ҳГ§ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’</option>\n                      <option value=\"approved\">в•ӘВ»в•ӘВәв•Әв–’в•ӘВәв–ҲГ® в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»в–ҲГ®в”ҳГ§</option>\n                      <option value=\"pending_exam\">в•ӘВ»в•Әв–’ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬ в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв”ҳГ§</option>\n                      <option value=\"expired\">в”ҳГ в”ҳГҘв”ҳГ©в•Әв•ўв–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§</option>\n                    </select>\n                  </div>\n                </div>\n\n                {/* Add Operator Form (Collapsible) */}\n                {showAddForm && (\n                  <form onSubmit={handleAddOperator} className=\"border border-border rounded-lg p-4 bg-surface space-y-4 mb-4\">\n                    <h4 className=\"text-xs font-bold text-foreground-muted border-b border-border pb-2\">в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</h4>\n                    <div className=\"grid grid-cols-1 gap-4 md:grid-cols-2\">\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ  в•ӘВ«в•ӘВәв”ҳГҘв”ҳГӘв•ӘВәв•ӘВ»в”ҢВ»в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ *</label>\n                        <input\n                          type=\"text\"\n                          required\n                          value={opName}\n                          onChange={(e) => setOpName(e.target.value)}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                        />\n                      </div>\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® *</label>\n                        <input\n                          type=\"text\"\n                          required\n                          value={opCode}\n                          onChange={(e) => setOpCode(e.target.value)}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"grid grid-cols-1 gap-4 md:grid-cols-3\">\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в•Әв–’в•ӘВ»в”ҳГ§ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</label>\n                        <select\n                          value={opTier}\n                          onChange={(e) => setOpTier(e.target.value as Operator['licenseTier'])}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                        >\n                          <option value=\"base_3\">в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв”Ӯ</option>\n                          <option value=\"base_2\">в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“</option>\n                          <option value=\"base_1\">в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’</option>\n                          <option value=\"senior\">в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ»</option>\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв”ҳГ§ в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’</label>\n                        <select\n                          value={opMedStatus}\n                          onChange={(e) => setOpMedStatus(e.target.value as Operator['medicalStatus'])}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                        >\n                          <option value=\"approved\">в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ®</option>\n                          <option value=\"pending_exam\">в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬</option>\n                          <option value=\"expired\">в”ҳГ в”ҳГҘв”ҳГ©в•Әв•ўв–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§</option>\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’</label>\n                        <input\n                          type=\"text\"\n                          value={opMedExpiry}\n                          onChange={(e) => setOpMedExpiry(e.target.value)}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm font-mono\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"grid grid-cols-1 gap-4 md:grid-cols-4\">\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ ( Simulator )</label>\n                        <input\n                          type=\"number\"\n                          value={opSimScore}\n                          onChange={(e) => setOpSimScore(Number(e.target.value))}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                        />\n                      </div>\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘГів•ӘВ«в•Әв–’в–ҲГ®в”ҳГҘ в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“</label>\n                        <input\n                          type=\"text\"\n                          value={opSimDate}\n                          onChange={(e) => setOpSimDate(e.target.value)}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm font-mono\"\n                        />\n                      </div>\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</label>\n                        <input\n                          type=\"text\"\n                          value={opLicExpiry}\n                          onChange={(e) => setOpLicExpiry(e.target.value)}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm font-mono\"\n                        />\n                      </div>\n                      <div className=\"space-y-1\">\n                        <label className=\"text-xs font-semibold\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ (в•ӘВәв•Әв–“ в–Ҳв–’в–Ҳв–‘в–Ҳв–‘)</label>\n                        <input\n                          type=\"number\"\n                          value={opSafety}\n                          onChange={(e) => setOpSafety(Number(e.target.value))}\n                          className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"flex justify-end gap-2 pt-2\">\n                      <Button type=\"button\" variant=\"ghost\" size=\"sm\" onClick={() => setShowAddForm(false)}>\n                        в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n                      </Button>\n                      <Button type=\"submit\" size=\"sm\">\n                        в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                      </Button>\n                    </div>\n                  </form>\n                )}\n\n                {/* Operators Table */}\n                <div className=\"overflow-x-auto\">\n                  <table className=\"w-full text-right border-collapse\">\n                    <thead>\n                      <tr className=\"border-b border-border-subtle bg-surface-container text-foreground-muted text-xs font-semibold\">\n                        <th className=\"p-3\">в”ҳГҘв•ӘВәв”ҳГ  в”ҳГӘ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’</th>\n                        <th className=\"p-3\">в•Әв–’в•ӘВ»в”ҳГ§ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</th>\n                        <th className=\"p-3\">в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в”ҳГӨв”ҢвҢҗв”ҳГӘв”ҳГ в”ҳГӘв•ӘВ¬в–ҲГ®в”ҳГӘ</th>\n                        <th className=\"p-3\">в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ® (в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’)</th>\n                        <th className=\"p-3\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’</th>\n                        <th className=\"p-3 text-left\">в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ в•ӘВәв•ӘВ¬ в•Әв”Ӯв•Әв–’в–ҲГ®в•Әв•Ј</th>\n                      </tr>\n                    </thead>\n                    <tbody className=\"divide-y divide-border-subtle text-sm\">\n                      {filteredOperators.map((op) => {\n                        const isSimFailed = op.simulatorScore < minPassingSimScore\n                        const isSafetyLow = op.safetyScore < safetyAlertThreshold\n\n                        return (\n                          <tr key={op.id} className=\"hover:bg-surface-hover\">\n                            <td className=\"p-3\">\n                              <div className=\"font-semibold text-foreground\">{op.name}</div>\n                              <div className=\"text-xs text-foreground-muted mt-0.5\">в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®: {op.employeeCode}</div>\n                            </td>\n                            <td className=\"p-3\">\n                              <div className=\"font-medium text-xs text-foreground-muted\">{TIER_LABELS[op.licenseTier]}</div>\n                              <div className=\"text-[10px] text-foreground-muted/70 font-mono mt-0.5\">в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВә: {op.licenseExpiry}</div>\n                            </td>\n                            <td className=\"p-3\">\n                              <div className={`font-mono font-bold ${isSimFailed ? 'text-critical' : 'text-success'}`}>\n                                {op.simulatorScore} в•ӘВәв•Әв–“ в–Ҳв–’в–Ҳв–‘в–Ҳв–‘\n                                {isSimFailed && <span className=\"text-[10px] mr-1 text-critical font-medium font-sans\">(в•Әв•Јв•ӘВ»в”ҳГ  в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨв–ҲГ®)</span>}\n                              </div>\n                              <div className=\"text-[10px] text-foreground-muted mt-0.5\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в•Әв”Ӯв•ӘВ¬: {op.lastSimulatorTest}</div>\n                            </td>\n                            <td className=\"p-3\">\n                              <div className=\"flex items-center gap-1.5\">\n                                <Badge\n                                  variant=\"outline\"\n                                  className={\n                                    op.medicalStatus === 'approved'\n                                      ? 'bg-success/15 text-success border-success/30'\n                                      : op.medicalStatus === 'expired'\n                                      ? 'bg-critical/10 text-critical border-critical/20'\n                                      : 'bg-warning/10 text-warning border-warning/20'\n                                  }\n                                >\n                                  {op.medicalStatus === 'approved' ? 'в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’' : op.medicalStatus === 'expired' ? 'в”ҳГ в”ҳГҘв”ҳГ©в•Әв•ўв–ҲГ® в•Әв”Өв•ӘВ»в”ҳГ§' : 'в•ӘВ»в•Әв–’ в”ҳГҘв”ҳГӘв•ӘВҝв•ӘВ¬ в•ӘВ¬в•Әв”Ӯв•ӘВ¬'}\n                                </Badge>\n                              </div>\n                              <div className=\"text-[10px] text-foreground-muted mt-0.5\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’: {op.medicalExpiry}</div>\n                            </td>\n                            <td className=\"p-3\">\n                              <div className={`font-mono font-bold ${isSafetyLow ? 'text-critical' : 'text-success'}`}>\n                                {op.safetyScore}в”ҳВ¬\n                              </div>\n                              <p className=\"text-[9px] text-foreground-muted mt-0.5\">в•ӘВҝв•Әв–’в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в•ӘВ«в•Әв•–в•ӘВәв”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨв–ҲГ®в”ҳГҘв”ҢВ»</p>\n                            </td>\n                            <td className=\"p-3 text-left space-y-1\">\n                              <div className=\"flex items-center justify-end gap-1\">\n                                <Button\n                                  size=\"sm\"\n                                  variant=\"outline\"\n                                  className=\"h-7 text-[10px] px-2\"\n                                  onClick={() => handleUpdateSimulatorScore(op.id, op.simulatorScore + 5)}\n                                >\n                                  в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n                                </Button>\n                              </div>\n                            </td>\n                          </tr>\n                        )\n                      })}\n                    </tbody>\n                  </table>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n\n          {/* Sidebar Area: Policy Config */}\n          <div className=\"space-y-6\">\n            <Card className=\"border-border-subtle bg-surface-container-low\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Settings className=\"size-4 text-accent\" />\n                  в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в”ҳГӘ в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-4\">\n                <div className=\"space-y-1\">\n                  <label className=\"text-xs text-foreground-muted\">в•ӘВЎв•ӘВ» в”ҳГҘв•Әв•Ўв•ӘВәв•ӘВҝ в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨв–ҲГ® в•ӘВ»в•Әв–’ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ ( Simulator )</label>\n                  <div className=\"flex items-center gap-2\">\n                    <input\n                      type=\"number\"\n                      value={minPassingSimScore}\n                      onChange={(e) => setMinPassingSimScore(Number(e.target.value))}\n                      className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                    />\n                    <span className=\"text-xs text-foreground-muted font-semibold\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“</span>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-xs text-foreground-muted\">в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГҘв•ӘВәв”ҳГӘв•ӘВҝ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв”Ӯв”ҳГӨв•ӘВәв”ҳГ в•ӘВ¬ в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ® (в•Әв•–в•ӘВҝ в”ҢвҢҗв•ӘВәв•Әв–’)</label>\n                  <div className=\"flex items-center gap-2\">\n                    <input\n                      type=\"number\"\n                      value={medicalValidityMonths}\n                      onChange={(e) => setMedicalValidityMonths(Number(e.target.value))}\n                      className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                    />\n                    <span className=\"text-xs text-foreground-muted font-semibold\">в”ҳГ в•ӘВәв”ҳГ§</span>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-xs text-foreground-muted\">в•ӘВЎв•ӘВ» в•ӘГів•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</label>\n                  <div className=\"flex items-center gap-2\">\n                    <input\n                      type=\"number\"\n                      value={safetyAlertThreshold}\n                      onChange={(e) => setSafetyAlertThreshold(Number(e.target.value))}\n                      className=\"w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm\"\n                    />\n                    <span className=\"text-xs text-foreground-muted font-semibold\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»</span>\n                  </div>\n                </div>\n\n                <div className=\"flex justify-end pt-2\">\n                  <Button\n                    size=\"sm\"\n                    onClick={() => {\n                      setSuccessMessage('в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҝв”ҳГ§О“ГҮГ®в•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в•Әв”Өв•ӘВ».')\n                      setTimeout(() => setSuccessMessage(''), 3000)\n                    }}\n                  >\n                    в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®\n                  </Button>\n                </div>\n              </CardContent>\n            </Card>\n\n            <Card className=\"border-border-subtle bg-surface-container-low\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Clock className=\"size-4 text-warning\" />\n                  в•ӘВҝв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘО“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв•ӘВәв•ӘВ¬ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ® в•ӘВҝв•Әв•Јв•ӘВ»в–ҲГ®\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-3 text-xs leading-relaxed\">\n                <div className=\"p-2.5 border border-border rounded-md bg-surface\">\n                  <div className=\"font-semibold\">в•ӘВ¬в•Әв”Ӯв•ӘВ¬ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВәв”ҳГӨв”ҳГј (в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВәв•Әв•Ўв”ҳГӨв–ҲГ®)</div>\n                  <div className=\"text-foreground-muted mt-1\">в•Әв”Өв”ҳГҘв•ӘВҝв”ҳГ§ в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ө/в–Ҳв–’в–Ҳв–‘ О“ГҮГі в•ӘВҝв–ҲГ®в”ҳГ в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВ¬в•ӘВәв”ҳГҘ в•ӘВ¬в•ӘВ«в•Әв•Ўв•Әв•Ўв–ҲГ® в”ҳГҘв•ӘВәв•ӘВјв•ӘВә</div>\n                </div>\n                <div className=\"p-2.5 border border-border rounded-md bg-surface\">\n                  <div className=\"font-semibold\">в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’в”ҢВ»в•ӘВәв”ҳГ§в–ҲГ® в”ҳГӘ в•Әв”Ӯв”ҳГҘв•ӘВәв•Әв–’в–ҲГ®в”ҳГӘв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ® в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в•Әв•Ўв•ӘВәв•ӘВ»в”ҳГ©в–ҲГ®в”ҳГ§</div>\n                  <div className=\"text-foreground-muted mt-1\">в•ӘВ»в”ҳГӘв•Әв”Өв”ҳГҘв•ӘВҝв”ҳГ§ в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ө/в–Ҳв–’в–Ҳв–“ О“ГҮГі в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в•Әв•Ўв•ӘВҝв•ӘВЎ</div>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        </div>\n      </main>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\performance-appeals\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'load'. Either include it or remove the dependency array.","line":78,"column":36,"nodeType":"ArrayExpression","endLine":78,"endColumn":57,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, filter, load]","fix":{"range":[2443,2464],"text":"[accessToken, filter, load]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent } from '@/components/ui/card'\nimport { Button } from '@/components/ui/button'\nimport { Badge } from '@/components/ui/badge'\nimport { toFa, jalali } from '@/lib/fa'\nimport {\n  FileText,\n  CheckCircle2,\n  XCircle,\n  Clock,\n  ChevronDown,\n  ChevronUp,\n  AlertCircle,\n} from 'lucide-react'\nimport { cn } from '@/lib/utils'\n\ninterface Appeal {\n  id: string\n  logId: string\n  employeeId: string\n  reason: string\n  status: 'pending' | 'approved' | 'rejected'\n  note: string | null\n  createdAt: string\n  resolvedAt: string | null\n  employee: { id: string; name: string; customFields: Record<string, unknown> }\n  reviewedBy: { id: string; name: string } | null\n  log: {\n    id: string\n    scoreValue: number\n    severity: string\n    periodId: string\n    status: string\n    actionType: {\n      title: string\n      competency: { name: string }\n    }\n    recordedBy: { name: string }\n  }\n}\n\nconst STATUS_CONFIG: Record<string, { label: string; color: string; icon: React.ElementType }> = {\n  pending: { label: 'в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ®', color: 'text-warning border-warning/30 bg-warning/5', icon: Clock },\n  approved: { label: 'в”ҳв•ӣв•Әв–‘в–ҲГ®в•Әв–’в”ҳГјв•ӘВ¬в”ҳГ§ в•Әв”Өв•ӘВ»', color: 'text-success border-success/30 bg-success/5', icon: CheckCircle2 },\n  rejected: { label: 'в•Әв–’в•ӘВ» в•Әв”Өв•ӘВ»', color: 'text-critical border-critical/30 bg-critical/5', icon: XCircle },\n}\n\nexport default function AdminAppealsPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const [appeals, setAppeals] = useState<Appeal[]>([])\n  const [loading, setLoading] = useState(true)\n  const [filter, setFilter] = useState<'all' | 'pending' | 'approved' | 'rejected'>('pending')\n  const [expanded, setExpanded] = useState<string | null>(null)\n  const [reviewNote, setReviewNote] = useState('')\n  const [reviewing, setReviewing] = useState<string | null>(null)\n  const [error, setError] = useState('')\n\n  async function load() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const url = filter === 'all'\n        ? '/api/admin/performance/appeal'\n        : `/api/admin/performance/appeal?status=${filter}`\n      const res = await fetch(url, {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      const json = await res.json()\n      setAppeals(json.data ?? [])\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => { void load() }, [accessToken, filter])\n\n  async function handleReview(appealId: string, status: 'approved' | 'rejected') {\n    setReviewing(appealId)\n    setError('')\n    try {\n      const res = await fetch(`/api/admin/performance/appeal/${appealId}`, {\n        method: 'PATCH',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({ status, note: reviewNote }),\n      })\n      const json = await res.json()\n      if (!res.ok) {\n        setError(json.error ?? 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў')\n      } else {\n        setExpanded(null)\n        setReviewNote('')\n        await load()\n      }\n    } catch {\n      setError('в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§')\n    } finally {\n      setReviewing(null)\n    }\n  }\n\n  const pendingCount = appeals.filter((a) => a.status === 'pending').length\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 md:p-6\" dir=\"rtl\">\n      {/* Header */}\n      <div className=\"flex items-start justify-between gap-4\">\n        <div>\n          <h1 className=\"text-xl font-bold text-foreground flex items-center gap-2\">\n            <FileText className=\"size-6 text-accent\" />\n            в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв•ӘВәв•ӘВ¬ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»\n          </h1>\n          <p className=\"text-sm text-foreground-muted mt-1\">\n            в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘ в•ӘВ»в•ӘВәв”ҳГӘв•Әв–’в–ҲГ® в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҝв”ҳГ§ в”ҳГҘв”ҳГ в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§\n          </p>\n        </div>\n        {pendingCount > 0 && filter !== 'pending' && (\n          <Badge className=\"bg-warning/15 text-warning border border-warning/30 shrink-0\">\n            {toFa(pendingCount)} в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’\n          </Badge>\n        )}\n      </div>\n\n      {/* Filter tabs */}\n      <div className=\"flex gap-1 rounded-xl border border-border bg-surface-container-low p-1 self-start\">\n        {(['all', 'pending', 'approved', 'rejected'] as const).map((f) => (\n          <button\n            key={f}\n            onClick={() => setFilter(f)}\n            className={cn(\n              'px-3 py-1.5 rounded-lg text-xs font-medium transition-all',\n              filter === f\n                ? 'bg-surface text-foreground shadow-sm'\n                : 'text-foreground-muted hover:text-foreground',\n            )}\n          >\n            {f === 'all' ? 'в”ҳГ§в”ҳГ в”ҳГ§' : STATUS_CONFIG[f].label}\n          </button>\n        ))}\n      </div>\n\n      {error && (\n        <div className=\"flex items-center gap-2 text-sm text-critical bg-critical/5 border border-critical/20 rounded-lg p-3\">\n          <AlertCircle className=\"size-4 shrink-0\" />\n          {error}\n        </div>\n      )}\n\n      {loading ? (\n        <div className=\"space-y-3\">\n          {[0, 1, 2].map((i) => (\n            <div key={i} className=\"h-20 animate-pulse rounded-xl bg-surface-container-low border border-border\" />\n          ))}\n        </div>\n      ) : appeals.length === 0 ? (\n        <Card>\n          <CardContent className=\"flex flex-col items-center justify-center py-12 gap-2\">\n            <FileText className=\"size-10 text-foreground-muted/40\" />\n            <p className=\"text-sm text-foreground-muted\">в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ўв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§ в”ҳГӘв•ӘВјв”ҳГӘв•ӘВ» в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в•ӘВ»</p>\n          </CardContent>\n        </Card>\n      ) : (\n        <div className=\"space-y-3\">\n          {appeals.map((appeal) => {\n            const statusCfg = STATUS_CONFIG[appeal.status]\n            const StatusIcon = statusCfg.icon\n            const isExpanded = expanded === appeal.id\n            const isPositive = appeal.log.scoreValue >= 0\n\n            return (\n              <Card key={appeal.id} className={cn('overflow-hidden', appeal.status === 'pending' && 'ring-1 ring-warning/20')}>\n                <button\n                  type=\"button\"\n                  className=\"w-full text-start\"\n                  onClick={() => setExpanded(isExpanded ? null : appeal.id)}\n                >\n                  <div className=\"flex items-start gap-3 p-4\">\n                    {/* Status icon */}\n                    <div className={cn('flex size-9 shrink-0 items-center justify-center rounded-lg border', statusCfg.color)}>\n                      <StatusIcon className=\"size-4\" />\n                    </div>\n\n                    <div className=\"flex-1 min-w-0 text-start\">\n                      {/* Employee name + action type */}\n                      <div className=\"flex items-center gap-2 flex-wrap\">\n                        <span className=\"text-sm font-semibold text-foreground\">{appeal.employee.name}</span>\n                        <Badge variant=\"outline\" className={`text-[10px] px-1.5 py-0 ${statusCfg.color}`}>\n                          {statusCfg.label}\n                        </Badge>\n                      </div>\n                      <p className=\"text-xs text-foreground-muted mt-0.5 truncate\">\n                        в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»: {appeal.log.actionType.title}\n                      </p>\n                      <div className=\"flex items-center gap-3 mt-1\">\n                        <span className={cn('text-xs font-bold', isPositive ? 'text-success' : 'text-critical')}>\n                          {isPositive ? '+' : ''}{toFa(appeal.log.scoreValue)} в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“\n                        </span>\n                        <span className=\"text-[10px] text-foreground-muted\">\n                          в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§: {appeal.log.periodId}\n                        </span>\n                        <span className=\"text-[10px] text-foreground-muted\">\n                          {jalali(appeal.createdAt)}\n                        </span>\n                      </div>\n                    </div>\n\n                    {isExpanded ? (\n                      <ChevronUp className=\"size-4 text-foreground-muted shrink-0 mt-1\" />\n                    ) : (\n                      <ChevronDown className=\"size-4 text-foreground-muted shrink-0 mt-1\" />\n                    )}\n                  </div>\n                </button>\n\n                {/* Expanded detail */}\n                {isExpanded && (\n                  <div className=\"border-t border-border/50 px-4 pb-4 pt-3 space-y-3\">\n                    {/* Appeal reason */}\n                    <div className=\"rounded-lg bg-surface-container-low/50 p-3 space-y-1\">\n                      <p className=\"text-[11px] font-semibold text-foreground-muted uppercase tracking-wide\">в•ӘВ»в”ҳГӨв–ҲГ®в”ҳГӨ в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</p>\n                      <p className=\"text-sm text-foreground leading-relaxed\">{appeal.reason}</p>\n                    </div>\n\n                    {/* Log details */}\n                    <div className=\"grid grid-cols-2 gap-2 text-xs\">\n                      <div className=\"rounded-lg bg-surface-container-low/30 p-2\">\n                        <p className=\"text-foreground-muted mb-0.5\">в•ӘВҪв•ӘВҝв•ӘВ¬О“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§</p>\n                        <p className=\"font-medium text-foreground\">{appeal.log.recordedBy.name}</p>\n                      </div>\n                      <div className=\"rounded-lg bg-surface-container-low/30 p-2\">\n                        <p className=\"text-foreground-muted mb-0.5\">в”ҳГ в•ӘВЎв”ҳГӘв•Әв–’ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®</p>\n                        <p className=\"font-medium text-foreground\">{appeal.log.actionType.competency.name}</p>\n                      </div>\n                    </div>\n\n                    {/* Review note (if reviewed) */}\n                    {appeal.note && (\n                      <div className=\"rounded-lg bg-surface-container/30 border border-border/40 p-3\">\n                        <p className=\"text-[11px] font-semibold text-foreground-muted mb-1\">в–ҲГ®в•ӘВәв•ӘВ»в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬ в•ӘВ»в•ӘВәв”ҳГӘв•Әв–’</p>\n                        <p className=\"text-xs text-foreground\">{appeal.note}</p>\n                        {appeal.reviewedBy && (\n                          <p className=\"text-[10px] text-foreground-muted mt-1\">\n                            в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–: {appeal.reviewedBy.name}\n                          </p>\n                        )}\n                      </div>\n                    )}\n\n                    {/* Review actions (only for pending) */}\n                    {appeal.status === 'pending' && (\n                      <div className=\"space-y-3 pt-1\">\n                        <div className=\"space-y-1.5\">\n                          <label className=\"text-xs text-foreground-muted\">в–ҲГ®в•ӘВәв•ӘВ»в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬ в•ӘВ»в•ӘВәв”ҳГӘв•Әв–’ (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)</label>\n                          <textarea\n                            value={reviewNote}\n                            onChange={(e) => setReviewNote(e.target.value)}\n                            placeholder=\"в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎ в•ӘВ¬в•Әв•Ўв”ҳГ в–ҲГ®в”ҳГ  в–ҲГ®в•ӘВә в•ӘВ»в”ҳГӨв–ҲГ®в”ҳГӨ в•Әв–’в•ӘВ»/в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨ...\"\n                            rows={2}\n                            className=\"w-full rounded-lg border border-outline-variant bg-surface px-3 py-2 text-sm text-foreground focus:border-accent focus:ring-1 focus:ring-accent outline-none resize-none\"\n                          />\n                        </div>\n\n                        <div className=\"flex items-center gap-2 justify-end\">\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            onClick={() => handleReview(appeal.id, 'rejected')}\n                            disabled={reviewing === appeal.id}\n                            className=\"text-xs border-critical/30 text-critical hover:bg-critical/5\"\n                          >\n                            <XCircle className=\"size-3.5 me-1.5\" />\n                            в•Әв–’в•ӘВ» в•ӘВәв•Әв•Јв•ӘВ¬в•Әв–’в•ӘВәв•Әв•ў\n                          </Button>\n                          <Button\n                            size=\"sm\"\n                            onClick={() => handleReview(appeal.id, 'approved')}\n                            disabled={reviewing === appeal.id}\n                            className=\"text-xs bg-success/90 hover:bg-success text-white\"\n                          >\n                            <CheckCircle2 className=\"size-3.5 me-1.5\" />\n                            {reviewing === appeal.id ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬...' : 'в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в•ӘВЎв•Әв–‘в”ҳГј в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§'}\n                          </Button>\n                        </div>\n                      </div>\n                    )}\n                  </div>\n                )}\n              </Card>\n            )\n          })}\n        </div>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\performance-config\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'load'. Either include it or remove the dependency array.","line":85,"column":6,"nodeType":"ArrayExpression","endLine":85,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, load]","fix":{"range":[2412,2425],"text":"[accessToken, load]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Label } from '@/components/ui/label'\nimport { Badge } from '@/components/ui/badge'\nimport { toFa } from '@/lib/fa'\nimport {\n  Plus,\n  Award,\n  ChevronDown,\n  ChevronUp,\n  TrendingUp,\n  TrendingDown,\n  Minus,\n  AlertCircle,\n  CheckCircle2,\n  Settings,\n} from 'lucide-react'\n\ninterface ActionType {\n  id: string\n  title: string\n  defaultScore: number\n  maxSeverity: string\n}\n\ninterface Competency {\n  id: string\n  name: string\n  weight: number\n  direction: string\n  actionTypes: ActionType[]\n}\n\nconst DIRECTION_CONFIG: Record<string, { label: string; color: string; icon: React.ElementType }> = {\n  positive: { label: 'в”ҳв•ӣв•ӘВәв•ӘВ»в•ӘВәв•Әв”Өв–ҲГ®', color: 'text-success', icon: TrendingUp },\n  negative: { label: 'в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®', color: 'text-critical', icon: TrendingDown },\n  both: { label: 'в•ӘВ»в”ҳГӘв•Әв•–в•Әв–’в”ҳГјв”ҳГ§', color: 'text-info', icon: Minus },\n}\n\nconst SEVERITY_LABELS: Record<string, string> = {\n  L1: 'в•Әв”Ӯв•Әв•–в•ӘВЎ в–Ҳв–’ (в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§)',\n  L2: 'в•Әв”Ӯв•Әв•–в•ӘВЎ в–Ҳв–“ (в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–)',\n  L3: 'в•Әв”Ӯв•Әв•–в•ӘВЎ в–Ҳв”Ӯ (в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®)',\n}\n\nexport default function PerformanceConfigPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n\n  const [competencies, setCompetencies] = useState<Competency[]>([])\n  const [loading, setLoading] = useState(true)\n  const [expandedId, setExpandedId] = useState<string | null>(null)\n  const [showForm, setShowForm] = useState<string | null>(null) // competency id for which form is open\n\n  // Form state\n  const [formTitle, setFormTitle] = useState('')\n  const [formScore, setFormScore] = useState<string>('10')\n  const [formSeverity, setFormSeverity] = useState<'L1' | 'L2' | 'L3'>('L1')\n  const [formLoading, setFormLoading] = useState(false)\n  const [formError, setFormError] = useState('')\n  const [formSuccess, setFormSuccess] = useState('')\n\n  async function load() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const res = await fetch('/api/admin/performance/logs', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const json = await res.json()\n        setCompetencies(json.data?.competencies ?? [])\n      }\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    void load()\n  }, [accessToken])\n\n  async function handleAddActionType(competencyId: string) {\n    const score = parseFloat(formScore)\n    if (!formTitle.trim()) { setFormError('в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬'); return }\n    if (isNaN(score)) { setFormError('в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в•ӘВҝв•ӘВәв–ҲГ®в•ӘВ» в•Әв•Јв•ӘВ»в•ӘВ» в•ӘВҝв•ӘВәв•Әв”Өв•ӘВ»'); return }\n\n    setFormLoading(true)\n    setFormError('')\n    setFormSuccess('')\n    try {\n      const res = await fetch('/api/admin/performance/action-types', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          competencyId,\n          title: formTitle.trim(),\n          defaultScore: score,\n          maxSeverity: formSeverity,\n        }),\n      })\n      const json = await res.json()\n      if (!res.ok) {\n        setFormError(json.error ?? 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»')\n      } else {\n        setFormSuccess('в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГ§ в•Әв”Өв•ӘВ»')\n        setFormTitle('')\n        setFormScore('10')\n        setFormSeverity('L1')\n        setShowForm(null)\n        await load()\n      }\n    } catch {\n      setFormError('в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§')\n    } finally {\n      setFormLoading(false)\n    }\n  }\n\n  function openForm(competencyId: string) {\n    setShowForm(showForm === competencyId ? null : competencyId)\n    setFormError('')\n    setFormSuccess('')\n    setFormTitle('')\n    setFormScore('10')\n    setFormSeverity('L1')\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 md:p-6\" dir=\"rtl\">\n      {/* Header */}\n      <div>\n        <h1 className=\"text-xl font-bold text-foreground flex items-center gap-2\">\n          <Settings className=\"size-6 text-accent\" />\n          в”ҳв•ӣв–ҲГ®в”ҢвҢҗв•Әв–’в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҢвҢҗв•ӘВәв•ӘВ¬в•ӘВәв”ҳГӨв”ҳГӘв”ҢВ» в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»\n        </h1>\n        <p className=\"text-sm text-foreground-muted mt-1\">\n          в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВәв”ҳГҘв”ҳГӘв•ӘВәв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГ©в•ӘВәв•ӘВҝв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n        </p>\n      </div>\n\n      {loading ? (\n        <div className=\"space-y-3\">\n          {[0, 1, 2].map((i) => (\n            <div key={i} className=\"h-16 animate-pulse rounded-xl bg-surface-container-low border border-border\" />\n          ))}\n        </div>\n      ) : (\n        <div className=\"space-y-4\">\n          {competencies.map((competency) => {\n            const dirCfg = DIRECTION_CONFIG[competency.direction] ?? DIRECTION_CONFIG.both\n            const DirIcon = dirCfg.icon\n            const isExpanded = expandedId === competency.id\n            const isFormOpen = showForm === competency.id\n\n            return (\n              <Card key={competency.id} className=\"overflow-hidden\">\n                {/* Competency Header */}\n                <button\n                  type=\"button\"\n                  onClick={() => setExpandedId(isExpanded ? null : competency.id)}\n                  className=\"w-full text-start\"\n                >\n                  <CardHeader className=\"pb-2 hover:bg-surface-container-low/50 transition-colors\">\n                    <div className=\"flex items-center justify-between gap-4\">\n                      <div className=\"flex items-center gap-3 min-w-0\">\n                        <div className=\"flex size-10 shrink-0 items-center justify-center rounded-lg bg-accent/10\">\n                          <Award className=\"size-5 text-accent\" />\n                        </div>\n                        <div className=\"min-w-0\">\n                          <CardTitle className=\"text-sm font-semibold text-foreground\">\n                            {competency.name}\n                          </CardTitle>\n                          <div className=\"flex items-center gap-2 mt-0.5 flex-wrap\">\n                            <Badge\n                              variant=\"outline\"\n                              className={`text-[10px] px-1.5 py-0 ${dirCfg.color} border-current/30`}\n                            >\n                              <DirIcon className=\"size-3 me-1 inline\" />\n                              {dirCfg.label}\n                            </Badge>\n                            <span className=\"text-[10px] text-foreground-muted\">\n                              в•Әв•ўв•Әв–’в–ҲГ®в•ӘВҝ: {toFa(competency.weight)}\n                            </span>\n                            <span className=\"text-[10px] text-foreground-muted\">\n                              {toFa(competency.actionTypes.length)} в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»\n                            </span>\n                          </div>\n                        </div>\n                      </div>\n                      {isExpanded ? (\n                        <ChevronUp className=\"size-4 text-foreground-muted shrink-0\" />\n                      ) : (\n                        <ChevronDown className=\"size-4 text-foreground-muted shrink-0\" />\n                      )}\n                    </div>\n                  </CardHeader>\n                </button>\n\n                {/* Expanded content */}\n                {isExpanded && (\n                  <CardContent className=\"pt-0 pb-4 space-y-2\">\n                    {/* Action Types list */}\n                    <div className=\"space-y-1.5 mb-3\">\n                      {competency.actionTypes.length === 0 ? (\n                        <p className=\"text-xs text-foreground-muted text-center py-4\">\n                          в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»в–ҲГ® в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬\n                        </p>\n                      ) : (\n                        competency.actionTypes.map((at) => (\n                          <div\n                            key={at.id}\n                            className=\"flex items-center gap-3 rounded-lg border border-border/60 bg-surface-container/40 px-3 py-2\"\n                          >\n                            <div className={`flex size-6 shrink-0 items-center justify-center rounded text-xs font-bold ${at.defaultScore >= 0 ? 'bg-success/10 text-success' : 'bg-critical/10 text-critical'}`}>\n                              {at.defaultScore >= 0 ? '+' : ''}\n                              {toFa(at.defaultScore)}\n                            </div>\n                            <div className=\"flex-1 min-w-0\">\n                              <p className=\"text-xs font-medium text-foreground truncate\">{at.title}</p>\n                              <p className=\"text-[10px] text-foreground-muted\">{SEVERITY_LABELS[at.maxSeverity]}</p>\n                            </div>\n                            <Badge\n                              variant=\"outline\"\n                              className={`text-[9px] shrink-0 ${at.id.startsWith('c-') ? 'border-accent/30 text-accent' : 'border-border text-foreground-muted'}`}\n                            >\n                              {at.id.startsWith('c-') ? 'в•Әв”Ӯв”ҳГјв•ӘВәв•Әв–’в•Әв”Өв–ҲГ®' : 'в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў'}\n                            </Badge>\n                          </div>\n                        ))\n                      )}\n                    </div>\n\n                    {/* Add new action type form */}\n                    {isFormOpen ? (\n                      <div className=\"rounded-xl border border-accent/20 bg-accent/5 p-4 space-y-3\">\n                        <p className=\"text-xs font-semibold text-accent\">в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в”¬ВҪ{competency.name}в”¬в•—</p>\n\n                        <div className=\"space-y-2\">\n                          <Label className=\"text-xs text-foreground-muted\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»</Label>\n                          <Input\n                            value={formTitle}\n                            onChange={(e) => setFormTitle(e.target.value)}\n                            placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ: в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВҝв”ҳГ§в–ҲГ®в”ҳГҘв”ҳГ§ в•ӘВәв”ҳГҘв•Әв–’в”ҢГҝв–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬\"\n                            className=\"text-sm\"\n                          />\n                        </div>\n\n                        <div className=\"grid grid-cols-2 gap-3\">\n                          <div className=\"space-y-2\">\n                            <Label className=\"text-xs text-foreground-muted\">\n                              в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§\n                              <span className=\"text-[10px] text-foreground-muted/60 ms-1\">(в”ҳГ в”ҳГҘв”ҳГјв–ҲГ® = в•ӘВјв•Әв–’в–ҲГ®в”ҳГ в”ҳГ§)</span>\n                            </Label>\n                            <Input\n                              type=\"number\"\n                              value={formScore}\n                              onChange={(e) => setFormScore(e.target.value)}\n                              placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВәв”ҳГҜ в–Ҳв–’в–Ҳв–‘ в–ҲГ®в•ӘВә в–Ҳв–’в–Ҳв•Ў-\"\n                              className=\"text-sm\"\n                            />\n                          </div>\n\n                          <div className=\"space-y-2\">\n                            <Label className=\"text-xs text-foreground-muted\">в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ</Label>\n                            <select\n                              value={formSeverity}\n                              onChange={(e) => setFormSeverity(e.target.value as 'L1' | 'L2' | 'L3')}\n                              className=\"flex h-9 w-full rounded-lg border border-outline-variant bg-surface px-3 text-sm text-foreground focus:border-accent focus:ring-1 focus:ring-accent outline-none\"\n                            >\n                              <option value=\"L1\">в•Әв”Ӯв•Әв•–в•ӘВЎ в–Ҳв–’ (в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§)</option>\n                              <option value=\"L2\">в•Әв”Ӯв•Әв•–в•ӘВЎ в–Ҳв–“ (в”ҳГ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•–)</option>\n                              <option value=\"L3\">в•Әв”Ӯв•Әв•–в•ӘВЎ в–Ҳв”Ӯ (в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®)</option>\n                            </select>\n                          </div>\n                        </div>\n\n                        {formError && (\n                          <div className=\"flex items-center gap-2 text-xs text-critical\">\n                            <AlertCircle className=\"size-3.5 shrink-0\" />\n                            {formError}\n                          </div>\n                        )}\n                        {formSuccess && (\n                          <div className=\"flex items-center gap-2 text-xs text-success\">\n                            <CheckCircle2 className=\"size-3.5 shrink-0\" />\n                            {formSuccess}\n                          </div>\n                        )}\n\n                        <div className=\"flex items-center gap-2 justify-end\">\n                          <Button\n                            variant=\"outline\"\n                            size=\"sm\"\n                            onClick={() => openForm(competency.id)}\n                            className=\"text-xs\"\n                          >\n                            в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n                          </Button>\n                          <Button\n                            size=\"sm\"\n                            onClick={() => handleAddActionType(competency.id)}\n                            disabled={formLoading}\n                            className=\"text-xs\"\n                          >\n                            {formLoading ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬...' : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»'}\n                          </Button>\n                        </div>\n                      </div>\n                    ) : (\n                      <Button\n                        variant=\"outline\"\n                        size=\"sm\"\n                        onClick={() => openForm(competency.id)}\n                        className=\"w-full text-xs border-dashed border-accent/40 text-accent hover:bg-accent/5\"\n                      >\n                        <Plus className=\"size-3.5 me-1\" />\n                        в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГҘ в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ®\n                      </Button>\n                    )}\n                  </CardContent>\n                )}\n              </Card>\n            )\n          })}\n        </div>\n      )}\n\n      {/* Legend */}\n      <Card className=\"bg-surface-container-low/50\">\n        <CardContent className=\"p-4\">\n          <p className=\"text-xs font-semibold text-foreground mb-2\">в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВәв–ҲГ® в•Әв”Ӯв•Әв•–в”ҳГӘв•ӘВЎ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ</p>\n          <div className=\"grid grid-cols-1 gap-1.5\">\n            {Object.entries(SEVERITY_LABELS).map(([key, label]) => (\n              <div key={key} className=\"flex items-center gap-2 text-xs text-foreground-muted\">\n                <Badge variant=\"outline\" className=\"text-[9px] px-1.5\">{key}</Badge>\n                <span>{label}</span>\n                <span className=\"text-foreground-muted/60\">\n                  {key === 'L1' ? 'О“ГҮГ¶ в•Әв•ўв•Әв–’в–ҲГ®в•ӘВҝ в–Ҳв–’в”ңГ№' : key === 'L2' ? 'О“ГҮГ¶ в•Әв•ўв•Әв–’в–ҲГ®в•ӘВҝ в–Ҳв–’.в–Ҳв•Ўв”ңГ№' : 'О“ГҮГ¶ в•Әв•ўв•Әв–’в–ҲГ®в•ӘВҝ в–Ҳв–“в”ңГ№'}\n                </span>\n              </div>\n            ))}\n          </div>\n        </CardContent>\n      </Card>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\settings\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":33,"column":11,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":33,"endColumn":14,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[873,876],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[873,876],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":34,"column":10,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":34,"endColumn":13,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[886,889],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[886,889],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadSettings'. Either include it or remove the dependency array.","line":143,"column":6,"nodeType":"ArrayExpression","endLine":143,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadSettings]","fix":{"range":[4032,4045],"text":"[accessToken, loadSettings]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadAuditLogs'. Either include it or remove the dependency array.","line":149,"column":6,"nodeType":"ArrayExpression","endLine":149,"endColumn":30,"suggestions":[{"desc":"Update the dependencies array to be: [activeTab, accessToken, loadAuditLogs]","fix":{"range":[4154,4178],"text":"[activeTab, accessToken, loadAuditLogs]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Label } from '@/components/ui/label'\nimport { Badge } from '@/components/ui/badge'\nimport { Loader2, Save, RotateCcw, Check, AlertCircle } from 'lucide-react'\nimport { toFa } from '@/lib/fa'\n\ninterface Setting {\n  id: string\n  key: string\n  label: string\n  description: string | null\n  type: string\n  value: string // JSON serialized string\n  defaultValue: string\n  category: string\n  min: number | null\n  max: number | null\n  options: string | null\n}\n\ninterface AuditLog {\n  id: string\n  actorId: string\n  entity: string\n  entityId: string\n  action: string\n  before: any\n  after: any\n  createdAt: string\n  actor?: {\n    name: string | null\n    email: string\n    role: string\n  }\n}\n\nconst CATEGORY_MAP: Record<string, { label: string; icon: string }> = {\n  general: { label: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ®', icon: 'О“ГңГ–вҲ©в••Г…' },\n  shifts: { label: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә', icon: 'вүЎЖ’ГҙГ ' },\n  tickets: { label: 'в•ӘВ«в•Әв–’в•ӘВәв•ӘВҝв–ҲГ® в”ҳГӘ в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬в–ҲГ®в”ҳГҘв”ҢВ»', icon: 'вүЎЖ’Г„ВҪ' },\n  chat: { label: 'в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ О“ГҮГ®в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘ в”ҳГӘ в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘ', icon: 'вүЎЖ’ГҶВј' },\n  mobile: { label: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВәв”ҳв•ӣв”ҳГӨв–ҲГ®в”ҢвҢҗв–ҲГ®в•Әв”Өв”ҳГҘ в”ҳГ в”ҳГӘв•ӘВҝв•ӘВәв–ҲГ®в”ҳГӨ', icon: 'вүЎЖ’Гҙв–’' },\n  comms: { label: 'в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в”ҳГӘ в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®в”ҳГ ', icon: 'вүЎЖ’Г„Г–вҲ©в••Г…' },\n  performance: { label: 'в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в”ҳГӘ в”ҢВ»в–ҲГ®в”ҳГ в–ҲГ®в”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ®в•Әв”Өв”ҳГҘ', icon: 'вүЎЖ’Г…ГҘ' },\n  audit: { label: 'в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬', icon: 'вүЎЖ’ГҙВҘ' },\n}\n\nexport default function AdminSettingsPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const [settings, setSettings] = useState<Setting[]>([])\n  const [localValues, setLocalValues] = useState<Record<string, string | number | boolean>>({})\n  const [loading, setLoading] = useState(true)\n  const [saving, setSaving] = useState(false)\n  const [activeTab, setActiveTab] = useState('general')\n\n  // Audit Logs state\n  const [auditLogs, setAuditLogs] = useState<AuditLog[]>([])\n  const [loadingAudit, setLoadingAudit] = useState(false)\n  \n  // Notification states\n  const [notification, setNotification] = useState<{\n    type: 'success' | 'error'\n    text: string\n  } | null>(null)\n\n  // Reset notification after 4 seconds\n  useEffect(() => {\n    if (notification) {\n      const timer = setTimeout(() => setNotification(null), 4000)\n      return () => clearTimeout(timer)\n    }\n  }, [notification])\n\n  // Load settings\n  async function loadSettings() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const res = await fetch('/api/admin/settings', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        const settingsList = data.data as Setting[]\n        setSettings(settingsList)\n        \n        // Parse values\n        const values: Record<string, string | number | boolean> = {}\n        settingsList.forEach((s) => {\n          try {\n            values[s.key] = JSON.parse(s.value)\n          } catch {\n            values[s.key] = s.value\n          }\n        })\n        setLocalValues(values)\n      } else {\n        const errData = await res.json()\n        setNotification({\n          type: 'error',\n          text: errData.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬',\n        })\n      }\n    } catch {\n      setNotification({\n        type: 'error',\n        text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•Әв–’в”ҳГ©в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’',\n      })\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  // Load audit logs\n  async function loadAuditLogs() {\n    if (!accessToken) return\n    setLoadingAudit(true)\n    try {\n      const res = await fetch('/api/admin/settings/audit-logs', {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setAuditLogs(data.data as AuditLog[])\n      }\n    } catch {\n      // audit logs fetch failed silently\n    } finally {\n      setLoadingAudit(false)\n    }\n  }\n\n  useEffect(() => {\n    if (accessToken) {\n      void loadSettings()\n    }\n  }, [accessToken])\n\n  useEffect(() => {\n    if (activeTab === 'audit' && accessToken) {\n      void loadAuditLogs()\n    }\n  }, [activeTab, accessToken])\n\n  // Handle local state changes\n  function handleValueChange(key: string, val: string | number | boolean) {\n    setLocalValues((prev) => ({\n      ...prev,\n      [key]: val,\n    }))\n  }\n\n  // Save active tab settings\n  async function handleSave() {\n    if (!accessToken) return\n    setSaving(true)\n    \n    // Filter updates for the active tab\n    const activeSettings = settings.filter((s) => s.category === activeTab)\n    const updates = activeSettings.map((s) => ({\n      key: s.key,\n      value: localValues[s.key],\n    }))\n\n    try {\n      const res = await fetch('/api/admin/settings', {\n        method: 'PATCH',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ updates }),\n      })\n\n      const data = await res.json()\n      if (res.ok) {\n        setNotification({\n          type: 'success',\n          text: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•Әв”Өв•ӘВ»в”ҳГҘв•ӘВ» в”ҳГӘ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГҘв•ӘВ».',\n        })\n        loadSettings()\n      } else {\n        setNotification({\n          type: 'error',\n          text: data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬',\n        })\n      }\n    } catch {\n      setNotification({\n        type: 'error',\n        text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•Әв–’в”ҳГӘв–ҲГ® в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’',\n      })\n    } finally {\n      setSaving(false)\n    }\n  }\n\n  // Reset a specific setting to default\n  async function handleReset(key: string) {\n    if (!accessToken) return\n    if (!confirm('в•ӘГів–ҲГ®в•ӘВә в”ҳГ в•Әв•–в”ҳГ в•ӘВӘв”ҳГҘ в”ҳГ§в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВ» в”ҢвҢҗв”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в•ӘВ» в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ  в•Әв–’в•ӘВә в•ӘВҝв”ҳГ§ в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»в•ӘЖ’')) {\n      return\n    }\n\n    try {\n      const res = await fetch('/api/admin/settings/reset', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${accessToken}`,\n        },\n        body: JSON.stringify({ key }),\n      })\n\n      const data = await res.json()\n      if (res.ok) {\n        setNotification({\n          type: 'success',\n          text: 'в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ  в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҝв”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•Әв”Өв•ӘВ».',\n        })\n        loadSettings()\n      } else {\n        setNotification({\n          type: 'error',\n          text: data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ ',\n        })\n      }\n    } catch {\n      setNotification({\n        type: 'error',\n        text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•Әв–’в”ҳГ©в•Әв–’в•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’',\n      })\n    }\n  }\n\n  // Bulk reset all settings\n  async function handleResetAll() {\n    if (!accessToken) return\n    if (!confirm('вүЎЖ’ГңВҝ в”ҳГ§в•Әв”Өв•ӘВ»в•ӘВәв•Әв–’ в”ҳГ в”ҳГ§в”ҳГ !\\nв•ӘГів–ҲГ®в•ӘВә в”ҳГ в•Әв•–в”ҳГ в•ӘВӘв”ҳГҘ в”ҳГ§в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВ» в”ҢвҢҗв”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в•ӘВ» в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•Әв–’в•ӘВә в•ӘВҝв”ҳГ§ в”ҳГ в”ҳГ©в•ӘВәв•ӘВ»в–ҲГ®в•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»в•ӘЖ’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ  в•ӘВҝв”ҳГӨв•ӘВәв”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВҝв•Әв–’ в•Әв–’в”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГӨв•ӘВәв–ҲГ®в”ҳГҘв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВәв”ҳв•ӣв”ҳГӨв–ҲГ®в”ҢвҢҗв–ҲГ®в•Әв”Өв”ҳГҘ в”ҳГ в”ҳГӘв•ӘВҝв•ӘВәв–ҲГ®в”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в•ӘВ» в•Әв”Өв•ӘВ».')) {\n      return\n    }\n\n    setSaving(true)\n    try {\n      const res = await fetch('/api/admin/settings/reset-all', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n        },\n      })\n\n      const data = await res.json()\n      if (res.ok) {\n        setNotification({\n          type: 'success',\n          text: 'в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВҝв”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГҘв•ӘВ».',\n        })\n        loadSettings()\n        if (activeTab === 'audit') {\n          void loadAuditLogs()\n        }\n      } else {\n        setNotification({\n          type: 'error',\n          text: data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҳГ§в”ҳГ в”ҢВ»в•ӘВәв”ҳГҘв–ҲГ® в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬',\n        })\n      }\n    } catch {\n      setNotification({\n        type: 'error',\n        text: 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’',\n      })\n    } finally {\n      setSaving(false)\n    }\n  }\n\n  // Filter settings by active tab\n  const tabSettings = settings.filter((s) => s.category === activeTab)\n\n  if (loading) {\n    return (\n      <div className=\"flex flex-1 flex-col items-center justify-center gap-2 p-8 bg-background\">\n        <Loader2 className=\"size-8 animate-spin text-accent\" />\n        <span className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ...</span>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 md:p-6 max-w-5xl mx-auto w-full\" dir=\"rtl\">\n      {/* Header */}\n      <div className=\"flex flex-col gap-3 md:flex-row md:items-center md:justify-between border-b border-border pb-4\">\n        <div>\n          <h1 className=\"text-lg font-semibold tracking-tight text-foreground md:text-xl\">\n            в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҳГӘ в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ®О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®\n          </h1>\n          <p className=\"text-xs text-foreground-muted mt-0.5\">\n            в”ҳв•ӣв–ҲГ®в”ҢвҢҗв•Әв–’в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в”ҳГӘ в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГ в•ӘВәв”ҢГҝв”ҳГӘв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ\n          </p>\n        </div>\n        \n        <div className=\"flex flex-col md:flex-row md:items-center gap-2 w-full md:w-auto\">\n          {/* Reset All Button */}\n          <Button\n            onClick={handleResetAll}\n            disabled={saving}\n            variant=\"ghost\"\n            className=\"w-full md:w-auto text-critical hover:bg-critical/10 border border-critical/20 font-medium flex items-center justify-center gap-2 px-4 py-2 rounded-lg cursor-pointer transition-colors\"\n          >\n            <RotateCcw className=\"size-4\" />\n            <span>в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҳГ§в”ҳГ в”ҢВ»в•ӘВәв”ҳГҘв–ҲГ®</span>\n          </Button>\n\n          {/* Save Button for active tab settings */}\n          <Button \n            onClick={handleSave} \n            disabled={saving || activeTab === 'audit' || tabSettings.length === 0}\n            className=\"w-full md:w-auto bg-accent hover:bg-accent-hover text-accent-foreground font-medium flex items-center justify-center gap-2 px-5 py-2 rounded-lg transition-colors cursor-pointer\"\n          >\n            {saving ? (\n              <Loader2 className=\"size-4 animate-spin\" />\n            ) : (\n              <Save className=\"size-4\" />\n            )}\n            в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө\n          </Button>\n        </div>\n      </div>\n\n      {/* Notifications */}\n      {notification && (\n        <div \n          className={`flex items-center gap-2 p-3 rounded-lg border text-sm animate-in fade-in slide-in-from-top-2 duration-300 ${\n            notification.type === 'success' \n              ? 'bg-success/10 border-success/30 text-success' \n              : 'bg-critical/10 border-critical/30 text-critical'\n          }`}\n          role=\"alert\"\n        >\n          {notification.type === 'success' ? (\n            <Check className=\"size-4 shrink-0\" />\n          ) : (\n            <AlertCircle className=\"size-4 shrink-0\" />\n          )}\n          <span>{notification.text}</span>\n        </div>\n      )}\n\n      {/* Category Tabs Layout */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-4 gap-6\">\n        {/* Tab Navigation Menu */}\n        <div className=\"lg:col-span-1 flex flex-row lg:flex-col overflow-x-auto lg:overflow-visible gap-1 border-b lg:border-b-0 lg:border-e border-border pb-2 lg:pb-0 lg:pe-4 shrink-0 scrollbar-none bg-surface-container-low/20 p-1 lg:p-0 rounded-lg\">\n          {Object.entries(CATEGORY_MAP).map(([key, item]) => {\n            const active = activeTab === key\n            return (\n              <button\n                key={key}\n                onClick={() => setActiveTab(key)}\n                className={`flex items-center gap-2.5 px-3 py-2 text-sm font-medium rounded-lg transition-all text-start whitespace-nowrap cursor-pointer ${\n                  active \n                    ? 'bg-accent/10 text-accent font-semibold border border-accent/20' \n                    : 'text-foreground-muted hover:bg-surface-hover hover:text-foreground'\n                }`}\n              >\n                <span className=\"text-base\">{item.icon}</span>\n                <span>{item.label}</span>\n              </button>\n            )\n          })}\n        </div>\n\n        {/* Tab Content Panel */}\n        <div className=\"lg:col-span-3\">\n          <Card className=\"border border-border-subtle bg-surface-container-low/30 backdrop-blur-md shadow-none\">\n            <CardHeader className=\"border-b border-border/60\">\n              <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                <span>{CATEGORY_MAP[activeTab]?.icon}</span>\n                <span>{CATEGORY_MAP[activeTab]?.label}</span>\n              </CardTitle>\n              <CardDescription className=\"text-xs\">\n                {activeTab === 'audit' \n                  ? 'в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в–Ҳв•Ўв–Ҳв–‘ в”ҳГӘв•ӘВәв”ҳГ©в•Әв•Јв”ҳГ§ в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•– в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ' \n                  : 'в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в•ӘВҝв”ҳГӨв•ӘВәв”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВ»в•Әв–’ в”ҢвҢҗв”ҳГӨ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в”ҳГӘ в”ҳГӨв•ӘВәв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬в–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢВ»в•Әв–’в•ӘВ»в•ӘВ».'}\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"divide-y divide-border/40 p-0\">\n              {activeTab === 'audit' ? (\n                loadingAudit ? (\n                  <div className=\"flex items-center justify-center p-8 gap-2\">\n                    <Loader2 className=\"size-5 animate-spin text-accent\" />\n                    <span className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬...</span>\n                  </div>\n                ) : auditLogs.length === 0 ? (\n                  <div className=\"p-8 text-center text-sm text-foreground-muted\">\n                    в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬в–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                  </div>\n                ) : (\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-right border-collapse\">\n                      <thead>\n                        <tr className=\"border-b border-border bg-surface-container/50 text-foreground-muted text-xs font-semibold\">\n                          <th className=\"p-3 w-40\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҳГӘ в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬</th>\n                          <th className=\"p-3 w-36\">в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§</th>\n                          <th className=\"p-3\">в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ» в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬в”ҳГ§</th>\n                          <th className=\"p-3\">в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳГ©в•ӘВ»в–ҲГ®в”ҳГ в–ҲГ®</th>\n                          <th className=\"p-3\">в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-border-subtle text-sm\">\n                        {auditLogs.map((log) => {\n                          let beforeVal = ''\n                          let afterVal = ''\n                          try {\n                            beforeVal = log.before && typeof log.before === 'object' && 'value' in log.before \n                              ? String(JSON.parse(log.before.value as string))\n                              : String(log.before)\n                          } catch {\n                            beforeVal = log.before ? String(log.before) : ''\n                          }\n                          try {\n                            afterVal = log.after && typeof log.after === 'object' && 'value' in log.after\n                              ? String(JSON.parse(log.after.value as string))\n                              : String(log.after)\n                          } catch {\n                            afterVal = log.after ? String(log.after) : ''\n                          }\n\n                          if (beforeVal === 'true') beforeVal = 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ'\n                          if (beforeVal === 'false') beforeVal = 'в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ'\n                          if (afterVal === 'true') afterVal = 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ'\n                          if (afterVal === 'false') afterVal = 'в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ'\n\n                          return (\n                            <tr key={log.id} className=\"hover:bg-surface-hover/30 transition-colors duration-150\">\n                              <td className=\"p-3 font-mono text-xs text-foreground-muted\">\n                                {toFa(new Date(log.createdAt).toLocaleDateString('fa-IR'))} - {toFa(new Date(log.createdAt).toLocaleTimeString('fa-IR', { hour: '2-digit', minute: '2-digit' }))}\n                              </td>\n                              <td className=\"p-3 font-medium text-xs\">\n                                <span className=\"block text-foreground\">{log.actor?.name || 'в”ҳГҘв•ӘВәв”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ў'}</span>\n                                <span className=\"block text-[10px] text-foreground-muted\">{log.actor?.email}</span>\n                              </td>\n                              <td className=\"p-3 font-mono text-xs text-foreground-muted dir-ltr text-end\">{log.entityId}</td>\n                              <td className=\"p-3 text-xs text-foreground-muted line-through truncate max-w-[120px]\">{toFa(beforeVal)}</td>\n                              <td className=\"p-3 text-xs text-accent font-semibold truncate max-w-[120px]\">{toFa(afterVal)}</td>\n                            </tr>\n                          )\n                        })}\n                      </tbody>\n                    </table>\n                  </div>\n                )\n              ) : tabSettings.length === 0 ? (\n                <div className=\"p-8 text-center text-sm text-foreground-muted\">\n                  в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВҝв•ӘВ«в•Әв”Ө в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                </div>\n              ) : (\n                tabSettings.map((setting) => {\n                  const currentValue = localValues[setting.key]\n                  const isModified = JSON.stringify(currentValue) !== setting.value\n\n                  return (\n                    <div \n                      key={setting.key} \n                      className=\"p-4 md:p-6 flex flex-col md:flex-row md:items-start justify-between gap-4 transition-all hover:bg-surface-hover/30\"\n                    >\n                      {/* Left: Metadata */}\n                      <div className=\"flex flex-col gap-1 max-w-xl\">\n                        <div className=\"flex items-center gap-2\">\n                          <Label className=\"text-sm font-semibold text-foreground cursor-default\">\n                            {setting.label}\n                          </Label>\n                          {isModified && (\n                            <Badge variant=\"outline\" className=\"text-[10px] px-1.5 py-0 border-accent/40 text-accent bg-accent/5 rounded-md\">\n                              в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬в”ҳГ§\n                            </Badge>\n                          )}\n                        </div>\n                        {setting.description && (\n                          <span className=\"text-xs text-foreground-muted leading-relaxed\">\n                            {setting.description}\n                          </span>\n                        )}\n                        <span className=\"text-[10px] text-foreground-muted/60 font-mono tracking-tight dir-ltr text-start mt-1\">\n                          {setting.key}\n                        </span>\n                      </div>\n\n                      {/* Right: Controller Input */}\n                      <div className=\"flex items-center gap-3 shrink-0 self-end md:self-center\">\n                        {/* Custom Inputs based on type */}\n                        {setting.type === 'text' && (\n                          setting.key.includes('Notice') || setting.key.includes('message') ? (\n                            <textarea\n                              value={String(currentValue ?? '')}\n                              onChange={(e) => handleValueChange(setting.key, e.target.value)}\n                              rows={2}\n                              className=\"w-48 md:w-64 rounded-lg border border-border bg-background/50 p-2 text-xs focus:outline-none focus:ring-1 focus:ring-ring focus:border-accent resize-y min-h-[60px]\"\n                            />\n                          ) : (\n                            <Input\n                              type=\"text\"\n                              value={String(currentValue ?? '')}\n                              onChange={(e) => handleValueChange(setting.key, e.target.value)}\n                              className=\"w-48 md:w-64 h-9 bg-background/50 text-sm focus-visible:ring-accent\"\n                            />\n                          )\n                        )}\n\n                        {setting.type === 'color' && (\n                          <div className=\"flex items-center gap-2 border border-border rounded-lg p-1 bg-background/50 w-48 md:w-64\">\n                            <input\n                              type=\"color\"\n                              value={String(currentValue ?? '#ffffff')}\n                              onChange={(e) => handleValueChange(setting.key, e.target.value)}\n                              className=\"size-7 rounded cursor-pointer border border-border/40 p-0 bg-transparent shrink-0\"\n                            />\n                            <Input\n                              type=\"text\"\n                              value={String(currentValue ?? '')}\n                              onChange={(e) => handleValueChange(setting.key, e.target.value)}\n                              className=\"h-7 border-none bg-transparent text-sm focus-visible:ring-0 p-1 font-mono uppercase\"\n                            />\n                          </div>\n                        )}\n\n                        {setting.type === 'number' && (\n                          <div className=\"flex flex-col gap-1.5 w-48 md:w-64\">\n                            <Input\n                              type=\"number\"\n                              min={setting.min ?? undefined}\n                              max={setting.max ?? undefined}\n                              value={Number(currentValue ?? 0)}\n                              onChange={(e) => handleValueChange(setting.key, Number(e.target.value))}\n                              className=\"h-9 bg-background/50 text-sm focus-visible:ring-accent font-mono\"\n                            />\n                            {(setting.min !== null || setting.max !== null) && (\n                              <div className=\"flex justify-between text-[10px] text-foreground-muted px-0.5\">\n                                <span>в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ: {toFa(setting.min ?? 0)}</span>\n                                <span>в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’: {toFa(setting.max ?? 0)}</span>\n                              </div>\n                            )}\n                          </div>\n                        )}\n\n                        {setting.type === 'boolean' && (\n                          <div className=\"flex items-center gap-2 w-48 md:w-64 justify-end\">\n                            <label className=\"relative inline-flex items-center cursor-pointer\">\n                              <input\n                                type=\"checkbox\"\n                                checked={!!currentValue}\n                                onChange={(e) => handleValueChange(setting.key, e.target.checked)}\n                                className=\"sr-only peer\"\n                              />\n                              <div className=\"w-11 h-6 bg-background border border-border peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:content-[''] after:content-[''] after:absolute after:top-[4px] after:start-[4px] after:bg-foreground-muted peer-checked:after:bg-accent-foreground after:border-none after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-accent\"></div>\n                              <span className=\"ms-2 text-xs font-medium text-foreground cursor-pointer\">\n                                {currentValue ? 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ' : 'в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ'}\n                              </span>\n                            </label>\n                          </div>\n                        )}\n\n                        {setting.type === 'select' && setting.options && (\n                          <select\n                            value={String(currentValue ?? '')}\n                            onChange={(e) => handleValueChange(setting.key, e.target.value)}\n                            className=\"w-48 md:w-64 h-9 rounded-lg border border-border bg-background/50 px-2.5 text-sm outline-none focus-visible:border-accent\"\n                          >\n                            {(JSON.parse(setting.options) as string[]).map((opt) => (\n                              <option key={opt} value={opt}>\n                                {toFa(opt)}\n                              </option>\n                            ))}\n                          </select>\n                        )}\n\n                        {/* Reset button to restore default value */}\n                        <Button\n                          variant=\"ghost\"\n                          size=\"icon\"\n                          title=\"в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВҝв”ҳГ§ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў\"\n                          onClick={() => handleReset(setting.key)}\n                          className=\"text-foreground-muted hover:text-accent hover:bg-accent/5 rounded-md cursor-pointer shrink-0 size-8 p-0\"\n                        >\n                          <RotateCcw className=\"size-4\" />\n                          <span className=\"sr-only\">в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ®</span>\n                        </Button>\n                      </div>\n                    </div>\n                  )\n                })\n              )}\n            </CardContent>\n          </Card>\n        </div>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\admin\\shifts\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Download' is defined but never used.","line":23,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":23,"endColumn":11,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Download"},"fix":{"range":[330,342],"text":""},"desc":"Remove unused variable \"Download\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'FileText' is defined but never used.","line":24,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":24,"endColumn":11,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"FileText"},"fix":{"range":[342,354],"text":""},"desc":"Remove unused variable \"FileText\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Eye' is defined but never used.","line":26,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":26,"endColumn":6,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Eye"},"fix":{"range":[367,374],"text":""},"desc":"Remove unused variable \"Eye\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CalendarDays' is defined but never used.","line":28,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":28,"endColumn":15,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CalendarDays"},"fix":{"range":[384,400],"text":""},"desc":"Remove unused variable \"CalendarDays\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","