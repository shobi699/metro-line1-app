ne":5,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":12,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"cn"},"fix":{"range":[205,238],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useState, useEffect, useRef } from 'react'\nimport { Send, Mic, History, AlertTriangle, Bot, Settings, X, Plus, FileText, Check, HelpCircle, ArrowLeft, Terminal } from 'lucide-react'\nimport { cn } from '@/lib/utils'\nimport { useAuthStore } from '@/features/auth'\nimport { Button } from '@/components/ui/button'\nimport { Badge } from '@/components/ui/badge'\n\ninterface Message {\n  id: string\n  role: 'user' | 'ai'\n  content: string\n  isBento?: boolean\n  source?: string\n  articles?: Array<{ slug: string; title: string }>\n}\n\ninterface CustomFieldDoc {\n  id: string\n  title: string\n  slug: string\n  category: string | null\n  body: string\n}\n\nexport function AiChatInterface() {\n  const user = useAuthStore((s) => s.user)\n  const [messages, setMessages] = useState<Message[]>([\n    {\n      id: '1',\n      role: 'ai',\n      content: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в•ӘВ«в•Әв•– в–Ҳв–’ в•ӘГів”ҳГ в•ӘВәв•ӘВ»в”ҳГ§ в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ«в”ҢВ»в”ҳГӘв–ҲГ®в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬. в”ҳГӨв•Әв•–в”ҳГјв•ӘВә в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ в”ҳГјв”ҳГҘв–ҲГ®в•ӘГ® в”ҢвҢҗв•ӘВ» в•ӘВ«в•Әв•–в•ӘВә (в”ҳГ в•ӘВәв”ҳГҘв”ҳГҘв•ӘВ» E102 в–ҲГ®в•ӘВә E205) в–ҲГ®в•ӘВә в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».',\n    },\n  ])\n  const [input, setInput] = useState('')\n  const [loading, setLoading] = useState(false)\n\n  // AI Configuration States\n  const [showSettings, setShowSettings] = useState(false)\n  const [aiModel, setAiModel] = useState('gemini-1.5-pro')\n  const [temperature, setTemperature] = useState(0.3)\n  const [maxTokens, setMaxTokens] = useState(1024)\n\n  // Document Ingestion States\n  const [docTitle, setDocTitle] = useState('')\n  const [docSlug, setDocSlug] = useState('')\n  const [docCategory, setDocCategory] = useState('technical')\n  const [docTags, setDocTags] = useState('')\n  const [docBody, setDocBody] = useState('')\n  const [docError, setDocError] = useState('')\n  const [docSuccess, setDocSuccess] = useState('')\n  const [ingestionLoading, setIngestionLoading] = useState(false)\n  const [knowledgeList, setKnowledgeList] = useState<CustomFieldDoc[]>([])\n\n  const chatEndRef = useRef<HTMLDivElement>(null)\n\n  // Auto-scroll chat area\n  useEffect(() => {\n    chatEndRef.current?.scrollIntoView({ behavior: 'smooth' })\n  }, [messages])\n\n  // Fetch registered knowledge articles\n  const fetchKnowledgeBase = async () => {\n    try {\n      const res = await fetch('/api/knowledge?pageSize=50', {\n        headers: {\n          Authorization: `Bearer ${useAuthStore.getState().accessToken}`,\n        },\n      })\n      const data = await res.json()\n      if (data.data && data.data.items) {\n        setKnowledgeList(data.data.items)\n      }\n    } catch {}\n  }\n\n  useEffect(() => {\n    fetchKnowledgeBase()\n  }, [])\n\n  // Send message to AI Route API\n  const handleSend = async () => {\n    if (!input.trim() || loading) return\n    setLoading(true)\n\n    const userText = input.trim()\n    const userMsg: Message = {\n      id: Date.now().toString(),\n      role: 'user',\n      content: userText,\n    }\n\n    setMessages((prev) => [...prev, userMsg])\n    setInput('')\n\n    try {\n      const res = await fetch('/api/ai', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${useAuthStore.getState().accessToken}`,\n        },\n        body: JSON.stringify({ prompt: userText }),\n      })\n\n      const data = await res.json()\n      if (res.ok && data.data) {\n        const reply = data.data.reply\n        const isBento = data.data.source === 'rulebook'\n        setMessages((prev) => [\n          ...prev,\n          {\n            id: (Date.now() + 1).toString(),\n            role: 'ai',\n            content: reply,\n            isBento: isBento,\n            source: data.data.source,\n            articles: data.data.articles,\n          },\n        ])\n      } else {\n        setMessages((prev) => [\n          ...prev,\n          {\n            id: (Date.now() + 1).toString(),\n            role: 'ai',\n            content: data.error || 'в”ҳГ в•ӘВ¬в•ӘГәв•Әв”Ӯв”ҳГјв•ӘВәв”ҳГҘв”ҳГ§ в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв–’в•ӘВ»в•ӘВәв•Әв–“в•Әв”Ө в•ӘВ»в•Әв–’в•ӘВ«в”ҳГӘв•ӘВәв•Әв”Ӯв•ӘВ¬ в•Әв”Өв”ҳГ в•ӘВә в•ӘВ«в•Әв•–в•ӘВәв–ҲГ®в–ҲГ® в•Әв–’в•ӘВ« в•ӘВ»в•ӘВәв•ӘВ».',\n          },\n        ])\n      }\n    } catch {\n      setMessages((prev) => [\n        ...prev,\n        {\n          id: (Date.now() + 1).toString(),\n          role: 'ai',\n          content: 'в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§ в•ӘВ»в•Әв–’ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•ӘВҝв•ӘВә в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’ в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ®.',\n        },\n      ])\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  // Handle Document Ingestion Submit\n  const handleIngestDocument = async (e: React.FormEvent) => {\n    e.preventDefault()\n    setDocError('')\n    setDocSuccess('')\n\n    if (!docTitle.trim() || !docSlug.trim() || !docBody.trim()) {\n      setDocError('в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘв•ӘГ® в•ӘВәв•Әв”Ӯв”ҳГӨв•ӘВәв”ҢВ» в–ҲГ®в”ҢвҢҗв•ӘВ¬в•ӘВә в”ҳГӘ в”ҳГ в•ӘВ¬в”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•Әв–’в•ӘВә в”ҳв•ӣв•Әв–’ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».')\n      return\n    }\n\n    setIngestionLoading(true)\n    try {\n      const res = await fetch('/api/knowledge', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          Authorization: `Bearer ${useAuthStore.getState().accessToken}`,\n        },\n        body: JSON.stringify({\n          title: docTitle.trim(),\n          slug: docSlug.trim().toLowerCase(),\n          body: docBody.trim(),\n          category: docCategory,\n          tags: docTags.trim(),\n        }),\n      })\n\n      const data = await res.json()\n      if (res.ok) {\n        setDocSuccess('в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Ө RAG в•ӘГів”ҳв•ӣв”ҳГӨв”ҳГӘв•ӘВ» в•Әв”Өв•ӘВ».')\n        setDocTitle('')\n        setDocSlug('')\n        setDocTags('')\n        setDocBody('')\n        fetchKnowledgeBase()\n      } else {\n        setDocError(data.error || 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•Әв”Ӯв”ҳГҘв•ӘВ»')\n      }\n    } catch {\n      setDocError('в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§ в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨ')\n    } finally {\n      setIngestionLoading(false)\n    }\n  }\n\n  const formatFarsiNumber = (numStr: string) => {\n    const farsiDigits = ['в–Ҳв–‘', 'в–Ҳв–’', 'в–Ҳв–“', 'в–Ҳв”Ӯ', 'в–Ҳв”Ө', 'в–Ҳв•Ў', 'в–Ҳв•ў', 'в–Ҳв•–', 'в–Ҳв••', 'в–Ҳв•Ј']\n    return numStr.replace(/\\d/g, (x) => farsiDigits[parseInt(x)])\n  }\n\n  return (\n    <section className=\"relative flex flex-1 flex-col bg-background text-right transition-colors duration-150\" dir=\"rtl\">\n      \n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* HEADER: AI Model status & Settings trigger */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"z-10 flex items-center justify-between border-b border-border-subtle bg-surface-container-low px-4 py-3.5 shadow-sm\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"flex size-9 items-center justify-center rounded-lg bg-accent/10 border border-accent/25 animate-pulse\">\n            <Bot className=\"size-5 text-accent\" />\n          </div>\n          <div>\n            <span className=\"font-semibold text-sm text-foreground block\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в•ӘВ«в•Әв•– в–Ҳв–’</span>\n            <span className=\"text-[10px] text-foreground-muted block font-mono\">\n              MODEL: {aiModel.toUpperCase()} | TEMP: {formatFarsiNumber(temperature.toString())}\n            </span>\n          </div>\n        </div>\n\n        <div className=\"flex gap-2\">\n          <button\n            onClick={() => setShowSettings(true)}\n            className=\"flex items-center gap-1.5 rounded-md border border-border bg-transparent hover:bg-surface-hover px-3 py-1.5 text-xs font-medium text-foreground transition-colors cursor-pointer\"\n          >\n            <Settings className=\"size-4 text-accent\" />\n            в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в”ҳГӘ RAG\n          </button>\n          <button className=\"flex items-center gap-1.5 rounded-md bg-critical text-critical-foreground hover:bg-critical/90 px-3 py-1.5 text-xs font-semibold shadow-sm transition-colors cursor-pointer\">\n            <AlertTriangle className=\"size-4 animate-bounce\" />\n            в”ҳв•ӣв•Әв–’в”ҳГӘв•ӘВ¬в”ҢвҢҗв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®\n          </button>\n        </div>\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* CHAT THREAD AREA */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"flex-1 space-y-5 overflow-y-auto px-4 py-6 pb-32\">\n        {messages.map((msg) =>\n          msg.role === 'user' ? (\n            /* User Message Bubble - Positioned to the Left (justify-end in RTL) */\n            <div key={msg.id} className=\"flex items-start gap-3 justify-end animate-fade-in-up\">\n              <div className=\"rounded-lg rounded-tl-none border border-accent/15 bg-accent/5 px-4 py-3 text-sm max-w-[75%] shadow-sm\">\n                <p className=\"font-medium text-foreground leading-relaxed\">{msg.content}</p>\n              </div>\n              <div className=\"flex size-8 shrink-0 items-center justify-center rounded-full bg-surface-container-high border border-border\">\n                <span className=\"text-[10px] font-semibold text-foreground-muted\">в•Әв”Өв”ҳГ в•ӘВә</span>\n              </div>\n            </div>\n          ) : msg.isBento ? (\n            /* AI Bento Response (Critical Analysis box style) */\n            <div key={msg.id} className=\"flex items-start gap-3 justify-start animate-fade-in-up\">\n              <div className=\"flex size-8 shrink-0 items-center justify-center rounded-full bg-accent text-accent-foreground\">\n                <Bot className=\"size-4\" />\n              </div>\n              <div className=\"w-full max-w-2xl overflow-hidden rounded-lg border border-accent/20 shadow-md\">\n                <div className=\"flex items-center gap-2 border-b border-border-subtle bg-gradient-to-r from-accent/10 to-transparent px-4 py-2.5\">\n                  <span className=\"size-2 rounded-full bg-accent animate-ping\" />\n                  <span className=\"text-xs font-semibold tracking-wide text-accent\">\n                    в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨ в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ® в•Әв•Јв–ҲГ®в•ӘВҝ в”ҳГӘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ\n                  </span>\n                  <span className=\"me-auto font-mono text-[10px] text-foreground-muted\">\n                    RAG Rulebook\n                  </span>\n                </div>\n\n                <div className=\"p-4 bg-surface-container-lowest/40 space-y-4\">\n                  <div className=\"rounded-lg border border-border-subtle bg-surface-container-low p-3.5\">\n                    <h4 className=\"mb-2 text-xs font-semibold text-foreground-muted\">\n                      в”ҳв•ӣв•Әв–’в”ҳГӘв•ӘВ¬в”ҢвҢҗв”ҳГӨ в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ в•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в•Әв”Өв•ӘВ»в”ҳГ§:\n                    </h4>\n                    <p className=\"text-sm text-foreground leading-relaxed whitespace-pre-line font-medium font-sans\">\n                      {msg.content}\n                    </p>\n                  </div>\n\n                  {msg.articles && msg.articles.length > 0 && (\n                    <div className=\"flex flex-col gap-2 rounded-lg border border-border-subtle bg-surface-container-low/50 p-3.5\">\n                      <h4 className=\"text-xs font-semibold text-foreground-muted flex items-center gap-1.5\">\n                        <FileText className=\"size-3.5 text-accent\" />\n                        в•ӘВҝв•ӘВ«в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•Әв–’в•ӘВјв•Әв•Ј в•ӘВ»в•Әв–’ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§:\n                      </h4>\n                      <div className=\"flex gap-2 mt-1 flex-wrap\">\n                        {msg.articles.map(art => (\n                          <Badge key={art.slug} variant=\"outline\" className=\"text-[10px] border-border bg-surface text-accent hover:bg-surface-hover\">\n                            {art.title}\n                          </Badge>\n                        ))}\n                      </div>\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n          ) : (\n            /* Simple AI Message Bubble - Positioned to the Right (justify-start in RTL) */\n            <div key={msg.id} className=\"flex items-start gap-3 justify-start animate-fade-in-up\">\n              <div className=\"flex size-8 shrink-0 items-center justify-center rounded-full bg-surface-container border border-border shadow-sm\">\n                <Bot className=\"size-4 text-accent\" />\n              </div>\n              <div className=\"rounded-lg rounded-tr-none border border-border bg-surface-container-high px-4 py-3 text-sm max-w-[75%] shadow-sm\">\n                <p className=\"text-foreground leading-relaxed whitespace-pre-line font-medium\">{msg.content}</p>\n                {msg.source && msg.source !== 'fallback' && (\n                  <span className=\"inline-flex mt-2.5 text-[9px] bg-accent/10 text-accent px-2 py-0.5 rounded-md font-semibold\">\n                    в”ҳГ в”ҳГҘв•ӘВҝв•Әв•Ј: {msg.source === 'knowledge' ? 'в•ӘВ»в•ӘВәв”ҳГҘв•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ RAG' : msg.source === 'rulebook' ? 'в”ҢвҢҗв•ӘВ¬в•ӘВәв•ӘВҝв”ҢГҘв”ҳГ§ в”ҳГ©в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ®в”ҳГҘ' : msg.source}\n                  </span>\n                )}\n              </div>\n            </div>\n          )\n        )}\n        {loading && (\n          <div className=\"flex items-start gap-3 justify-start\">\n            <div className=\"flex size-8 shrink-0 items-center justify-center rounded-full bg-surface-container border border-border animate-pulse\">\n              <Bot className=\"size-4 text-foreground-muted\" />\n            </div>\n            <div className=\"rounded-lg rounded-tr-none border border-border bg-surface-container px-4 py-3 text-sm text-foreground-muted animate-pulse\">\n              в•ӘВ»в•Әв”Ӯв•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’ в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в”ҳГӘ в•ӘВ¬в•ӘВЎв”ҳГӨв–ҲГ®в”ҳГӨ в”ҳв•ӣв•Әв–’в”ҳГӘв•ӘВ¬в”ҢвҢҗв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®...\n            </div>\n          </div>\n        )}\n        <div ref={chatEndRef} />\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* INPUT AREA: Floating Glassmorphism Container */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"absolute bottom-0 left-0 w-full bg-gradient-to-t from-background via-background/95 to-transparent pt-8 pb-4\">\n        <div className=\"mx-auto max-w-4xl px-4\">\n          <div className=\"relative rounded-lg border border-border bg-surface/85 backdrop-blur-md p-2 shadow-lg flex items-center gap-2\">\n            <button className=\"p-2 text-foreground-muted hover:text-foreground transition-colors hover:bg-surface-hover rounded-md\">\n              <Mic className=\"size-4\" />\n            </button>\n            <input\n              className=\"flex-1 bg-transparent px-3 py-1.5 text-sm text-foreground placeholder:text-foreground-muted focus:outline-none text-right font-sans\"\n              placeholder=\"в”ҢвҢҗв•ӘВ» в•ӘВ«в•Әв•–в•ӘВә (в”ҳГ в•ӘВәв”ҳГҘв”ҳГҘв•ӘВ» E102) в–ҲГ®в•ӘВә в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВҝв”ҳв•ӣв•Әв–’в•Әв”Ӯв–ҲГ®в•ӘВ»...\"\n              value={input}\n              onChange={(e) => setInput(e.target.value)}\n              onKeyDown={(e) => e.key === 'Enter' && handleSend()}\n            />\n            <button\n              onClick={handleSend}\n              className=\"flex size-9 items-center justify-center rounded-md bg-accent text-accent-foreground transition-all hover:bg-accent-hover active:scale-95 cursor-pointer\"\n            >\n              <Send className=\"size-4 -rotate-90\" />\n            </button>\n          </div>\n          <div className=\"mt-2 text-center flex items-center justify-center gap-1.5\">\n            <span className=\"size-1.5 rounded-full bg-success animate-pulse\" />\n            <span className=\"text-[9px] text-foreground-muted font-mono tracking-wider uppercase\">\n              Secure Railway AI Network | Line 1 Core\n            </span>\n          </div>\n        </div>\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* MODAL: AI RAG & DOCUMENTATION SETTINGS */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {showSettings && (\n        <div className=\"fixed inset-0 bg-black/70 backdrop-blur-sm z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-surface border border-border rounded-lg w-full max-w-3xl p-6 space-y-5 shadow-xl animate-fade-in text-right\">\n            \n            <div className=\"flex justify-between items-center pb-3 border-b border-border\">\n              <div className=\"flex items-center gap-2\">\n                <Settings className=\"size-5 text-accent animate-spin-slow\" />\n                <h3 className=\"text-sm font-semibold text-foreground\">в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в”ҳГӘ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Ө RAG</h3>\n              </div>\n              <button\n                onClick={() => setShowSettings(false)}\n                className=\"text-foreground-muted hover:text-foreground hover:bg-surface-hover p-1.5 rounded-md transition-colors\"\n              >\n                <X className=\"size-5\" />\n              </button>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 max-h-[480px] overflow-y-auto px-1\">\n              \n              {/* Left Column: AI Config & Ingestion Form */}\n              <div className=\"space-y-4\">\n                <div className=\"bg-surface-container-low p-4 rounded-lg border border-border-subtle space-y-3\">\n                  <h4 className=\"text-xs font-semibold text-foreground flex items-center gap-1.5\">\n                    <Terminal className=\"size-4 text-accent\" />\n                    в”ҳв•ӣв•ӘВәв•Әв–’в•ӘВәв”ҳГ в•ӘВ¬в•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГӘв•ӘВ¬в”ҳГӘв•Әв–’ в•ӘВ¬в”ҳГӘв”ҳГӨв–ҲГ®в•ӘВ» в”ҳГ в•ӘВ¬в”ҳГҘ\n                  </h4>\n                  \n                  <div className=\"space-y-1\">\n                    <label className=\"text-[11px] text-foreground-muted\">в”ҳГ в•ӘВ»в”ҳГӨ в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ:</label>\n                    <select\n                      value={aiModel}\n                      onChange={(e) => setAiModel(e.target.value)}\n                      className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                    >\n                      <option value=\"gemini-1.5-pro\">Google Gemini 1.5 Pro (в”ҳв•ӣв–ҲГ®в•Әв”Өв”ҳГҘв”ҳГ§в•ӘВәв•ӘВ»в–ҲГ®)</option>\n                      <option value=\"gemini-1.5-flash\">Google Gemini 1.5 Flash (в•Әв”Ӯв•Әв–’в–ҲГ®в•Әв•Ј)</option>\n                      <option value=\"gpt-4o\">OpenAI GPT-4o (в•ӘВјв•ӘВәв”ҳГ в•Әв•Ј)</option>\n                      <option value=\"claude-3.5-sonnet\">Anthropic Claude 3.5 Sonnet</option>\n                    </select>\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-3 pt-2\">\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[11px] text-foreground-muted\">в•ӘВ»в•Әв–’в•ӘВјв”ҳГ§ в•ӘВ«в”ҳГӨв•ӘВәв”ҳГ©в–ҲГ®в•ӘВ¬ (Temperature):</label>\n                      <input\n                        type=\"number\"\n                        min=\"0\"\n                        max=\"1\"\n                        step=\"0.1\"\n                        value={temperature}\n                        onChange={(e) => setTemperature(Number(e.target.value))}\n                        className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring text-center\"\n                      />\n                    </div>\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[11px] text-foreground-muted\">в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в•Әв•–в”ҳГӘв”ҳГӨ в”ҢвҢҗв”ҳГӨв”ҳГ в•ӘВәв•ӘВ¬ (Tokens):</label>\n                      <input\n                        type=\"number\"\n                        value={maxTokens}\n                        onChange={(e) => setMaxTokens(Number(e.target.value))}\n                        className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring text-center\"\n                      />\n                    </div>\n                  </div>\n                </div>\n\n                {/* Form to upload new documentation */}\n                {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') ? (\n                  <form onSubmit={handleIngestDocument} className=\"bg-surface-container-low p-4 rounded-lg border border-border-subtle space-y-3.5\">\n                    <h4 className=\"text-xs font-semibold text-foreground flex items-center gap-1.5\">\n                      <Plus className=\"size-4 text-accent\" />\n                      в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ/в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» (RAG)\n                    </h4>\n\n                    {docError ? (\n                      <div className=\"p-2.5 bg-critical/10 border border-critical/20 text-critical text-xs rounded-md\">\n                        {docError}\n                      </div>\n                    ) : null}\n                    {docSuccess ? (\n                      <div className=\"p-2.5 bg-success/10 border border-success/20 text-success text-xs rounded-md\">\n                        {docSuccess}\n                      </div>\n                    ) : null}\n\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[11px] text-foreground-muted\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•Әв”Ӯв”ҳГҘв•ӘВ» в”ҳГјв”ҳГҘв–ҲГ® (в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ®):</label>\n                      <input\n                        type=\"text\"\n                        placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘГів–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв•Јв”ҳГӨв•ӘВәв•ӘВӘв”ҳГ  в”ҢвҢҗв•ӘВәв•ӘВҝв–ҲГ®в”ҳГҘ\"\n                        value={docTitle}\n                        onChange={(e) => setDocTitle(e.target.value)}\n                        className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                      />\n                    </div>\n\n                    <div className=\"grid grid-cols-2 gap-3\">\n                      <div className=\"space-y-1\">\n                        <label className=\"text-[11px] text-foreground-muted\">в•ӘВәв•Әв”Ӯв”ҳГӨв•ӘВәв”ҢВ» в–ҲГ®в”ҢвҢҗв•ӘВ¬в•ӘВә (в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ®):</label>\n                        <input\n                          type=\"text\"\n                          placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: cabin-signaling\"\n                          value={docSlug}\n                          onChange={(e) => setDocSlug(e.target.value)}\n                          className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                        />\n                      </div>\n                      <div className=\"space-y-1\">\n                        <label className=\"text-[11px] text-foreground-muted\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВә:</label>\n                        <select\n                          value={docCategory}\n                          onChange={(e) => setDocCategory(e.target.value)}\n                          className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                        >\n                          <option value=\"technical\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в”ҳГјв”ҳГҘв–ҲГ®</option>\n                          <option value=\"safety\">в•ӘГів–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®</option>\n                          <option value=\"operation\">в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВәв–ҲГ® в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®</option>\n                        </select>\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[11px] text-foreground-muted\">в”ҢвҢҗв”ҳГӨв”ҳГ в•ӘВәв•ӘВ¬ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ»в–ҲГ®/в•ӘВ¬в”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВә (в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВәв”ҳГ в•ӘВә):</label>\n                      <input\n                        type=\"text\"\n                        placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в•ӘВ»в•Әв–’в•ӘВҝ, в•ӘВ¬в•Әв–’в”ҳГ в•Әв–“, в”ҳв•ӣв”ҳГҘв”ҳГӘв”ҳГ в•ӘВәв•ӘВ¬в–ҲГ®в”ҢвҢҗ, e102\"\n                        value={docTags}\n                        onChange={(e) => setDocTags(e.target.value)}\n                        className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                      />\n                    </div>\n\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[11px] text-foreground-muted\">в”ҳГ в•ӘВ¬в”ҳГҘ в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в”ҳГјв”ҳГҘв–ҲГ® (в”ҳГ в•ӘВЎв•ӘВ¬в”ҳГӘв•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГҘв•ӘВ»):</label>\n                      <textarea\n                        rows={4}\n                        placeholder=\"в”ҳГ в•ӘВ¬в”ҳГҘ в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ©в•Әв”Ӯв”ҳГ в•ӘВ¬ в”ҢвҢҗв”ҳв•ӣв–ҲГ® в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»...\"\n                        value={docBody}\n                        onChange={(e) => setDocBody(e.target.value)}\n                        className=\"w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-ring resize-none font-medium leading-relaxed\"\n                      />\n                    </div>\n\n                    <Button\n                      type=\"submit\"\n                      disabled={ingestionLoading}\n                      className=\"w-full bg-accent hover:bg-accent-hover text-accent-foreground text-sm font-semibold h-9 rounded-md transition-colors cursor-pointer\"\n                    >\n                      {ingestionLoading ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ»в•Әв–’ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Ө...' : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в•Әв–’ RAG'}\n                    </Button>\n                  </form>\n                ) : (\n                  <div className=\"bg-accent/5 border border-accent/15 p-4 rounded-lg\">\n                    <p className=\"text-xs text-accent leading-relaxed font-medium\">\n                      в•ӘВ¬в”ҳГҘв”ҳГ§в•ӘВә в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВҝв•ӘВә в”ҳГҘв”ҳГ©в•Әв”Ө в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГ в”ҢвҢҗв•ӘВәв”ҳГҘ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  RAG в•Әв–’в•ӘВә в•ӘВ»в•ӘВәв•Әв–’в”ҳГҘв•ӘВ». в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•Әв•Јв•ӘВәв•ӘВ»в–ҲГ® в”ҳГ в–ҲГ®О“ГҮГ®в•ӘВ¬в”ҳГӘв•ӘВәв”ҳГҘв”ҳГҘв•ӘВ» в”ҢвҢҗв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ«в•Әв•–в•ӘВә в•Әв–’в•ӘВә в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в•Әв–’в•ӘВәв”ҳГ§в”ҳГҘв”ҳГ в•ӘВә в•Әв”Ӯв•Әв–’в”ҢГҘ в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ».\n                    </p>\n                  </div>\n                )}\n              </div>\n\n              {/* Right Column: Ingested Documents List & Explanations */}\n              <div className=\"space-y-4\">\n                \n                {/* How it works Box */}\n                <div className=\"bg-surface-container-low p-4 rounded-lg border border-border-subtle space-y-3 text-xs leading-relaxed text-foreground-muted\">\n                  <h4 className=\"text-xs font-semibold text-foreground flex items-center gap-1.5\">\n                    <HelpCircle className=\"size-4 text-accent\" />\n                    в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  RAG в”ҢГҘв”ҢВ»в”ҳГӘв”ҳГҘв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢвҢҗв”ҳГҘв•ӘВ»в•ӘЖ’\n                  </h4>\n                  <p>\n                    в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘГів–ҲГ®в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВ»в•Әв–’ в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ <code className=\"text-accent font-semibold font-mono\">knowledgeArticle</code> в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ в•ӘВҝв”ҳГ§ в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Ө в”ҳГ в•ӘВЎв”ҳГӨв–ҲГ® в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ».\n                  </p>\n                  <p>\n                    в”ҳГ§в”ҳГҘв”ҢВ»в•ӘВәв”ҳГ в–ҲГ® в”ҢвҢҗв”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв–ҲГ® в•Әв–’в•ӘВә в”ҳГ в•Әв•–в•Әв–’в•ӘВЎ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢвҢҗв”ҳГҘв•ӘВ» в–ҲГ®в•ӘВә в”ҢвҢҗв•ӘВ» в•ӘВ«в•Әв•–в•ӘВәв–ҲГ®в–ҲГ® в•Әв–’в•ӘВә в”ҳГ в–ҲГ®О“ГҮГ®в”ҳГјв•Әв–’в•Әв”Ӯв•ӘВ¬в•ӘВ»в•ӘГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҳГ§в”ҳГӘв•Әв”Өв”ҳГ в”ҳГҘв•ӘВ» в•Әв”Ӯв•Әв–’в”ҳГӘв•Әв–’ в•ӘВҝв”ҳГ§ в•Әв•–в”ҳГӘв•Әв–’ в•ӘВ«в”ҳГӘв•ӘВ»в”ҢвҢҗв•ӘВәв•Әв–’ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГӘ в”ҳГ в•ӘВ¬в”ҳГҘв”ҳГү в•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв•ӘВ» в•ӘГів”ҳв•ӣв”ҳГӨв”ҳГӘв•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§ в•Әв–’в•ӘВә в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢвҢҗв”ҳГҘв•ӘВ». в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в”ҳГ в•Әв–’в•ӘВ¬в•ӘВҝв•Әв•– в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•Әв–’в•ӘВәв•ӘВј в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв–’в•ӘВәв”ҳГ в”ҳв•ӣв•ӘВ¬ в”ҳГ§в”ҳГӘв•Әв”Ө в”ҳГ в•Әв•Ўв”ҳГҘв”ҳГӘв•Әв•Јв–ҲГ® в•Әв•ўв”ҳГ в–ҲГ®в”ҳГ в”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв”ҳГҘв•ӘВ».\n                  </p>\n                  <p className=\"font-semibold text-foreground bg-accent/5 border border-accent/10 p-2.5 rounded-md mt-1\">\n                    вүЎЖ’ГҶГӯ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГӨв”ҳГӘв•ӘВ» в•Әв”Өв•ӘВ»в”ҳГҘ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬в•ӘГ® в”ҢвҢҗв•ӘВәв”ҳГјв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ в•ӘВ¬в”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в”ҳГјв•Әв–’в”ҳГ  в•Әв”Ӯв”ҳГ в•ӘВ¬ в”ҢГҘв”ҳв•ӣ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ» в•ӘВ¬в•ӘВә в•ӘВҝв”ҳГӨв•ӘВәв”ҳГјв•ӘВәв•Әв•Ўв”ҳГӨв”ҳГ§ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Ө в”ҳГ в•ӘВ¬в•Әв•Ўв”ҳГӨ в”ҢВ»в•Әв–’в•ӘВ»в”ҳГҘв•ӘВ».\n                  </p>\n                </div>\n\n                {/* List of uploaded documents */}\n                <div className=\"bg-surface-container-low p-4 rounded-lg border border-border-subtle space-y-3\">\n                  <h4 className=\"text-xs font-semibold text-foreground flex items-center gap-1.5\">\n                    <FileText className=\"size-4 text-accent\" />\n                    в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГ в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ»в•ӘВәв•ӘВ¬ в”ҳГӘ в”ҳГ в”ҳГҘв•ӘВәв•ӘВҝв•Әв•Ј в•ӘВ»в•ӘВәв”ҳГҘв•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ\n                  </h4>\n\n                  <div className=\"space-y-2 max-h-[220px] overflow-y-auto pr-1\">\n                    {knowledgeList.length === 0 ? (\n                      <p className=\"text-xs text-foreground-muted italic text-center py-6\">в”ҳГ§в–ҲГ®в”ҢГҘ в•Әв”Ӯв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГ§в”ҳГҘв”ҳГӘв•Әв–“ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n                    ) : (\n                      knowledgeList.map(doc => (\n                        <div key={doc.id} className=\"p-3 bg-surface border border-border rounded-lg flex items-center justify-between shadow-sm\">\n                          <div className=\"space-y-0.5\">\n                            <span className=\"text-xs font-semibold text-foreground block\">{doc.title}</span>\n                            <span className=\"text-[10px] text-foreground-muted block font-mono\">SLUG: {doc.slug}</span>\n                          </div>\n                          <Badge variant=\"outline\" className=\"text-[10px] border-border-subtle bg-surface-container-high text-foreground-muted\">\n                            {doc.category === 'technical' ? 'в”ҳГјв”ҳГҘв–ҲГ®' : doc.category === 'safety' ? 'в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®' : 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®'}\n                          </Badge>\n                        </div>\n                      ))\n                    )}\n                  </div>\n                </div>\n\n              </div>\n\n            </div>\n\n            <div className=\"flex gap-2 justify-end pt-3.5 border-t border-border\">\n              <Button\n                onClick={() => setShowSettings(false)}\n                className=\"bg-accent hover:bg-accent-hover text-accent-foreground text-xs font-semibold rounded-md h-9 px-6 cursor-pointer\"\n              >\n                в•ӘВҝв•Әв”Ӯв•ӘВ¬в”ҳГҘ в”ҳв•ӣв”ҳГҘв•ӘВјв•Әв–’в”ҳГ§ в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬\n              </Button>\n            </div>\n\n          </div>\n        </div>\n      )}\n\n    </section>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\announcement-library.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\broadcast-history.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\bulletin-guard.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\components\\shared\\chat-room-list.tsx","messages":[],"