ring[]\n  isEmergency: boolean\n  creatorName: string\n  creatorId: string\n  participantsCount: number\n  isDefaultMuted: boolean\n}\n\nexport default function AudioConferencePage() {\n  const router = useRouter()\n  const user = useAuthStore((s) => s.user)\n  \n  const [rooms, setRooms] = useState<VoiceRoom[]>([])\n  const [config, setConfig] = useState<any>(null)\n\n  useEffect(() => {\n    fetch('/api/config')\n      .then((res) => res.json())\n      .then((data) => {\n        if (data.data) {\n          setConfig(data.data)\n        }\n      })\n      .catch(() => {})\n  }, [])\n  const [activeRoomId, setActiveRoomId] = useState<string | null>(null)\n  const [joined, setJoined] = useState(false)\n  const [myMuted, setMyMuted] = useState(false)\n  const [myDeaf, setMyDeaf] = useState(false)\n  const [participants, setParticipants] = useState<Participant[]>([])\n  \n  // Room Creation Form States\n  const [showCreateModal, setShowCreateModal] = useState(false)\n  const [newRoomName, setNewRoomName] = useState('')\n  const [newRoomAccess, setNewRoomAccess] = useState<'public' | 'role' | 'shift' | 'manual'>('public')\n  const [selectedRoles, setSelectedRoles] = useState<string[]>([])\n  const [selectedShifts, setSelectedShifts] = useState<string[]>([])\n  const [selectedUsers, setSelectedUsers] = useState<string[]>([])\n  const [isEmergency, setIsEmergency] = useState(false)\n  const [isDefaultMuted, setIsDefaultMuted] = useState(false)\n\n  // Simulation speaker states\n  const [pulse, setPulse] = useState(false)\n  const audioCtxRef = useRef<AudioContext | null>(null)\n\n  // Mock list of database personnel for manual selection\n  const mockPersonnel = [\n    { id: 'u1', name: 'в”ҳГ в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯ в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘв–ҲГ®', role: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» OCC' },\n    { id: 'u2', name: 'в•ӘВЎв”ҳГ в–ҲГ®в•ӘВ» в•Әв”Өв•Әв–’в–ҲГ®в”ҳГјв–ҲГ®', role: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’' },\n    { id: 'u3', name: 'в•Әв”Ӯв•ӘВәв•Әв–’в•ӘВә в•ӘВәв•ӘВЎв”ҳГ в•ӘВ»в–ҲГ®', role: 'в•Әв–’в•ӘВӘв–ҲГ®в•Әв”Ӯ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§' },\n    { id: 'u4', name: 'в•Әв•Јв”ҳГӨв–ҲГ® в•Әв–’в•Әв•ўв•ӘВәв–ҲГ®в–ҲГ®', role: 'в•ӘВ¬в”ҢвҢҗв”ҳГҘв•Әв”Ӯв–ҲГ®в”ҳГҘ в”ҳГјв”ҳГҘв–ҲГ® в•Әв–’в–ҲГ®в”ҳГӨ' },\n    { id: 'u5', name: 'в”ҳГ в•Әв–’в–ҲГ®в”ҳГ  в”ҳГ в•ӘВЎв•Әв”Ӯв”ҳГҘв–ҲГ®', role: 'в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’ в•Әв”Ӯв”ҢвҢҗв”ҳГӘ' }\n  ]\n\n  // Load Initial Rooms\n  useEffect(() => {\n    setRooms([\n      {\n        id: 'room-1',\n        name: 'в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“в–ҲГ® OCC',\n        allowedAccess: 'public',\n        isEmergency: true,\n        creatorName: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ',\n        creatorId: 'sys',\n        participantsCount: 4,\n        isDefaultMuted: false\n      },\n      {\n        id: 'room-2',\n        name: 'в”ҢвҢҗв”ҳГ в–ҲГ®в•ӘВ¬в”ҳГ§ в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ»в–ҲГ® в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘ в”ҳГӘ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГҘв•ӘВЎ в•ӘВ«в•Әв•– в–Ҳв–’',\n        allowedAccess: 'role',\n        allowedRoles: ['admin', 'super_admin'],\n        isEmergency: true,\n        creatorName: 'в”ҳГ в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯ в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘв–ҲГ® (OCC)',\n        creatorId: 'u1',\n        participantsCount: 1,\n        isDefaultMuted: true\n      },\n      {\n        id: 'room-3',\n        name: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГӘ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ»в”ҳв•ӣв”ҳГӘв–ҲГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗ (в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ A)',\n        allowedAccess: 'shift',\n        allowedShifts: ['A', 'morning'],\n        isEmergency: false,\n        creatorName: 'в•Әв•Јв”ҳГӨв–ҲГ® в•Әв–’в•Әв•ўв•ӘВәв–ҲГ®в–ҲГ® (в”ҳГјв”ҳГҘв–ҲГ®)',\n        creatorId: 'u4',\n        participantsCount: 2,\n        isDefaultMuted: false\n      },\n      {\n        id: 'room-4',\n        name: 'в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в”ҢВ»в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГӘв”ҢВ»в”ҳГӘв–ҲГ® в•ӘВәв”ҳГ в”ҳГҘ в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ»',\n        allowedAccess: 'manual',\n        allowedUsers: ['в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§', 'в”ҳГ в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯ в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘв–ҲГ®'],\n        isEmergency: false,\n        creatorName: 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§',\n        creatorId: 'admin-id',\n        participantsCount: 1,\n        isDefaultMuted: true\n      }\n    ])\n\n    setParticipants([\n      { id: '1', name: 'в”ҳГ в”ҳГ§в”ҳГҘв•ӘВ»в•Әв”Ӯ в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘв–ҲГ® (OCC)', role: 'в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ» в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ»', isMuted: false, isSpeaking: false, avatarColor: 'bg-accent/10 text-accent' },\n      { id: '2', name: 'в•ӘВЎв”ҳГ в–ҲГ®в•ӘВ» в•Әв”Өв•Әв–’в–ҲГ®в”ҳГјв–ҲГ® (в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’)', role: 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•Әв–’в•ӘВәв”ҳГ  в–Ҳв–’в–Ҳв–‘в–Ҳв”Ө', isMuted: true, isSpeaking: false, avatarColor: 'bg-warning/10 text-warning' },\n      { id: '3', name: 'в•Әв”Ӯв•ӘВәв•Әв–’в•ӘВә в•ӘВәв•ӘВЎв”ҳГ в•ӘВ»в–ҲГ® (в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§)', role: 'в•Әв–’в•ӘВӘв–ҲГ®в•Әв”Ӯ в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•ӘВ»в•Әв–’в”ҳГӘв•ӘВәв•Әв–“в”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГӨв•ӘВ¬', isMuted: false, isSpeaking: false, avatarColor: 'bg-success/10 text-success' },\n      { id: '4', name: 'в•Әв•Јв”ҳГӨв–ҲГ® в•Әв–’в•Әв•ўв•ӘВәв–ҲГ®в–ҲГ® (в”ҳГјв”ҳГҘв–ҲГ®)', role: 'в•ӘВ¬в”ҢвҢҗв”ҳГҘв•Әв”Ӯв–ҲГ®в”ҳГҘ в”ҢвҢҗв•Әв”Өв•Әв”Ө в•Әв–’в–ҲГ®в”ҳГӨ', isMuted: false, isSpeaking: false, avatarColor: 'bg-info/10 text-info' },\n    ])\n  }, [])\n\n  // Simulating active speakers\n  useEffect(() => {\n    if (!joined) return\n    const interval = setInterval(() => {\n      setParticipants((prev) =>\n        prev.map((p) => {\n          if (p.isMuted) return { ...p, isSpeaking: false }\n          const speak = Math.random() > 0.6\n          return { ...p, isSpeaking: speak }\n        })\n      )\n    }, 2800)\n\n    const pulseInterval = setInterval(() => {\n      setPulse((p) => !p)\n    }, 850)\n\n    return () => {\n      clearInterval(interval)\n      clearInterval(pulseInterval)\n    }\n  }, [joined])\n\n  const initAudio = () => {\n    if (!audioCtxRef.current) {\n      audioCtxRef.current = new (window.AudioContext || (window as any).webkitAudioContext)()\n    }\n  }\n\n  const playSystemTone = (freq: number, duration: number) => {\n    try {\n      initAudio()\n      const ctx = audioCtxRef.current\n      if (!ctx) return\n      const osc = ctx.createOscillator()\n      const gain = ctx.createGain()\n      osc.connect(gain)\n      gain.connect(ctx.destination)\n      osc.type = 'sine'\n      osc.frequency.setValueAtTime(freq, ctx.currentTime)\n      gain.gain.setValueAtTime(0.08, ctx.currentTime)\n      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration)\n      osc.start()\n      osc.stop(ctx.currentTime + duration)\n    } catch {\n      // silent fallback\n    }\n  }\n\n  const checkRoomPermission = (room: VoiceRoom): boolean => {\n    if (!user) return false\n    \n    // Super admin bypassing\n    if (user.roleKey === 'super_admin' || user.roleKey === 'admin') return true\n\n    if (room.allowedAccess === 'public') return true\n\n    if (room.allowedAccess === 'role') {\n      const userRole = user.roleKey || 'operator'\n      return room.allowedRoles?.includes(userRole) ?? false\n    }\n\n    if (room.allowedAccess === 'shift') {\n      // user shift metadata checking\n      const userShift = (user.customFields as any)?.workShiftGroup || 'A'\n      return room.allowedShifts?.includes(userShift) ?? false\n    }\n\n    if (room.allowedAccess === 'manual') {\n      const userName = user.name || ''\n      return room.allowedUsers?.some(u => userName.includes(u) || u.includes(userName)) ?? false\n    }\n\n    return false\n  }\n\n  const handleJoinRoom = (room: VoiceRoom) => {\n    if (!checkRoomPermission(room)) {\n      alert('в•Әв”Өв”ҳГ в•ӘВә в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в”ҳГӨв•ӘВәв•Әв–“в”ҳГ  в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•Әв–’в•ӘВә в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®в•ӘВ».')\n      return\n    }\n\n    const maxParticipants = config?.comms?.maxConferenceParticipants ?? 15\n    if (room.participantsCount >= maxParticipants) {\n      alert(`в•ӘВәв–ҲГ®в”ҳГҘ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в•Әв••в•Әв–’в”ҳГјв–ҲГ®в•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬ (в•ӘВЎв•ӘВ»в•ӘВәв”ҢвҢҗв•ӘВҪв•Әв–’ в•Әв••в•Әв–’в”ҳГјв–ҲГ®в•ӘВ¬: ${toFa(maxParticipants)} в”ҳГҘв”ҳГјв•Әв–’).`)\n      return\n    }\n\n    if (activeRoomId === room.id && joined) return\n\n    playSystemTone(440, 0.15)\n    setTimeout(() => playSystemTone(880, 0.15), 150)\n    \n    setActiveRoomId(room.id)\n    setJoined(true)\n    setMyMuted(room.isDefaultMuted)\n  }\n\n  const handleLeave = () => {\n    playSystemTone(330, 0.2)\n    setJoined(false)\n    setActiveRoomId(null)\n  }\n\n  const handleCreateRoom = (e: React.FormEvent) => {\n    e.preventDefault()\n    if (!newRoomName.trim() || !user) return\n\n    const newRoom: VoiceRoom = {\n      id: `room-${crypto.randomUUID()}`,\n      name: newRoomName.trim(),\n      allowedAccess: newRoomAccess,\n      allowedRoles: newRoomAccess === 'role' ? selectedRoles : undefined,\n      allowedShifts: newRoomAccess === 'shift' ? selectedShifts : undefined,\n      allowedUsers: newRoomAccess === 'manual' ? selectedUsers : undefined,\n      isEmergency: isEmergency,\n      creatorName: user.name || 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’',\n      creatorId: user.id || 'admin',\n      participantsCount: 0,\n      isDefaultMuted: isDefaultMuted\n    }\n\n    setRooms((prev) => [...prev, newRoom])\n    setShowCreateModal(false)\n    \n    // reset form\n    setNewRoomName('')\n    setNewRoomAccess('public')\n    setSelectedRoles([])\n    setSelectedShifts([])\n    setSelectedUsers([])\n    setIsEmergency(false)\n    setIsDefaultMuted(false)\n\n    playSystemTone(600, 0.1)\n  }\n\n  const handleDeleteRoom = (roomId: string) => {\n    if (activeRoomId === roomId) {\n      handleLeave()\n    }\n    setRooms((prev) => prev.filter(r => r.id !== roomId))\n    playSystemTone(250, 0.2)\n  }\n\n  const handleToggleMuteAll = () => {\n    playSystemTone(400, 0.08)\n    setParticipants((prev) => prev.map(p => ({ ...p, isMuted: true, isSpeaking: false })))\n  }\n\n  const activeRoom = rooms.find((r) => r.id === activeRoomId) ?? null\n  const isCreatorOrAdmin = activeRoom ? (activeRoom.creatorId === user?.id || user?.roleKey === 'admin' || user?.roleKey === 'super_admin') : false\n\n  if (config && config.comms?.conferenceEnabled === false) {\n    return (\n      <div className=\"flex flex-1 flex-col items-center justify-center bg-background p-8 text-center\" dir=\"rtl\">\n        <div className=\"w-full max-w-md rounded-lg border border-critical/30 bg-surface-container-low/40 backdrop-blur-md p-6 shadow-2xl space-y-6 relative overflow-hidden\">\n          <div className=\"absolute top-0 right-0 h-[3px] w-full bg-gradient-to-l from-critical via-transparent to-critical\" />\n          <div className=\"flex flex-col items-center gap-3 text-critical\">\n            <Shield className=\"size-12 animate-pulse\" />\n            <h1 className=\"text-lg font-semibold tracking-tight text-foreground\">в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•ӘВәв•Әв”Ӯв•ӘВ¬</h1>\n          </div>\n          <p className=\"text-xs text-foreground-muted leading-relaxed\">\n            в•ӘВәв”ҳГ в”ҢвҢҗв•ӘВәв”ҳГҘ в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§в–ҲГ® в”ҳГӘ в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВЎв•ӘВәв•Әв•ўв•Әв–’ в•ӘВ¬в”ҳГӘв•Әв”Ӯв•Әв•– в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬. в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в•ӘВәв•Әв–“ в•Әв”Өв•ӘВҝв–ҲГ®в”ҳГ§О“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“ в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв”Ӯв–ҲГ®в”ҳГ  TETRA в–ҲГ®в•ӘВә в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ О“ГҮГ®в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘ в”ҳГ в•ӘВ¬в”ҳГҘв–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬в”ҳГјв•ӘВәв•ӘВ»в”ҳГ§ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n          </p>\n          <div className=\"text-[10px] text-foreground-muted font-mono tracking-wider\">\n            AUDIO CONFERENCE SYSTEM OFF\n          </div>\n        </div>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"flex flex-col lg:flex-row h-full bg-background text-foreground p-6 gap-6 text-right transition-colors duration-150\" dir=\"rtl\">\n      \n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* RIGHT PANEL: Voice Channels List / Sidebar */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"w-full lg:w-96 flex flex-col border border-border p-4 bg-surface-container-low rounded-lg shrink-0 shadow-sm\">\n        <div className=\"flex justify-between items-center mb-6\">\n          <div>\n            <h2 className=\"text-sm font-semibold text-foreground flex items-center gap-2\">\n              <Radio className=\"size-4 text-accent\" />\n              в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ\n            </h2>\n            <p className=\"text-[10px] text-foreground-muted mt-0.5 font-medium\">в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в”ҳГ в”ҳГӘв•Әв–’в•ӘВ» в”ҳГҘв•Әв••в•Әв–’ в•Әв–’в•ӘВә в•ӘВјв”ҳГ§в•ӘВ¬ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»</p>\n          </div>\n          {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n            <Button\n              onClick={() => setShowCreateModal(true)}\n              className=\"bg-accent hover:bg-accent-hover text-accent-foreground rounded-md px-2.5 h-8 text-xs font-semibold flex items-center gap-1 active:scale-95 transition-all cursor-pointer\"\n            >\n              <Plus className=\"size-3.5\" />\n              в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬ в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ©\n            </Button>\n          )}\n        </div>\n\n        <div className=\"flex-1 overflow-y-auto space-y-3 pr-1\">\n          {rooms.map((room) => {\n            const hasAccess = checkRoomPermission(room)\n            const isActive = activeRoomId === room.id\n\n            return (\n              <div\n                key={room.id}\n                onClick={() => hasAccess && handleJoinRoom(room)}\n                className={`p-4 rounded-lg border transition-all text-right cursor-pointer flex flex-col justify-between relative ${\n                  isActive\n                    ? 'bg-accent/10 border-accent shadow-sm'\n                    : hasAccess\n                    ? 'bg-surface border-border hover:border-accent/40'\n                    : 'bg-surface-container border-border-subtle opacity-50 cursor-not-allowed'\n                }`}\n              >\n                {/* Upper row: Name & Delete Option for Admins */}\n                <div className=\"flex justify-between items-start gap-4\">\n                  <div className=\"flex items-center gap-2\">\n                    {!hasAccess && <Lock className=\"size-3.5 text-foreground-muted shrink-0\" />}\n                    <h3 className={`text-xs font-semibold ${isActive ? 'text-accent' : 'text-foreground'}`}>\n                      {room.name}\n                    </h3>\n                  </div>\n                  {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n                    <button\n                      onClick={(e) => {\n                        e.stopPropagation()\n                        handleDeleteRoom(room.id)\n                      }}\n                      className=\"text-foreground-muted hover:text-accent p-1 rounded-md transition-colors\"\n                      title=\"в•ӘВЎв•Әв–‘в”ҳГј в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ®\"\n                    >\n                      <Trash2 className=\"size-3.5\" />\n                    </button>\n                  )}\n                </div>\n\n                {/* Tags and Metadata */}\n                <div className=\"flex items-center justify-between flex-wrap gap-2 mt-4 pt-2 border-t border-border-subtle text-[10px] text-foreground-muted font-medium\">\n                  <div className=\"flex items-center gap-1.5 flex-wrap\">\n                    {room.isEmergency && (\n                      <Badge variant=\"outline\" className=\"bg-critical/10 text-critical border-critical/20 px-1.5 py-0.2 rounded-sm font-semibold text-[9px]\">\n                        в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®\n                      </Badge>\n                    )}\n                    {room.allowedAccess === 'public' && (\n                      <Badge variant=\"outline\" className=\"bg-success/10 text-success border-success/20 px-1.5 py-0.2 rounded-sm text-[9px]\">\n                        в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ®\n                      </Badge>\n                    )}\n                    {room.allowedAccess === 'role' && (\n                      <Badge variant=\"outline\" className=\"bg-warning/10 text-warning border-warning/20 px-1.5 py-0.2 rounded-sm text-[9px]\">\n                        в”ҳГҘв”ҳГ©в•Әв”Ө в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®\n                      </Badge>\n                    )}\n                    {room.allowedAccess === 'shift' && (\n                      <Badge variant=\"outline\" className=\"bg-info/10 text-info border-info/20 px-1.5 py-0.2 rounded-sm text-[9px]\">\n                        в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬\n                      </Badge>\n                    )}\n                    {room.allowedAccess === 'manual' && (\n                      <Badge variant=\"outline\" className=\"bg-accent/10 text-accent border-accent/20 px-1.5 py-0.2 rounded-sm text-[9px]\">\n                        в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ» (в•Әв”Өв•ӘВ«в•Әв•Ўв–ҲГ®)\n                      </Badge>\n                    )}\n                  </div>\n\n                  <span className=\"flex items-center gap-1 text-[10px] font-semibold text-foreground-muted\">\n                    <Users className=\"size-3 text-accent\" />\n                    {toFa(room.participantsCount.toString())} в”ҳГҘв”ҳГјв•Әв–’ в•ӘВЎв•ӘВәв•Әв•ўв•Әв–’\n                  </span>\n                </div>\n              </div>\n            )\n          })}\n        </div>\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* LEFT PANEL: Conference Room View */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      <div className=\"flex-1 flex flex-col min-h-[480px]\">\n        {/* Page Header */}\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between border-b border-border-subtle pb-4 mb-6 gap-4\">\n          <div>\n            <h1 className=\"text-lg font-semibold text-foreground flex items-center gap-2\">\n              <Radio className={`size-5 text-accent ${joined ? 'animate-pulse' : ''}`} />\n              в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ (OCC & Stations)\n            </h1>\n            <p className=\"text-xs text-foreground-muted mt-1 font-medium\">\n              в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ® в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•–в•ӘВәв•ӘВ¬ в”ҳГӨв•ӘВЎв•Әв••в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВ»в–ҲГ®в•Әв”Ӯв”ҳв•ӣв•ӘВәв”ҢГҘв–ҲГ®в”ҳГҘв”ҢВ» в”ҳГӘ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬\n            </p>\n          </div>\n\n          <div className=\"flex items-center gap-3\">\n            <div className=\"flex items-center gap-1.5 px-3 py-1 bg-surface border border-border rounded-full shadow-sm\">\n              <Wifi className=\"size-3.5 text-success\" />\n              <span className=\"text-[10px] text-foreground-muted font-mono\">RTT: {toFa('в–Ҳв”Ӯв–Ҳв–“')}ms</span>\n            </div>\n            {joined && (\n              <div className=\"flex items-center gap-1 bg-success/10 px-3 py-1 rounded-full border border-success/20 text-success text-[10px] font-semibold\">\n                <span className=\"relative flex h-1.5 w-1.5 rounded-full bg-success\">\n                  <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75\"></span>\n                </span>\n                в•ӘВәв•ӘВ¬в•Әв•Ўв•ӘВәв”ҳГӨ в•ӘВҝв•Әв–’в”ҳГ©в•Әв–’в•ӘВәв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВ¬\n              </div>\n            )}\n          </div>\n        </div>\n\n        {!joined ? (\n          <div className=\"flex-1 flex flex-col items-center justify-center max-w-md mx-auto space-y-5 text-center\">\n            <div className=\"size-16 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center text-accent shadow-sm animate-pulse\">\n              <Users className=\"size-8\" />\n            </div>\n            <div className=\"space-y-2\">\n              <h2 className=\"text-sm font-semibold text-foreground\">в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬в”ҳГҘ в•ӘВҝв”ҳГ§ в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ</h2>\n              <p className=\"text-xs text-foreground-muted leading-relaxed font-medium\">\n                в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в•ӘВәв•Әв–“ в•Әв”Ӯв•ӘВәв–ҲГ®в•ӘВ»в•ӘВҝв•ӘВәв•Әв–’ в•Әв”Ӯв”ҳГ в•ӘВ¬ в•Әв–’в•ӘВәв•Әв”Ӯв•ӘВ¬ в–ҲГ®в”ҢвҢҗв–ҲГ® в•ӘВәв•Әв–“ в”ҢвҢҗв•ӘВәв”ҳГҘв•ӘВәв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•Әв–’в•ӘВә в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•ӘВ¬в•ӘВә в•ӘВәв•Әв–’в•ӘВ¬в•ӘВҝв•ӘВәв•Әв•– в•Әв–“в”ҳГҘв•ӘВ»в”ҳГ§ в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•ӘГів•Әв•‘в•ӘВәв•Әв–“ в”ҢВ»в•Әв–’в•ӘВ»в•ӘВ».\n              </p>\n            </div>\n          </div>\n        ) : (\n          <div className=\"flex-1 flex flex-col min-h-0 bg-surface-container-low border border-border rounded-lg p-4 md:p-6 justify-between gap-6 shadow-sm\">\n            <div className=\"flex justify-between items-center border-b border-border-subtle pb-3 mb-2\">\n              <span className=\"text-xs font-semibold text-accent\">\n                в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ: {activeRoom?.name}\n              </span>\n              {isCreatorOrAdmin && (\n                <div className=\"flex items-center gap-2\">\n                  <Button\n                    onClick={handleToggleMuteAll}\n                    className=\"bg-accent/10 border border-accent/20 text-accent text-xs h-8 px-3 rounded-md hover:bg-accent/15 font-semibold active:scale-95 transition-all cursor-pointer\"\n                  >\n                    в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв•Ўв•ӘВ»в•ӘВә в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в”ҳГ§в”ҳГ в”ҳГ§\n                  </Button>\n                </div>\n              )}\n            </div>\n\n            <div className=\"flex-1 min-h-0 overflow-y-auto\">\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n                {/* Current User Card */}\n                <div className={`p-4 rounded-lg border transition-all flex flex-col justify-between items-center text-center gap-3 relative ${\n                  !myMuted && !myDeaf ? 'bg-surface border-accent/40 shadow-sm' : 'bg-surface-container border-border-subtle/50'\n                }`}>\n                  {!myMuted && !myDeaf && (\n                    <div className=\"absolute top-3 right-3 flex items-center gap-1 bg-accent/10 border border-accent/20 px-2 py-0.5 rounded text-[8px] font-semibold text-accent\">\n                      <Sparkles className=\"size-2.5\" />\n                      в•Әв”Өв”ҳГ в•ӘВә\n                    </div>\n                  )}\n                  \n                  <div className={`size-14 rounded-full flex items-center justify-center text-base font-semibold border transition-all ${\n                    !myMuted && !myDeaf ? 'bg-accent/10 border-accent text-accent' : 'bg-surface-container border-border text-foreground-muted'\n                  }`}>\n                    {user?.name?.substring(0, 1)}\n                  </div>\n\n                  <div className=\"space-y-0.5\">\n                    <span className=\"text-xs font-semibold text-foreground block\">{user?.name} (в•Әв”Өв”ҳГ в•ӘВә)</span>\n                    <span className=\"text-[10px] text-foreground-muted font-medium\">{user?.roleKey === 'admin' ? 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§' : 'в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’'}</span>\n                  </div>\n\n                  <div className=\"flex items-center gap-2\">\n                    {myMuted || myDeaf ? (\n                      <div className=\"bg-critical/10 p-1.5 rounded-full text-critical border border-critical/15\">\n                        <MicOff className=\"size-3.5\" />\n                      </div>\n                    ) : (\n                      <div className=\"bg-success/10 p-1.5 rounded-full text-success border border-success/15 animate-pulse\">\n                        <Mic className=\"size-3.5\" />\n                      </div>\n                    )}\n                    {myDeaf && (\n                      <div className=\"bg-critical/10 p-1.5 rounded-full text-critical border border-critical/15\">\n                        <VolumeX className=\"size-3.5\" />\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n                {/* Other Participants */}\n                {participants.map((p) => (\n                  <div\n                    key={p.id}\n                    className={`p-4 rounded-lg border transition-all flex flex-col justify-between items-center text-center gap-3 relative ${\n                      p.isSpeaking && !myDeaf\n                        ? 'bg-surface border-accent shadow-sm scale-[1.01]'\n                        : 'bg-surface/60 border-border-subtle'\n                    }`}\n                  >\n                    {p.isSpeaking && !myDeaf && (\n                      <div className={`absolute inset-0 border border-accent/40 rounded-lg pointer-events-none transition-transform duration-300 ${pulse ? 'scale-103 opacity-20' : 'scale-100 opacity-40'}`} />\n                    )}\n\n                    <div className={`size-14 rounded-full flex items-center justify-center text-base font-semibold border transition-all ${\n                      p.isSpeaking && !myDeaf\n                        ? 'bg-accent/20 border-accent text-accent animate-pulse'\n                        : 'bg-surface-container border-border-subtle text-foreground-muted'\n                    }`}>\n                      {p.name.substring(0, 1)}\n                    </div>\n\n                    <div className=\"space-y-0.5\">\n                      <span className=\"text-xs font-semibold text-foreground block\">{p.name}</span>\n                      <span className=\"text-[10px] text-foreground-muted font-medium\">{p.role}</span>\n                    </div>\n\n                    <div className=\"flex items-center gap-2\">\n                      {p.isMuted ? (\n                        <div className=\"bg-surface-container p-1.5 rounded-full text-foreground-muted border border-border-subtle\">\n                          <MicOff className=\"size-3.5\" />\n                        </div>\n                      ) : (\n                        <div className={`p-1.5 rounded-full border ${p.isSpeaking && !myDeaf ? 'bg-accent/10 border-accent/20 text-accent' : 'bg-surface-container border-border-subtle text-foreground-muted'}`}>\n                          <Mic className=\"size-3.5\" />\n                        </div>\n                      )}\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Footer Control Toolbar */}\n            <div className=\"bg-surface border border-border p-3.5 rounded-lg flex justify-between items-center flex-wrap gap-4 shadow-sm\">\n              <div className=\"flex items-center gap-2\">\n                <div className=\"size-2 rounded-full bg-success animate-pulse\" />\n                <span className=\"text-xs font-semibold text-foreground\">\n                  в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•ӘВЎв•ӘВәв•Әв•ўв•Әв–’в–ҲГ®в”ҳГҘ: {toFa((participants.length + 1).toString())} в”ҳГҘв”ҳГјв•Әв–’\n                </span>\n              </div>\n\n              <div className=\"flex items-center gap-3\">\n                <Button\n                  onClick={() => setMyMuted(!myMuted)}\n                  variant={myMuted ? \"default\" : \"outline\"}\n                  className={`size-10 rounded-full p-0 flex items-center justify-center active:scale-95 transition-all cursor-pointer ${\n                    myMuted ? 'bg-critical hover:bg-critical/90 text-critical-foreground' : 'border-border hover:bg-surface-hover text-foreground'\n                  }`}\n                  title={myMuted ? \"в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в”ҳГ в–ҲГ®в”ҢвҢҗв•Әв–’в”ҳГӘв”ҳГјв”ҳГӘв”ҳГҘ\" : \"в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв•Ўв•ӘВ»в•ӘВә в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ\"}\n                >\n                  {myMuted ? <MicOff className=\"size-4.5\" /> : <Mic className=\"size-4.5\" />}\n                </Button>\n\n                <Button\n                  onClick={() => setMyDeaf(!myDeaf)}\n                  variant={myDeaf ? \"default\" : \"outline\"}\n                  className={`size-10 rounded-full p-0 flex items-center justify-center active:scale-95 transition-all cursor-pointer ${\n                    myDeaf ? 'bg-critical hover:bg-critical/90 text-critical-foreground' : 'border-border hover:bg-surface-hover text-foreground'\n                  }`}\n                  title={myDeaf ? \"в•Әв”Өв”ҳГҘв–ҲГ®в•ӘВ»в”ҳГҘ в•Әв•Ўв•ӘВ»в•ӘВәв”ҳГ§в•ӘВә\" : \"в”ҳГ©в•Әв•–в•Әв•Ј в•Әв•Ўв•ӘВ»в•ӘВәв–ҲГ® в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ\"}\n                >\n                  {myDeaf ? <VolumeX className=\"size-4.5\" /> : <Volume2 className=\"size-4.5\" />}\n                </Button>\n\n                <Button\n                  onClick={handleLeave}\n                  className=\"bg-critical hover:bg-critical/90 text-critical-foreground size-10 rounded-full p-0 flex items-center justify-center active:scale-95 transition-all cursor-pointer\"\n                  title=\"в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј в•ӘВәв•Әв–“ в”ҢвҢҗв”ҳГҘв”ҳГјв•Әв–’в•ӘВәв”ҳГҘв•Әв”Ӯ\"\n                >\n                  <PhoneOff className=\"size-4.5\" />\n                </Button>\n              </div>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {/* MODAL: Create New Voice Room Form */}\n      {/* О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ */}\n      {showCreateModal && (\n        <div className=\"fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-surface border border-border rounded-lg w-full max-w-lg p-6 space-y-5 shadow-xl animate-fade-in text-right\">\n            <div className=\"flex justify-between items-center pb-3 border-b border-border\">\n              <h3 className=\"text-sm font-semibold text-foreground\">в•Әв”Ӯв•ӘВәв•ӘВ«в•ӘВ¬ в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</h3>\n              <button\n                onClick={() => setShowCreateModal(false)}\n                className=\"text-foreground-muted hover:text-foreground hover:bg-surface-hover p-1.5 rounded-md transition-colors\"\n              >\n                <X className=\"size-5\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleCreateRoom} className=\"space-y-4\">\n              <div className=\"space-y-1\">\n                <label className=\"text-xs font-semibold text-foreground-muted block\">в”ҳГҘв•ӘВәв”ҳГ  в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ®:</label>\n                <input\n                  type=\"text\"\n                  required\n                  placeholder=\"в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: в”ҳГ§в”ҳГ в•ӘВәв”ҳГ§в”ҳГҘв”ҢВ»в–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬ в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө\"\n                  value={newRoomName}\n                  onChange={(e) => setNewRoomName(e.target.value)}\n                  className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"flex items-center justify-between bg-surface-container-low p-3 rounded-lg border border-border-subtle\">\n                  <label className=\"text-xs font-semibold text-foreground-muted\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® (в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘв–ҲГ®):</label>\n                  <input\n                    type=\"checkbox\"\n                    checked={isEmergency}\n                    onChange={(e) => setIsEmergency(e.target.checked)}\n                    className=\"accent-accent size-4 cursor-pointer\"\n                  />\n                </div>\n\n                <div className=\"flex items-center justify-between bg-surface-container-low p-3 rounded-lg border border-border-subtle\">\n                  <label className=\"text-xs font-semibold text-foreground-muted\">в•ӘВҝв–ҲГ®О“ГҮГ®в•Әв•Ўв•ӘВ»в•ӘВә в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВ»в”ҳГӘ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»:</label>\n                  <input\n                    type=\"checkbox\"\n                    checked={isDefaultMuted}\n                    onChange={(e) => setIsDefaultMuted(e.target.checked)}\n                    className=\"accent-accent size-4 cursor-pointer\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-xs font-semibold text-foreground-muted block\">в•Әв”Ӯв•Әв•–в•ӘВЎ в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГӘ в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬:</label>\n                <select\n                  value={newRoomAccess}\n                  onChange={(e) => setNewRoomAccess(e.target.value as any)}\n                  className=\"h-9 w-full bg-surface border border-border rounded-lg px-3 text-sm focus:outline-none focus:ring-1 focus:ring-ring\"\n                >\n                  <option value=\"public\">в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® (в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬в”ҳГҘ в•ӘГів•Әв–“в•ӘВәв•ӘВ» в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГ§в”ҳГ в”ҳГ§)</option>\n                  <option value=\"role\">в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҳГҘв”ҳГ©в•Әв”Ө в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® (RBAC)</option>\n                  <option value=\"shift\">в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®</option>\n                  <option value=\"manual\">в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГ в•ӘВЎв•ӘВ»в”ҳГӘв•ӘВ» в•ӘВҝв”ҳГ§ в•ӘВәв”ҳГјв•Әв–’в•ӘВәв•ӘВ» в•ӘВ«в•ӘВәв•Әв•Ў</option>\n                </select>\n              </div>\n\n              {/* Conditional permission parameters */}\n              {newRoomAccess === 'role' && (\n                <div className=\"space-y-2 bg-surface-container-low p-3 rounded-lg border border-border-subtle\">\n                  <span className=\"text-[10px] font-semibold text-foreground-muted block\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•ӘВјв•ӘВәв•Әв–“:</span>\n                  <div className=\"flex gap-4 flex-wrap\">\n                    {['admin', 'operator'].map((roleKey) => {\n                      const label = roleKey === 'admin' ? 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§' : 'в•ӘВәв”ҳв•ӣв•Әв–’в•ӘВәв•ӘВ¬в”ҳГӘв•Әв–’в”ҳГ§в•ӘВә / в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ'\n                      const isSelected = selectedRoles.includes(roleKey)\n                      return (\n                        <label key={roleKey} className=\"flex items-center gap-1.5 text-xs cursor-pointer\">\n                          <input\n                            type=\"checkbox\"\n                            checked={isSelected}\n                            onChange={() => {\n                              setSelectedRoles(prev =>\n                                isSelected ? prev.filter(r => r !== roleKey) : [...prev, roleKey]\n                              )\n                            }}\n                            className=\"accent-accent\"\n                          />\n                          <span className=\"text-foreground-muted font-medium\">{label}</span>\n                        </label>\n                      )\n                    })}\n                  </div>\n                </div>\n              )}\n\n              {newRoomAccess === 'shift' && (\n                <div className=\"space-y-2 bg-surface-container-low p-3 rounded-lg border border-border-subtle\">\n                  <span className=\"text-[10px] font-semibold text-foreground-muted block\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҳГ в•ӘВјв•ӘВәв•Әв–“:</span>\n                  <div className=\"flex gap-4 flex-wrap\">\n                    {['A', 'B', 'C', 'morning', 'evening', 'night'].map((shift) => {\n                      const isSelected = selectedShifts.includes(shift)\n                      return (\n                        <label key={shift} className=\"flex items-center gap-1.5 text-xs cursor-pointer\">\n                          <input\n                            type=\"checkbox\"\n                            checked={isSelected}\n                            onChange={() => {\n                              setSelectedShifts(prev =>\n                                isSelected ? prev.filter(s => s !== shift) : [...prev, shift]\n                              )\n                            }}\n                            className=\"accent-accent\"\n                          />\n                          <span className=\"text-foreground-muted font-medium\">в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ {shift}</span>\n                        </label>\n                      )\n                    })}\n                  </div>\n                </div>\n              )}\n\n              {newRoomAccess === 'manual' && (\n                <div className=\"space-y-2 bg-surface-container-low p-3 rounded-lg border border-border-subtle\">\n                  <span className=\"text-[10px] font-semibold text-foreground-muted block\">в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВјв•ӘВәв•Әв–“:</span>\n                  <div className=\"max-h-32 overflow-y-auto space-y-1.5\">\n                    {mockPersonnel.map((person) => {\n                      const isSelected = selectedUsers.includes(person.name)\n                      return (\n                        <label key={person.id} className=\"flex items-center justify-between text-xs cursor-pointer p-1.5 hover:bg-surface-container rounded-md\">\n                          <div className=\"flex items-center gap-2\">\n                            <input\n                              type=\"checkbox\"\n                              checked={isSelected}\n                              onChange={() => {\n                                setSelectedUsers(prev =>\n                                  isSelected ? prev.filter(u => u !== person.name) : [...prev, person.name]\n                                )\n                              }}\n                              className=\"accent-accent\"\n                            />\n                            <span className=\"text-foreground font-semibold\">{person.name}</span>\n                          </div>\n                          <span className=\"text-[10px] text-foreground-muted font-medium\">{person.role}</span>\n                        </label>\n                      )\n                    })}\n                  </div>\n                </div>\n              )}\n\n              <div className=\"flex gap-3 pt-3 border-t border-border justify-end\">\n                <Button\n                  type=\"button\"\n                  onClick={() => setShowCreateModal(false)}\n                  className=\"bg-transparent border border-border hover:bg-surface-hover text-foreground-muted hover:text-foreground rounded-md h-9 px-4 text-xs font-semibold transition-colors cursor-pointer\"\n                >\n                  в”ҳГӨв•Әв•‘в”ҳГӘ\n                </Button>\n                <Button\n                  type=\"submit\"\n                  disabled={!newRoomName.trim()}\n                  className=\"bg-accent hover:bg-accent-hover text-accent-foreground rounded-md h-9 px-6 text-xs font-bold active:scale-95 transition-all cursor-pointer\"\n                >\n                  в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в•ӘВәв•ӘВ¬в•ӘВәв”ҳГ© в•Әв•Ўв”ҳГӘв•ӘВ¬в–ҲГ®\n                </Button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\comms\\radio\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Button' is defined but never used.","line":4,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":16,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"Button"},"fix":{"range":[66,114],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'toFa' is defined but never used.","line":5,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":14,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"toFa"},"fix":{"range":[114,146],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Volume2' is defined but never used.","line":9,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":10,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Volume2"},"fix":{"range":[170,181],"text":""},"desc":"Remove unused variable \"Volume2\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'VolumeX' is defined but never used.","line":10,"column":3,"no