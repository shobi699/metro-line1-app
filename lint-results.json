ndleSort('hireDate', direction)}\n                              currentSort={sortConfig?.key === 'hireDate' ? sortConfig.direction : null}\n                              searchTerm={columnSearchTerms['hireDate'] || ''}\n                              onSearchChange={(val) => handleColumnSearchChange('hireDate', val)}\n                            />\n                          </div>\n                        </TableHead>\n                        <TableHead className=\"text-start whitespace-nowrap\">\n                          <div className=\"flex items-center gap-1\">\n                            <span>в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»</span>\n                            <ColumnHeaderFilter\n                              columnKey=\"birthDate\"\n                              columnLabel=\"в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»\"\n                              uniqueValues={getUniqueValues('birthDate')}\n                              selectedValues={columnFilters['birthDate'] || []}\n                              onFilterChange={(values) => handleFilterChange('birthDate', values)}\n                              onSort={(direction) => handleSort('birthDate', direction)}\n                              currentSort={sortConfig?.key === 'birthDate' ? sortConfig.direction : null}\n                              searchTerm={columnSearchTerms['birthDate'] || ''}\n                              onSearchChange={(val) => handleColumnSearchChange('birthDate', val)}\n                            />\n                          </div>\n                        </TableHead>\n                        <TableHead className=\"text-start whitespace-nowrap\">\n                          <div className=\"flex items-center gap-1\">\n                            <span>в•Әв”Ӯв”ҳГҘ</span>\n                            <ColumnHeaderFilter\n                              columnKey=\"age\"\n                              columnLabel=\"в•Әв”Ӯв”ҳГҘ\"\n                              uniqueValues={getUniqueValues('age')}\n                              selectedValues={columnFilters['age'] || []}\n                              onFilterChange={(values) => handleFilterChange('age', values)}\n                              onSort={(direction) => handleSort('age', direction)}\n                              currentSort={sortConfig?.key === 'age' ? sortConfig.direction : null}\n                              searchTerm={columnSearchTerms['age'] || ''}\n                              onSearchChange={(val) => handleColumnSearchChange('age', val)}\n                            />\n                          </div>\n                        </TableHead>\n                        <TableHead className=\"text-start whitespace-nowrap\">\n                          <div className=\"flex items-center gap-1\">\n                            <span>в”ҳГ в•ӘВЎв”ҳГӨ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВҝв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’</span>\n                            <ColumnHeaderFilter\n                              columnKey=\"startLocation\"\n                              columnLabel=\"в”ҳГ в•ӘВЎв”ҳГӨ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВҝв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’\"\n                              uniqueValues={getUniqueValues('startLocation')}\n                              selectedValues={columnFilters['startLocation'] || []}\n                              onFilterChange={(values) => handleFilterChange('startLocation', values)}\n                              onSort={(direction) => handleSort('startLocation', direction)}\n                              currentSort={sortConfig?.key === 'startLocation' ? sortConfig.direction : null}\n                              searchTerm={columnSearchTerms['startLocation'] || ''}\n                              onSearchChange={(val) => handleColumnSearchChange('startLocation', val)}\n                            />\n                          </div>\n                        </TableHead>\n                        <TableHead className=\"text-end pl-6 whitespace-nowrap\">в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬</TableHead>\n                      </TableRow>\n                    </TableHeader>\n                    <TableBody className=\"divide-y divide-border/40\">\n                      {filteredAndSortedUsers.map((user) => (\n                        <TableRow\n                          key={user.id}\n                          onClick={() => openUserDetail(user)}\n                          className=\"group border-b border-border/40 hover:bg-surface-hover/35 transition-colors cursor-pointer\"\n                        >\n                          <TableCell className=\"sticky right-0 z-10 bg-surface border-l border-border/40 group-hover:bg-surface-hover transition-colors font-semibold pr-6 text-foreground whitespace-nowrap w-[160px] min-w-[160px] max-w-[160px]\">{user.name}</TableCell>\n                          <TableCell className=\"sticky right-[160px] z-10 bg-surface border-l border-border/40 group-hover:bg-surface-hover transition-colors font-mono text-xs text-foreground/80 whitespace-nowrap w-[120px] min-w-[120px] max-w-[120px]\">\n                            {(() => {\n                              const pNo = getUserFieldValue(user, 'personnelNo')\n                              return pNo ? toFa(String(pNo)) : 'О“ГҮГ¶'\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"font-mono text-xs text-foreground/80 whitespace-nowrap\">{toFa(user.nationalId)}</TableCell>\n                          <TableCell className=\"font-mono text-xs text-foreground/80 whitespace-nowrap\">\n                            {user.phone ? toFa(user.phone) : 'О“ГҮГ¶'}\n                          </TableCell>\n                          <TableCell className=\"font-mono text-xs text-foreground/80 whitespace-nowrap\">\n                            {(() => {\n                              const p2 = getUserFieldValue(user, 'phone2')\n                              return p2 ? toFa(String(p2)) : 'О“ГҮГ¶'\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"text-xs whitespace-nowrap\">\n                            <Badge variant=\"outline\" className=\"border-border/80 text-[10px] bg-surface text-foreground/90 font-medium\">\n                              {String(getUserFieldValue(user, 'post') || user.role?.name || 'в”ҳГјв•ӘВәв”ҳГ©в•ӘВ» в”ҳГҘв”ҳГ©в•Әв”Ө')}\n                            </Badge>\n                          </TableCell>\n                          <TableCell className=\"text-xs whitespace-nowrap\">\n                            {(() => {\n                              const shiftVal = getUserFieldValue(user, 'shift')\n                              if (!shiftVal) return 'О“ГҮГ¶'\n                              return (\n                                <Badge variant=\"outline\" className={cn(\n                                  \"text-[9px] font-bold border\",\n                                  shiftVal === 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®' && \"bg-purple-500/5 text-purple-400 border-purple-500/20\",\n                                  shiftVal === 'A' && \"bg-success/5 text-success border-success/20\",\n                                  shiftVal === 'B' && \"bg-info/5 text-info border-info/20\",\n                                  shiftVal === 'C' && \"bg-amber-500/5 text-amber-400 border-amber-500/20\"\n                                )}>\n                                  {String(shiftVal)}\n                                </Badge>\n                              )\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"text-xs whitespace-nowrap\">\n                            {String(getUserFieldValue(user, 'shiftType') || 'О“ГҮГ¶')}\n                          </TableCell>\n                          <TableCell className=\"text-xs whitespace-nowrap\">\n                            {(() => {\n                              const cert = getColumnValue(user, 'certificate')\n                              if (!cert || cert === 'в”ҳГјв•ӘВәв”ҳГ©в•ӘВ» в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§') return <span className=\"text-foreground-muted\">в”ҳГјв•ӘВәв”ҳГ©в•ӘВ» в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</span>\n                              return (\n                                <Badge variant=\"secondary\" className=\"text-[9px] bg-indigo-500/10 text-indigo-400 border-indigo-500/20\">\n                                  {String(cert)}\n                                </Badge>\n                              )\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"text-xs whitespace-nowrap\">\n                            {(() => {\n                              const groupVal = getUserFieldValue(user, 'group')\n                              if (!groupVal) return 'О“ГҮГ¶'\n                              return (\n                                <Badge variant=\"outline\" className={cn(\n                                  \"text-[9px] font-bold border\",\n                                  groupVal === 'Staff' && \"bg-purple-500/5 text-purple-400 border-purple-500/20\",\n                                  groupVal === 'A' && \"bg-success/5 text-success border-success/20\",\n                                  groupVal === 'B' && \"bg-info/5 text-info border-info/20\",\n                                  groupVal === 'C' && \"bg-amber-500/5 text-amber-400 border-amber-500/20\"\n                                )}>\n                                  {groupVal === 'Staff' ? 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®' : `в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ ${groupVal}`}\n                                </Badge>\n                              )\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"whitespace-nowrap\">\n                            <Badge\n                              className={`border text-[9px] px-2 py-0.5 rounded-full font-medium ${statusLabels[user.status]?.color || ''\n                                }`}\n                            >\n                              {statusLabels[user.status]?.text || user.status}\n                            </Badge>\n                          </TableCell>\n                          <TableCell className=\"text-xs text-foreground-muted whitespace-nowrap\">\n                            {(() => {\n                              const hDate = getUserFieldValue(user, 'hireDate')\n                              return hDate ? toFa(String(hDate)) : 'О“ГҮГ¶'\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"text-xs text-foreground-muted whitespace-nowrap\">\n                            {(() => {\n                              const bDate = getUserFieldValue(user, 'birthDate')\n                              return bDate ? toFa(String(bDate)) : 'О“ГҮГ¶'\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"font-mono text-xs text-foreground/80 whitespace-nowrap\">\n                            {(() => {\n                              const bDate = getUserFieldValue(user, 'birthDate')\n                              return bDate ? toFa(calculateAge(String(bDate))) : 'О“ГҮГ¶'\n                            })()}\n                          </TableCell>\n                          <TableCell className=\"text-xs whitespace-nowrap\">\n                            {String(getUserFieldValue(user, 'startLocation') || getUserFieldValue(user, 'station') || 'О“ГҮГ¶')}\n                          </TableCell>\n                          <TableCell className=\"text-end pl-6 whitespace-nowrap\" onClick={(e) => e.stopPropagation()}>\n                            <div className=\"flex items-center justify-end gap-1.5\">\n                              {user.status === 'pending' && (\n                                <Button\n                                  size=\"sm\"\n                                  variant=\"outline\"\n                                  onClick={() => handleApprove(user.id)}\n                                  disabled={actionLoading}\n                                  className=\"h-8 border-success/30 bg-success/5 text-success hover:bg-success/15 hover:border-success/60 flex items-center gap-1 cursor-pointer text-[11px] font-bold shadow-sm transition-all animate-pulse\"\n                                >\n                                  <UserCheck className=\"size-3.5\" />\n                                  в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв•Јв•Әв•ўв”ҳГӘв–ҲГ®в•ӘВ¬\n                                </Button>\n                              )}\n                              <Button\n                                size=\"icon-sm\"\n                                variant=\"ghost\"\n                                onClick={() => openUserDetail(user)}\n                                title=\"в•ӘВјв•Әв–“в•ӘВӘв–ҲГ®в•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§\"\n                                className=\"border border-border/40 hover:border-accent/30 text-foreground-muted hover:text-accent hover:bg-accent/5 rounded-lg cursor-pointer h-8 w-8 transition-all duration-200 shadow-sm\"\n                              >\n                                <Eye className=\"size-3.5\" />\n                              </Button>\n                              <Button\n                                size=\"icon-sm\"\n                                variant=\"ghost\"\n                                onClick={() => openEditUserModal(user)}\n                                title=\"в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’\"\n                                className=\"border border-border/40 hover:border-accent/30 text-foreground-muted hover:text-accent hover:bg-accent/5 rounded-lg cursor-pointer h-8 w-8 transition-all duration-200 shadow-sm\"\n                              >\n                                <Edit2 className=\"size-3.5\" />\n                              </Button>\n                              {user.id !== sessionUser?.id && (\n                                <Button\n                                  size=\"icon-sm\"\n                                  variant=\"ghost\"\n                                  onClick={() => handleDeleteUser(user.id)}\n                                  title=\"в•ӘВЎв•Әв–‘в”ҳГј в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’\"\n                                  disabled={actionLoading}\n                                  className=\"border border-border/40 hover:border-critical/30 text-foreground-muted hover:text-critical hover:bg-critical/5 rounded-lg cursor-pointer h-8 w-8 transition-all duration-200 shadow-sm\"\n                                >\n                                  <Trash2 className=\"size-3.5\" />\n                                </Button>\n                              )}\n                            </div>\n                          </TableCell>\n                        </TableRow>\n                      ))}\n                    </TableBody>\n                  </Table>\n              )}\n            </CardContent>\n          </Card>\n        </div>\n      )}\n\n      {activeTab === 'roles' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 animate-in fade-in duration-300\">\n          {/* Roles List Panel */}\n          <Card className=\"border border-border bg-surface/50 shadow-md h-fit overflow-hidden\">\n            <CardHeader className=\"border-b border-border/50 bg-surface/30\">\n              <CardTitle className=\"text-base font-semibold\">в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә</CardTitle>\n              <CardDescription className=\"text-xs\">\n                в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҳГҘв”ҳГ©в•Әв”Ө в•ӘВјв”ҳГ§в•ӘВ¬ в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в”ҳГ§в•ӘВә в–ҲГ®в•ӘВә в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•Әв”Ӯв•Әв•–в•ӘВЎв–ҲГ®\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"p-2 flex flex-col gap-1.5 max-h-[60vh] overflow-y-auto\">\n              {loadingRoles ? (\n                <div className=\"flex flex-col items-center justify-center p-8 gap-2\">\n                  <Loader2 className=\"size-6 animate-spin text-accent\" />\n                  <span className=\"text-xs text-foreground-muted\">в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә...</span>\n                </div>\n              ) : roles.length === 0 ? (\n                <div className=\"p-4 text-center text-xs text-foreground-muted\">в”ҳГҘв”ҳГ©в•Әв”Өв–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».</div>\n              ) : (\n                roles.map((r) => {\n                  const active = selectedRole?.id === r.id\n                  return (\n                    <div\n                      key={r.id}\n                      onClick={() => selectRoleItem(r)}\n                      className={`flex items-center justify-between px-3 py-3 rounded-lg border text-sm font-medium transition-all cursor-pointer ${active\n                          ? 'bg-accent/15 border-accent text-accent font-bold'\n                          : 'border-border/60 hover:bg-surface-hover/30 hover:border-border text-foreground-muted hover:text-foreground'\n                        }`}\n                    >\n                      <div className=\"flex flex-col gap-0.5\">\n                        <span className=\"text-start\">{r.name}</span>\n                        <span className=\"text-[10px] text-foreground-muted/60 font-mono tracking-tight text-start dir-ltr\">\n                          {r.key}\n                        </span>\n                      </div>\n                      <div className=\"flex items-center gap-2\">\n                        <Badge variant=\"outline\" className=\"text-[10px] px-2 py-0 border-border bg-surface font-semibold text-foreground/80\">\n                          {toFa(r._count?.users || 0)} в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’\n                        </Badge>\n                        {!r.isSystem && (\n                          <Button\n                            size=\"icon-sm\"\n                            variant=\"ghost\"\n                            onClick={(e) => {\n                              e.stopPropagation()\n                              handleDeleteRole(r)\n                            }}\n                            className=\"text-foreground-muted/60 hover:text-critical hover:bg-critical/5 rounded cursor-pointer h-7 w-7\"\n                          >\n                            <X className=\"size-3.5\" />\n                          </Button>\n                        )}\n                      </div>\n                    </div>\n                  )\n                })\n              )}\n            </CardContent>\n          </Card>\n\n          {/* Permissions Matrix Panel */}\n          {selectedRole ? (\n            <Card className=\"border border-border bg-surface/50 shadow-md lg:col-span-2 overflow-hidden\">\n              <CardHeader className=\"border-b border-border/50 bg-surface/30 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 py-4\">\n                <div>\n                  <CardTitle className=\"text-base font-semibold flex items-center gap-1.5\">\n                    <span>в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ  в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө:</span>\n                    <span className=\"text-accent font-bold\">{selectedRole.name}</span>\n                  </CardTitle>\n                  <CardDescription className=\"text-xs mt-0.5\">\n                    в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’в•ӘВәв•ӘВ¬ в•ӘВҝв”ҳГ§ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в•ӘГів”ҳГҘв–ҲГ® в•ӘВ»в•Әв–’ в”ҢвҢҗв”ҳГӨ в•Әв”Ӯв•ӘВәв”ҳГ в•ӘВәв”ҳГҘв”ҳГ§ в•ӘВәв•Әв•Јв”ҳГ в•ӘВәв”ҳГӨ в”ҳГӘ в”ҳГӨв•ӘВәв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГ в”ҳГҘв–ҲГ®в•ӘВ¬в–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГ в–ҲГ®О“ГҮГ®в”ҢВ»в•Әв–’в•ӘВ»в•ӘВ».\n                  </CardDescription>\n                </div>\n                <div className=\"flex items-center gap-2 self-end sm:self-auto\">\n                  <Button\n                    onClick={handleSavePermissions}\n                    disabled={actionLoading}\n                    className=\"bg-accent hover:bg-accent-hover text-accent-foreground font-semibold px-4 h-9 text-xs rounded-lg cursor-pointer flex items-center gap-1.5 shadow\"\n                  >\n                    {actionLoading ? (\n                      <Loader2 className=\"size-3.5 animate-spin\" />\n                    ) : (\n                      <CheckCircle className=\"size-3.5\" />\n                    )}\n                    в•Әв–‘в•ӘВ«в–ҲГ®в•Әв–’в”ҳГ§ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в”ҳГ§в•ӘВә\n                  </Button>\n                </div>\n              </CardHeader>\n\n              {/* Permission live search */}\n              <div className=\"px-4 pt-4 border-b border-border/30\">\n                <div className=\"relative\">\n                  <Search className=\"absolute start-3 top-2.5 size-4 text-foreground-muted\" />\n                  <Input\n                    type=\"text\"\n                    placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в•ӘВ»в•Әв–’ в”ҳГҘв•ӘВәв”ҳГ  в–ҲГ®в•ӘВә в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ» в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в”ҳГ§в•ӘВә...\"\n                    value={permissionSearch}\n                    onChange={(e) => setPermissionSearch(e.target.value)}\n                    className=\"ps-9 h-9 bg-background/30 text-xs focus-visible:ring-accent border-border/70\"\n                  />\n                </div>\n              </div>\n\n              <CardContent className=\"p-4 md:p-6 max-h-[70vh] overflow-y-auto space-y-6\">\n                {filteredCatalog.map((group) => {\n                  const groupKeys = group.permissions.map((p) => p.key)\n                  const allSelectedInGroup = groupKeys.every((k) => rolePermissions.includes(k))\n\n                  return (\n                    <div key={group.resource} className=\"border border-border/60 rounded-xl bg-surface/20 p-4 transition-all hover:border-border\">\n                      <div className=\"flex items-center justify-between border-b border-border/30 pb-2.5 mb-3.5\">\n                        <h3 className=\"text-sm font-bold text-foreground flex items-center gap-1.5\">\n                          <span className=\"size-1.5 rounded-full bg-accent animate-pulse\"></span>\n                          <span>в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в”ҳГ в•ӘВәв”ҢГҝв”ҳГӘв”ҳГӨ {group.label}</span>\n                        </h3>\n\n                        {/* Bulk Select Toggles */}\n                        <Button\n                          variant=\"outline\"\n                          size=\"sm\"\n                          onClick={() => handleToggleAllInGroup(groupKeys, allSelectedInGroup)}\n                          className=\"text-[10px] h-6 px-2.5 border-border/80 hover:bg-surface-hover text-foreground-muted hover:text-foreground cursor-pointer font-semibold\"\n                        >\n                          {allSelectedInGroup ? 'в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в”ҳГ§в”ҳГ в”ҳГ§' : 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в”ҳГ§в”ҳГ в”ҳГ§'}\n                        </Button>\n                      </div>\n\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3\">\n                        {group.permissions.map((perm) => {\n                          const checked = rolePermissions.includes(perm.key)\n                          return (\n                            <label\n                              key={perm.key}\n                              className={`flex items-center gap-2.5 p-2 rounded-lg border cursor-pointer select-none transition-all text-xs ${checked\n                                  ? 'bg-accent/5 border-accent/40 text-foreground shadow-sm font-medium'\n                                  : 'border-border/50 hover:bg-surface-hover/30 text-foreground-muted'\n                                }`}\n                            >\n                              <input\n                                type=\"checkbox\"\n                                checked={checked}\n                                onChange={() => handlePermissionToggle(perm.key)}\n                                className=\"accent-accent size-3.5 rounded border-border\"\n                              />\n                              <div className=\"flex flex-col gap-0.5\">\n                                <span className=\"font-semibold text-start\">{perm.label}</span>\n                                <span className=\"text-[9px] font-mono text-foreground-muted/70 tracking-tight dir-ltr text-start\">\n                                  {perm.key}\n                                </span>\n                              </div>\n                            </label>\n                          )\n                        })}\n                      </div>\n                    </div>\n                  )\n                })}\n                {filteredCatalog.length === 0 && (\n                  <div className=\"p-8 text-center text-xs text-foreground-muted\">\n                    в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в–ҲГ® в”ҳГ в”ҳГҘв•Әв•–в•ӘВҝв”ҳГ© в•ӘВҝв•ӘВә в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘв–ҲГ® в•Әв”Өв”ҳГ в•ӘВә в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ».\n                  </div>\n                )}\n              </CardContent>\n            </Card>\n          ) : (\n            <Card className=\"border border-border bg-surface/50 shadow-md lg:col-span-2 flex items-center justify-center p-12 text-center h-fit\">\n              <div className=\"flex flex-col items-center gap-2\">\n                <Shield className=\"size-12 text-foreground-muted/40\" />\n                <span className=\"text-sm text-foreground-muted\">в–ҲГ®в”ҢвҢҗ в”ҳГҘв”ҳГ©в•Әв”Ө в•Әв–’в•ӘВә в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в”ҳГ§в•ӘВә в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».</span>\n              </div>\n            </Card>\n          )}\n        </div>\n      )}\n\n      {activeTab === 'fields' && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 animate-in fade-in duration-300\">\n          {/* Create Field Definition Dialog / Left Form */}\n          <Card className=\"border border-border bg-surface/50 shadow-md h-fit overflow-hidden\">\n            <CardHeader className=\"border-b border-border/50 bg-surface/30\">\n              <CardTitle className=\"text-base font-semibold flex items-center gap-1\">\n                <Settings className=\"size-4 text-accent\" />\n                <span>в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ® в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</span>\n              </CardTitle>\n              <CardDescription className=\"text-xs\">\n                в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ»в”ҳГӨв•ӘВ«в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в”ҢвҢҗв”ҳГ§ в•ӘВ¬в”ҳГ в•ӘВәв–ҲГ®в”ҳГӨ в•ӘВ»в•ӘВәв•Әв–’в–ҲГ®в•ӘВ» в•ӘВ»в•Әв–’ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГӘ в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в•ӘВ»в•ӘВәв•Әв”Өв•ӘВ¬в”ҳГ§ в•ӘВҝв•ӘВәв•Әв”Өв–ҲГ®в•ӘВ»\n              </CardDescription>\n            </CardHeader>\n            <CardContent className=\"p-4\">\n              <form onSubmit={handleCreateField} className=\"space-y-4\">\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"fieldName\" className=\"text-xs font-semibold text-foreground\">\n                    в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» (в”ҳГҘв•ӘВәв”ҳГ  в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ®)\n                  </Label>\n                  <Input\n                    id=\"fieldName\"\n                    required\n                    placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: station_name\"\n                    value={fieldName}\n                    onChange={(e) => setFieldName(e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                  />\n                  <span className=\"text-[10px] text-foreground-muted\">\n                    в”ҳГјв”ҳГ©в•Әв•– в•ӘВЎв•Әв–’в”ҳГӘв”ҳГј в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ® в”ҢвҢҗв”ҳГӘв”ҢГҘв”ҢвҢҗ в”ҳГӘ в•ӘВ«в•Әв•– в•ӘВ¬в–ҲГ®в•Әв–’в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в–ҲГ®в”ҳГҘ (в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: car_plate_no)\n                  </span>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"fieldLabel\" className=\"text-xs font-semibold text-foreground\">\n                    в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» (в•ӘВҝв•Әв–’в”ҢГҘв•Әв”Ӯв•ӘВҝ)\n                  </Label>\n                  <Input\n                    id=\"fieldLabel\"\n                    required\n                    placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в”ҳГ в•ӘВЎв”ҳГӨ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬\"\n                    value={fieldLabel}\n                    onChange={(e) => setFieldLabel(e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"fieldType\" className=\"text-xs font-semibold text-foreground\">\n                    в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»\n                  </Label>\n                  <select\n                    id=\"fieldType\"\n                    value={fieldType}\n                    onChange={(e) => setFieldType(e.target.value as any)}\n                    className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                  >\n                    <option value=\"text\">в”ҳГ в•ӘВ¬в”ҳГҘ (в–ҲГ®в”ҢвҢҗ в•ӘВ«в•Әв•–в–ҲГ®)</option>\n                    <option value=\"number\">в•Әв•Јв•ӘВ»в•ӘВ»</option>\n                    <option value=\"select\">в”ҳГ в”ҳГҘв”ҳГӘв–ҲГ® в”ҢвҢҗв•Әв”Өв”ҳГӘв–ҲГ®в–ҲГ® (в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝв–ҲГ®)</option>\n                    <option value=\"date\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•Әв”Өв”ҳГ в•Әв”Ӯв–ҲГ®</option>\n                    <option value=\"boolean\">в•ӘВ¬в–ҲГ®в”ҢвҢҗО“ГҮГ®в•ӘВҝв•ӘВәв”ҢвҢҗв•Әв”Ӯ (в•ӘВҝв”ҳГӨв”ҳГ§/в•ӘВ«в–ҲГ®в•Әв–’)</option>\n                  </select>\n                </div>\n\n                {fieldType === 'select' && (\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"fieldOptionsRaw\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГҘв”ҳГӘ (в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВәв”ҳГ в•ӘВә в•ӘВјв•ӘВ»в•ӘВә в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»)\n                    </Label>\n                    <Input\n                      id=\"fieldOptionsRaw\"\n                      required\n                      placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Өв•ӘГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗв•ӘГ® в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ®\"\n                      value={fieldOptionsRaw}\n                      onChange={(e) => setFieldOptionsRaw(e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border\"\n                    />\n                  </div>\n                )}\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"fieldDefaultValue\" className=\"text-xs font-semibold text-foreground flex justify-start\">\n                    в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)\n                  </Label>\n                  {fieldType === 'boolean' ? (\n                    <select\n                      id=\"fieldDefaultValue\"\n                      value={fieldDefaultValue}\n                      onChange={(e) => setFieldDefaultValue(e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      <option value=\"\">в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў</option>\n                      <option value=\"true\">в•ӘВҝв”ҳГӨв”ҳГ§ (True)</option>\n                      <option value=\"false\">в•ӘВ«в–ҲГ®в•Әв–’ (False)</option>\n                    </select>\n                  ) : fieldType === 'select' ? (\n                    <select\n                      id=\"fieldDefaultValue\"\n                      value={fieldDefaultValue}\n                      onChange={(e) => setFieldDefaultValue(e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      <option value=\"\">в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў</option>\n                      {fieldOptionsRaw.split(',').map((o) => o.trim()).filter((o) => o.length > 0).map((opt) => (\n                        <option key={opt} value={opt}>{opt}</option>\n                      ))}\n                    </select>\n                  ) : fieldType === 'date' ? (\n                    <Input\n                      id=\"fieldDefaultValue\"\n                      placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв–’/в–Ҳв–‘в–Ҳв–’\"\n                      value={fieldDefaultValue}\n                      onChange={(e) => setFieldDefaultValue(e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  ) : (\n                    <Input\n                      id=\"fieldDefaultValue\"\n                      type={fieldType === 'number' ? 'number' : 'text'}\n                      placeholder=\"в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»...\"\n                      value={fieldDefaultValue}\n                      onChange={(e) => setFieldDefaultValue(e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border text-start\"\n                    />\n                  )}\n                </div>\n\n                <div className=\"flex items-center gap-2 pt-1\">\n                  <input\n                    type=\"checkbox\"\n                    id=\"fieldRequired\"\n                    checked={fieldRequired}\n                    onChange={(e) => setFieldRequired(e.target.checked)}\n                    className=\"accent-accent size-4 rounded\"\n                  />\n                  <Label htmlFor=\"fieldRequired\" className=\"text-xs font-semibold text-foreground cursor-pointer select-none\">\n                    в”ҳв•ӣв•Әв–’ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬\n                  </Label>\n                </div>\n\n                <Button\n                  type=\"submit\"\n                  disabled={actionLoading}\n                  className=\"w-full bg-accent hover:bg-accent-hover text-accent-foreground font-semibold px-4 h-10 rounded-lg cursor-pointer flex items-center justify-center gap-1.5\"\n                >\n                  {actionLoading ? <Loader2 className=\"size-4 animate-spin\" /> : <Plus className=\"size-4\" />}\n                  в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВә\n                </Button>\n              </form>\n            </CardContent>\n          </Card>\n\n          {/* Fields List Panel / Right Table */}\n          <Card className=\"border border-border bg-surface/50 shadow-md lg:col-span-2 overflow-hidden\">\n            <CardHeader className=\"border-b border-border/50 bg-surface/30 flex flex-row justify-between items-center flex-wrap gap-4\">\n              <div>\n                <CardTitle className=\"text-base font-semibold\">в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ® в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</CardTitle>\n                <CardDescription className=\"text-xs\">\n                  в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ  в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв”ҳГјв•ӘВәв•Әв–’в•Әв”Өв–ҲГ® в”ҢвҢҗв”ҳГ§ в•ӘВҝв”ҳГ§ в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВ¬в•Әв•Ўв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳГӘ в•ӘВ»в•Әв–’ в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’ в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГҘв”ҳГ в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§ в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв”ҳГҘв•ӘВ».\n                </CardDescription>\n              </div>\n              <Button\n                variant=\"outline\"\n                size=\"sm\"\n                onClick={handleCreateDefaultRosterFields}\n                disabled={actionLoading}\n                className=\"text-[11px] h-8 font-bold border-accent/30 text-accent hover:bg-accent/5 cursor-pointer flex items-center gap-1.5\"\n              >\n                <Sparkles className=\"size-3.5\" />\n                в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’\n              </Button>\n            </CardHeader>\n            <CardContent className=\"p-0\">\n              {loadingFields ? (\n                <div className=\"flex flex-col items-center justify-center p-12 gap-2\">\n                  <Loader2 className=\"size-8 animate-spin text-accent\" />\n                  <span className=\"text-sm text-foreground-muted\">в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВә...</span>\n                </div>\n              ) : customFieldDefs.length === 0 ? (\n                <div className=\"p-8 text-center text-sm text-foreground-muted\">\n                  в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ®в–ҲГ® в•ӘВ»в•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n                </div>\n              ) : (\n                <Table>\n                  <TableHeader className=\"bg-surface/30\">\n                    <TableRow className=\"border-b border-border/60 hover:bg-transparent\">\n                      <TableHead className=\"text-start pr-6\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ®</TableHead>\n                      <TableHead className=\"text-start\">в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ®</TableHead>\n                      <TableHead className=\"text-start\">в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»в–ҲГ®</TableHead>\n                      <TableHead className=\"text-start\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬</TableHead>\n                      <TableHead className=\"text-start\">в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝв–ҲГ®</TableHead>\n                      <TableHead className=\"text-start\">в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў</TableHead>\n                      <TableHead className=\"text-end pl-6\">в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬</TableHead>\n                    </TableRow>\n                  </TableHeader>\n                  <TableBody className=\"divide-y divide-border/40\">\n                    {customFieldDefs.map((field) => {\n                      let optionsList: string[] = []\n                      if (field.options) {\n                        optionsList = typeof field.options === 'string'\n                          ? JSON.parse(field.options)\n                          : field.options\n                      }\n                      return (\n                        <TableRow\n                          key={field.id}\n                          className=\"border-b border-border/40 hover:bg-surface-hover/30 transition-colors\"\n                        >\n                          <TableCell className=\"font-semibold pr-6 text-foreground\">{field.label}</TableCell>\n                          <TableCell className=\"font-mono text-xs text-foreground-muted\">{field.name}</TableCell>\n                          <TableCell className=\"text-xs text-foreground/80\">{fieldTypeLabels[field.type]}</TableCell>\n                          <TableCell>\n                            <Badge variant={field.required ? 'default' : 'outline'} className=\"text-[10px] px-2 py-0.5 rounded-full font-medium\">\n                              {field.required ? 'в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ®' : 'в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®'}\n                            </Badge>\n                          </TableCell>\n                          <TableCell className=\"text-xs text-foreground-muted max-w-[150px] truncate\">\n                            {optionsList.length > 0 ? optionsList.join('в•ӘГ® ') : 'О“ГҮГ¶'}\n                          </TableCell>\n                          <TableCell className=\"text-xs font-mono text-foreground/80\">\n                            {field.defaultValue === 'true' ? 'в•ӘВҝв”ҳГӨв”ҳГ§' : field.defaultValue === 'false' ? 'в•ӘВ«в–ҲГ®в•Әв–’' : field.defaultValue || 'О“ГҮГ¶'}\n                          </TableCell>\n                          <TableCell className=\"text-end pl-6\">\n                            <Button\n                              size=\"icon-sm\"\n                              variant=\"ghost\"\n                              onClick={() => openEditFieldModal(field)}\n                              title=\"в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»\"\n                              disabled={actionLoading}\n                              className=\"text-foreground-muted hover:text-accent hover:bg-accent/5 rounded-md cursor-pointer me-1\"\n                            >\n                              <Edit2 className=\"size-3.5\" />\n                            </Button>\n                            <Button\n                              size=\"icon-sm\"\n                              variant=\"ghost\"\n                              onClick={() => handleDeleteField(field.id)}\n                              title=\"в•ӘВЎв•Әв–‘в”ҳГј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»\"\n                              disabled={actionLoading}\n                              className=\"text-foreground-muted hover:text-critical hover:bg-critical/5 rounded-md cursor-pointer\"\n                            >\n                              <Trash2 className=\"size-3.5\" />\n                            </Button>\n                          </TableCell>\n                        </TableRow>\n                      )\n                    })}\n                  </TableBody>\n                </Table>\n              )}\n            </CardContent>\n          </Card>\n        </div>\n      )}\n\n      {/* Tab: System Activity Logs */}\n      {activeTab === 'audit_logs' && (\n        <div className=\"flex flex-col gap-5 animate-in fade-in duration-300\">\n          {/* Filters Bar */}\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4 bg-surface/40 p-4 rounded-xl border border-border\">\n            <div className=\"relative\">\n              <Search className=\"absolute start-3 top-2.5 size-4 text-foreground-muted\" />\n              <Input\n                type=\"text\"\n                placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘв–ҲГ® в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ О“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§ в–ҲГ®в•ӘВә в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в”ҳГ§в•ӘВ»в”ҳГј...\"\n                value={auditLogSearch}\n                onChange={(e) => setAuditLogSearch(e.target.value)}\n                className=\"ps-9 h-10 bg-background/50 text-sm focus-visible:ring-accent border-border\"\n              />\n            </div>\n            <div>\n              <select\n                value={auditLogAction}\n                onChange={(e) => setAuditLogAction(e.target.value)}\n                className=\"w-full h-10 rounded-lg border border-border bg-background/50 px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n              >\n                <option value=\"\">в”ҳГ§в”ҳГ в”ҳГ§ в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә</option>\n                <option value=\"create\">в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» (Create)</option>\n                <option value=\"update\">в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө (Update)</option>\n                <option value=\"delete\">в•ӘВЎв•Әв–‘в”ҳГј (Delete)</option>\n                <option value=\"login\">в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» (Login)</option>\n                <option value=\"logout\">в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј (Logout)</option>\n                <option value=\"import\">в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ (Import)</option>\n                <option value=\"export\">в•ӘВ«в•Әв–’в”ҳГӘв•ӘВјв–ҲГ® в•ӘВәв”ҢвҢҗв•Әв”Ӯв”ҳГӨ (Export)</option>\n              </select>\n            </div>\n            <div>\n              <select\n                value={auditLogEntity}\n                onChange={(e) => setAuditLogEntity(e.target.value)}\n                className=\"w-full h-10 rounded-lg border border-border bg-background/50 px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n              >\n                <option value=\"\">в”ҳГ§в”ҳГ в”ҳГ§ в”ҳГ в•ӘВәв”ҢГҝв”ҳГӘв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВә</option>\n                <option value=\"User\">в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ (User)</option>\n                <option value=\"Role\">в”ҳГҘв”ҳГ©в•Әв”ӨО“ГҮГ®в”ҳГ§в•ӘВә (Role)</option>\n                <option value=\"Setting\">в•ӘВ¬в”ҳГҘв•Әв••в–ҲГ®в”ҳГ в•ӘВәв•ӘВ¬ (Setting)</option>\n                <option value=\"Shift\">в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә (Shift)</option>\n                <option value=\"SafetyBulletin\">в•ӘВҝв•ӘВ«в•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә (SafetyBulletin)</option>\n                <option value=\"Ticket\">в•ӘВ¬в–ҲГ®в”ҢвҢҗв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә (Ticket)</option>\n              </select>\n            </div>\n          </div>\n\n          {/* Audit Logs Table */}\n          <Card className=\"border border-border bg-surface/50 backdrop-blur-sm shadow-md overflow-hidden\">\n            <CardContent className=\"p-0\">\n              {loadingGlobalAuditLogs ? (\n                <div className=\"flex flex-col items-center justify-center p-12 gap-3\">\n                  <Loader2 className=\"size-8 animate-spin text-accent\" />\n                  <span className=\"text-sm text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГӨв•ӘВәв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГ в–ҲГ®в•Әв–“в–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ ...</span>\n                </div>\n              ) : globalAuditLogs.length === 0 ? (\n                <div className=\"flex flex-col items-center justify-center p-12 text-center\">\n                  <Database className=\"size-12 text-foreground-muted/40 mb-3\" />\n                  <span className=\"text-sm text-foreground-muted\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГӨв•ӘВәв”ҢВ» в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬в–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</span>\n                </div>\n              ) : (\n                <Table>\n                  <TableHeader className=\"bg-surface/30\">\n                    <TableRow className=\"border-b border-border/60 hover:bg-transparent\">\n                      <TableHead className=\"text-start pr-6\">в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВәв”ҳГ©в•ӘВ»в•ӘВәв”ҳГ О“ГҮГ®в”ҢвҢҗв”ҳГҘв”ҳГҘв•ӘВ»в”ҳГ§</TableHead>\n                      <TableHead className=\"text-start\">в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬</TableHead>\n                      <TableHead className=\"text-start\">в•ӘВҝв•ӘВ«в•Әв”Ө в”ҳГ в•Әв–’в•ӘВҝв”ҳГӘв•Әв•–в”ҳГ§</TableHead>\n                      <TableHead className=\"text-start\">в•ӘВ¬в”ҳГӘв•Әв•ўв–ҲГ®в•ӘВЎв•ӘВәв•ӘВ¬ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»</TableHead>\n                      <TableHead className=\"text-start\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в”ҳГӘ в•Әв–“в”ҳГ в•ӘВәв”ҳГҘ в”ҳГӘв”ҳГ©в”ҳГӘв•Әв•Ј</TableHead>\n                    </TableRow>\n                  </TableHeader>\n                  <TableBody className=\"divide-y divide-border/40\">\n                    {globalAuditLogs.map((log) => {\n                      // Color schemes for action badges\n                      let badgeStyle = 'border-border bg-surface/50 text-foreground-muted'\n                      switch (log.action) {\n                        case 'create': badgeStyle = 'border-success/30 bg-success/10 text-success'\n                          break\n                        case 'update': badgeStyle = 'border-warning/30 bg-warning/10 text-warning'\n                          break\n                        case 'delete': badgeStyle = 'border-critical/30 bg-critical/10 text-critical'\n                          break\n                        case 'login':\n                        case 'logout': badgeStyle = 'border-accent/30 bg-accent/10 text-accent'\n                          break\n                        case 'import':\n                        case 'export': badgeStyle = 'border-purple-500/30 bg-purple-500/10 text-purple-400'\n                          break\n                      }\n\n                      return (\n                        <TableRow\n                          key={log.id}\n                          className=\"border-b border-border/40 hover:bg-surface-hover/20 transition-colors\"\n                        >\n                          <TableCell className=\"font-semibold pr-6\">\n                            <div className=\"flex flex-col gap-0.5\">\n                              <span className=\"text-foreground\">{log.actor?.name || 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ '}</span>\n                              <span className=\"text-[10px] text-foreground-muted/60 font-mono tracking-tight text-start\">\n                                в”ҢвҢҗв•ӘВ»в”ҳГ в”ҳГӨв–ҲГ®: {log.actor?.nationalId ? toFa(log.actor.nationalId) : 'О“ГҮГ¶'}\n                              </span>\n                            </div>\n                          </TableCell>\n                          <TableCell>\n                            <Badge variant=\"outline\" className={`text-[10px] px-2.5 py-0.5 font-bold ${badgeStyle}`}>\n                              {log.action}\n                            </Badge>\n                          </TableCell>\n                          <TableCell className=\"text-xs font-semibold text-foreground/80\">{log.entity}</TableCell>\n                          <TableCell className=\"text-xs text-foreground/90 font-medium leading-relaxed max-w-[300px]\">\n                            {getAuditLogDescription(log)}\n                          </TableCell>\n                          <TableCell className=\"text-xs text-foreground-muted font-mono whitespace-nowrap\">\n                            {jalali(log.createdAt)}\n                          </TableCell>\n                        </TableRow>\n                      )\n                    })}\n                  </TableBody>\n                </Table>\n              )}\n            </CardContent>\n          </Card>\n        </div>\n      )}\n\n      {/* User Details Slide-over Drawer (Sheet) */}\n      <Sheet open={detailDrawerOpen} onOpenChange={setDetailDrawerOpen}>\n        <SheetContent className=\"w-full sm:max-w-lg overflow-y-auto border-s border-border/80 bg-surface/90 backdrop-blur-md p-0 flex flex-col h-full\" side=\"left\" dir=\"rtl\">\n          {selectedUserForDetail && (\n            <div className=\"flex flex-col h-full\">\n              {/* Colored Brand Top Border */}\n              <div className=\"h-1 bg-accent w-full\"></div>\n\n              {/* Drawer Header Profile Box */}\n              <div className=\"p-6 border-b border-border/50 bg-gradient-to-b from-surface/50 to-surface-hover/20 flex flex-col items-center text-center relative\">\n                <button\n                  type=\"button\"\n                  onClick={() => setDetailDrawerOpen(false)}\n                  className=\"absolute left-4 top-4 text-foreground-muted hover:text-foreground hover:bg-surface/50 p-1.5 rounded-full transition-colors cursor-pointer\"\n                >\n                  <X className=\"size-4\" />\n                </button>\n\n                <div className=\"w-16 h-16 rounded-full bg-accent/10 border-2 border-accent/40 flex items-center justify-center mb-3 text-accent font-bold text-xl shadow-inner\">\n                  {selectedUserForDetail.name.slice(0, 2)}\n                </div>\n\n                <h2 className=\"text-base font-bold text-foreground\">{selectedUserForDetail.name}</h2>\n                <p className=\"text-[10px] text-foreground-muted mt-1 font-mono tracking-wide\">\n                  в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§: {selectedUserForDetail.id}\n                </p>\n\n                <div className=\"flex items-center gap-2 mt-3\">\n                  <Badge variant=\"outline\" className=\"border-accent/30 bg-accent/5 text-accent font-bold text-[10px] py-0.5 px-2.5\">\n                    {selectedUserForDetail.role?.name || 'в”ҳГјв•ӘВәв”ҳГ©в•ӘВ» в”ҳГҘв”ҳГ©в•Әв”Ө'}\n                  </Badge>\n                  <Badge className={`border text-[10px] font-semibold py-0.5 px-2.5 rounded-full ${statusLabels[selectedUserForDetail.status]?.color}`}>\n                    {statusLabels[selectedUserForDetail.status]?.text || selectedUserForDetail.status}\n                  </Badge>\n                </div>\n              </div>\n\n              {/* Drawer Tab Switcher */}\n              <div className=\"flex border-b border-border/40 bg-surface/30 p-1 gap-1\">\n                <button\n                  type=\"button\"\n                  onClick={() => setDetailTab('profile')}\n                  className={cn(\n                    \"flex-1 py-2 text-[11px] font-bold rounded-lg transition-all cursor-pointer text-center\",\n                    detailTab === 'profile'\n                      ? \"bg-accent/15 text-accent border border-accent/20\"\n                      : \"text-foreground-muted hover:text-foreground hover:bg-surface/50 border border-transparent\"\n                  )}\n                >\n                  в”ҳв•ӣв•Әв–’в”ҳГӘв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®\n                </button>\n                <button\n                  type=\"button\"\n                  onClick={() => setDetailTab('vehicles')}\n                  className={cn(\n                    \"flex-1 py-2 text-[11px] font-bold rounded-lg transition-all cursor-pointer text-center\",\n                    detailTab === 'vehicles'\n                      ? \"bg-accent/15 text-accent border border-accent/20\"\n                      : \"text-foreground-muted hover:text-foreground hover:bg-surface/50 border border-transparent\"\n                  )}\n                >\n                  в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв”ҳГ§в•ӘВә ({toFa(((selectedUserForDetail.customFields as any)?.vehicles || []).length)})\n                </button>\n                <button\n                  type=\"button\"\n                  onClick={() => setDetailTab('logs')}\n                  className={cn(\n                    \"flex-1 py-2 text-[11px] font-bold rounded-lg transition-all cursor-pointer text-center\",\n                    detailTab === 'logs'\n                      ? \"bg-accent/15 text-accent border border-accent/20\"\n                      : \"text-foreground-muted hover:text-foreground hover:bg-surface/50 border border-transparent\"\n                  )}\n                >\n                  в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ ({toFa(userAuditLogs.length)})\n                </button>\n              </div>\n\n              {/* Drawer Content */}\n              <div className=\"flex-1 overflow-y-auto p-6 space-y-6\">\n                {detailTab === 'profile' && (\n                  <div className=\"space-y-5 animate-in fade-in duration-200\">\n                    {/* Card 1: Personal & Contact Info */}\n                    <div className=\"border border-border/50 bg-surface/20 rounded-xl p-4 space-y-3.5 shadow-sm\">\n                      <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/30 pb-2\">\n                        <User className=\"size-4 text-accent\" />\n                        <span>в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳГјв•Әв–’в•ӘВ»в–ҲГ® в”ҳГӘ в”ҳГ§в”ҳГӘв–ҲГ®в•ӘВ¬в–ҲГ®</span>\n                      </h3>\n\n                      <div className=\"grid grid-cols-2 gap-4\">\n                        <div className=\"flex items-center gap-2.5\">\n                          <CreditCard className=\"size-4 text-foreground-muted shrink-0\" />\n                          <div className=\"flex flex-col\">\n                            <span className=\"text-[9px] text-foreground-muted\">в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ® (в”ҳГҘв•ӘВәв”ҳГ  в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®)</span>\n                            <span className=\"text-xs font-bold text-foreground font-mono\">{toFa(selectedUserForDetail.nationalId)}</span>\n                          </div>\n                        </div>\n\n                        <div className=\"flex items-center gap-2.5\">\n                          <Phone className=\"size-4 text-foreground-muted shrink-0\" />\n                          <div className=\"flex flex-col\">\n                            <span className=\"text-[9px] text-foreground-muted\">в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в–Ҳв–’</span>\n                            <span className=\"text-xs font-bold text-foreground font-mono\">\n                              {selectedUserForDetail.phone ? toFa(selectedUserForDetail.phone) : 'О“ГҮГ¶'}\n                            </span>\n                          </div>\n                        </div>\n\n                        <div className=\"flex items-center gap-2.5 col-span-2 border-t border-border/20 pt-2.5\">\n                          <Mail className=\"size-4 text-foreground-muted shrink-0\" />\n                          <div className=\"flex flex-col overflow-hidden\">\n                            <span className=\"text-[9px] text-foreground-muted\">в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ</span>\n                            <span className=\"text-xs font-semibold text-foreground font-mono truncate\">\n                              {selectedUserForDetail.email || 'в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§'}\n                            </span>\n                          </div>\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Group 1: в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГӘ в”ҳГјв•Әв–’в•ӘВ»в–ҲГ® */}\n                    <div className=\"border border-border/50 bg-surface/20 rounded-xl p-4 space-y-3 shadow-sm\">\n                      <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/30 pb-2\">\n                        <User className=\"size-4 text-accent\" />\n                        <span>в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГӘ в”ҳГјв•Әв–’в•ӘВ»в–ҲГ®</span>\n                      </h3>\n                      <div className=\"space-y-1\">\n                        {renderDetailFieldRow('в”ҳГҘв•ӘВәв”ҳГ  в”ҳв•ӣв•ӘВ»в•Әв–’', 'fatherName', <User className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§', 'idNumber', <CreditCard className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»', 'birthDate', <Calendar className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•Әв”Ӯв”ҳГҘ', 'age', <Calendar className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в”ҳГ в•ӘВЎв”ҳГӨ в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ»', 'birthPlace', <MapPin className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВ¬в•ӘВәв”ҳГ§в”ҳГӨ / в”ҳГјв•Әв–’в•Әв–“в”ҳГҘв•ӘВ»в•ӘВәв”ҳГҘ', 'maritalStatus', <User className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•ӘВ«в”ҳГӘв”ҳГҘв–ҲГ® / в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в•ӘВҝв–ҲГ®в”ҳГ в”ҳГ§', 'insuranceNo', <Shield className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в•ӘВЎв•Әв•Ўв–ҲГ®в”ҳГӨв•ӘВәв•ӘВ¬', 'education', <Award className=\"size-3.5 text-accent\" />)}\n                      </div>\n                    </div>\n\n                    {/* Group 2: в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ® в”ҳГӘ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® */}\n                    <div className=\"border border-border/50 bg-surface/20 rounded-xl p-4 space-y-3 shadow-sm\">\n                      <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/30 pb-2\">\n                        <Briefcase className=\"size-4 text-accent\" />\n                        <span>в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ® в”ҳГӘ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®</span>\n                      </h3>\n                      <div className=\"space-y-1\">\n                        {renderDetailFieldRow('в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®', 'personnelNo', <CreditCard className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®', 'post', <Briefcase className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в”ҢвҢҗв•ӘВ» в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®', 'group', <Activity className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в”ҳГҘв•ӘВәв”ҳГ  в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®', 'shift', <Calendar className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ®', 'shiftType', <Clock className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в•ӘВҝв”ҳГ§ в”ҢвҢҗв•ӘВәв•Әв–’', 'startLocation', <MapPin className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ ', 'hireDate', <Calendar className=\"size-3.5 text-accent\" />)}\n                      </div>\n                    </div>\n\n                    {/* Group 3: в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв•ӘГ® в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»в”ҳГ§в•ӘВә */}\n                    <div className=\"border border-border/50 bg-surface/20 rounded-xl p-4 space-y-3 shadow-sm\">\n                      <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/30 pb-2\">\n                        <Award className=\"size-4 text-accent\" />\n                        <span>в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв•ӘГ® в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»в”ҳГ§в•ӘВә</span>\n                      </h3>\n                      <div className=\"space-y-1\">\n                        {renderDetailFieldRow('в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’', 'drivingStatus', <Award className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’', 'licenseClass1Date', <Award className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“', 'licenseClass2Date', <Award className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВәв•Әв•Јв•ӘВ¬в•ӘВҝв•ӘВәв•Әв–’ в”ҳГ в•Әв•Јв•ӘВәв–ҲГ®в”ҳГҘв”ҳГ§ в”ҳв•ӣв•Әв–“в•Әв”Өв”ҢвҢҗв–ҲГ®', 'medicalExamValidity', <Shield className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’', 'driverPercent', <Activity className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в”ҢвҢҗв”ҳГ в”ҢвҢҗ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ®', 'coDriverPercent', <Activity className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в•Әв”Ӯв”ҳГ§в”ҳГ  в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®', 'traineeDriverPercent', <Activity className=\"size-3.5 text-accent\" />)}\n                      </div>\n                    </div>\n\n                    {/* Group 4: в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘ в•ӘВ¬в”ҳГ в•ӘВәв•Әв”ӮО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® */}\n                    <div className=\"border border-border/50 bg-surface/20 rounded-xl p-4 space-y-3 shadow-sm\">\n                      <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/30 pb-2\">\n                        <MapPin className=\"size-4 text-accent\" />\n                        <span>в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҳГӘ в•ӘВ¬в”ҳГ в•ӘВәв•Әв”ӮО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®</span>\n                      </h3>\n                      <div className=\"space-y-1\">\n                        {renderDetailFieldRow('в•ӘГів•ӘВ»в•Әв–’в•Әв”Ӯ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬в–ҲГ® в•Әв”Ӯв”ҢвҢҗв”ҳГӘв”ҳГҘв•ӘВ¬', 'address', <MapPin className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в–Ҳв”Ӯ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®', 'phone3', <Phone className=\"size-3.5 text-accent\" />)}\n                        {renderDetailFieldRow('в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в–Ҳв”Ө в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®', 'phone4', <Phone className=\"size-3.5 text-accent\" />)}\n                        \n                        {/* Additional phones display if any */}\n                        {(((selectedUserForDetail.customFields as any)?.additionalPhones || []) as string[]).map((ph: string, idx: number) => {\n                          return (\n                            <div key={idx} className=\"flex flex-col border-b border-border/20 py-2.5 last:border-0\">\n                              <div className=\"flex items-center justify-between\">\n                                <span className=\"text-[10px] font-semibold text-foreground-muted\">в•ӘВ¬в”ҳГӨв”ҳГјв”ҳГҘ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ® {toFa(idx + 2)}</span>\n                                <Badge variant=\"outline\" className=\"text-[8px] px-1.5 py-0.2 bg-green-500/10 text-green-400 border-green-500/20 font-bold\">в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ</Badge>\n                              </div>\n                              <span className=\"text-xs font-bold text-foreground font-mono mt-1\">{toFa(ph)}</span>\n                            </div>\n                          )\n                        })}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {detailTab === 'vehicles' && (\n                  <div className=\"space-y-4 animate-in fade-in duration-200\">\n                    <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/40 pb-2\">\n                      <Car className=\"size-4 text-accent\" />\n                      <span>в”ҳГӘв•Әв”Ӯв•ӘВәв–ҲГ®в”ҳГӨ в”ҳГҘв”ҳГ©в”ҳГӨв–ҲГ®в”ҳГ§ в”ҳГӘ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в•Әв–’в•ӘВ»в•ӘВ»</span>\n                    </h3>\n\n                    {(() => {\n                      const userVehicles = ((selectedUserForDetail.customFields as any)?.vehicles || []) as Vehicle[]\n                      if (userVehicles.length === 0) {\n                        return (\n                          <div className=\"flex flex-col items-center justify-center p-12 text-foreground-muted gap-2 border border-dashed border-border/60 rounded-xl\">\n                            <Car className=\"size-8 opacity-30\" />\n                            <span className=\"text-xs font-semibold\">в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘв–ҲГ®в–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</span>\n                          </div>\n                        )\n                      }\n                      \n                      return (\n                        <div className=\"space-y-4\">\n                          {userVehicles.map((v) => {\n                            const isPending = v.status === 'pending'\n                            const isRejected = v.status === 'rejected'\n                            const isApproved = v.status === 'approved' || !v.status\n\n                            return (\n                              <Card key={v.id} className=\"border-border/60 shadow-sm relative overflow-hidden bg-surface/40\">\n                                <CardContent className=\"p-4 flex flex-col gap-4\">\n                                  \n                                  {/* Visual Plate Renderer */}\n                                  <div className=\"flex justify-center\">\n                                    <div className=\"relative w-56 h-11 bg-white border border-neutral-300 rounded shadow flex items-center justify-between font-sans overflow-hidden select-none\" dir=\"ltr\">\n                                      {/* Blue section (left) */}\n                                      <div className=\"w-7 h-full bg-[#003399] flex flex-col items-center justify-between py-1 text-white text-[6px] font-bold\">\n                                        <div className=\"flex flex-col gap-0.5 items-center\">\n                                          <div className=\"w-2.5 h-0.5 bg-[#FF0000]\" />\n                                          <div className=\"w-2.5 h-0.5 bg-[#FFFFFF]\" />\n                                          <div className=\"w-2.5 h-0.5 bg-[#009933]\" />\n                                        </div>\n                                        <div className=\"flex flex-col items-center text-[5px]\">\n                                          <span>I.R.</span>\n                                          <span>IRAN</span>\n                                        </div>\n                                      </div>\n                                      \n                                      {/* Left Plate Numbers */}\n                                      <div className=\"flex-1 flex items-center justify-center gap-1.5 text-lg font-bold text-neutral-800 tracking-tight\">\n                                        <span>{toFa(v.plateNum1)}</span>\n                                        <span className=\"text-sm font-normal\">{v.plateLetter}</span>\n                                        <span>{toFa(v.plateNum2)}</span>\n                                      </div>\n                                      \n                                      {/* Right Box (City Code) */}\n                                      <div className=\"w-9 h-full border-l border-neutral-300 flex flex-col items-center justify-center bg-white text-neutral-800\">\n                                        <span className=\"text-[6px] text-neutral-500 font-semibold -mb-0.5\">в•ӘВәв–ҲГ®в•Әв–’в•ӘВәв”ҳГҘ</span>\n                                        <span className=\"text-sm font-bold tracking-tight\">{toFa(v.plateCity)}</span>\n                                      </div>\n                                    </div>\n                                  </div>\n\n                                  {/* Vehicle Meta Details */}\n                                  <div className=\"grid grid-cols-2 gap-2 text-[11px] text-right border-t border-b border-border/20 py-2\">\n                                    <div>\n                                      <span className=\"text-foreground-muted\">в”ҳГҘв”ҳГӘв•Әв•Ј в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ: </span>\n                                      <strong className=\"text-foreground\">{v.carType}</strong>\n                                    </div>\n                                    <div>\n                                      <span className=\"text-foreground-muted\">в•Әв–’в”ҳГҘв”ҢВ» в•ӘВ«в”ҳГӘв•ӘВ»в•Әв–’в”ҳГӘ: </span>\n                                      <strong className=\"text-foreground\">{v.carColor || 'О“ГҮГ¶'}</strong>\n                                    </div>\n                                    <div className=\"col-span-2 mt-1\">\n                                      <span className=\"text-foreground-muted\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв”ҳГҘв”ҳГ©в•Әв•ўв•ӘВәв–ҲГ® в”ҳГ в•ӘВјв”ҳГӘв•Әв–“: </span>\n                                      <strong className=\"text-foreground font-mono\">{toFa(v.carLicenseExpiry || 'О“ГҮГ¶')}</strong>\n                                    </div>\n                                  </div>\n\n                                  {/* Status and Action Buttons */}\n                                  <div className=\"flex items-center justify-between\">\n                                    <div className=\"flex items-center gap-1.5\">\n                                      <span className=\"text-[10px] text-foreground-muted\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГ в•ӘВјв”ҳГӘв•Әв–“:</span>\n                                      {isPending && (\n                                        <Badge className=\"bg-yellow-500/20 text-yellow-300 border border-yellow-500/30 px-2 py-0.5 font-bold text-[9px] rounded-full\">\n                                          в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ»\n                                        </Badge>\n                                      )}\n                                      {isApproved && (\n                                        <Badge className=\"bg-green-500/20 text-green-400 border border-green-500/30 px-2 py-0.5 font-bold text-[9px] rounded-full\">\n                                          в”ҳГ в•ӘВјв”ҳГӘв•Әв–“ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ\n                                        </Badge>\n                                      )}\n                                      {isRejected && (\n                                        <Badge className=\"bg-red-500/20 text-red-400 border border-red-500/30 px-2 py-0.5 font-bold text-[9px] rounded-full\">\n                                          в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ / в”ҳГјв•ӘВәв”ҳГ©в•ӘВ» в”ҳГ в•ӘВјв”ҳГӘв•Әв–“\n                                        </Badge>\n                                      )}\n                                    </div>\n\n                                    <div className=\"flex items-center gap-1\">\n                                      {v.status !== 'approved' && (\n                                        <Button\n                                          size=\"xs\"\n                                          className=\"bg-green-500 hover:bg-green-600 text-white font-bold text-[10px] h-7 px-2.5 rounded cursor-pointer\"\n                                          onClick={() => handleUpdateVehicleStatus(selectedUserForDetail.id, v.id, 'approved')}\n                                          disabled={actionLoading}\n                                        >\n                                          в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГӘ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®\n                                        </Button>\n                                      )}\n                                      {v.status !== 'rejected' && (\n                                        <Button\n                                          size=\"xs\"\n                                          variant=\"outline\"\n                                          className=\"border-red-500/30 hover:bg-red-500/10 text-red-400 font-bold text-[10px] h-7 px-2.5 rounded cursor-pointer\"\n                                          onClick={() => handleUpdateVehicleStatus(selectedUserForDetail.id, v.id, 'rejected')}\n                                          disabled={actionLoading}\n                                        >\n                                          в•Әв•‘в–ҲГ®в•Әв–’в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®\n                                        </Button>\n                                      )}\n                                    </div>\n                                  </div>\n\n                                </CardContent>\n                              </Card>\n                            )\n                          })}\n                        </div>\n                      )\n                    })()}\n                  </div>\n                )}\n\n                {detailTab === 'logs' && (\n                  <div className=\"space-y-4 animate-in fade-in duration-200\">\n                    <h3 className=\"text-xs font-bold text-foreground flex items-center gap-1.5 border-b border-border/40 pb-2\">\n                      <Activity className=\"size-4 text-accent\" />\n                      <span>в”ҳГӨв•ӘВәв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГ в–ҲГ®в•Әв–“в–ҲГ® в”ҳГӘ в•Әв–’в”ҳГӘв–ҲГ®в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•ӘВ«в–ҲГ®в•Әв–’ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</span>\n                    </h3>\n\n                    {loadingUserAuditLogs ? (\n                      <div className=\"flex flex-col items-center justify-center p-12 gap-2\">\n                        <Loader2 className=\"size-5 animate-spin text-accent\" />\n                        <span className=\"text-xs text-foreground-muted\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•ӘВәв•Әв–’в”ҢВ»в•Әв–‘в•ӘВәв•Әв–’в–ҲГ® в”ҳГӨв•ӘВәв”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВә...</span>\n                      </div>\n                    ) : userAuditLogs.length === 0 ? (\n                      <p className=\"text-xs text-foreground-muted text-center py-8\">в”ҳГ§в–ҲГ®в”ҢГҘ в”ҳГӨв•ӘВәв”ҢВ» в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬в–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВәв–ҲГ®в”ҳГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.</p>\n                    ) : (\n                      <div className=\"relative border-r border-border/50 pe-4 mr-2.5 space-y-4 py-1.5\">\n                        {userAuditLogs.map((log) => (\n                          <div key={log.id} className=\"relative\">\n                            {/* Dot marker */}\n                            <span className=\"absolute -right-[21.5px] top-1.5 size-2.5 rounded-full border border-accent bg-surface shrink-0\"></span>\n\n                            <div className=\"flex flex-col gap-0.5\">\n                              <span className=\"text-xs text-foreground/90 font-semibold leading-relaxed text-start\">\n                                {getAuditLogDescription(log)}\n                              </span>\n                              <span className=\"text-[9px] text-foreground-muted font-mono tracking-tight text-start\">\n                                {jalali(log.createdAt)}\n                              </span>\n                            </div>\n                          </div>\n                        ))}\n                      </div>\n                    )}\n                  </div>\n                )}\n              </div>\n\n              {/* Drawer Sticky Footer Actions */}\n              <div className=\"p-4 border-t border-border bg-surface flex flex-wrap gap-2 justify-end\">\n                {selectedUserForDetail.status === 'pending' && (\n                  <Button\n                    onClick={() => handleApprove(selectedUserForDetail.id)}\n                    disabled={actionLoading}\n                    className=\"bg-success hover:bg-success/90 text-white font-bold text-xs h-9 px-4 rounded-lg cursor-pointer flex items-center gap-1 shrink-0 shadow\"\n                  >\n                    <UserCheck className=\"size-3.5\" />\n                    в•ӘВ¬в•ӘГәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв•Јв•Әв•ўв”ҳГӘв–ҲГ®в•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                  </Button>\n                )}\n\n                {/* Status Switcher Dropdown */}\n                <DropdownMenu>\n                  <DropdownMenuTrigger\n                    render={\n                      <Button\n                        variant=\"outline\"\n                        className=\"border-border hover:bg-surface-hover text-foreground text-xs h-9 px-3 rounded-lg cursor-pointer font-bold shrink-0 shadow-sm\"\n                      >\n                        в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬\n                      </Button>\n                    }\n                  />\n                  <DropdownMenuContent align=\"end\" className=\"bg-surface border-border p-1 rounded-lg\">\n                    <DropdownMenuItem\n                      onClick={() => handleQuickUpdateStatus(selectedUserForDetail.id, 'active')}\n                      className=\"text-xs font-semibold text-success hover:bg-success/10 cursor-pointer rounded-md px-2.5 py-1.5\"\n                    >\n                      в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ® в•ӘВЎв•Әв”Ӯв•ӘВәв•ӘВҝ\n                    </DropdownMenuItem>\n                    <DropdownMenuItem\n                      onClick={() => handleQuickUpdateStatus(selectedUserForDetail.id, 'suspended')}\n                      className=\"text-xs font-semibold text-critical hover:bg-critical/10 cursor-pointer rounded-md px-2.5 py-1.5\"\n                    >\n                      в•ӘВ¬в•Әв•Јв”ҳГӨв–ҲГ®в”ҳГ© (в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ»в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®)\n                    </DropdownMenuItem>\n                  </DropdownMenuContent>\n                </DropdownMenu>\n\n                {/* Role Switcher Dropdown */}\n                <DropdownMenu>\n                  <DropdownMenuTrigger\n                    render={\n                      <Button\n                        variant=\"outline\"\n                        className=\"border-border hover:bg-surface-hover text-foreground text-xs h-9 px-3 rounded-lg cursor-pointer font-bold shrink-0 shadow-sm\"\n                      >\n                        в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҳГҘв”ҳГ©в•Әв”Ө\n                      </Button>\n                    }\n                  />\n                  <DropdownMenuContent align=\"end\" className=\"bg-surface border-border p-1 rounded-lg max-h-[250px] overflow-y-auto\">\n                    {roles.map((r) => (\n                      <DropdownMenuItem\n                        key={r.id}\n                        onClick={() => handleQuickUpdateRole(selectedUserForDetail.id, r.id)}\n                        className=\"text-xs font-semibold hover:bg-accent/10 cursor-pointer rounded-md px-2.5 py-1.5\"\n                      >\n                        {r.name}\n                      </DropdownMenuItem>\n                    ))}\n                  </DropdownMenuContent>\n                </DropdownMenu>\n\n                <Button\n                  onClick={() => openPasswordResetModal(selectedUserForDetail)}\n                  className=\"bg-surface border border-border hover:bg-surface-hover text-foreground font-bold text-xs h-9 px-3 rounded-lg cursor-pointer flex items-center gap-1 shrink-0 shadow-sm\"\n                >\n                  <Lock className=\"size-3.5\" />\n                  в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’\n                </Button>\n\n                <Button\n                  onClick={() => openEditUserModal(selectedUserForDetail)}\n                  className=\"bg-accent hover:bg-accent-hover text-accent-foreground font-bold text-xs h-9 px-4 rounded-lg cursor-pointer flex items-center gap-1 shrink-0 shadow\"\n                >\n                  <Edit2 className=\"size-3.5\" />\n                  в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҢвҢҗв•ӘВәв”ҳГ в”ҳГӨ\n                </Button>\n\n                {selectedUserForDetail.id !== sessionUser?.id && (\n                  <Button\n                    onClick={() => handleDeleteUser(selectedUserForDetail.id)}\n                    disabled={actionLoading}\n                    className=\"bg-critical hover:bg-critical-hover text-critical-foreground font-bold text-xs h-9 px-3 rounded-lg cursor-pointer flex items-center gap-1 shrink-0 shadow\"\n                  >\n                    <Trash2 className=\"size-3.5\" />\n                    в•ӘВЎв•Әв–‘в”ҳГј в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ\n                  </Button>\n                )}\n              </div>\n            </div>\n          )}\n        </SheetContent>\n      </Sheet>\n\n      {/* User Create/Edit Dialog */}\n      <Dialog open={userModalOpen} onOpenChange={setUserModalOpen}>\n        <DialogContent className=\"max-w-2xl w-full max-h-[90vh] overflow-y-auto\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-lg font-bold text-foreground text-start\">\n              {userModalMode === 'create' ? 'в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»' : 'в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ'}\n            </DialogTitle>\n            <DialogDescription className=\"text-xs text-foreground-muted text-start\">\n              в”ҳГӨв•Әв•–в”ҳГјв•ӘВәв”ҳГҜ в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® в•Әв–“в–ҲГ®в•Әв–’ в•Әв–’в•ӘВә в•ӘВҝв•ӘВә в•ӘВ»в”ҳГ©в•ӘВ¬ в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ». в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв•ӘВ¬в•ӘВәв•Әв–’в”ҳГ§О“ГҮГ®в•ӘВ»в•ӘВәв•Әв–’ (*) в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ® в”ҳГ§в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ».\n            </DialogDescription>\n          </DialogHeader>\n          <form onSubmit={handleSaveUser} className=\"space-y-6 py-2\">\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 text-start\">\n              {/* Right Column (Personal & Contact Info) */}\n              <div className=\"space-y-4\">\n                <h3 className=\"text-xs font-bold text-accent/90 border-b border-border/40 pb-2 flex items-center gap-1.5\">\n                  <User className=\"size-4 text-accent\" />\n                  в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳГјв•Әв–’в•ӘВ»в–ҲГ® в”ҳГӘ в•ӘВ¬в”ҳГ в•ӘВәв•Әв”Ӯ\n                </h3>\n                \n                {userModalMode === 'create' && (\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"nationalId\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ® (в”ҳГҘв•ӘВәв”ҳГ  в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в–ҲГ®) <span className=\"text-critical\">*</span>\n                    </Label>\n                    <Input\n                      id=\"nationalId\"\n                      required\n                      maxLength={10}\n                      placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–‘в–Ҳв–‘в–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ўв–Ҳв•–в–Ҳв••\"\n                      value={nationalId}\n                      onChange={(e) => setNationalId(e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n                )}\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"name\" className=\"text-xs font-semibold text-foreground\">\n                    в”ҳГҘв•ӘВәв”ҳГ  в”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ  в•ӘВ«в•ӘВәв”ҳГҘв”ҳГӘв•ӘВәв•ӘВ»в”ҢВ»в–ҲГ® <span className=\"text-critical\">*</span>\n                  </Label>\n                  <Input\n                    id=\"name\"\n                    required\n                    placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в•Әв–’в•Әв•ўв•ӘВә в•Әв•Јв”ҳГӨв–ҲГ®в•Әв–“в•ӘВәв•ӘВ»в”ҳГ§\"\n                    value={name}\n                    onChange={(e) => setName(e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border text-start\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"phone\" className=\"text-xs font-semibold text-foreground\">\n                    в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВәв”ҳГӘв”ҳГӨ <span className=\"text-critical\">*</span>\n                  </Label>\n                  <Input\n                    id=\"phone\"\n                    required\n                    placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–‘в–Ҳв•Јв–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ўв–Ҳв•–в–Ҳв••в–Ҳв•Ј\"\n                    value={phone}\n                    onChange={(e) => setPhone(e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"phone2\" className=\"text-xs font-semibold text-foreground\">\n                    в•Әв”Өв”ҳГ в•ӘВәв•Әв–’в”ҳГ§ в”ҳГ§в”ҳГ в•Әв–’в•ӘВәв”ҳГ§ в•ӘВ»в”ҳГӘв”ҳГ  (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)\n                  </Label>\n                  <Input\n                    id=\"phone2\"\n                    placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–‘в–Ҳв•Јв–Ҳв–’в–Ҳв•Јв–Ҳв••в–Ҳв•–в–Ҳв•ўв–Ҳв•Ўв–Ҳв”Өв–Ҳв”Ӯв–Ҳв–“\"\n                    value={userCustomFields.phone2 as string || ''}\n                    onChange={(e) => handleUserCustomFieldChange('phone2', e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"email\" className=\"text-xs font-semibold text-foreground\">\n                    в•ӘВәв–ҲГ®в”ҳГ в–ҲГ®в”ҳГӨ (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)\n                  </Label>\n                  <Input\n                    id=\"email\"\n                    type=\"email\"\n                    placeholder=\"example@gmail.com\"\n                    value={email}\n                    onChange={(e) => setEmail(e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                  />\n                </div>\n\n                {userModalMode === 'create' && (\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"password\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВәв”ҳГӘв”ҳГӨв–ҲГ®в”ҳГ§ <span className=\"text-critical\">*</span>\n                    </Label>\n                    <Input\n                      id=\"password\"\n                      type=\"password\"\n                      required\n                      placeholder=\"в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в–Ҳв•ў в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’\"\n                      value={password}\n                      onChange={(e) => setPassword(e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n                )}\n              </div>\n\n              {/* Left Column (Job & Roster Info) */}\n              <div className=\"space-y-4\">\n                <h3 className=\"text-xs font-bold text-accent/90 border-b border-border/40 pb-2 flex items-center gap-1.5\">\n                  <Briefcase className=\"size-4 text-accent\" />\n                  в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬ в•Әв”Өв•Әв•‘в”ҳГӨв–ҲГ® в”ҳГӘ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ®\n                </h3>\n\n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"personnelNo\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҢвҢҗв•ӘВ» в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ® <span className=\"text-critical\">*</span>\n                    </Label>\n                    <Input\n                      id=\"personnelNo\"\n                      required\n                      placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ў\"\n                      value={userCustomFields.personnelNo as string || ''}\n                      onChange={(e) => handleUserCustomFieldChange('personnelNo', e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"post\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҳв•ӣв•Әв”Ӯв•ӘВ¬ в•Әв”Ӯв•ӘВәв•Әв–“в”ҳГ в•ӘВәв”ҳГҘв–ҲГ® <span className=\"text-critical\">*</span>\n                    </Label>\n                    <select\n                      id=\"post\"\n                      required\n                      value={userCustomFields.post as string || 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’'}\n                      onChange={(e) => handleUserCustomFieldChange('post', e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      {['в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’', 'в”ҳГ в•Әв”Ӯв•ӘВӘв”ҳГӘв”ҳГӨ в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬', 'в”ҢвҢҗв•ӘВәв•Әв–’в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯ', 'в•ӘВ¬в”ҢвҢҗв”ҳГҘв•Әв”Ӯв–ҲГ®в”ҳГҘ в•ӘВәв•Әв•Јв•Әв–“в•ӘВәв”ҳГ  в”ҳв•ӣв•Әв–‘в–ҲГ®в•Әв–’в•Әв”Ө', 'в•Әв”Ӯв•Әв–’в”ҳв•ӣв•Әв–’в•Әв”Ӯв•ӘВ¬', 'в•Әв–’в•ӘВӘв–ҲГ®в•Әв”Ӯ', 'в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’', 'в•ӘВ»в”ҳГјв•ӘВ¬в•Әв–’в–ҲГ®'].map((p) => (\n                        <option key={p} value={p}>{p}</option>\n                      ))}\n                    </select>\n                  </div>\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"roleId\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҳГҘв”ҳГ©в•Әв”Ө в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в–ҲГ® <span className=\"text-critical\">*</span>\n                    </Label>\n                    <select\n                      id=\"roleId\"\n                      required\n                      value={roleId}\n                      onChange={(e) => setRoleId(e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      {roles.map((r) => (\n                        <option key={r.id} value={r.id}>\n                          {r.name}\n                        </option>\n                      ))}\n                    </select>\n                  </div>\n\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"status\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬ в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨв–ҲГ®в•ӘВ¬ <span className=\"text-critical\">*</span>\n                    </Label>\n                    <select\n                      id=\"status\"\n                      required\n                      value={status}\n                      onChange={(e) => setStatus(e.target.value as any)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      <option value=\"active\">в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ</option>\n                      <option value=\"pending\">в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВҝв•Әв–’в•Әв–’в•Әв”Ӯв–ҲГ®</option>\n                      <option value=\"suspended\">в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ© (в”ҳГ в•Әв”Ӯв•ӘВ»в”ҳГӘв•ӘВ»)</option>\n                    </select>\n                  </div>\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"shift\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в”ҳГӨв”ҳГӘв•ӘВЎв”ҳГ§ (в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬) <span className=\"text-critical\">*</span>\n                    </Label>\n                    <select\n                      id=\"shift\"\n                      required\n                      value={userCustomFields.shift as string || 'A'}\n                      onChange={(e) => handleUserCustomFieldChange('shift', e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      {['A', 'B', 'C', 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®'].map((s) => (\n                        <option key={s} value={s}>{s}</option>\n                      ))}\n                    </select>\n                  </div>\n\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"shiftType\" className=\"text-xs font-semibold text-foreground\">\n                      в”ҳГҘв”ҳГӘв•Әв•Ј в•Әв”Өв–ҲГ®в”ҳГјв•ӘВ¬ в”ҢвҢҗв•ӘВәв•Әв–’в–ҲГ® <span className=\"text-critical\">*</span>\n                    </Label>\n                    <select\n                      id=\"shiftType\"\n                      required\n                      value={userCustomFields.shiftType as string || '9-15'}\n                      onChange={(e) => handleUserCustomFieldChange('shiftType', e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                    >\n                      {['9-15', '12-24', '9 в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', '12 в•Әв”Ӯв•ӘВәв•Әв•Јв•ӘВ¬в”ҳГ§', 'в•Әв”Ӯв•ӘВ¬в•ӘВәв•ӘВ»в–ҲГ®'].map((st) => (\n                        <option key={st} value={st}>{st}</option>\n                      ))}\n                    </select>\n                  </div>\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"licenseClass1Date\" className=\"text-xs font-semibold text-foreground\">\n                      в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–’\n                    </Label>\n                    <Input\n                      id=\"licenseClass1Date\"\n                      placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–’в–Ҳв”Ӯв–Ҳв•Јв–Ҳв•ў/в–Ҳв–’в–Ҳв–“/в–Ҳв–’в–Ҳв•–\"\n                      value={userCustomFields.licenseClass1Date as string || ''}\n                      onChange={(e) => handleUserCustomFieldChange('licenseClass1Date', e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"licenseClass2Date\" className=\"text-xs font-semibold text-foreground\">\n                      в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•ӘВ«в•Әв–‘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в”ҳГ§ в–Ҳв–“\n                    </Label>\n                    <Input\n                      id=\"licenseClass2Date\"\n                      placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–’в–Ҳв”Ӯв–Ҳв•Јв–Ҳв”Ӯ/в–Ҳв–‘в–Ҳв••/в–Ҳв–“в–Ҳв••\"\n                      value={userCustomFields.licenseClass2Date as string || ''}\n                      onChange={(e) => handleUserCustomFieldChange('licenseClass2Date', e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"group\" className=\"text-xs font-semibold text-foreground\">\n                    в”ҢвҢҗв•ӘВ» в”ҢВ»в•Әв–’в”ҳГӘв”ҳГ§ в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’в–ҲГ® <span className=\"text-critical\">*</span>\n                  </Label>\n                  <Input\n                    id=\"group\"\n                    required\n                    value={userCustomFields.group === undefined ? '' : String(userCustomFields.group)}\n                    onChange={(e) => handleUserCustomFieldChange('group', e.target.value)}\n                    className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                  />\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"hireDate\" className=\"text-xs font-semibold text-foreground\">\n                      в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВәв•Әв”Ӯв•ӘВ¬в•ӘВ«в•ӘВ»в•ӘВәв”ҳГ  <span className=\"text-critical\">*</span>\n                    </Label>\n                    <Input\n                      id=\"hireDate\"\n                      required\n                      placeholder=\"в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв–“/в–Ҳв–’в–Ҳв–‘/в–Ҳв–‘в–Ҳв–’\"\n                      value={userCustomFields.hireDate as string || ''}\n                      onChange={(e) => handleUserCustomFieldChange('hireDate', e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n\n                  <div className=\"space-y-1.5\">\n                    <Label htmlFor=\"birthDate\" className=\"text-xs font-semibold text-foreground\">\n                      в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВ¬в”ҳГӘв”ҳГӨв•ӘВ» <span className=\"text-critical\">*</span>\n                    </Label>\n                    <Input\n                      id=\"birthDate\"\n                      required\n                      placeholder=\"в–Ҳв–’в–Ҳв”Ӯв–Ҳв•–в–Ҳв–‘/в–Ҳв–‘в–Ҳв•Ў/в–Ҳв–’в–Ҳв•Ў\"\n                      value={userCustomFields.birthDate as string || ''}\n                      onChange={(e) => handleUserCustomFieldChange('birthDate', e.target.value)}\n                      className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                    />\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <Label htmlFor=\"startLocation\" className=\"text-xs font-semibold text-foreground\">\n                    в”ҳГ в•ӘВЎв”ҳГӨ в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҢвҢҗв•ӘВәв•Әв–’ (в”ҳГ в•ӘВҝв•ӘВ»в•ӘВә в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬) <span className=\"text-critical\">*</span>\n                  </Label>\n                  <select\n                    id=\"startLocation\"\n                    required\n                    value={userCustomFields.startLocation as string || 'в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө'}\n                    onChange={(e) => handleUserCustomFieldChange('startLocation', e.target.value)}\n                    className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                  >\n                    {['в•Әв”Өв”ҳГ§в•Әв–’в•Әв–’в–ҲГ®', 'в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Ө', 'в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘв”ҳГ§ в”ҳГјв•ӘВ¬в•ӘВЎ в•ӘГів•ӘВҝв•ӘВәв•ӘВ»', 'в•Әв”Өв•ӘВәв”ҳГ§в•ӘВ» в•ӘВҝв•ӘВәв”ҳГ©в•Әв–’ в•Әв”Өв”ҳГ§в•Әв–’'].map((sl) => (\n                      <option key={sl} value={sl}>{sl}</option>\n                    ))}\n                  </select>\n                </div>\n              </div>\n            </div>\n\n            <DialogFooter className=\"pt-4 flex justify-end gap-2 border-t border-border/40\">\n              <Button\n                type=\"button\"\n                variant=\"ghost\"\n                onClick={() => setUserModalOpen(false)}\n                className=\"cursor-pointer\"\n              >\n                в”ҳГӨв•Әв•‘в”ҳГӘ\n              </Button>\n              <Button\n                type=\"submit\"\n                disabled={actionLoading}\n                className=\"bg-accent hover:bg-accent-hover text-accent-foreground font-semibold px-6 cursor-pointer\"\n              >\n                {actionLoading ? <Loader2 className=\"size-4 animate-spin\" /> : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВәв•Әв•–в”ҳГӨв•ӘВәв•Әв•Јв•ӘВәв•ӘВ¬'}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n\n      {/* Role Create Dialog */}\n      <Dialog open={roleModalOpen} onOpenChange={setRoleModalOpen}>\n        <DialogContent className=\"max-w-sm w-full\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-lg font-bold text-foreground text-start\">в•ӘВәв”ҳГјв•Әв–“в”ҳГӘв•ӘВ»в”ҳГҘ в”ҳГҘв”ҳГ©в•Әв”Ө в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»</DialogTitle>\n            <DialogDescription className=\"text-xs text-foreground-muted text-start\">\n              в–ҲГ®в”ҢвҢҗ в”ҢвҢҗв”ҳГӨв–ҲГ®в•ӘВ» в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ® в”ҳГӘ в”ҳГҘв•ӘВәв”ҳГ  в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө в•ӘВ¬в•Әв•Јв•Әв–’в–ҲГ®в”ҳГј в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ».\n            </DialogDescription>\n          </DialogHeader>\n          <form onSubmit={handleCreateRole} className=\"space-y-4 py-2\">\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"roleKey\" className=\"text-xs font-semibold text-foreground\">\n                в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в–ҲГ®в”ҢвҢҗв•ӘВ¬в•ӘВә в”ҳГҘв”ҳГ©в•Әв”Ө (Key)\n              </Label>\n              <Input\n                id=\"roleKey\"\n                required\n                placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: line_manager\"\n                value={roleKey}\n                onChange={(e) => setRoleKey(e.target.value)}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n              />\n              <span className=\"text-[10px] text-foreground-muted text-start block\">\n                в”ҳГјв”ҳГ©в•Әв•– в•ӘВЎв•Әв–’в”ҳГӘв”ҳГј в”ҢвҢҗв”ҳГӘв”ҢГҘв”ҢвҢҗ в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ® в”ҳГӘ в•ӘВ«в•Әв•– в•ӘВ¬в–ҲГ®в•Әв–’в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в–ҲГ®в”ҳГҘ в”ҳГ в•ӘВјв•ӘВәв•Әв–“ в•ӘВәв•Әв”Ӯв•ӘВ¬ (в”ҳГ в•ӘВҪв•ӘВәв”ҳГӨ: supervisor_line1).\n              </span>\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"roleName\" className=\"text-xs font-semibold text-foreground\">\n                в”ҳГҘв•ӘВәв”ҳГ  в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө (Label)\n              </Label>\n              <Input\n                id=\"roleName\"\n                required\n                placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’ в•ӘВ«в•Әв•–\"\n                value={roleName}\n                onChange={(e) => setRoleName(e.target.value)}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border text-start\"\n              />\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"roleRank\" className=\"text-xs font-semibold text-foreground\">\n                в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГҘв”ҳГ©в•Әв”Ө (Rank)\n              </Label>\n              <Input\n                id=\"roleRank\"\n                type=\"number\"\n                min={0}\n                max={100}\n                required\n                value={roleRank}\n                onChange={(e) => setRoleRank(Number(e.target.value))}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n              />\n              <span className=\"text-[10px] text-foreground-muted text-start block\">\n                в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВҝв–ҲГ®в”ҳГҘ в–Ҳв–‘ (в”ҢвҢҗв”ҳГ в•ӘВ¬в•Әв–’в–ҲГ®в”ҳГҘ) в•ӘВ¬в•ӘВә в–Ҳв–’в–Ҳв–‘в–Ҳв–‘ (в•ӘВҝв–ҲГ®в•Әв”Өв•ӘВ¬в•Әв–’в–ҲГ®в”ҳГҘ) в•ӘВјв”ҳГ§в•ӘВ¬ в•ӘВәв”ҳГӘв”ҳГӨв”ҳГӘв–ҲГ®в•ӘВ¬О“ГҮГ®в•ӘВ»в”ҳГ§в–ҲГ® в•ӘВ»в•Әв–’ в”ҢвҢҗв”ҳГҘв•ӘВ¬в•Әв–’в”ҳГӨ в•ӘВ»в•Әв”Ӯв•ӘВ¬в•Әв–’в•Әв”Ӯв–ҲГ®.\n              </span>\n            </div>\n\n            <DialogFooter className=\"pt-4 flex justify-end gap-2\">\n              <Button\n                type=\"button\"\n                variant=\"ghost\"\n                onClick={() => setRoleModalOpen(false)}\n                className=\"cursor-pointer\"\n              >\n                в”ҳГӨв•Әв•‘в”ҳГӘ\n              </Button>\n              <Button\n                type=\"submit\"\n                disabled={actionLoading}\n                className=\"bg-accent hover:bg-accent-hover text-accent-foreground font-semibold px-6 cursor-pointer\"\n              >\n                {actionLoading ? <Loader2 className=\"size-4 animate-spin\" /> : 'в•ӘВәв–ҲГ®в•ӘВјв•ӘВәв•ӘВ» в”ҳГҘв”ҳГ©в•Әв”Ө'}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n\n      {/* Password Reset Dialog */}\n      <Dialog open={passwordResetModalOpen} onOpenChange={setPasswordResetModalOpen}>\n        <DialogContent className=\"max-w-sm w-full\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-lg font-bold text-foreground flex items-center gap-1.5 justify-start\">\n              <Lock className=\"size-5 text-accent\" />\n              <span>в•ӘВҝв•ӘВәв•Әв–“в”ҳГҘв•Әв”Өв•ӘВәв”ҳГҘв–ҲГ® в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ</span>\n            </DialogTitle>\n            <DialogDescription className=\"text-xs text-foreground-muted text-start\">\n              в•ӘВ¬в•Әв•Јв–ҲГ®в–ҲГ®в”ҳГҘ в•Әв–’в”ҳГ в•Әв–“ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ» в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’: <strong className=\"text-foreground\">{resettingUser?.name}</strong>\n            </DialogDescription>\n          </DialogHeader>\n          <form onSubmit={handlePasswordReset} className=\"space-y-4 py-2\">\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"newPassword\" className=\"text-xs font-semibold text-foreground\">\n                в”ҢвҢҗв”ҳГӨв”ҳГ в”ҳГ§ в•Әв•Јв•ӘВҝв”ҳГӘв•Әв–’ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»\n              </Label>\n              <Input\n                id=\"newPassword\"\n                type=\"password\"\n                required\n                placeholder=\"в•ӘВЎв•ӘВ»в•ӘВәв”ҳГ©в”ҳГӨ в–Ҳв•ў в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВәв”ҢвҢҗв•ӘВ¬в•Әв–’ в”ҳГӘв•ӘВәв•Әв–’в•ӘВ» в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»...\"\n                value={newPassword}\n                onChange={(e) => setNewPassword(e.target.value)}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n              />\n            </div>\n\n            <DialogFooter className=\"pt-4 flex justify-end gap-2\">\n              <Button\n                type=\"button\"\n                variant=\"ghost\"\n                onClick={() => setPasswordResetModalOpen(false)}\n                className=\"cursor-pointer\"\n              >\n                в”ҳГӨв•Әв•‘в”ҳГӘ\n              </Button>\n              <Button\n                type=\"submit\"\n                disabled={actionLoading}\n                className=\"bg-accent hover:bg-accent-hover text-accent-foreground font-semibold px-6 cursor-pointer\"\n              >\n                {actionLoading ? <Loader2 className=\"size-4 animate-spin\" /> : 'в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв–’в”ҳГ в•Әв–“ в•ӘВјв•ӘВ»в–ҲГ®в•ӘВ»'}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n\n      {/* Edit Custom Field Modal Dialog */}\n      <Dialog open={fieldEditModalOpen} onOpenChange={setFieldEditModalOpen}>\n        <DialogContent className=\"max-w-md w-full\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-lg font-bold text-foreground text-start\">в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВә</DialogTitle>\n            <DialogDescription className=\"text-xs text-foreground-muted text-start\">\n              в”ҳГ в•Әв”Өв•ӘВ«в•Әв•Ўв•ӘВәв•ӘВ¬ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в”ҳв•ӣв”ҳГӘв–ҲГ®в•ӘВәв–ҲГ® в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝ в•Әв”Өв•ӘВ»в”ҳГ§ в•Әв–’в•ӘВә в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•ӘВ»в”ҳГ§в–ҲГ®в•ӘВ».\n            </DialogDescription>\n          </DialogHeader>\n          <form onSubmit={handleEditField} className=\"space-y-4 py-2 text-start\">\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"editFieldName\" className=\"text-xs font-semibold text-foreground\">\n                в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» (в”ҳГҘв•ӘВәв”ҳГ  в•ӘВәв”ҳГҘв”ҢВ»в”ҳГӨв–ҲГ®в•Әв”Ӯв–ҲГ®)\n              </Label>\n              <Input\n                id=\"editFieldName\"\n                required\n                placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: station_name\"\n                value={editFieldName}\n                onChange={(e) => setEditFieldName(e.target.value)}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n              />\n              <span className=\"text-[10px] text-foreground-muted\">\n                в•ӘВ¬в”ҳГӘв•ӘВјв”ҳГ§: в•ӘВ¬в•Әв•‘в–ҲГ®в–ҲГ®в•Әв–’ в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ в–ҲГ® в”ҳГ в”ҳГ в”ҢвҢҗв”ҳГҘ в•ӘВәв•Әв”Ӯв•ӘВ¬ в•ӘВҝв•ӘВәв•Әв•Јв•ӘВҪ в•Әв”Өв”ҳГӘв•ӘВ» в”ҳГ в”ҳГ©в•ӘВәв•ӘВ»в–ҲГ®в•Әв–’ в”ҳГ©в•ӘВҝв”ҳГӨв–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҢвҢҗв•ӘВәв•Әв–’в•ӘВҝв•Әв–’в•ӘВәв”ҳГҘ в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГҘв•Әв”Өв”ҳГӘв”ҳГҘв•ӘВ».\n              </span>\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"editFieldLabel\" className=\"text-xs font-semibold text-foreground\">\n                в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в”ҳГјв•ӘВәв•Әв–’в•Әв”Ӯв–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» (в•ӘВҝв•Әв–’в”ҢГҘв•Әв”Ӯв•ӘВҝ)\n              </Label>\n              <Input\n                id=\"editFieldLabel\"\n                required\n                placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в•ӘВәв”ҳГ§ в”ҳГ в•ӘВЎв”ҳГӨ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬\"\n                value={editFieldLabel}\n                onChange={(e) => setEditFieldLabel(e.target.value)}\n                className=\"h-10 text-sm focus-visible:ring-accent border-border\"\n              />\n            </div>\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"editFieldType\" className=\"text-xs font-semibold text-foreground\">\n                в”ҳГҘв”ҳГӘв•Әв•Ј в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»\n              </Label>\n              <select\n                id=\"editFieldType\"\n                value={editFieldType}\n                onChange={(e) => setEditFieldType(e.target.value as any)}\n                className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n              >\n                <option value=\"text\">в”ҳГ в•ӘВ¬в”ҳГҘ (в–ҲГ®в”ҢвҢҗ в•ӘВ«в•Әв•–в–ҲГ®)</option>\n                <option value=\"number\">в•Әв•Јв•ӘВ»в•ӘВ»</option>\n                <option value=\"select\">в”ҳГ в”ҳГҘв”ҳГӘв–ҲГ® в”ҢвҢҗв•Әв”Өв”ҳГӘв–ҲГ®в–ҲГ® (в•ӘВәв”ҳГҘв•ӘВ¬в•ӘВ«в•ӘВәв•ӘВҝв–ҲГ®)</option>\n                <option value=\"date\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•Әв”Өв”ҳГ в•Әв”Ӯв–ҲГ®</option>\n                <option value=\"boolean\">в•ӘВ¬в–ҲГ®в”ҢвҢҗО“ГҮГ®в•ӘВҝв•ӘВәв”ҢвҢҗв•Әв”Ӯ (в•ӘВҝв”ҳГӨв”ҳГ§/в•ӘВ«в–ҲГ®в•Әв–’)</option>\n              </select>\n            </div>\n\n            {editFieldType === 'select' && (\n              <div className=\"space-y-1.5\">\n                <Label htmlFor=\"editFieldOptionsRaw\" className=\"text-xs font-semibold text-foreground\">\n                  в”ҢВ»в•Әв–“в–ҲГ®в”ҳГҘв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГҘв”ҳГӘ (в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВәв”ҳГ в•ӘВә в•ӘВјв•ӘВ»в•ӘВә в”ҢвҢҗв”ҳГҘв–ҲГ®в•ӘВ»)\n                </Label>\n                <Input\n                  id=\"editFieldOptionsRaw\"\n                  required\n                  placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в•ӘВ¬в•ӘВјв•Әв–’в–ҲГ®в•Әв”Өв•ӘГ® в”ҢвҢҗв”ҳГ§в•Әв–’в–ҲГ®в•Әв–“в”ҢвҢҗв•ӘГ® в•ӘВәв”ҳГ в•ӘВәв”ҳГ  в•ӘВ«в”ҳГ в–ҲГ®в”ҳГҘв–ҲГ®\"\n                  value={editFieldOptionsRaw}\n                  onChange={(e) => setEditFieldOptionsRaw(e.target.value)}\n                  className=\"h-10 text-sm focus-visible:ring-accent border-border\"\n                />\n              </div>\n            )}\n\n            <div className=\"space-y-1.5\">\n              <Label htmlFor=\"editFieldDefaultValue\" className=\"text-xs font-semibold text-foreground flex justify-start\">\n                в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў (в•ӘВәв•ӘВ«в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–’в–ҲГ®)\n              </Label>\n              {editFieldType === 'boolean' ? (\n                <select\n                  id=\"editFieldDefaultValue\"\n                  value={editFieldDefaultValue}\n                  onChange={(e) => setEditFieldDefaultValue(e.target.value)}\n                  className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                >\n                  <option value=\"\">в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў</option>\n                  <option value=\"true\">в•ӘВҝв”ҳГӨв”ҳГ§ (True)</option>\n                  <option value=\"false\">в•ӘВ«в–ҲГ®в•Әв–’ (False)</option>\n                </select>\n              ) : editFieldType === 'select' ? (\n                <select\n                  id=\"editFieldDefaultValue\"\n                  value={editFieldDefaultValue}\n                  onChange={(e) => setEditFieldDefaultValue(e.target.value)}\n                  className=\"w-full h-10 rounded-lg border border-border bg-background px-3 text-sm text-foreground outline-none focus-visible:border-accent cursor-pointer\"\n                >\n                  <option value=\"\">в•ӘВҝв•ӘВ»в”ҳГӘв”ҳГҘ в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў</option>\n                  {editFieldOptionsRaw.split(/[в•ӘГ®,]/).map((o) => o.trim()).filter((o) => o.length > 0).map((opt) => (\n                    <option key={opt} value={opt}>{opt}</option>\n                  ))}\n                </select>\n              ) : editFieldType === 'date' ? (\n                <Input\n                  id=\"editFieldDefaultValue\"\n                  placeholder=\"в”ҳГ в•ӘВҪв”ҳГӨв•ӘВә: в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв–’/в–Ҳв–‘в–Ҳв–’\"\n                  value={editFieldDefaultValue}\n                  onChange={(e) => setEditFieldDefaultValue(e.target.value)}\n                  className=\"h-10 text-sm focus-visible:ring-accent border-border font-mono text-start\"\n                />\n              ) : (\n                <Input\n                  id=\"editFieldDefaultValue\"\n                  type={editFieldType === 'number' ? 'number' : 'text'}\n                  placeholder=\"в”ҳГ в”ҳГ©в•ӘВ»в•ӘВәв•Әв–’ в”ҳв•ӣв–ҲГ®в•Әв”ӨО“ГҮГ®в”ҳГјв•Әв–’в•Әв•ў в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»...\"\n                  value={editFieldDefaultValue}\n                  onChange={(e) => setEditFieldDefaultValue(e.target.value)}\n                  className=\"h-10 text-sm focus-visible:ring-accent border-border text-start\"\n                />\n              )}\n            </div>\n\n            <div className=\"flex items-center gap-2 pt-1\">\n              <input\n                type=\"checkbox\"\n                id=\"editFieldRequired\"\n                checked={editFieldRequired}\n                onChange={(e) => setEditFieldRequired(e.target.checked)}\n                className=\"accent-accent size-4 rounded\"\n              />\n              <Label htmlFor=\"editFieldRequired\" className=\"text-xs font-semibold text-foreground cursor-pointer select-none\">\n                в”ҳв•ӣв•Әв–’ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ» в•ӘВәв•ӘВјв•ӘВҝв•ӘВәв•Әв–’в–ҲГ® в•ӘВәв•Әв”Ӯв•ӘВ¬\n              </Label>\n            </div>\n\n            <DialogFooter className=\"pt-4 flex justify-end gap-2 border-t border-border/40\">\n              <Button\n                type=\"button\"\n                variant=\"ghost\"\n                onClick={() => setFieldEditModalOpen(false)}\n                className=\"cursor-pointer\"\n              >\n                в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n              </Button>\n              <Button\n                type=\"submit\"\n                disabled={actionLoading}\n                className=\"bg-accent hover:bg-accent-hover text-accent-foreground font-semibold px-6 cursor-pointer\"\n              >\n                {actionLoading ? <Loader2 className=\"size-4 animate-spin\" /> : 'в•ӘВҝв•Әв–’в”ҳГӘв•Әв–“в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв–ҲГ® в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ»'}\n              </Button>\n            </DialogFooter>\n          </form>\n        </DialogContent>\n      </Dialog>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\ai\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\attendance\\page.tsx","messages":[{"ruleId":null,"message":"Unused eslint-disable directive (no problems were reported from 'react-hooks/set-state-in-effect').","line":59,"column":3,"severity":1,"nodeType":null,"fix":{"range":[1619,1671],"text":" "}},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadData'. Either include it or remove the dependency array.","line":62,"column":6,"nodeType":"ArrayExpression","endLine":62,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadData]","fix":{"range":[1717,1730],"text":"[accessToken, loadData]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":1,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { toFa, jalali } from '@/lib/fa'\nimport {\n  MapPin,\n  LogIn,\n  LogOut,\n  Clock,\n  CheckCircle,\n} from 'lucide-react'\n\ninterface AttendanceRecord {\n  id: string\n  checkInGeo: string | null\n  checkInTime: string\n  checkOutGeo: string | null\n  checkOutTime: string | null\n  method: string\n}\n\nexport default function AttendancePage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const [todayRecord, setTodayRecord] = useState<AttendanceRecord | null>(null)\n  const [history, setHistory] = useState<AttendanceRecord[]>([])\n  const [loading, setLoading] = useState(true)\n  const [checking, setChecking] = useState(false)\n\n  async function loadData() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const [todayRes, historyRes] = await Promise.all([\n        fetch('/api/attendance/check-in', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        }),\n        fetch('/api/attendance/me?limit=14', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        }),\n      ])\n\n      if (todayRes.ok) {\n        const todayData = await todayRes.json()\n        setTodayRecord(todayData.data)\n      }\n      if (historyRes.ok) {\n        const historyData = await historyRes.json()\n        setHistory(historyData.data ?? [])\n      }\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  /* eslint-disable react-hooks/set-state-in-effect */\n  useEffect(() => {\n    void loadData()\n  }, [accessToken])\n\n  async function handleCheckIn() {\n    if (!accessToken) return\n    setChecking(true)\n    try {\n      let geoLocation: string | undefined\n      if (navigator.geolocation) {\n        try {\n          const pos = await new Promise<GeolocationPosition>(\n            (resolve, reject) =>\n              navigator.geolocation.getCurrentPosition(resolve, reject, {\n                timeout: 5000,\n              }),\n          )\n          geoLocation = `${pos.coords.latitude},${pos.coords.longitude}`\n        } catch {\n          // geolocation not available\n        }\n      }\n\n      await fetch('/api/attendance/check-in', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({ action: 'checkIn', geoLocation }),\n      })\n      loadData()\n    } finally {\n      setChecking(false)\n    }\n  }\n\n  async function handleCheckOut() {\n    if (!accessToken) return\n    setChecking(true)\n    try {\n      let geoLocation: string | undefined\n      if (navigator.geolocation) {\n        try {\n          const pos = await new Promise<GeolocationPosition>(\n            (resolve, reject) =>\n              navigator.geolocation.getCurrentPosition(resolve, reject, {\n                timeout: 5000,\n              }),\n          )\n          geoLocation = `${pos.coords.latitude},${pos.coords.longitude}`\n        } catch {\n          // geolocation not available\n        }\n      }\n\n      await fetch('/api/attendance/check-in', {\n        method: 'POST',\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({ action: 'checkOut', geoLocation }),\n      })\n      loadData()\n    } finally {\n      setChecking(false)\n    }\n  }\n\n  const isCheckedIn = todayRecord && !todayRecord.checkOutTime\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4\">\n      <div>\n        <h1 className=\"font-headline-lg text-headline-lg-mobile md:text-headline-lg text-foreground flex items-center gap-2\">\n          <MapPin className=\"size-6 text-accent\" />\n          в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’ в”ҳГӘ в•Әв•‘в–ҲГ®в•ӘВәв•ӘВҝ\n        </h1>\n        <p className=\"text-sm text-foreground-muted mt-1\">\n          в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ» в”ҳГӘ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГ©в•Әв•Јв–ҲГ®в•ӘВ¬ в•ӘВјв•Әв•‘в•Әв–’в•ӘВәв”ҳГјв–ҲГ®в•ӘВәв–ҲГ®в–ҲГ®\n        </p>\n      </div>\n\n      {/* Check In/Out Card */}\n      <Card className=\"relative overflow-hidden\">\n        <div className={`absolute top-0 right-0 w-full h-1 ${isCheckedIn ? 'bg-success' : 'bg-foreground-muted/30'}`} />\n        <CardContent className=\"flex flex-col items-center gap-4 p-6 pt-8\">\n          <div\n            className={`flex size-16 items-center justify-center rounded-full ${\n              isCheckedIn ? 'bg-success/15 text-success' : 'bg-surface-container-high text-foreground-muted'\n            }`}\n          >\n            {isCheckedIn ? (\n              <CheckCircle className=\"size-8\" />\n            ) : (\n              <Clock className=\"size-8\" />\n            )}\n          </div>\n          <div className=\"text-center\">\n            <div className=\"text-sm font-medium\">\n              {isCheckedIn ? 'в•ӘВ»в•Әв–’ в•ӘВЎв•ӘВәв”ҳГӨ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬' : 'в•ӘВ«в•ӘВәв•Әв–’в•ӘВј в•ӘВәв•Әв–“ в•ӘВ«в•ӘВ»в”ҳГ в•ӘВ¬'}\n            </div>\n            {todayRecord && (\n              <div className=\"mt-1 text-xs text-foreground-muted\">\n                в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»: {toFa(new Date(todayRecord.checkInTime).toLocaleTimeString('fa-IR'))}\n                {todayRecord.checkOutTime && (\n                  <> О“ГҮГ¶ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј: {toFa(new Date(todayRecord.checkOutTime).toLocaleTimeString('fa-IR'))}</>\n                )}\n              </div>\n            )}\n          </div>\n          <div className=\"flex gap-2\">\n            {!isCheckedIn ? (\n              <Button onClick={handleCheckIn} disabled={checking}>\n                <LogIn className=\"size-4\" />\n                в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГӘв•Әв–’в”ҳГӘв•ӘВ»\n              </Button>\n            ) : (\n              <Button variant=\"destructive\" onClick={handleCheckOut} disabled={checking}>\n                <LogOut className=\"size-4\" />\n                в•ӘВҪв•ӘВҝв•ӘВ¬ в•ӘВ«в•Әв–’в”ҳГӘв•ӘВј\n              </Button>\n            )}\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* History */}\n      <Card>\n        <CardHeader>\n          <CardTitle className=\"text-sm font-medium\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ«в”ҢГҘв”ҳГ§ в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’</CardTitle>\n        </CardHeader>\n        <CardContent>\n          {loading ? (\n            <div className=\"space-y-2\">\n              {Array.from({ length: 5 }).map((_, i) => (\n                <div\n                  key={i}\n                  className=\"h-12 animate-pulse rounded-md bg-background-subtle\"\n                />\n              ))}\n            </div>\n          ) : history.length === 0 ? (\n            <p className=\"py-4 text-center text-sm text-foreground-muted\">\n              в•Әв”Ӯв”ҳГӘв•ӘВәв•ӘВҝв”ҳГ© в•ӘВЎв•Әв•ўв”ҳГӘв•Әв–’в–ҲГ® в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬\n            </p>\n          ) : (\n            <div className=\"space-y-2\">\n              {history.map((r) => (\n                <div\n                  key={r.id}\n                  className=\"flex items-center justify-between rounded-lg border border-outline-variant p-3 transition-colors hover:bg-surface-hover\"\n                >\n                  <div className=\"flex items-center gap-3\">\n                    <MapPin className=\"size-4 text-foreground-muted\" />\n                    <div>\n                      <div className=\"text-sm\">\n                        {jalali(r.checkInTime)}\n                      </div>\n                      <div className=\"text-xs text-foreground-muted\">\n                        {toFa(new Date(r.checkInTime).toLocaleTimeString('fa-IR'))}\n                        {r.checkOutTime && (\n                          <> О“ГҮГ¶ {toFa(new Date(r.checkOutTime).toLocaleTimeString('fa-IR'))}</>\n                        )}\n                      </div>\n                    </div>\n                  </div>\n                  <Badge\n                    className={\n                      r.checkOutTime\n                        ? 'bg-success/15 text-success'\n                        : 'bg-warning/15 text-warning'\n                    }\n                  >\n                    {r.checkOutTime ? 'в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§' : 'в”ҳГјв•Әв•Јв•ӘВәв”ҳГӨ'}\n                  </Badge>\n                </div>\n              ))}\n            </div>\n          )}\n        </CardContent>\n      </Card>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\chat\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Textarea' is defined but never used.","line":13,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":13,"endColumn":18,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data