ption>\n                    <option value=\"appreciation\">в•ӘВ¬в”ҳГ©в•ӘВ»в–ҲГ®в•Әв–’</option>\n                  </select>\n                </div>\n                <div className=\"flex items-end\">\n                  <label className=\"flex items-center gap-2 text-sm\">\n                    <input\n                      type=\"checkbox\"\n                      checked={form.isAnonymous}\n                      onChange={(e) =>\n                        setForm({ ...form, isAnonymous: e.target.checked })\n                      }\n                      className=\"size-4\"\n                    />\n                    в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳГҘв•ӘВәв•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯ\n                  </label>\n                </div>\n              </div>\n              <div>\n                <Label>в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј</Label>\n                <Input\n                  value={form.title}\n                  onChange={(e) => setForm({ ...form, title: e.target.value })}\n                  placeholder=\"в”ҳГ в”ҳГӘв•Әв•ўв”ҳГӘв•Әв•Ј в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ ...\"\n                  className=\"mt-1\"\n                />\n              </div>\n              <div>\n                <Label>в”ҳГ в•ӘВ¬в”ҳГҘ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ </Label>\n                <textarea\n                  value={form.body}\n                  onChange={(e) => setForm({ ...form, body: e.target.value })}\n                  placeholder=\"в”ҳГ в•ӘВ¬в”ҳГҘ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ  в•ӘВ«в”ҳГӘв•ӘВ» в•Әв–’в•ӘВә в•ӘВҝв”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв–ҲГ®в•ӘВ»...\"\n                  rows={4}\n                  className=\"mt-1 flex w-full rounded-lg border border-border bg-surface px-3 py-2 text-sm\"\n                />\n              </div>\n              <div className=\"flex justify-end gap-2\">\n                <Button\n                  type=\"button\"\n                  variant=\"outline\"\n                  onClick={() => setShowForm(false)}\n                >\n                  в•ӘВәв”ҳГҘв•Әв•Ўв•Әв–’в•ӘВәв”ҳГј\n                </Button>\n                <Button type=\"submit\" disabled={submitting}>\n                  в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ \n                </Button>\n              </div>\n            </form>\n          </CardContent>\n        </Card>\n      )}\n\n      {/* Messages List */}\n      {loading ? (\n        <div className=\"space-y-3\">\n          {Array.from({ length: 3 }).map((_, i) => (\n            <div\n              key={i}\n              className=\"h-24 animate-pulse rounded-lg border border-border bg-background-subtle\"\n            />\n          ))}\n        </div>\n      ) : items.length === 0 ? (\n        <Card>\n          <CardContent className=\"flex flex-col items-center justify-center py-12\">\n            <MessageSquare className=\"mb-3 size-10 text-foreground-muted\" />\n            <p className=\"text-sm text-foreground-muted\">в”ҳв•ӣв–ҲГ®в•ӘВәв”ҳГ в–ҲГ® в•ӘВәв•Әв–’в•Әв”Ӯв•ӘВәв”ҳГӨ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬</p>\n          </CardContent>\n        </Card>\n      ) : (\n        <div className=\"space-y-3\">\n          {items.map((item) => {\n            const typeConf = TYPE_CONFIG[item.type] ?? TYPE_CONFIG.suggestion\n            const TypeIcon = typeConf.icon\n            return (\n              <Card key={item.id}>\n                <CardContent className=\"p-4\">\n                  <div className=\"flex items-start justify-between\">\n                    <div className=\"flex items-start gap-3\">\n                      <div className={`mt-0.5 ${typeConf.color}`}>\n                        <TypeIcon className=\"size-5\" />\n                      </div>\n                      <div>\n                        <div className=\"flex items-center gap-2\">\n                          <span className=\"text-sm font-medium\">\n                            {item.title}\n                          </span>\n                          <Badge className={statusColor[item.status]}>\n                            {statusLabel[item.status]}\n                          </Badge>\n                        </div>\n                        <p className=\"mt-1 text-sm text-foreground-muted\">\n                          {item.body}\n                        </p>\n                        <div className=\"mt-2 flex items-center gap-3 text-xs text-foreground-muted\">\n                          <span>{jalali(item.createdAt)}</span>\n                          <span>{typeConf.label}</span>\n                          {item.isAnonymous && <span>в”ҳГҘв•ӘВәв•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯ</span>}\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                  {item.reply && (\n                    <div className=\"mt-3 rounded-md border border-success/20 bg-success/5 p-3\">\n                      <div className=\"mb-1 text-xs font-medium text-success\">\n                        в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬\n                      </div>\n                      <p className=\"text-sm\">{item.reply}</p>\n                      {item.repliedAt && (\n                        <span className=\"mt-1 block text-xs text-foreground-muted\">\n                          {jalali(item.repliedAt)}\n                        </span>\n                      )}\n                    </div>\n                  )}\n                </CardContent>\n              </Card>\n            )\n          })}\n        </div>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\knowledge\\[slug]\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadArticle'. Either include it or remove the dependency array.","line":50,"column":6,"nodeType":"ArrayExpression","endLine":50,"endColumn":32,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadArticle, params.slug]","fix":{"range":[1431,1457],"text":"[accessToken, loadArticle, params.slug]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useParams } from 'next/navigation'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { jalali } from '@/lib/fa'\nimport { ArrowRight, BookOpen, Tag, Pencil } from 'lucide-react'\nimport Link from 'next/link'\n\ninterface Article {\n  id: string\n  title: string\n  slug: string\n  body: string\n  category: string | null\n  tags: string | null\n  attachments: Array<{ url: string; name: string; type: string }> | null\n  createdAt: string\n  author?: { name: string }\n}\n\nexport default function KnowledgeArticlePage() {\n  const params = useParams()\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const user = useAuthStore((s) => s.user)\n  const [article, setArticle] = useState<Article | null>(null)\n  const [loading, setLoading] = useState(true)\n\n  async function loadArticle() {\n    if (!accessToken || !params.slug) return\n    setLoading(true)\n    try {\n      const res = await fetch(`/api/knowledge/${params.slug}`, {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setArticle(data.data)\n      }\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    void loadArticle()\n  }, [accessToken, params.slug])\n\n  if (loading) {\n    return (\n      <div role=\"status\" className=\"flex flex-1 items-center justify-center p-8\">\n        <div className=\"size-8 animate-spin rounded-full border-2 border-accent border-t-transparent\" />\n      </div>\n    )\n  }\n\n  if (!article) {\n    return (\n      <div className=\"flex flex-1 flex-col items-center justify-center gap-4 p-8 select-none\">\n        <BookOpen className=\"size-12 text-foreground-muted opacity-45 animate-pulse\" />\n        <p className=\"text-sm text-foreground-muted\">в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»</p>\n        <Link href=\"/knowledge\">\n          <Button variant=\"outline\" size=\"sm\">\n            <ArrowRight className=\"size-4\" />\n            <span>в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв”Өв•ӘВ¬ в•ӘВҝв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</span>\n          </Button>\n        </Link>\n      </div>\n    )\n  }\n\n  return (\n    <div className=\"mx-auto flex w-full max-w-3xl flex-1 flex-col gap-6 p-4\" dir=\"rtl\">\n      {/* Back Link & Edit button header */}\n      <div className=\"flex items-center justify-between gap-4 border-b border-border pb-3 select-none\">\n        <Link\n          href=\"/knowledge\"\n          className=\"inline-flex items-center gap-1.5 text-xs text-foreground-muted hover:text-foreground font-semibold\"\n        >\n          <ArrowRight className=\"size-4\" />\n          <span>в•ӘВҝв•ӘВәв•Әв–“в”ҢВ»в•Әв”Өв•ӘВ¬ в•ӘВҝв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВ«в•Әв•– в–Ҳв–’</span>\n        </Link>\n        {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n          <Link href={`/admin/knowledge?edit=${article.slug}`}>\n            <Button size=\"sm\" variant=\"outline\" className=\"h-8 text-xs gap-1.5 cursor-pointer border-accent/30 text-accent hover:bg-accent/5 rounded-lg transition-all font-semibold shadow-sm\">\n              <Pencil className=\"size-3.5\" />\n              <span>в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</span>\n            </Button>\n          </Link>\n        )}\n      </div>\n\n      {/* Article Header */}\n      <div className=\"space-y-3 bg-surface-container-low/25 p-4 rounded-xl border border-border-subtle\">\n        <h1 className=\"text-xl font-extrabold tracking-tight text-foreground leading-relaxed\">{article.title}</h1>\n        <div className=\"flex flex-wrap items-center gap-3 text-[10px] text-foreground-muted font-mono border-t border-border/20 pt-2\">\n          <span>в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•Әв•Ўв•ӘВ»в”ҳГӘв•Әв–’ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§: {jalali(article.createdAt)}</span>\n          {article.author && <span>в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв”ҳГҘв•ӘВ»в”ҳГ§: {article.author.name}</span>}\n          {article.category && (\n            <Badge className=\"bg-accent/15 border-transparent text-accent text-[9px] font-bold select-none\">\n              {article.category}\n            </Badge>\n          )}\n        </div>\n        {article.tags && (\n          <div className=\"flex flex-wrap gap-1 pt-1\">\n            {article.tags.split(',').map((tag, i) => (\n              <Badge key={i} className=\"bg-neutral-900 border-neutral-800 text-[9px] text-neutral-400 font-medium select-none\">\n                <Tag className=\"size-2.5\" />\n                <span>{tag.trim()}</span>\n              </Badge>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {/* Article Body */}\n      <Card className=\"border border-border-subtle bg-surface/30 backdrop-blur-md rounded-xl overflow-hidden shadow-sm\">\n        <CardContent className=\"p-6\">\n          <div className=\"prose prose-invert max-w-none text-sm leading-8 text-foreground text-right whitespace-pre-line\">\n            {article.body}\n          </div>\n        </CardContent>\n      </Card>\n\n      {/* Attachments */}\n      {article.attachments && article.attachments.length > 0 && (\n        <Card className=\"border border-border-subtle bg-surface/35 backdrop-blur shadow-sm rounded-xl\">\n          <CardHeader className=\"py-3 border-b border-border/20 bg-neutral-900/10\">\n            <CardTitle className=\"text-xs font-bold text-foreground flex items-center gap-2\">\n              <BookOpen className=\"size-4 text-accent\" />\n              <span>в”ҳв•ӣв–ҲГ®в”ҳГӘв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГјв•ӘВәв–ҲГ®в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв•ўв”ҳГ в–ҲГ®в”ҳГ в”ҳГ§ в”ҳГјв”ҳГҘв–ҲГ®</span>\n            </CardTitle>\n          </CardHeader>\n          <CardContent className=\"p-4 pt-4\">\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n              {article.attachments.map((att, i) => (\n                <a\n                  key={i}\n                  href={att.url}\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"flex items-center justify-between rounded-lg border border-border/75 p-3 text-xs font-semibold transition-all hover:bg-surface-hover hover:border-accent/30\"\n                >\n                  <span className=\"truncate max-w-[70%]\">{att.name}</span>\n                  <span className=\"text-[9px] text-foreground-muted font-mono uppercase bg-neutral-900 px-1.5 py-0.5 rounded border border-neutral-800\">{att.type}</span>\n                </a>\n              ))}\n            </div>\n          </CardContent>\n        </Card>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\knowledge\\page.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadArticles'. Either include it or remove the dependency array.","line":34,"column":6,"nodeType":"ArrayExpression","endLine":34,"endColumn":37,"suggestions":[{"desc":"Update the dependencies array to be: [accessToken, loadArticles, selectedCategory]","fix":{"range":[1036,1067],"text":"[accessToken, loadArticles, selectedCategory]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { Input } from '@/components/ui/input'\nimport { jalali } from '@/lib/fa'\nimport { BookOpen, Search, FileText, Pencil, Plus } from 'lucide-react'\nimport Link from 'next/link'\n\ninterface Article {\n  id: string\n  title: string\n  slug: string\n  body: string\n  category: string | null\n  tags: string | null\n  createdAt: string\n  author?: { name: string }\n}\n\nexport default function KnowledgePage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const user = useAuthStore((s) => s.user)\n  const [articles, setArticles] = useState<Article[]>([])\n  const [loading, setLoading] = useState(true)\n  const [search, setSearch] = useState('')\n  const [selectedCategory, setSelectedCategory] = useState<string | null>(null)\n\n  useEffect(() => {\n    void loadArticles()\n  }, [accessToken, selectedCategory])\n\n  async function loadArticles() {\n    if (!accessToken) return\n    setLoading(true)\n    try {\n      const params = new URLSearchParams()\n      if (selectedCategory) params.set('category', selectedCategory)\n      if (search) params.set('q', search)\n\n      const res = await fetch(`/api/knowledge?${params}`, {\n        headers: { Authorization: `Bearer ${accessToken}` },\n      })\n      if (res.ok) {\n        const data = await res.json()\n        setArticles(data.data?.items ?? [])\n      }\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  const categories = [\n    'в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®',\n    'в•ӘГів•Әв”Өв”ҳГҘв•ӘВәв–ҲГ®в–ҲГ® в•ӘВҝв•ӘВә в•ӘВ¬в•ӘВјв”ҳГ§в–ҲГ®в•Әв–“в•ӘВәв•ӘВ¬',\n    'в•Әв–’в”ҳГӘв–ҲГ®в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВәв•Әв•ўв•Әв•–в•Әв–’в•ӘВәв•Әв–’в–ҲГ®',\n    'в”ҳГҘв”ҳГ©в•Әв”Өв”ҳГ§О“ГҮГ®в•ӘВ«в”ҳГӘв•ӘВәв”ҳГҘв–ҲГ® в”ҳГ в•Әв”Ӯв–ҲГ®в•Әв–’',\n    'в”ҳГ в”ҳГ©в•Әв–’в•Әв–’в•ӘВәв•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬',\n    'в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨ в•ӘВҝв•ӘВәв–ҲГ®в”ҢвҢҗв”ҳГӘв•ӘВ¬ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’',\n  ]\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4\" dir=\"rtl\">\n      {/* Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-border pb-4 select-none\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg-mobile md:text-headline-lg text-foreground flex items-center gap-2\">\n            <BookOpen className=\"size-6 text-accent\" />\n            в•ӘВ»в•ӘВәв”ҳГҘв•Әв”ӨО“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВ«в•Әв•– в–Ҳв–’\n          </h1>\n          <p className=\"text-sm text-foreground-muted mt-1\">\n            в”ҳГ в•ӘВ«в•Әв–“в”ҳГҘ в•ӘВјв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГӘв•ӘВјв”ҳГӘв”ҳв•ӣв•Әв–‘в–ҲГ®в•Әв–’ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГӘв•Әв–’в•ӘВәв”ҳГӨв•Әв•Јв”ҳГ в”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВәв•ӘГ® в”ҳГјв•Әв–’в”ҳГ О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГјв”ҳГҘв–ҲГ®в•ӘГ® в”ҳГҘв”ҳГ©в•Әв”Өв”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в•Әв–’в”ҳГӘв–ҲГ®в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв–ҲГ®в•ӘВәв•ӘВ¬в–ҲГ® в•ӘВ«в•Әв•– в–Ҳв–’ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ\n          </p>\n        </div>\n        {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n          <Link href=\"/admin/knowledge\" className=\"shrink-0\">\n            <Button size=\"sm\" className=\"h-9 text-xs gap-1.5 cursor-pointer bg-accent hover:bg-accent-hover text-white rounded-lg shadow-md shadow-accent/15 font-semibold\">\n              <Plus className=\"size-4\" />\n              <span>в”ҳГ в•ӘВ»в–ҲГ®в•Әв–’в–ҲГ®в•ӘВ¬ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</span>\n            </Button>\n          </Link>\n        )}\n      </div>\n\n      {/* Search */}\n      <div className=\"relative\">\n        <Search className=\"absolute start-3 top-1/2 size-4 -translate-y-1/2 text-foreground-muted\" />\n        <Input\n          value={search}\n          onChange={(e) => setSearch(e.target.value)}\n          onKeyDown={(e) => e.key === 'Enter' && loadArticles()}\n          placeholder=\"в•ӘВјв•Әв”Ӯв•ӘВ¬в•ӘВјв”ҳГӘ в•ӘВ»в•Әв–’ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬в•ӘГ® в•ӘВ¬в”ҢВ»О“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҳГ в•ӘВ¬в”ҳГӘв”ҳГҘ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§...\"\n          className=\"pe-9 ps-9\"\n        />\n      </div>\n\n      {/* Categories */}\n      <div className=\"flex flex-wrap gap-2\">\n        <Button\n          variant={selectedCategory === null ? 'default' : 'outline'}\n          size=\"sm\"\n          onClick={() => setSelectedCategory(null)}\n          className=\"h-8 text-xs cursor-pointer rounded-lg\"\n        >\n          в”ҳГ§в”ҳГ в”ҳГ§ в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬\n        </Button>\n        {categories.map((cat) => (\n          <Button\n            key={cat}\n            variant={selectedCategory === cat ? 'default' : 'outline'}\n            size=\"sm\"\n            onClick={() => setSelectedCategory(cat)}\n            className=\"h-8 text-xs cursor-pointer rounded-lg\"\n          >\n            {cat}\n          </Button>\n        ))}\n      </div>\n\n      {/* Articles Grid / List */}\n      {loading ? (\n        <div className=\"space-y-3\">\n          {Array.from({ length: 4 }).map((_, i) => (\n            <div\n              key={i}\n              className=\"h-24 animate-pulse rounded-lg border border-border bg-background-subtle\"\n            />\n          ))}\n        </div>\n      ) : articles.length === 0 ? (\n        <Card>\n          <CardContent className=\"flex flex-col items-center justify-center py-12\">\n            <BookOpen className=\"mb-3 size-10 text-foreground-muted\" />\n            <p className=\"text-sm text-foreground-muted\">в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в•Әв”Ӯв•ӘВ¬в”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»</p>\n          </CardContent>\n        </Card>\n      ) : (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n          {articles.map((article) => (\n            <div key={article.id} className=\"relative group\">\n              <Link href={`/knowledge/${article.slug}`} className=\"block\">\n                <Card className=\"transition-all hover:bg-surface-hover hover:border-accent/30 bg-surface/40 backdrop-blur-md rounded-xl overflow-hidden shadow-sm h-full flex flex-col justify-between\">\n                  <CardContent className=\"p-4 flex flex-col gap-2\">\n                    <div className=\"flex items-center gap-2\">\n                      <FileText className=\"size-4 text-accent shrink-0\" />\n                      <span className=\"text-sm font-semibold text-foreground truncate max-w-[85%]\">\n                        {article.title}\n                      </span>\n                    </div>\n                    {article.category && (\n                      <Badge className=\"w-fit bg-accent/10 text-accent text-[10px] font-semibold border-transparent select-none\">\n                        {article.category}\n                      </Badge>\n                    )}\n                    <div className=\"mt-2 flex items-center gap-3 font-mono text-[10px] text-foreground-muted border-t border-border/20 pt-2\">\n                      <span>в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВҪв•ӘВҝв•ӘВ¬: {jalali(article.createdAt)}</span>\n                      {article.author && <span>в”ҳГҘв”ҳГӘв–ҲГ®в•Әв”Ӯв”ҳГҘв•ӘВ»в”ҳГ§: {article.author.name}</span>}\n                    </div>\n                  </CardContent>\n                </Card>\n              </Link>\n              \n              {/* Overlay Edit Button for Admins */}\n              {(user?.roleKey === 'admin' || user?.roleKey === 'super_admin') && (\n                <div className=\"absolute left-4 top-1/2 -translate-y-1/2 z-10 opacity-0 group-hover:opacity-100 transition-all duration-200\">\n                  <Link href={`/admin/knowledge?edit=${article.slug}`}>\n                    <Button\n                      size=\"icon-sm\"\n                      variant=\"ghost\"\n                      className=\"size-8 text-foreground-muted hover:text-accent hover:bg-accent/5 rounded-lg border border-border/60 bg-background/85 backdrop-blur shadow-sm cursor-pointer\"\n                      title=\"в”ҳГӘв–ҲГ®в•Әв–’в•ӘВәв–ҲГ®в•Әв”Ө в”ҳГ в”ҳГ©в•ӘВәв”ҳГӨв”ҳГ§ в•ӘВ»в•ӘВәв”ҳГҘв•Әв”Өв”ҳГҘв•ӘВәв”ҳГ в”ҳГ§\"\n                    >\n                      <Pencil className=\"size-4\" />\n                    </Button>\n                  </Link>\n                </div>\n              )}\n            </div>\n          ))}\n        </div>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\leaderboard\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardHeader' is defined but never used.","line":5,"column":29,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":39,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CardHeader"},"fix":{"range":[140,152],"text":""},"desc":"Remove unused variable \"CardHeader\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'CardTitle' is defined but never used.","line":5,"column":41,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":50,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"CardTitle"},"fix":{"range":[152,163],"text":""},"desc":"Remove unused variable \"CardTitle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'jalali' is defined but never used.","line":7,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":22,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"jalali"},"fix":{"range":[253,261],"text":""},"desc":"Remove unused variable \"jalali\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'TrendingUp' is defined but never used.","line":8,"column":39,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":49,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"TrendingUp"},"fix":{"range":[316,328],"text":""},"desc":"Remove unused variable \"TrendingUp\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'User' is defined but never used.","line":8,"column":51,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":55,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"User"},"fix":{"range":[328,334],"text":""},"desc":"Remove unused variable \"User\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Star' is defined but never used.","line":8,"column":57,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":61,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Star"},"fix":{"range":[334,340],"text":""},"desc":"Remove unused variable \"Star\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState, useMemo } from 'react'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { toFa, jalali } from '@/lib/fa'\nimport { Trophy, Medal, Crown, Award, TrendingUp, User, Star, ChevronDown } from 'lucide-react'\nimport { cn } from '@/lib/utils'\n\ninterface TopEntry {\n  rank: number\n  employeeId: string\n  name: string\n  avatar: string\n  dept: string\n  score: number\n}\n\ninterface MyRank {\n  rank: number | null\n  percentile: number\n  score: number\n  totalCount: number\n}\n\ninterface LeaderboardData {\n  topFive: TopEntry[]\n  myPrivateRank: MyRank\n}\n\n// Calculate current Jalali period\nfunction getCurrentJalaliPeriod(): string {\n  const d = new Date()\n  const gy = d.getFullYear()\n  const gm = d.getMonth() + 1\n  const gd = d.getDate()\n  const g_d_m = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334]\n  const gy2 = gm > 2 ? gy + 1 : gy\n  let days =\n    355666 +\n    365 * gy +\n    Math.floor((gy2 + 3) / 4) -\n    Math.floor((gy2 + 99) / 100) +\n    Math.floor((gy2 + 399) / 400) +\n    gd +\n    g_d_m[gm - 1]\n  let jy = -1595 + 33 * Math.floor(days / 12053)\n  days %= 12053\n  jy += 4 * Math.floor(days / 1461)\n  days %= 1461\n  if (days > 365) {\n    jy += Math.floor((days - 1) / 365)\n    days = (days - 1) % 365\n  }\n  const jm = days < 186 ? 1 + Math.floor(days / 31) : 7 + Math.floor((days - 186) / 30)\n  return `${jy}-${String(jm).padStart(2, '0')}`\n}\n\nconst JALALI_MONTHS = [\n  'в”ҳГјв•Әв–’в”ҳГӘв•Әв–’в•ӘВ»в–ҲГ®в”ҳГҘ', 'в•ӘВәв•Әв–’в•ӘВ»в–ҲГ®в•ӘВҝв”ҳГ§в•Әв”Өв•ӘВ¬', 'в•ӘВ«в•Әв–’в•ӘВ»в•ӘВәв•ӘВ»', 'в•ӘВ¬в–ҲГ®в•Әв–’', 'в”ҳГ в•Әв–’в•ӘВ»в•ӘВәв•ӘВ»', 'в•Әв”Өв”ҳГ§в•Әв–’в–ҲГ®в”ҳГӘв•Әв–’',\n  'в”ҳГ в”ҳГ§в•Әв–’', 'в•ӘГів•ӘВҝв•ӘВәв”ҳГҘ', 'в•ӘГів•Әв–‘в•Әв–’', 'в•ӘВ»в–ҲГ®', 'в•ӘВҝв”ҳГ§в”ҳГ в”ҳГҘ', 'в•ӘВәв•Әв”Ӯв”ҳГјв”ҳГҘв•ӘВ»',\n]\n\nfunction formatPeriod(periodId: string): string {\n  const [year, month] = periodId.split('-')\n  return `${JALALI_MONTHS[parseInt(month) - 1]} ${year}`\n}\n\nexport default function LeaderboardPage() {\n  const accessToken = useAuthStore((s) => s.accessToken)\n  const userId = useAuthStore((s) => s.user?.id)\n\n  const currentPeriod = useMemo(() => getCurrentJalaliPeriod(), [])\n  const [selectedPeriod, setSelectedPeriod] = useState(currentPeriod)\n  const [data, setData] = useState<LeaderboardData | null>(null)\n  const [loading, setLoading] = useState(true)\n  const [error, setError] = useState('')\n\n  // Generate last 6 months for selector\n  const periodsList = useMemo(() => {\n    const [y, m] = currentPeriod.split('-').map(Number)\n    const list: string[] = []\n    for (let i = 0; i < 6; i++) {\n      let month = m - i\n      let year = y\n      if (month <= 0) { month += 12; year -= 1 }\n      list.push(`${year}-${String(month).padStart(2, '0')}`)\n    }\n    return list\n  }, [currentPeriod])\n\n  useEffect(() => {\n    if (!accessToken) return\n    setLoading(true)\n    setError('')\n    fetch(`/api/performance/leaderboard?periodId=${selectedPeriod}`, {\n      headers: { Authorization: `Bearer ${accessToken}` },\n    })\n      .then((r) => r.json())\n      .then((json) => {\n        if (json.data) setData(json.data)\n        else setError(json.error ?? 'в•ӘВ«в•Әв•–в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ»в•Әв–’в–ҲГ®в•ӘВәв”ҳГјв•ӘВ¬ в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§')\n      })\n      .catch(() => setError('в•ӘВ«в•Әв•–в•ӘВәв–ҲГ® в•Әв”Өв•ӘВҝв”ҢвҢҗв”ҳГ§'))\n      .finally(() => setLoading(false))\n  }, [accessToken, selectedPeriod])\n\n  const podiumOrder = [1, 0, 2] // silver, gold, bronze\n  const podiumConfig = [\n    {\n      icon: Medal,\n      ringColor: 'ring-neutral-400/30',\n      bgIcon: 'bg-neutral-200/20 dark:bg-neutral-700/30',\n      textColor: 'text-neutral-400',\n      label: 'вүЎЖ’Г‘ГӘ',\n    },\n    {\n      icon: Crown,\n      ringColor: 'ring-warning/40',\n      bgIcon: 'bg-warning/10',\n      textColor: 'text-warning',\n      label: 'вүЎЖ’Г‘Г§',\n      isBig: true,\n    },\n    {\n      icon: Award,\n      ringColor: 'ring-orange-400/30',\n      bgIcon: 'bg-orange-400/10',\n      textColor: 'text-orange-400',\n      label: 'вүЎЖ’Г‘Г«',\n    },\n  ]\n\n  return (\n    <div className=\"flex flex-1 flex-col gap-6 p-4 max-w-2xl mx-auto w-full\" dir=\"rtl\">\n      {/* Header */}\n      <div className=\"flex items-start justify-between gap-4\">\n        <div>\n          <h1 className=\"text-xl font-bold text-foreground flex items-center gap-2\">\n            <Trophy className=\"size-6 text-warning\" />\n            в•ӘВјв•ӘВ»в”ҳГӘв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВҝв•Әв–’в•ӘВ¬в•Әв–’\n          </h1>\n          <p className=\"text-sm text-foreground-muted mt-0.5\">\n            в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ»\n          </p>\n        </div>\n\n        {/* Period Dropdown */}\n        <div className=\"relative\">\n          <select\n            value={selectedPeriod}\n            onChange={(e) => setSelectedPeriod(e.target.value)}\n            className=\"appearance-none h-9 rounded-lg border border-outline-variant bg-surface-container px-3 pe-8 text-sm text-foreground focus:border-accent focus:ring-1 focus:ring-accent outline-none cursor-pointer\"\n          >\n            {periodsList.map((p) => (\n              <option key={p} value={p}>{formatPeriod(p)}</option>\n            ))}\n          </select>\n          <ChevronDown className=\"absolute inset-y-0 end-2 my-auto size-4 text-foreground-muted pointer-events-none\" />\n        </div>\n      </div>\n\n      {loading ? (\n        <div className=\"space-y-3\">\n          <div className=\"grid grid-cols-3 gap-3 h-36\">\n            {[0, 1, 2].map((i) => (\n              <div key={i} className=\"animate-pulse rounded-xl bg-surface-container-low border border-border\" />\n            ))}\n          </div>\n          {[0, 1, 2].map((i) => (\n            <div key={i} className=\"h-14 animate-pulse rounded-lg bg-surface-container-low border border-border\" />\n          ))}\n        </div>\n      ) : error ? (\n        <Card>\n          <CardContent className=\"flex flex-col items-center justify-center py-10 text-center gap-2\">\n            <Trophy className=\"size-10 text-foreground-muted/40\" />\n            <p className=\"text-sm text-foreground-muted\">{error}</p>\n          </CardContent>\n        </Card>\n      ) : !data || data.topFive.length === 0 ? (\n        <Card>\n          <CardContent className=\"flex flex-col items-center justify-center py-12 text-center gap-2\">\n            <Trophy className=\"size-10 text-foreground-muted/40\" />\n            <p className=\"text-sm text-foreground-muted\">\n              в•ӘВ»в•ӘВәв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ <strong>{formatPeriod(selectedPeriod)}</strong> в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬\n            </p>\n          </CardContent>\n        </Card>\n      ) : (\n        <div className=\"space-y-4\">\n          {/* My Rank Card (private) */}\n          {data.myPrivateRank && (\n            <div className=\"rounded-xl border border-accent/20 bg-accent/5 p-4 flex items-center gap-4\">\n              <div className=\"flex size-12 items-center justify-center rounded-full bg-accent/10 text-accent font-bold text-lg\">\n                {data.myPrivateRank.rank ? toFa(data.myPrivateRank.rank) : 'О“ГҮГҙ'}\n              </div>\n              <div className=\"flex-1 min-w-0\">\n                <p className=\"text-xs text-foreground-muted\">в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•Әв”Өв”ҳГ в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§</p>\n                <p className=\"text-sm font-semibold text-foreground\">\n                  в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“: <span className=\"text-accent\">{toFa(Math.round(data.myPrivateRank.score))}</span>\n                  {' '}в•ӘВәв•Әв–“ {toFa(data.myPrivateRank.totalCount)} в”ҳГҘв”ҳГјв•Әв–’\n                </p>\n              </div>\n              <div className=\"text-end\">\n                <p className=\"text-xs text-foreground-muted\">в•Әв•Ўв•ӘВ»в”ҢвҢҗ</p>\n                <p className=\"text-sm font-bold text-success\">\n                  {toFa(Math.round(data.myPrivateRank.percentile))}%\n                </p>\n              </div>\n            </div>\n          )}\n\n          {/* Podium - top 3 */}\n          {data.topFive.length >= 3 && (\n            <div className=\"grid grid-cols-3 gap-2 items-end\">\n              {podiumOrder.map((rank, col) => {\n                const entry = data.topFive[rank]\n                if (!entry) return <div key={col} />\n                const cfg = podiumConfig[col]\n                const Icon = cfg.icon\n                const isMe = entry.employeeId === userId\n                return (\n                  <Card\n                    key={entry.employeeId}\n                    className={cn(\n                      'relative overflow-hidden transition-all',\n                      cfg.isBig ? 'ring-2' : 'ring-1',\n                      cfg.ringColor,\n                      isMe && 'ring-2 ring-accent/50',\n                    )}\n                  >\n                    <CardContent className={cn('flex flex-col items-center gap-2 p-3 text-center', cfg.isBig ? 'pt-8 pb-5' : 'pt-5 pb-4')}>\n                      {/* Medal emoji */}\n                      <span className=\"text-xl leading-none\">{cfg.label}</span>\n                      {/* Avatar circle */}\n                      <div className={cn('flex size-10 items-center justify-center rounded-full', cfg.bgIcon)}>\n                        <Icon className={cn('size-5', cfg.textColor)} />\n                      </div>\n                      <div className=\"w-full\">\n                        <p className=\"text-xs font-semibold text-foreground truncate leading-tight\">{entry.name}</p>\n                        {entry.dept && (\n                          <p className=\"text-[10px] text-foreground-muted truncate mt-0.5\">{entry.dept}</p>\n                        )}\n                        <p className={cn('text-sm font-bold mt-1', cfg.textColor)}>\n                          {toFa(Math.round(entry.score))}\n                        </p>\n                      </div>\n                      {isMe && (\n                        <Badge variant=\"outline\" className=\"text-[9px] px-1 py-0 border-accent/40 text-accent\">\n                          в•Әв”Өв”ҳГ в•ӘВә\n                        </Badge>\n                      )}\n                    </CardContent>\n                  </Card>\n                )\n              })}\n            </div>\n          )}\n\n          {/* Ranks 4-5 and beyond */}\n          {data.topFive.slice(3).map((entry) => {\n            const isMe = entry.employeeId === userId\n            return (\n              <Card key={entry.employeeId} className={cn('transition-all', isMe && 'ring-1 ring-accent/30 bg-accent/5')}>\n                <CardContent className=\"flex items-center gap-3 p-3\">\n                  <div className=\"flex size-8 shrink-0 items-center justify-center rounded-full bg-surface-container-high text-xs font-bold text-foreground-muted\">\n                    {toFa(entry.rank)}\n                  </div>\n                  <div className=\"flex-1 min-w-0\">\n                    <div className=\"text-sm font-medium text-foreground truncate flex items-center gap-1\">\n                      {entry.name}\n                      {isMe && <Badge variant=\"outline\" className=\"text-[9px] px-1 py-0 border-accent/40 text-accent\">в•Әв”Өв”ҳГ в•ӘВә</Badge>}\n                    </div>\n                    {entry.dept && (\n                      <div className=\"text-[11px] text-foreground-muted truncate\">{entry.dept}</div>\n                    )}\n                  </div>\n                  <div className=\"text-sm font-bold text-foreground-muted shrink-0\">\n                    {toFa(Math.round(entry.score))}\n                    <span className=\"text-[10px] font-normal text-foreground-muted/60 ms-1\">pt</span>\n                  </div>\n                </CardContent>\n              </Card>\n            )\n          })}\n\n          {/* Note */}\n          <p className=\"text-center text-[11px] text-foreground-muted/70 pt-2\">\n            * в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҳГҘв•Әв–’в”ҳГ в•ӘВәв”ҳГӨО“ГҮГ®в•Әв”Ӯв•ӘВәв•Әв–“в–ҲГ®О“ГҮГ®в•Әв”Өв•ӘВ»в”ҳГ§ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв•Јв”ҳГ в”ҳГӨв”ҢвҢҗв•Әв–’в•ӘВ» в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ {formatPeriod(selectedPeriod)}\n          </p>\n        </div>\n      )}\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"D:\\metro-line1-app\\src\\app\\(app)\\learning\\exams\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'XCircle' is defined but never used.","line":17,"column":38,"nodeType":"Identifier","messageId":"unusedVar","endLine":17,"endColumn":45,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"XCircle"},"fix":{"range":[523,532],"text":""},"desc":"Remove unused variable \"XCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AlertCircle' is defined but never used.","line":17,"column":53,"nodeType":"Identifier","messageId":"unusedVar","endLine":17,"endColumn":64,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AlertCircle"},"fix":{"range":[538,551],"text":""},"desc":"Remove unused variable \"AlertCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'HelpCircle' is defined but never used.","line":17,"column":76,"nodeType":"Identifier","messageId":"unusedVar","endLine":17,"endColumn":86,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"HelpCircle"},"fix":{"range":[561,573],"text":""},"desc":"Remove unused variable \"HelpCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'COMPLETED_EXAMS' is assigned a value but never used.","line":49,"column":7,"nodeType":"Identifier","messageId":"unusedVar","endLine":49,"endColumn":22},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'PENDING_EXAMS' is assigned a value but never used.","line":72,"column":7,"nodeType":"Identifier","messageId":"unusedVar","endLine":72,"endColumn":20},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'setRank' is assigned a value but never used.","line":99,"column":16,"nodeType":"Identifier","messageId":"unusedVar","endLine":99,"endColumn":23},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":122,"column":41,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":122,"endColumn":44,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3363,3366],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3363,3366],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":7,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\n\nimport { useEffect, useState } from 'react'\nimport Link from 'next/link'\nimport { useAuthStore } from '@/features/auth'\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'\nimport { Badge } from '@/components/ui/badge'\nimport { Button } from '@/components/ui/button'\nimport { TopAppBar } from '@/components/shared/top-app-bar'\nimport {\n  Dialog,\n  DialogContent,\n  DialogHeader,\n  DialogTitle,\n  DialogDescription,\n} from '@/components/ui/dialog'\nimport { Award, Trophy, CheckCircle, XCircle, Play, AlertCircle, FileText, HelpCircle, Clock, Printer, Train, ShieldCheck } from 'lucide-react'\nimport { toFa } from '@/lib/fa'\n\ninterface Certificate {\n  userName: string\n  courseTitle: string\n  score: number\n  date: string\n  id: string\n}\n\ninterface ExamRecord {\n  id: string\n  title: string\n  slug: string\n  totalQuestions: number\n  correctAnswers: number\n  score: number // percentage\n  status: 'passed' | 'failed'\n  date: string\n}\n\ninterface PendingExam {\n  id: string\n  title: string\n  slug: string\n  category: string\n  questionCount: number\n  mandatory: boolean\n  dueDate?: string\n}\n\nconst COMPLETED_EXAMS: ExamRecord[] = [\n  {\n    id: 'ex-1',\n    title: 'в”ҳГ в”ҳГ©в•Әв–’в•Әв–’в•ӘВәв•ӘВ¬ в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВ«в•Әв•– в–Ҳв–’ (в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВә)',\n    slug: 'в”ҳГ в”ҳГ©в•Әв–’в•Әв–’в•ӘВәв•ӘВ¬-в•Әв•Јв”ҳГ в”ҳГӘв”ҳГ в–ҲГ®-в•Әв”Ӯв–ҲГ®в•Әв–’-в”ҳГӘ-в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬-в•ӘВ«в•Әв•–-в–Ҳв–’-в•Әв”Ӯв–ҲГ®в”ҢВ»в”ҳГҘв•ӘВәв”ҳГӨО“ГҮГ®в”ҳГ§в•ӘВә',\n    totalQuestions: 3,\n    correctAnswers: 3,\n    score: 100,\n    status: 'passed',\n    date: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв–“/в–Ҳв–’в–Ҳв•Ў',\n  },\n  {\n    id: 'ex-2',\n    title: 'в•Әв•Јв–ҲГ®в•ӘВҝО“ГҮГ®в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ  в”ҳГ в”ҢвҢҗв•ӘВәв”ҳГҘв–ҲГ®в•Әв–“в”ҳГ  в•ӘВ»в•Әв–’в•ӘВҝ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•Әв”Ӯв•Әв–’в–ҲГ® в–Ҳв–’в–Ҳв–‘в–Ҳв–‘',\n    slug: 'в•Әв•Јв–ҲГ®в•ӘВҝО“ГҮГ®в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ®-в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ -в”ҳГ в”ҢвҢҗв•ӘВәв”ҳГҘв–ҲГ®в•Әв–“в”ҳГ -в•ӘВ»в•Әв–’в•ӘВҝ-в”ҳГ©в•Әв•–в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ®-в•Әв”Ӯв•Әв–’в–ҲГ®-в–Ҳв–’в–Ҳв–‘в–Ҳв–‘',\n    totalQuestions: 4,\n    correctAnswers: 3,\n    score: 75,\n    status: 'passed',\n    date: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ӯ/в–Ҳв–‘в–Ҳв–’',\n  },\n]\n\nconst PENDING_EXAMS: PendingExam[] = [\n  {\n    id: 'ex-p1',\n    title: 'в”ҳв•ӣв•Әв–’в”ҳГӘв•ӘВ¬в”ҢвҢҗв”ҳГӨ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в•ӘВ¬в•ӘВ«в”ҳГӨв–ҲГ®в”ҳГ§ в”ҳГ в•Әв”Ӯв•ӘВәв”ҳГјв•Әв–’в–ҲГ®в”ҳГҘ в•ӘВ»в•Әв–’ в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ в•ӘВ¬в”ҳГӘв”ҳГҘв”ҳГӨ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ',\n    slug: 'в”ҳв•ӣв•Әв–’в”ҳГӘв•ӘВ¬в”ҢвҢҗв”ҳГӨ-в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ®-в•ӘВ¬в•ӘВ«в”ҳГӨв–ҲГ®в”ҳГ§-в”ҳГ в•Әв”Ӯв•ӘВәв”ҳГјв•Әв–’в–ҲГ®в”ҳГҘ-в•ӘВ»в•Әв–’-в•ӘВ»в•ӘВәв•ӘВ«в”ҳГӨ-в•ӘВ¬в”ҳГӘв”ҳГҘв”ҳГӨ-в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ',\n    category: 'в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГӘ в•ӘВҝв•ӘВЎв•Әв–’в•ӘВәв”ҳГҘ',\n    questionCount: 3,\n    mandatory: true,\n    dueDate: 'в–Ҳв–’в–Ҳв”Өв–Ҳв–‘в–Ҳв•Ў/в–Ҳв–‘в–Ҳв”Ө/в–Ҳв–’в–Ҳв•Ў',\n  },\n  {\n    id: 'ex-p2',\n    title: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҢвҢҗв•ӘВәв”ҳГҘв–ҲГ®в”ҢвҢҗв–ҲГ® в”ҢвҢҗв”ҳГӨв•ӘВәв”ҢГҘ в”ҳГӘ в•ӘВҝв”ҳГӘв”ҢГҝв–ҲГ® в”ҳГ©в•Әв•–в•ӘВәв•Әв–’в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’в”ҳГӘв”ҳГҘО“ГҮГ®в•Әв”Өв”ҳГ§в•Әв–’в–ҲГ®',\n    slug: 'в•Әв”Ӯв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҳГ О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ®-в”ҳГ в”ҢвҢҗв•ӘВәв”ҳГҘв–ҲГ®в”ҢвҢҗв–ҲГ®-в”ҢвҢҗв”ҳГӨв•ӘВәв”ҢГҘ-в”ҳГӘ-в•ӘВҝв”ҳГӘв”ҢГҝв–ҲГ®',\n    category: 'в•Әв•Јв–ҲГ®в•ӘВҝО“ГҮГ®в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в”ҳГјв”ҳГҘв–ҲГ®',\n    questionCount: 4,\n    mandatory: false,\n  },\n]\n\nexport default function MyExamsPage() {\n  const user = useAuthStore((s) => s.user)\n  const accessToken = useAuthStore((s) => s.accessToken)\n\n  const [completedList, setCompletedList] = useState<ExamRecord[]>([])\n  const [pendingList, setPendingList] = useState<PendingExam[]>([])\n  const [points, setPoints] = useState(150) // в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҢВ»в–ҲГ®в”ҳГ в–ҲГ®в”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ®в•Әв”Өв”ҳГҘ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®\n  const [rank, setRank] = useState(12) // в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•ӘВ»в•Әв–’ в”ҳГ в–ҲГ®в•ӘВәв”ҳГҘ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ в•ӘВ«в•Әв•– в–Ҳв–’\n  const [selectedCert, setSelectedCert] = useState<Certificate | null>(null)\n\n  // в•ӘВ¬в”ҳГӨв•ӘВәв•Әв”Ө в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в”ҳГӨв”ҳГӘв•ӘВ» в•ӘВәв•Әв–“ в•ӘВ»в–ҲГ®в•ӘВ¬в•ӘВәв•ӘВҝв–ҲГ®в•Әв”Ӯ в•ӘВ»в•Әв–’ в•Әв•Ўв”ҳГӘв•Әв–’в•ӘВ¬ в”ҳГӨв•Әв–“в”ҳГӘв”ҳГ \n  useEffect(() => {\n    if (!accessToken) return\n    async function loadExams() {\n      try {\n        const profRes = await fetch('/api/profile', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        })\n        if (profRes.ok) {\n          const data = await profRes.json()\n          if (data.data && data.data.customFields?.points) {\n            setPoints(Number(data.data.customFields.points))\n          }\n        }\n\n        const postsRes = await fetch('/api/posts', {\n          headers: { Authorization: `Bearer ${accessToken}` },\n        })\n        if (postsRes.ok) {\n          const data = await postsRes.json()\n          const allPosts = data.data as any[]\n\n          // в”ҳГјв–ҲГ®в”ҳГӨв•ӘВ¬в•Әв–’ в”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГҘ в”ҳв•ӣв•Әв”Ӯв•ӘВ¬О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ®в–ҲГ® в”ҢвҢҗв”ҳГ§ в•ӘВ»в•ӘВәв•Әв–’в•ӘВәв–ҲГ® в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в”ҳГ§в•Әв”Ӯв•ӘВ¬в”ҳГҘв•ӘВ» (в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в”ҳГӘ в”ҢГҘв”ҳГҘв•ӘВ»в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®)\n          const quizPosts = allPosts.filter((p) => p.hasQuiz === true)\n\n          // в”ҳГҘв”ҳГ©в•Әв”Өв”ҳГ§О“ГҮГ®в”ҳГҘв”ҢВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳв•ӣв•ӘВәв•Әв”Ӯ в•Әв”Өв•ӘВ»в”ҳГ§\n          const completed = quizPosts\n            .filter((p) => p.isCompleted === true)\n            .map((p) => ({\n              id: p.id,\n              title: p.title,\n              slug: p.slug,\n              totalQuestions: 3, // в”ҳГјв•Әв–’в•Әв•ўв–ҲГ® в•ӘВҝв•Әв–’в•ӘВәв–ҲГ® в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬\n              correctAnswers: 3,\n              score: 100,\n              status: 'passed' as const,\n              date: p.createdAt.substring(0, 10).replace(/-/g, '/'),\n            }))\n\n          // в”ҳГҘв”ҳГ©в•Әв”Өв”ҳГ§О“ГҮГ®в”ҳГҘв”ҢВ»в•ӘВәв•Әв–’в–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ© в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ\n          const pending = quizPosts\n            .filter((p) => p.isCompleted === false)\n            .map((p) => ({\n              id: p.id,\n              title: p.title,\n              slug: p.slug,\n              category: p.category || (p.type === 'gallery' ? 'в”ҢВ»в•ӘВәв”ҳГӨв•Әв–’в–ҲГ® в”ҢГҘв”ҳГҘв•ӘВ»в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®' : 'в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в•ӘВ¬в•ӘВ«в•Әв•Ўв•Әв•Ўв–ҲГ®'),\n              questionCount: 3,\n              mandatory: p.mandatory,\n            }))\n\n          setCompletedList(completed)\n          setPendingList(pending)\n        }\n      } catch {\n        // dynamic exams load failed silently\n      }\n    }\n    loadExams()\n  }, [accessToken])\n\n  const passingRate = (completedList.filter((e) => e.status === 'passed').length / (completedList.length || 1)) * 100\n\n  return (\n    <div className=\"flex min-h-screen flex-col\" dir=\"rtl\">\n      <TopAppBar\n        title=\"в”ҢвҢҗв•ӘВәв•Әв–’в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳГӘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГҘ\"\n        subtitle=\"в•Әв”Ӯв”ҳГӘв•ӘВәв•ӘВҝв”ҳГ© в”ҢвҢҗв”ҳГӘв•ӘВӘв–ҲГ®в•Әв–“в”ҳГ§в•ӘВәв•ӘГ® в”ҳГҘв•ӘВ¬в•ӘВәв–ҲГ®в•ӘВј в•ӘВәв•Әв–’в•Әв–“в•Әв”Өв–ҲГ®в•ӘВәв•ӘВҝв–ҲГ®О“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ® в”ҳГӘ в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в”ҢВ»в–ҲГ®в”ҳГ в–ҲГ®в”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ®в•Әв”Өв”ҳГҘ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®\"\n      />\n\n      <main className=\"flex-1 p-4 pt-16 md:p-6 space-y-6\">\n        {/* Top Widgets / Stats Cards */}\n        <div className=\"grid grid-cols-1 gap-4 md:grid-cols-4\">\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в”ҳГ в•ӘВјв”ҳГ в”ҳГӘв•Әв•Ј в”ҢвҢҗв”ҳГӘв•ӘВӘв–ҲГ®в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©</p>\n                <h3 className=\"text-lg font-bold mt-1 text-success\">\n                  {toFa(completedList.filter((e) => e.status === 'passed').length)} в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ\n                </h3>\n              </div>\n              <div className=\"bg-success/10 p-2.5 rounded-lg text-success\">\n                <CheckCircle className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ» в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨв–ҲГ® в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә</p>\n                <h3 className=\"text-lg font-bold mt-1 text-foreground\">\n                  {toFa(Math.round(passingRate))} в•ӘВ»в•Әв–’в•Әв•Ўв•ӘВ»\n                </h3>\n              </div>\n              <div className=\"bg-info/10 p-2.5 rounded-lg text-info\">\n                <Award className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“ в”ҢвҢҗв”ҳГӨ в”ҢВ»в–ҲГ®в”ҳГ в–ҲГ®в”ҳГјв–ҲГ®в”ҢвҢҗв–ҲГ®в•Әв”Өв”ҳГҘ</p>\n                <h3 className=\"text-lg font-bold mt-1 text-accent\">\n                  {toFa(points)} в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“\n                </h3>\n              </div>\n              <div className=\"bg-accent/10 p-2.5 rounded-lg text-accent\">\n                <Trophy className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n\n          <Card className=\"bg-surface-container-low border-border-subtle\">\n            <CardContent className=\"pt-4 flex items-center justify-between\">\n              <div>\n                <p className=\"text-xs text-foreground-muted\">в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ в•Әв”Өв”ҳГ в•ӘВә в•ӘВ»в•Әв–’ в•ӘВ«в•Әв•– в–Ҳв–’</p>\n                <h3 className=\"text-lg font-bold mt-1 text-amber-500\">\n                  в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§ {toFa(rank)}\n                </h3>\n              </div>\n              <div className=\"bg-amber-500/10 p-2.5 rounded-lg text-amber-500\">\n                <Trophy className=\"size-5\" />\n              </div>\n            </CardContent>\n          </Card>\n        </div>\n\n        <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-3\">\n          {/* Main: Completed Exams Table */}\n          <div className=\"lg:col-span-2 space-y-6\">\n            <Card className=\"border-border-subtle bg-surface-container-low\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <CheckCircle className=\"size-4 text-success\" />\n                  в”ҳГӨв–ҲГ®в•Әв”Ӯв•ӘВ¬ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВә в”ҳГӘ в”ҢвҢҗв”ҳГӘв•ӘВӘв–ҲГ®в•Әв–“в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ¬в”ҢвҢҗв”ҳГ в–ҲГ®в”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨв–ҲГ®\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"p-0\">\n                {completedList.length === 0 ? (\n                  <div className=\"flex flex-col items-center justify-center p-8 text-foreground-muted\">\n                    <FileText className=\"size-10 mb-2 opacity-50\" />\n                    <p className=\"text-sm\">в”ҳГ§в”ҳГҘв”ҳГӘв•Әв–“ в•ӘВ»в•Әв–’ в”ҳГ§в–ҲГ®в”ҢГҘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘв–ҲГ® в•Әв”Өв•Әв–’в”ҢвҢҗв•ӘВ¬ в”ҳГҘв”ҢвҢҗв•Әв–’в•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв–ҲГ®в•ӘВ».</p>\n                  </div>\n                ) : (\n                  <div className=\"overflow-x-auto\">\n                    <table className=\"w-full text-right border-collapse\">\n                      <thead>\n                        <tr className=\"border-b border-border-subtle bg-surface-container text-foreground-muted text-xs font-semibold\">\n                          <th className=\"p-3\">в•Әв•Јв”ҳГҘв”ҳГӘв•ӘВәв”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ®</th>\n                          <th className=\"p-3\">в”ҳв•ӣв•ӘВәв•Әв”Ӯв•ӘВ« в•Әв•Ўв•ӘВЎв–ҲГ®в•ӘВЎ</th>\n                          <th className=\"p-3\">в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в•ӘВәв•Әв–’в•Әв–“в•Әв”Өв–ҲГ®в•ӘВәв•ӘВҝв–ҲГ®</th>\n                          <th className=\"p-3\">в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•ӘВҪв•ӘВҝв•ӘВ¬</th>\n                          <th className=\"p-3 text-center\">в”ҳГӘв•Әв•ўв•Әв•Јв–ҲГ®в•ӘВ¬</th>\n                          <th className=\"p-3 text-left\">в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-border-subtle text-sm\">\n                        {completedList.map((exam) => (\n                          <tr key={exam.id} className=\"hover:bg-surface-hover\">\n                            <td className=\"p-3 font-semibold text-foreground\">\n                              <Link href={`/content/${exam.slug}`} className=\"hover:underline hover:text-accent\">\n                                {exam.title}\n                              </Link>\n                            </td>\n                            <td className=\"p-3 font-mono text-xs\">\n                              {toFa(exam.correctAnswers)} в•ӘВәв•Әв–“ {toFa(exam.totalQuestions)}\n                            </td>\n                            <td className=\"p-3 font-mono font-bold\">\n                              {toFa(exam.score)}в”ҳВ¬\n                            </td>\n                            <td className=\"p-3 font-mono text-xs\">{exam.date}</td>\n                            <td className=\"p-3 text-center\">\n                              <Badge\n                                variant=\"outline\"\n                                className={\n                                  exam.status === 'passed'\n                                    ? 'bg-success/15 text-success border-success/30'\n                                    : 'bg-critical/10 text-critical border-critical/20'\n                                }\n                              >\n                                {exam.status === 'passed' ? 'в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨ в•Әв”Өв•ӘВ»в”ҳГ§' : 'в”ҳГҘв–ҲГ®в•ӘВәв•Әв–“ в•ӘВҝв”ҳГ§ в•ӘВ¬в”ҳГӨв•ӘВәв•Әв”Ө в”ҳГ в•ӘВјв•ӘВ»в•ӘВ»'}\n                              </Badge>\n                            </td>\n                            <td className=\"p-3 text-left\">\n                              {exam.status === 'passed' ? (\n                                <Button\n                                  size=\"sm\"\n                                  variant=\"outline\"\n                                  onClick={() => setSelectedCert({\n                                    userName: user?.name || 'в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в”ҳГ©в•Әв•–в•ӘВәв•Әв–’ в•ӘВ«в•Әв•– в–Ҳв–’',\n                                    courseTitle: exam.title,\n                                    score: exam.score,\n                                    date: exam.date,\n                                    id: `CERT-${exam.id.toUpperCase()}-${user?.nationalId || '123'}`\n                                  })}\n                                  className=\"h-8 text-xs border-accent/25 hover:bg-accent/5 text-accent gap-1 cursor-pointer\"\n                                >\n                                  <Award className=\"size-3.5\" />\n                                  <span>в”ҳГ в•Әв”Өв•ӘВәв”ҳГ§в•ӘВ»в”ҳГ§ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®</span>\n                                </Button>\n                              ) : (\n                                <span className=\"text-xs text-foreground-muted\">-</span>\n                              )}\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n              </CardContent>\n            </Card>\n          </div>\n\n          {/* Sidebar Area: Pending Exams & Gamification */}\n          <div className=\"space-y-6\">\n            {/* Pending Exams */}\n            <Card className=\"border-border-subtle bg-surface-container-low\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Clock className=\"size-4 text-warning\" />\n                  в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВәв”ҳГҘв•ӘВ¬в•Әв••в•ӘВәв•Әв–’ в•Әв”Өв•Әв–’в”ҢвҢҗв•ӘВ¬\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-3\">\n                {pendingList.length === 0 ? (\n                  <div className=\"text-center py-6 text-foreground-muted text-xs\">\n                    вүЎЖ’ГҶГӯ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ в”ҳГ в•Әв•Јв”ҳГӨв”ҳГ©в–ҲГ® в”ҳГҘв•ӘВ»в•ӘВәв•Әв–’в–ҲГ®в•ӘВ»! в•ӘВ¬в”ҳГ в•ӘВәв”ҳГ в–ҲГ® в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§О“ГҮГ®в”ҳГ§в•ӘВә в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в•ӘВәв”ҳГҘв•ӘВјв•ӘВәв”ҳГ  в•Әв”Өв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв”ҳГҘв•ӘВ».\n                  </div>\n                ) : (\n                  pendingList.map((p) => (\n                    <div key={p.id} className=\"p-3 border border-border rounded-lg bg-surface flex flex-col gap-2 relative\">\n                      <div className=\"flex items-start justify-between\">\n                        <div>\n                          <h4 className=\"text-xs font-bold text-foreground leading-relaxed pe-14\">{p.title}</h4>\n                          <span className=\"text-[10px] text-foreground-muted font-semibold mt-0.5 block\">{p.category}</span>\n                        </div>\n                        <div className=\"absolute top-3 left-3 flex flex-col items-end gap-1\">\n                          {p.mandatory && (\n                            <Badge className=\"bg-critical/15 text-critical border-transparent text-[8px] font-bold\">\n                              в•ӘВәв”ҳГӨв•Әв–“в•ӘВәв”ҳГ в–ҲГ®\n                            </Badge>\n                          )}\n                        </div>\n                      </div>\n\n                      <div className=\"flex items-center justify-between mt-1 text-[10px] text-foreground-muted\">\n                        <span>в•ӘВ¬в•Әв•Јв•ӘВ»в•ӘВәв•ӘВ» в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬: {toFa(p.questionCount)} в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨ</span>\n                        {p.dueDate && <span className=\"text-critical font-bold\">в”ҳГ в”ҳГ§в”ҳГӨв•ӘВ¬: {p.dueDate}</span>}\n                      </div>\n\n                      <Link href={`/content/${p.slug}`} className=\"mt-2\">\n                        <Button size=\"sm\" className=\"w-full h-8 gap-1 text-xs\">\n                          <Play className=\"size-3.5 fill-current\" />\n                          <span>в•Әв”Өв•Әв–’в”ҳГӘв•Әв•Ј в”ҳГӘв–ҲГ®в•ӘВ»в–ҲГ®в”ҳГӘ в”ҳГӘ в•ӘГів•Әв–“в”ҳГ в”ҳГӘв”ҳГҘ</span>\n                        </Button>\n                      </Link>\n                    </div>\n                  ))\n                )}\n              </CardContent>\n            </Card>\n\n            {/* Leaderboard Summary (Gamification) */}\n            <Card className=\"border-border-subtle bg-surface-container-low\">\n              <CardHeader className=\"border-b border-border-subtle pb-3\">\n                <CardTitle className=\"text-sm font-semibold flex items-center gap-2\">\n                  <Trophy className=\"size-4 text-amber-500\" />\n                  в•ӘВҝв•Әв–’в•ӘВ¬в•Әв–’в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГ§в•ӘВәв–ҲГ® в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Ө в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в•ӘВәв”ҳГ§ в•ӘВ«в•Әв•– в–Ҳв–’\n                </CardTitle>\n              </CardHeader>\n              <CardContent className=\"pt-4 space-y-3\">\n                <div className=\"flex items-center justify-between text-xs p-2 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-600 font-bold\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"font-mono\">в–Ҳв–’.</span>\n                    <span>в•Әв”Ӯв–ҲГ®в•ӘВ» в•Әв–’в•Әв”Ӯв”ҳГӘв”ҳГӨ в•Әв•Јв•ӘВҝв•ӘВәв•Әв”Ӯв–ҲГ® (в•Әв–’в•ӘВәв”ҳГ§в•ӘВҝв•Әв–’ в•ӘВәв•Әв–’в•Әв”Өв•ӘВ»)</span>\n                  </div>\n                  <span className=\"font-mono\">в–Ҳв”Ӯв–Ҳв•Ўв–Ҳв–‘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“</span>\n                </div>\n\n                <div className=\"flex items-center justify-between text-xs p-2 rounded-lg bg-surface border border-border\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"font-mono\">в–Ҳв–“.</span>\n                    <span>в”ҳГ в•ӘВЎв”ҳГ в”ҳГӘв•ӘВ» в•Әв–’в”ҳГ в•Әв•ўв•ӘВәв”ҳГҘв–ҲГ®</span>\n                  </div>\n                  <span className=\"font-mono\">в–Ҳв”Ӯв–Ҳв–‘в–Ҳв–‘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“</span>\n                </div>\n\n                <div className=\"flex items-center justify-between text-xs p-2 rounded-lg bg-surface border border-border\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"font-mono\">в–Ҳв”Ӯ.</span>\n                    <span>в•ӘВәв”ҳГ в–ҲГ®в•Әв–’в•ӘВЎв•Әв”Ӯв–ҲГ®в”ҳГҘ в•Әв–“в•ӘВәв•Әв–’в•Әв•Јв–ҲГ®</span>\n                  </div>\n                  <span className=\"font-mono\">в–Ҳв–“в–Ҳв••в–Ҳв–‘ в•ӘВәв”ҳГ в•ӘВ¬в–ҲГ®в•ӘВәв•Әв–“</span>\n                </div>\n\n                <div className=\"text-center pt-2\">\n                  <Link href=\"/leaderboard\">\n                    <Button variant=\"ghost\" size=\"sm\" className=\"text-xs text-accent\">\n                      в”ҳГ в•Әв”Өв•ӘВәв”ҳГ§в•ӘВ»в”ҳГ§ в•Әв–’в•ӘВ¬в•ӘВҝв”ҳГ§О“ГҮГ®в•ӘВҝв”ҳГҘв•ӘВ»в–ҲГ® в”ҢвҢҗв”ҳГӨ в”ҳв•ӣв•Әв–’в•Әв”Ӯв”ҳГҘв”ҳГӨ О“ГҘГү\n                    </Button>\n                  </Link>\n                </div>\n              </CardContent>\n            </Card>\n          </div>\n        </div>\n      </main>\n\n      {/* Certificate Viewer Modal Dialog */}\n      <Dialog open={!!selectedCert} onOpenChange={(open) => !open && setSelectedCert(null)}>\n        <DialogContent className=\"sm:max-w-2xl bg-neutral-900 border-neutral-800 text-white p-6 max-h-[90vh] overflow-y-auto\" dir=\"rtl\">\n          <DialogHeader>\n            <DialogTitle className=\"text-right text-base font-bold text-accent flex items-center gap-2\">\n              <Award className=\"size-5\" />\n              <span>в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘГів”ҳГ в”ҳГӘв•Әв–“в•Әв”Өв–ҲГ® в•ӘВәв”ҳГӨв”ҢвҢҗв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв–ҲГ®в”ҢвҢҗв–ҲГ®</span>\n            </DialogTitle>\n            <DialogDescription className=\"text-right text-xs text-neutral-400\">\n              в•ӘВәв–ҲГ®в”ҳГҘ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•ӘВҝв•Әв–’ в•ӘВәв•Әв”Ӯв•ӘВәв•Әв”Ӯ в•ӘВҪв•ӘВҝв•ӘВ¬ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в”ҳГ©в•ӘВҝв”ҳГӘв”ҳГӨв–ҲГ® в•ӘВ»в•Әв–’ в•ӘВҝв•ӘВәв”ҳГҘв”ҢвҢҗ в•Әв”Ӯв”ҳГӘв•ӘВәв”ҳГӨв•ӘВәв•ӘВ¬ в”ҳГӘ в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в”ҳГ в•Әв–’в”ҢвҢҗв•Әв–“ в”ҳГјв•Әв–’в”ҳГ в•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§в–ҲГ® (OCC) в•Әв•Ўв•ӘВәв•ӘВ»в•Әв–’ в”ҢВ»в•Әв–’в•ӘВ»в–ҲГ®в•ӘВ»в”ҳГ§ в•ӘВәв•Әв”Ӯв•ӘВ¬.\n            </DialogDescription>\n          </DialogHeader>\n\n          {selectedCert && (\n            <div className=\"flex flex-col gap-6 mt-4\">\n              {/* Certificate Template Styling Container */}\n              <div className=\"relative border-4 border-double border-accent/40 bg-radial from-neutral-900 via-neutral-950 to-stone-950 p-6 md:p-10 rounded-lg overflow-hidden text-center flex flex-col items-center justify-between gap-6 min-h-[360px] shadow-2xl\">\n                {/* Background watermarks & borders */}\n                <div className=\"absolute top-0 right-0 size-32 bg-accent/5 rounded-bl-full pointer-events-none\" />\n                <div className=\"absolute bottom-0 left-0 size-32 bg-accent/5 rounded-tr-full pointer-events-none\" />\n                \n                {/* Certificate Header */}\n                <div className=\"flex flex-col items-center gap-2\">\n                  <div className=\"flex items-center justify-center gap-2 text-accent\">\n                    <Train className=\"size-8\" />\n                    <span className=\"font-bold text-lg md:text-xl tracking-wider\">в•Әв”Өв•Әв–’в”ҢвҢҗв•ӘВ¬ в•ӘВҝв”ҳГ§в•Әв–’в”ҳГ§О“ГҮГ®в•ӘВҝв•Әв–’в•ӘВ»в•ӘВәв•Әв–’в–ҲГ® в•Әв–’в•ӘВәв”ҳГ§ в•ӘГів”ҳГ§в”ҳГҘ в•Әв”Өв”ҳГ§в•Әв–’в–ҲГ® в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ в”ҳГӘ в•ӘВЎв”ҳГӘв”ҳГ в”ҳГ§</span>\n                  </div>\n                  <span className=\"text-[10px] md:text-xs text-neutral-400 font-semibold tracking-widest mt-1\">в”ҳГ в•Әв•Јв•ӘВәв”ҳГӘв”ҳГҘв•ӘВ¬ в•ӘВәв”ҳГ в”ҳГӘв•Әв–’ в•Әв”Ӯв–ҲГ®в•Әв–’ в”ҳГӘ в•ӘВЎв•Әв–’в”ҢвҢҗв•ӘВ¬ - в•ӘВ«в•Әв•– в–ҲГ®в”ҢвҢҗ в”ҳГ в•ӘВ¬в•Әв–’в”ҳГӘ в•ӘВ¬в”ҳГ§в•Әв–’в•ӘВәв”ҳГҘ</span>\n                  <div className=\"h-[2px] w-24 bg-gradient-to-r from-transparent via-accent to-transparent mt-2\" />\n                </div>\n\n                {/* Certificate Body */}\n                <div className=\"space-y-4 my-2 max-w-lg\">\n                  <h3 className=\"text-xl md:text-2xl font-bold text-amber-400 font-headline-lg\">в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§ в•Әв–’в•Әв”Ӯв”ҳГ в–ҲГ® в•Әв”Өв•ӘВәв–ҲГ®в•Әв”Ӯв•ӘВ¬в”ҢВ»в–ҲГ® в”ҳГјв”ҳГҘв–ҲГ®</h3>\n                  <p className=\"text-xs md:text-sm text-neutral-300 leading-8\">\n                    в•ӘВҝв•ӘВ»в–ҲГ®в”ҳГҘО“ГҮГ®в”ҳГӘв•Әв”Ӯв–ҲГ®в”ҳГӨв”ҳГ§ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ® в”ҳГ в–ҲГ®О“ГҮГ®в•Әв”Өв”ҳГӘв•ӘВ» в”ҳГ§в”ҳГ в”ҢвҢҗв•ӘВәв•Әв–’ в”ҢВ»в•Әв–’в•ӘВәв”ҳГ в–ҲГ® в•ӘВјв”ҳГҘв•ӘВәв•ӘВҝ в•ӘГів”ҳГ©в•ӘВәв–ҲГ®/в•Әв”Ӯв•Әв–’в”ҢвҢҗв•ӘВәв•Әв–’ в•ӘВ«в•ӘВәв”ҳГҘв”ҳГ  <span className=\"font-bold text-white text-sm md:text-base underline decoration-accent decoration-2 underline-offset-4\">{selectedCert.userName}</span> в•ӘВҝв•ӘВә в”ҢвҢҗв•ӘВ» в”ҳГ в”ҳГӨв–ҲГ® <span className=\"font-mono text-neutral-200 font-bold\">{toFa(user?.nationalId || 'в–Ҳв–’в–Ҳв–“в–Ҳв”Ӯв–Ҳв”Өв–Ҳв•Ўв–Ҳв•ўв–Ҳв•–в–Ҳв••в–Ҳв•Јв–Ҳв–‘')}</span> в•ӘВ»в”ҳГӘв•Әв–’в”ҳГ§ в•ӘВ¬в•ӘВ«в•Әв•Ўв•Әв•Ўв–ҲГ® в”ҳГӘ в•ӘВәв•Әв–’в•Әв–“в–ҲГ®в•ӘВәв•ӘВҝв–ҲГ® в•ӘВәв”ҳГӨв”ҢвҢҗв•ӘВ¬в•Әв–’в”ҳГӘв”ҳГҘв–ҲГ®в”ҢвҢҗв–ҲГ®:\n                  </p>\n                  <h4 className=\"text-sm md:text-base font-bold text-white bg-neutral-800/50 border border-neutral-700/35 px-4 py-2 rounded-lg inline-block my-1 leading-relaxed\">\n                    {selectedCert.courseTitle}\n                  </h4>\n                  <p className=\"text-xs md:text-sm text-neutral-300 leading-8\">\n                    в•Әв–’в•ӘВә в•ӘВҝв•ӘВә в”ҳГ в”ҳГӘв”ҳГјв”ҳГ©в–ҲГ®в•ӘВ¬ в”ҳГӘ в”ҢвҢҗв•Әв”Ӯв•ӘВҝ в”ҳГҘв”ҳГ в•Әв–’в”ҳГ§ в”ҳГ в”ҳГ в•ӘВ¬в•ӘВәв•Әв–“ <span className=\"font-bold text-success font-mono text-sm md:text-base\">{toFa(selectedCert.score)}в”ҳВ¬</span> в•ӘВҝв”ҳГ§ в”ҳв•ӣв•ӘВәв–ҲГ®в•ӘВәв”ҳГҘ в•Әв–’в•Әв”Ӯв•ӘВәв”ҳГҘв•ӘВ»в”ҳГ§ в”ҳГӘ в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ® в”ҳГӘ в•ӘВәв–ҲГ®в”ҳГ в”ҳГҘв–ҲГ® в”ҳГӨв•ӘВәв•Әв–“в”ҳГ  в•Әв–’в•ӘВә в•ӘВ»в•Әв–’ в•ӘВәв–ҲГ®в”ҳГҘ в”ҳГ в•ӘВәв”ҢГҝв”ҳГӘв”ҳГӨ в•ӘВәв•ӘВ«в•Әв–‘ в”ҳГҘв”ҳГ в”ҳГӘв•ӘВ»в”ҳГ§О“ГҮГ®в•ӘВәв”ҳГҘв•ӘВ».\n                  </p>\n                </div>\n\n                {/* Certificate Footer */}\n                <div className=\"w-full flex flex-col md:flex-row items-center justify-between gap-6 pt-4 border-t border-neutral-800/60 mt-4 text-xs\">\n                  <div className=\"flex flex-col items-center md:items-start gap-1 text-[10px] text-neutral-400\">\n                    <span>в•Әв”Өв”ҳГҘв•ӘВәв•Әв”Ӯв”ҳГ§ в•ӘВәв•Әв•Ўв•ӘВәв”ҳГӨв•ӘВ¬ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®:</span>\n                    <span className=\"font-mono text-neutral-300 select-all font-semibold uppercase\">{selectedCert.id}</span>\n                  </div>\n                  <div className=\"flex items-center gap-1.5 text-success font-semibold\">\n                    <ShieldCheck className=\"size-4\" />\n                    <span>в•Әв•Ўв”ҳГӨв•ӘВәв•ӘВЎв–ҲГ®в•ӘВ¬ в”ҳГјв”ҳГҘв–ҲГ® в•ӘВ¬в•ӘВәв–ҲГ®в–ҲГ®в•ӘВ» в•Әв”Өв•ӘВ»в”ҳГ§ OCC</span>\n                  </div>\n                  <div className=\"flex flex-col items-center md:items-end gap-1 text-[10px] text-neutral-400\">\n                    <span>в•ӘВ¬в•ӘВәв•Әв–’в–ҲГ®в•ӘВ« в•Әв•Ўв•ӘВ»в”ҳГӘв•Әв–’ в”ҢВ»в”ҳГӘв•ӘВәв”ҳГ§в–ҲГ®О“ГҮГ®в”ҳГҘв•ӘВәв”ҳГ в”ҳГ§:</span>\n                    <span className=\"font-mono text-neutral-200 font-bold\">{toFa(selectedCert.date)}</span>\n                  </div>\n                </div>\n              </div>\n\n              {/* Certificate Actions */}\n              <div className=\"flex items-center justify-end gap-2\">\n                <Button variant=\"outline\